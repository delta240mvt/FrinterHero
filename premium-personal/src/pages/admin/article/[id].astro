---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { articles } from '@/db/schema';
import { eq } from 'drizzle-orm';

const { id } = Astro.params;
const articleId = parseInt(id || '0');

let article: any = null;
try {
  const [result] = await db.select().from(articles).where(eq(articles.id, articleId)).limit(1);
  article = result;
} catch {}

if (!article) return Astro.redirect('/admin');
---

<Base title={`Edit: ${article.title} — Admin`}>
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">Edit Article</h1>
      <div style="margin-left: auto; display: flex; gap: 0.75rem;">
        <a href={`/blog/${article.slug}`} target="_blank" class="preview-link">Preview ↗</a>
        <a href="/api/logout" class="logout-btn">Logout</a>
      </div>
    </header>
    <main class="editor-main">
      <form id="article-form" class="article-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="title">Title</label>
            <input type="text" id="title" name="title" class="form-input" value={article.title} required />
          </div>
          <div class="form-group">
            <label class="form-label" for="slug">Slug</label>
            <input type="text" id="slug" name="slug" class="form-input" value={article.slug} />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="description">Description (max 160 chars)</label>
          <input type="text" id="description" name="description" class="form-input" value={article.description || ''} maxlength="160" />
        </div>

        <div class="form-group">
          <label class="form-label" for="content">Content (Markdown — stored as HTML)</label>
          <textarea id="content" name="content" class="form-textarea" rows="24">{article.content}</textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="tags">Tags (comma-separated)</label>
            <input type="text" id="tags" name="tags" class="form-input" value={(article.tags || []).join(', ')} />
          </div>
          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select id="status" name="status" class="form-input">
              <option value="draft" selected={article.status === 'draft'}>Draft</option>
              <option value="published" selected={article.status === 'published'}>Published</option>
              <option value="archived" selected={article.status === 'archived'}>Archived</option>
            </select>
          </div>
        </div>

        <div class="form-check">
          <input type="checkbox" id="featured" name="featured" class="check-input" checked={article.featured} />
          <label for="featured" class="check-label">Featured article</label>
        </div>

        <div class="editor-actions">
          <button type="submit" class="btn-save">Save Changes</button>
          <button type="button" class="btn-delete" id="delete-btn">Delete Article</button>
          <a href="/admin" class="btn-cancel">Back to Admin</a>
          <span class="autosave-indicator" id="autosave-status"></span>
        </div>
      </form>
    </main>
  </div>
</Base>

<script define:vars={{ articleId: article.id }}>
  const form = document.getElementById('article-form');
  const status = document.getElementById('autosave-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    data.featured = document.getElementById('featured').checked;

    const res = await fetch(`/api/articles/${articleId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      status.textContent = 'Saved!';
      setTimeout(() => { status.textContent = ''; }, 2000);
    } else {
      alert('Failed to save');
    }
  });

  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    if (!confirm('Delete this article? Cannot be undone.')) return;
    const res = await fetch(`/api/articles/${articleId}`, { method: 'DELETE' });
    if (res.ok) window.location.href = '/admin';
    else alert('Failed to delete');
  });

  // Autosave every 30s
  let autosaveTimer = setInterval(async () => {
    const statusVal = document.getElementById('status').value;
    if (statusVal !== 'draft') return;
    const data = Object.fromEntries(new FormData(form));
    data.featured = document.getElementById('featured').checked;
    await fetch(`/api/articles/${articleId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    status.textContent = 'Autosaved';
    setTimeout(() => { status.textContent = ''; }, 1500);
  }, 30000);
</script>

<style>
  /* Same styles as new.astro */
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); }
  .preview-link { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid rgba(74,141,131,0.3); border-radius: 0.25rem; }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .editor-main { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
  .article-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .form-input, .form-textarea { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm); padding: 0.6rem 0.875rem; outline: none; transition: border-color 0.15s; width: 100%; }
  .form-input:focus, .form-textarea:focus { border-color: var(--teal); }
  .form-textarea { resize: vertical; font-size: var(--text-sm); line-height: 1.6; }
  .form-check { display: flex; align-items: center; gap: 0.5rem; }
  .check-input { width: 1rem; height: 1rem; accent-color: var(--teal); cursor: pointer; }
  .check-label { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); cursor: pointer; }
  .editor-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; padding-top: 0.5rem; }
  .btn-save { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
  .btn-delete { padding: 0.625rem 1.25rem; background: none; border: 1px solid rgba(239,68,68,0.4); color: #ef4444; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; transition: all 0.15s; }
  .btn-delete:hover { background: rgba(239,68,68,0.1); }
  .btn-cancel { padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-secondary); text-decoration: none; font-family: var(--font-mono); font-size: var(--text-sm); }
  .autosave-indicator { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
</style>
