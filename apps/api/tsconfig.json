{
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/db/*": ["../../src/db/*"],
      "@/lib/*": ["../../src/lib/*"],
      "@/utils/*": ["../../src/utils/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
