---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';
import BcPainPointCard from '@/components/admin/BcPainPointCard.astro';

const { id } = Astro.params;
const projectId = parseInt(id || '0', 10);
const headers = { cookie: Astro.request.headers.get('cookie') ?? '' };
const scrapeResponse = await fetch(new URL(`/api/brand-clarity/${projectId}/scrape-data`, Astro.url), { headers });
const scrapeData = scrapeResponse.ok ? await scrapeResponse.json() : null;
const project = scrapeData?.project ?? null;
const painPoints = scrapeData?.painPoints ?? [];
const clusters = scrapeData?.clusters ?? [];
const selectedVideos = scrapeData?.selectedVideos ?? [];
const iterations = scrapeData?.iterations ?? [];

if (!project) return Astro.redirect('/admin/brand-clarity');

const pending = painPoints.filter(p => p.status === 'pending').length;
const approved = painPoints.filter(p => p.status === 'approved').length;
const rejected = painPoints.filter(p => p.status === 'rejected').length;

const toScrape  = selectedVideos.filter(v => !v.isScraped);
const scraped   = selectedVideos.filter(v => v.isScraped);
---

<Base title={`Pain Points Base — ${project.name}`} description="Brand Clarity pain points base and iteration management">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin/brand-clarity" class="bc-link">Brand Clarity</a>
      <span class="bc-sep">›</span>
      <a href={`/admin/brand-clarity/${projectId}/channels`} class="bc-link">{project.name}</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">Pain Points Base</span>
    </nav>
    <div class="header-actions">
      <span class="project-status">{project.status}</span>
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <div class="stage-bar">
      <a href={`/admin/brand-clarity/${projectId}/docs`} class="stage done stage-link">1. LP Parsed</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/channels`} class="stage done stage-link">2. Channels</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/videos`} class="stage done stage-link">3. Videos</a>
      <span class="stage-arrow">→</span>
      <span class="stage active">4–5. Pain Points Base</span>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/variants`} class="stage stage-link">6. LP Variants</a>
    </div>

    <!-- Scrape control -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Comment Scrape</h2>
          <p class="section-subtitle">
            {selectedVideos.length === 0
              ? 'No videos selected — go back to Videos step'
              : `${scraped.length} scraped · ${toScrape.length} pending`}
          </p>
        </div>
      </div>

      {selectedVideos.length === 0 ? (
        <div class="empty-state">No selected videos. <a href={`/admin/brand-clarity/${projectId}/videos`} class="link-teal">← Go to Videos</a></div>
      ) : (
        <>
          <!-- Tabs -->
          <div class="video-tabs">
            <button class="vtab active" data-tab="pending">To Scrape <span class="vtab-count">{toScrape.length}</span></button>
            <button class="vtab" data-tab="scraped">Scraped <span class="vtab-count">{scraped.length}</span></button>
          </div>

          <!-- Pending tab -->
          <div id="tab-pending" class="tab-content">
            {toScrape.length === 0 ? (
              <div class="empty-state small">All selected videos have been scraped ✓</div>
            ) : (
              toScrape.map(v => (
                <div class="video-scrape-row" id={`video-row-${v.id}`}>
                  <div class="video-scrape-info">
                    <span class="video-scrape-title">{v.title}</span>
                    <div class="video-scrape-meta">
                      <span class="vmeta">{v.channelName}</span>
                      <span class="vmeta-sep">·</span>
                      <span class="vmeta">{v.commentCount?.toLocaleString() ?? '–'} comments</span>
                      <span class="vmeta-sep">·</span>
                      <a href={v.videoUrl} target="_blank" rel="noopener" class="vmeta-watch" onclick="event.stopPropagation()">▶ Watch</a>
                    </div>
                  </div>
                  <button class="btn-scrape-one" data-video-id={v.id}>Scrape</button>
                </div>
              ))
            )}
          </div>

          <!-- Scraped tab -->
          <div id="tab-scraped" class="tab-content" style="display:none">
            {scraped.length === 0 ? (
              <div class="empty-state small">No videos scraped yet.</div>
            ) : (
              scraped.map(v => (
                <div class="video-scrape-row is-scraped" id={`video-row-${v.id}`}>
                  <div class="video-scrape-info">
                    <span class="video-scrape-title">{v.title}</span>
                    <div class="video-scrape-meta">
                      <span class="vmeta">{v.channelName}</span>
                      <span class="vmeta-sep">·</span>
                      <span class="vmeta">{v.commentCount?.toLocaleString() ?? '–'} comments</span>
                      <span class="vmeta-sep">·</span>
                      <a href={v.videoUrl} target="_blank" rel="noopener" class="vmeta-watch" onclick="event.stopPropagation()">▶ Watch</a>
                    </div>
                  </div>
                  <span class="badge-scraped">✓ Scraped</span>
                </div>
              ))
            )}
          </div>
        </>
      )}

      <!-- Console panel (shown during/after scrape) -->
      <div id="scrape-panel" class="scrape-panel" style="display:none">
        <div class="scrape-panel-top">
          <span id="scrape-status" class="scrape-status">Initializing…</span>
          <div class="scrape-panel-actions">
            <span id="scrape-elapsed" class="scrape-elapsed"></span>
            <button id="scrape-stop" class="btn-stop-scrape" style="display:none">■ Stop</button>
            <button id="scrape-close" class="scrape-close-btn" style="display:none">✕ Close</button>
          </div>
        </div>
        <div class="scrape-metrics">
          <span class="metric">Comments: <strong id="comments-count">0</strong></span>
          <span class="metric">Pain Points: <strong id="pp-count">0</strong></span>
        </div>
        <div id="scrape-log" class="scrape-log"></div>
        <div id="scrape-footer" class="scrape-footer" style="display:none">
          <span id="scrape-result-msg"></span>
        </div>
      </div>
    </section>

    <!-- Iterations -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Iteracje LP</h2>
          <p class="section-subtitle">
            {approved > 0
              ? `${approved} approved PP w bazie · każda iteracja = intencja → AI wybiera top 30 → clustering → LP`
              : 'Zatwierdź pain pointy poniżej, żeby móc tworzyć iteracje'}
          </p>
        </div>
        <button id="btn-new-iteration" class="btn-primary" disabled={approved === 0} title={approved === 0 ? 'Najpierw zatwierdź pain pointy' : 'Utwórz nową iterację LP'}>+ Nowa iteracja</button>
      </div>

      {iterations.length === 0 ? (
        <div class="empty-state">
          {approved === 0
            ? 'Brak zatwierdzonych pain pointów. Scrape filmów i zaakceptuj pain pointy poniżej.'
            : `Brak iteracji. Kliknij "+ Nowa iteracja" żeby wygenerować LP pod konkretną grupę docelową (${approved} PP gotowych).`}
        </div>
      ) : (
        <div class="iterations-grid">
          {iterations.map((it: any) => {
            const statusColors = {
              draft: 'var(--text-muted)',
              selecting: 'var(--gold)',
              selected: 'var(--teal)',
              clustering: 'var(--gold)',
              clustered: 'var(--teal)',
              generating: 'var(--gold)',
              done: 'var(--teal)',
            };
            const statusColor = statusColors[it.status] || 'var(--text-muted)';
            return (
              <a href={`/admin/brand-clarity/${projectId}/iterations/${it.id}`} class="iteration-card">
                <div class="iteration-card-header">
                  <span class="iteration-name">{it.name}</span>
                  <span class="iteration-status" style={`color: ${statusColor}`}>{it.status}</span>
                </div>
                {it.intention ? (
                  <div class="iteration-intention">"{it.intention.substring(0, 100)}{it.intention.length > 100 ? '…' : ''}"</div>
                ) : (
                  <div class="iteration-intention muted">Brak intencji</div>
                )}
                <div class="iteration-meta">
                  <span>{it.selectionCount} PP wybranych</span>
                  <span>·</span>
                  <span>{new Date(it.createdAt).toLocaleDateString('pl-PL')}</span>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </section>

    <!-- Pain Points Base -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Pain Points Base</h2>
          <p class="section-subtitle">
            <button class="pp-stat-btn" data-group="approved" id="stat-approved">{approved} approved</button>
            <span class="pp-stat-sep"> · </span>
            <button class="pp-stat-btn" data-group="rejected" id="stat-rejected">{rejected} rejected</button>
            <span class="pp-stat-sep"> · </span>
            <button class="pp-stat-btn pp-stat-active" data-group="pending" id="stat-pending">{pending} pending</button>
          </p>
        </div>
        <div class="header-btns">
          <!-- Always render; JS shows/hides based on approved count -->
          <button
            id="cluster-btn"
            class="btn-cluster"
            style={clusters.length > 0 ? '' : (approved >= 3 ? '' : 'display:none')}
          >
            {clusters.length > 0 ? '↺ Re-cluster' : 'Cluster Pain Points'}
          </button>
          {clusters.length > 0 && (
            <a href={`/admin/brand-clarity/${projectId}/variants`} class="btn-primary">Generate LPs →</a>
          )}
        </div>
      </div>

      {clusters.length > 0 && (
        <div class="clusters-panel">
          <div class="clusters-label">Pain Clusters (synthesized from approved pain points)</div>
          <div class="clusters-grid">
            {clusters.map((c: any) => (
              <div class="cluster-card">
                <div class="cluster-header">
                  <span class="cluster-emotion">{c.dominantEmotion}</span>
                  <span class="cluster-intensity">{c.aggregateIntensity?.toFixed(1)}/10</span>
                </div>
                <div class="cluster-theme">{c.clusterTheme}</div>
                {c.synthesizedProblemLabel && (
                  <div class="cluster-label">Customer calls it: <em>"{c.synthesizedProblemLabel}"</em></div>
                )}
                {c.synthesizedSuccessVision && (
                  <div class="cluster-vision">They want: <em>"{c.synthesizedSuccessVision}"</em></div>
                )}
                {Array.isArray(c.bestQuotes) && c.bestQuotes.length > 0 && (
                  <div class="cluster-quotes">
                    {c.bestQuotes.slice(0, 2).map((q: string) => (
                      <div class="cluster-quote">"{q}"</div>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      <details id="cluster-log-panel" class="run-logs-section" style="display:none">
        <summary class="run-logs-toggle">
          <span class="logs-toggle-label">📋 Cluster Run Log</span>
          <span id="cluster-log-count" class="logs-count">0 lines</span>
          <button id="btn-download-cluster-logs" class="btn-download-logs" onclick="event.stopPropagation()">Download .txt</button>
        </summary>
        <div id="cluster-log-container" class="run-logs-container"></div>
      </details>

      {painPoints.length === 0 ? (
        <div class="empty-state">No pain points yet. Scrape a video above to extract them from YouTube comments.</div>
      ) : (
        <>
          <div id="pp-section-approved" class="pp-group" style="display:none">
            <div class="pp-group-label">Approved ({approved})</div>
            <div id="pp-list-approved">
              {painPoints.filter(p => p.status === 'approved').map(pp => (
                <BcPainPointCard pp={pp} projectId={projectId} />
              ))}
            </div>
          </div>

          <div id="pp-section-rejected" class="pp-group" style="display:none">
            <div class="pp-group-label">Rejected ({rejected})</div>
            <div id="pp-list-rejected">
              {painPoints.filter(p => p.status === 'rejected').map(pp => (
                <BcPainPointCard pp={pp} projectId={projectId} />
              ))}
            </div>
          </div>

          <div id="pp-section-pending" class="pp-group">
            <div id="pp-list-pending">
              {painPoints.filter(p => p.status === 'pending').length === 0 ? (
                <div class="empty-state small">Brak oczekujących — wszystkie przejrzane ✓</div>
              ) : (
                painPoints.filter(p => p.status === 'pending').map(pp => (
                  <BcPainPointCard pp={pp} projectId={projectId} />
                ))
              )}
            </div>
          </div>
        </>
      )}
    </section>
  </main>
</div>

<script define:vars={{ projectId }}>
  const PROJECT_ID = projectId;

  // ── Tabs ────────────────────────────────────────────────────
  document.querySelectorAll('.vtab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.vtab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = btn.dataset.tab;
      document.getElementById('tab-pending').style.display = tab === 'pending' ? '' : 'none';
      document.getElementById('tab-scraped').style.display = tab === 'scraped' ? '' : 'none';
    });
  });

  // ── Scrape console ──────────────────────────────────────────
  const scrapePanel   = document.getElementById('scrape-panel');
  const scrapeLog     = document.getElementById('scrape-log');
  const scrapeStatus  = document.getElementById('scrape-status');
  const scrapeClose   = document.getElementById('scrape-close');
  const scrapeStop    = document.getElementById('scrape-stop');
  const scrapeElapsed = document.getElementById('scrape-elapsed');
  const scrapeFooter  = document.getElementById('scrape-footer');
  const scrapeResultMsg = document.getElementById('scrape-result-msg');
  const commentsCount = document.getElementById('comments-count');
  const ppCount       = document.getElementById('pp-count');

  let elapsedTimer = null;
  let elapsedStart = 0;

  function startElapsed() {
    elapsedStart = Date.now();
    elapsedTimer = setInterval(() => {
      scrapeElapsed.textContent = `${Math.floor((Date.now() - elapsedStart) / 1000)}s`;
    }, 1000);
  }

  function stopElapsed() {
    clearInterval(elapsedTimer);
    elapsedTimer = null;
  }

  scrapeClose?.addEventListener('click', () => {
    scrapePanel.style.display = 'none';
    stopElapsed();
  });

  scrapeStop?.addEventListener('click', async () => {
    if (!confirm('Abort the scrape? Already collected data will be kept.')) return;
    scrapeStop.disabled = true;
    scrapeStop.textContent = 'Stopping…';
    try { await fetch(`/api/brand-clarity/${PROJECT_ID}/scrape/stop`, { method: 'POST' }); } catch {}
  });

  function appendLog(line) {
    const el = document.createElement('div');
    el.className = 'scrape-log-line';
    if (line.includes('[WARN]') || line.includes('[ERROR]') || line.includes('[FATAL]')) el.classList.add('error');
    else if (line.includes('[QUOTA]') || line.includes('QUOTA_EXCEEDED')) { el.classList.add('quota'); }
    else if (line.includes('pain point') || line.includes('FILTER') || line.includes('Extracted') || line.includes('Marked video')) el.classList.add('highlight');
    el.textContent = line;
    scrapeLog.appendChild(el);
    scrapeLog.scrollTop = scrapeLog.scrollHeight;
  }

  function showPanel(videoTitle) {
    scrapeLog.innerHTML = '';
    scrapeFooter.style.display = 'none';
    scrapeResultMsg.textContent = '';
    commentsCount.textContent = '0';
    ppCount.textContent = '0';
    scrapeElapsed.textContent = '';
    scrapeStatus.textContent = `Scraping: ${videoTitle}`;
    scrapeStatus.className = 'scrape-status running';
    scrapeStop.style.display = 'inline-block';
    scrapeStop.disabled = false;
    scrapeStop.textContent = '■ Stop';
    scrapeClose.style.display = 'none';
    scrapePanel.style.display = 'block';
    scrapePanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    startElapsed();
  }

  function finishPanel(ok, quotaExceeded) {
    stopElapsed();
    scrapeStop.style.display = 'none';
    scrapeClose.style.display = 'inline-block';
    scrapeFooter.style.display = 'flex';
    if (quotaExceeded) {
      scrapeStatus.className = 'scrape-status quota';
      scrapeStatus.textContent = 'YouTube quota exceeded ✗';
      scrapeResultMsg.className = 'scrape-result-quota';
      scrapeResultMsg.textContent = 'Daily YouTube API quota reached. Already scraped data is saved. Try again tomorrow.';
    } else if (ok) {
      scrapeStatus.className = 'scrape-status done';
      scrapeStatus.textContent = 'Scrape complete ✓';
      scrapeResultMsg.className = 'scrape-result-ok';
      scrapeResultMsg.textContent = 'Pain points saved. Reloading…';
    } else {
      scrapeStatus.className = 'scrape-status error';
      scrapeStatus.textContent = 'Error ✗';
      scrapeResultMsg.className = 'scrape-result-error';
      scrapeResultMsg.textContent = 'Scrape failed. Check logs.';
    }
  }

  // Move a video row from pending to scraped tab in-place
  function markVideoScraped(videoId) {
    const row = document.getElementById(`video-row-${videoId}`);
    if (!row) return;
    // swap button for badge
    const btn = row.querySelector('.btn-scrape-one');
    if (btn) {
      const badge = document.createElement('span');
      badge.className = 'badge-scraped';
      badge.textContent = '✓ Scraped';
      btn.replaceWith(badge);
    }
    row.classList.add('is-scraped');
    // move to scraped tab
    const scrapedTab = document.getElementById('tab-scraped');
    const emptyMsg = scrapedTab?.querySelector('.empty-state');
    if (emptyMsg) emptyMsg.remove();
    scrapedTab?.appendChild(row);
    // update tab counts
    document.querySelectorAll('.vtab').forEach(t => {
      const tab = t.dataset.tab;
      const contentEl = document.getElementById(`tab-${tab}`);
      const count = contentEl?.querySelectorAll('.video-scrape-row').length ?? 0;
      const badge = t.querySelector('.vtab-count');
      if (badge) badge.textContent = count;
    });
  }

  async function connectScrapeStream(fromIndex) {
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/scrape/stream?from=${fromIndex}`);
      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop() ?? '';
        for (const part of parts) {
          const dataLine = part.split('\n').find(l => l.startsWith('data: '));
          if (!dataLine) continue;
          let payload;
          try { payload = JSON.parse(dataLine.slice(6)); } catch { continue; }
          if (payload.line) {
            appendLog(payload.line);
            const cm = payload.line.match(/commentsCollected:(\d+)/);
            if (cm) commentsCount.textContent = cm[1];
            const pm = payload.line.match(/painPointsExtracted:(\d+)/);
            if (pm) ppCount.textContent = pm[1];
          }
          if (payload.videoScraped) {
            markVideoScraped(payload.videoScraped);
          }
          if (payload.done) {
            const ok = payload.code === 0;
            finishPanel(ok, !!payload.quota);
            if (ok) setTimeout(() => window.location.reload(), 2500);
            return;
          }
        }
      }
    } catch (e) {
      stopElapsed();
      scrapeStatus.textContent = `Stream error: ${e.message}`;
      scrapeStatus.className = 'scrape-status error';
      scrapeClose.style.display = 'inline-block';
      scrapeStop.style.display = 'none';
    }
  }

  // Restore panel on page load if running
  (async () => {
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/scrape/status`);
      const data = await res.json();
      if (data.status === 'idle') return;
      scrapePanel.style.display = 'block';
      commentsCount.textContent = data.commentsCollected;
      ppCount.textContent = data.painPointsExtracted;
      if (data.status === 'running') {
        scrapeStatus.className = 'scrape-status running';
        scrapeStatus.textContent = 'Scraping…';
        scrapeStop.style.display = 'inline-block';
        scrapeStop.disabled = false;
        scrapeStop.textContent = '■ Stop';
        scrapeClose.style.display = 'none';
        startElapsed();
        connectScrapeStream(data.linesCount ?? 0);
      } else {
        stopElapsed();
        scrapeStatus.className = `scrape-status ${data.status === 'done' ? 'done' : 'error'}`;
        scrapeStatus.textContent = data.status === 'done' ? 'Scrape complete' : 'Error';
        scrapeClose.style.display = 'inline-block';
      }
    } catch { /* non-critical */ }
  })();

  // Per-video scrape buttons
  document.querySelectorAll('.btn-scrape-one').forEach(btn => {
    btn.addEventListener('click', async () => {
      const videoId = parseInt(btn.dataset.videoId, 10);
      const row = document.getElementById(`video-row-${videoId}`);
      const title = row?.querySelector('.video-scrape-title')?.textContent || `Video ${videoId}`;

      if (!confirm(`Scrape comments for:\n"${title}"?\n\nYouTube API will be called.`)) return;

      btn.disabled = true;
      btn.textContent = 'Starting…';
      showPanel(title);

      const startRes = await fetch(`/api/brand-clarity/${PROJECT_ID}/scrape/start`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ videoId }),
      });

      if (startRes.status === 409) {
        // Already running — reconnect to stream
        btn.disabled = false;
        btn.textContent = 'Scrape';
        connectScrapeStream(0);
        return;
      }
      if (!startRes.ok) {
        stopElapsed();
        const err = await startRes.json();
        scrapeStatus.textContent = `Error: ${err.error}`;
        scrapeStatus.className = 'scrape-status error';
        scrapeClose.style.display = 'inline-block';
        scrapeStop.style.display = 'none';
        btn.disabled = false;
        btn.textContent = 'Scrape';
        return;
      }

      connectScrapeStream(0);
    });
  });

  // ── Pain point actions ─────────────────────────────────────

  function updateStatCounts() {
    const counts = {
      approved: document.getElementById('pp-list-approved')?.querySelectorAll('.bcpp-card').length ?? 0,
      rejected: document.getElementById('pp-list-rejected')?.querySelectorAll('.bcpp-card').length ?? 0,
      pending:  document.getElementById('pp-list-pending')?.querySelectorAll('.bcpp-card').length ?? 0,
    };
    ['approved', 'rejected', 'pending'].forEach(g => {
      const btn = document.getElementById(`stat-${g}`);
      if (btn) btn.textContent = `${counts[g]} ${g}`;
    });
    // Update group labels
    ['approved', 'rejected'].forEach(g => {
      const lbl = document.querySelector(`#pp-section-${g} .pp-group-label`);
      if (lbl) lbl.textContent = `${g.charAt(0).toUpperCase() + g.slice(1)} (${counts[g]})`;
    });
    // Show cluster btn once 3+ approved
    const clusterBtn = document.getElementById('cluster-btn');
    if (clusterBtn && counts.approved >= 3) clusterBtn.style.display = '';
  }

  function checkSectionEmpty(group) {
    const list = document.getElementById(`pp-list-${group}`);
    if (!list) return;
    if (list.querySelectorAll('.bcpp-card').length === 0 && !list.querySelector('.empty-state')) {
      const el = document.createElement('div');
      el.className = 'empty-state small';
      el.textContent = group === 'pending' ? 'Brak oczekujących — wszystkie przejrzane ✓' : `Brak ${group}`;
      list.appendChild(el);
    }
  }

  async function bcppSetStatus(ppId, projId, status) {
    const res = await fetch(`/api/brand-clarity/${projId}/pain-points/${ppId}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    if (!res.ok) { alert('Failed to update status'); return; }

    const card = document.getElementById(`bcpp-${ppId}`);
    if (!card) return;

    card.style.transition = 'opacity 0.25s, transform 0.25s';
    card.style.opacity = '0';
    card.style.transform = 'translateX(12px)';

    setTimeout(() => {
      card.style.transition = '';
      card.style.opacity = '';
      card.style.transform = '';
      card.dataset.status = status;
      const statusEl = card.querySelector('.bcpp-status');
      if (statusEl) statusEl.textContent = status;

      const targetListId = status === 'pending' ? 'pp-list-pending' : `pp-list-${status}`;
      const targetList = document.getElementById(targetListId);
      if (targetList) {
        targetList.querySelector('.empty-state')?.remove();
        targetList.insertBefore(card, targetList.firstChild);
      }

      updateStatCounts();
      checkSectionEmpty('pending');
    }, 260);
  }

  function bcppToggle(ppId) {
    const expanded = document.getElementById(`bcpp-expanded-${ppId}`);
    if (expanded) expanded.style.display = expanded.style.display === 'none' ? 'block' : 'none';
  }

  window.bcppSetStatus = bcppSetStatus;
  window.bcppToggle = bcppToggle;

  // ── Stat button toggles ─────────────────────────────────────
  document.querySelectorAll('.pp-stat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.group;
      const section = document.getElementById(`pp-section-${group}`);
      if (!section) return;
      const isVisible = section.style.display !== 'none';
      section.style.display = isVisible ? 'none' : '';
      btn.classList.toggle('pp-stat-active', !isVisible);
    });
  });

  // ── Cluster pain points ─────────────────────────────────────
  const clusterLogPanel     = document.getElementById('cluster-log-panel');
  const clusterLogContainer = document.getElementById('cluster-log-container');
  const clusterLogCount     = document.getElementById('cluster-log-count');

  function renderClusterLogs(logs) {
    if (!logs || !logs.length) return;
    clusterLogPanel.style.display = 'block';
    clusterLogPanel.open = true;
    clusterLogCount.textContent = `${logs.length} lines`;
    clusterLogContainer.innerHTML = logs.map(line => {
      let cls = 'log-line';
      if (line.includes('[WARN]') || line.includes('[FATAL]') || line.includes('[ERROR]')) cls += ' log-line--warn';
      else if (line.includes('CLUSTERS_CREATED') || line.includes('Done') || line.includes('Inserted')) cls += ' log-line--done';
      else if (line.includes('[LLM]') || line.includes('Sonnet') || line.includes('cluster')) cls += ' log-line--llm';
      return `<div class="${cls}">${line}</div>`;
    }).join('');
    clusterLogContainer.scrollTop = clusterLogContainer.scrollHeight;
  }

  document.getElementById('btn-download-cluster-logs')?.addEventListener('click', () => {
    const text = Array.from(clusterLogContainer.querySelectorAll('.log-line')).map(el => el.textContent).join('\n');
    const blob = new Blob([text], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `bc-cluster-${PROJECT_ID}-logs.txt`;
    document.body.appendChild(a); a.click();
    document.body.removeChild(a); URL.revokeObjectURL(url);
  });

  document.getElementById('cluster-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('cluster-btn');
    if (!btn) return;
    if (!confirm('Cluster approved pain points using Claude Sonnet? (~1 API call, ~10s)')) return;
    btn.disabled = true;
    btn.textContent = 'Clustering…';
    clusterLogPanel.style.display = 'none';
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/cluster-pain-points`, { method: 'POST' });
      const data = await res.json();
      renderClusterLogs(data.logs);
      if (!res.ok) throw new Error(data.error || 'Failed');
      setTimeout(() => window.location.reload(), 2500);
    } catch (e) {
      clusterLogPanel.style.display = 'block';
      clusterLogPanel.open = true;
      const errEl = document.createElement('div');
      errEl.className = 'log-line log-line--warn';
      errEl.textContent = `[ERROR] ${e.message}`;
      clusterLogContainer.appendChild(errEl);
      btn.disabled = false;
      btn.textContent = 'Cluster Pain Points';
    }
  });

  // ── New iteration ────────────────────────────────────────────
  document.getElementById('btn-new-iteration')?.addEventListener('click', async () => {
    const name = prompt('Nazwa iteracji:', `Iteracja ${new Date().toLocaleDateString('pl-PL')}`);
    if (name === null) return; // cancelled
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name.trim() || `Iteracja ${new Date().toLocaleDateString('pl-PL')}` }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      window.location.href = `/admin/brand-clarity/${PROJECT_ID}/iterations/${data.iteration.id}`;
    } catch (e) {
      alert(`Błąd: ${e.message}`);
    }
  });
</script>

