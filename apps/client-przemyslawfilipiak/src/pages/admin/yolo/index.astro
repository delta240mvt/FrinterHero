---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';

const session = Astro.cookies.get('session')?.value;
if (!session) return Astro.redirect('/admin/login');

const headers = { cookie: Astro.request.headers.get('cookie') ?? '' };

let settings: any = {};
let preview: any = { ytPainPointsPending: 0, gapsNew: 0, draftsReady: 0 };

try {
  const [settingsRes, previewRes] = await Promise.all([
    fetch(new URL('/api/yolo/settings', Astro.url), { headers }),
    fetch(new URL('/api/yolo/preview', Astro.url), { headers }),
  ]);
  if (settingsRes.ok) settings = (await settingsRes.json()).settings ?? {};
  if (previewRes.ok) preview = await previewRes.json();
} catch (e) {
  console.error(e);
}
---

<Base title="Yolo Mode — Admin" description="Automated content pipeline configuration">
<div class="yolo-layout">
  <header class="yolo-header">
    <div class="yolo-header-inner">
      <h1 class="yolo-title">Yolo Mode <span class="yolo-badge">Pipeline</span></h1>
      <p class="yolo-subtitle">Mass-approval automation: YT pain points → gaps → drafts → published articles</p>
    </div>
  </header>

  <main class="yolo-main">

    <!-- PREVIEW COUNTS -->
    <div class="pipeline-preview">
      <a href="/admin/yolo/pain-points" class="preview-card preview-card-link">
        <div class="preview-num" id="cnt-pp">{preview.ytPainPointsPending}</div>
        <div class="preview-label">Pain points pending</div>
        <div class="preview-action">→ Select &amp; approve</div>
      </a>
      <div class="preview-arrow">→</div>
      <a href="/admin/yolo/gaps" class="preview-card preview-card-link">
        <div class="preview-num" id="cnt-gaps">{preview.gapsNew}</div>
        <div class="preview-label">New content gaps</div>
        <div class="preview-action">→ Select &amp; queue</div>
      </a>
      <div class="preview-arrow">→</div>
      <div class="preview-card">
        <div class="preview-num" id="cnt-drafts">{preview.draftsReady}</div>
        <div class="preview-label">Drafts ready to publish</div>
      </div>
    </div>

    <!-- STAGE 1 -->
    <section class="stage-card" id="stage-1">
      <div class="stage-head">
        <div class="stage-info">
          <span class="stage-num">01</span>
          <div>
            <h2 class="stage-title">YT Pain Points → Content Gaps</h2>
            <p class="stage-desc">Approves top N pending YT pain points and creates content gaps from them.</p>
          </div>
        </div>
        <label class="toggle">
          <input type="checkbox" id="yt-enabled" {settings.ytPainPointsEnabled ? 'checked' : ''} />
          <span class="toggle-track"></span>
        </label>
      </div>
      <div class="stage-config">
        <label class="cfg-field">
          <span>Limit</span>
          <input type="number" id="yt-limit" value={settings.ytPainPointsLimit ?? 10} min="1" max="100" />
        </label>
        <label class="cfg-field">
          <span>Min emotional intensity (1–10)</span>
          <input type="number" id="yt-intensity" value={settings.ytPainPointsMinIntensity ?? 5} min="1" max="10" />
        </label>
      </div>
      <div class="stage-actions">
        <button class="btn-save" data-stage="1">Save</button>
        <button class="btn-run" data-stage="pain-points">▶ Run now</button>
      </div>
      <div class="stage-log" id="log-1"></div>
    </section>

    <!-- STAGE 2 -->
    <section class="stage-card" id="stage-2">
      <div class="stage-head">
        <div class="stage-info">
          <span class="stage-num">02</span>
          <div>
            <h2 class="stage-title">Content Gaps → Draft Jobs</h2>
            <p class="stage-desc">Acknowledges top N new content gaps and enqueues AI draft generation jobs.</p>
          </div>
        </div>
        <label class="toggle">
          <input type="checkbox" id="gaps-enabled" {settings.gapsEnabled ? 'checked' : ''} />
          <span class="toggle-track"></span>
        </label>
      </div>
      <div class="stage-config">
        <label class="cfg-field">
          <span>Limit</span>
          <input type="number" id="gaps-limit" value={settings.gapsLimit ?? 5} min="1" max="50" />
        </label>
        <label class="cfg-field">
          <span>Model</span>
          <select id="gaps-model">
            <option value="anthropic/claude-sonnet-4-6" selected={settings.gapsModel === 'anthropic/claude-sonnet-4-6' || !settings.gapsModel}>claude-sonnet-4-6</option>
            <option value="anthropic/claude-opus-4-6" selected={settings.gapsModel === 'anthropic/claude-opus-4-6'}>claude-opus-4-6</option>
            <option value="anthropic/claude-haiku-4-5-20251001" selected={settings.gapsModel === 'anthropic/claude-haiku-4-5-20251001'}>claude-haiku-4-5</option>
          </select>
        </label>
      </div>
      <div class="stage-actions">
        <button class="btn-save" data-stage="2">Save</button>
        <button class="btn-run" data-stage="gaps">▶ Run now</button>
      </div>
      <div class="stage-log" id="log-2"></div>
    </section>

    <!-- STAGE 3 -->
    <section class="stage-card" id="stage-3">
      <div class="stage-head">
        <div class="stage-info">
          <span class="stage-num">03</span>
          <div>
            <h2 class="stage-title">Drafts → Published Articles</h2>
            <p class="stage-desc">Auto-publishes completed draft articles that were generated from content gaps.</p>
          </div>
        </div>
        <label class="toggle">
          <input type="checkbox" id="publish-enabled" {settings.autoPublishEnabled ? 'checked' : ''} />
          <span class="toggle-track"></span>
        </label>
      </div>
      <div class="stage-config">
        <label class="cfg-field">
          <span>Limit per run</span>
          <input type="number" id="publish-limit" value={settings.autoPublishLimit ?? 10} min="1" max="50" />
        </label>
      </div>
      <div class="stage-actions">
        <button class="btn-save" data-stage="3">Save</button>
        <button class="btn-run" data-stage="publish">▶ Run now</button>
      </div>
      <div class="stage-log" id="log-3"></div>
    </section>

    <!-- RUN ALL -->
    <section class="run-all-card">
      <div>
        <h2 class="stage-title">Run Full Pipeline</h2>
        <p class="stage-desc">Runs all enabled stages in order: pain points → gaps → publish.</p>
      </div>
      <button class="btn-run-all" id="btn-run-all">▶ Run all enabled stages</button>
      <div class="stage-log" id="log-all"></div>
    </section>

  </main>
</div>
</Base>

<script>
async function saveSettings(stage: number) {
  const body: Record<string, unknown> = {};
  if (stage === 1) {
    body.ytPainPointsEnabled = (document.getElementById('yt-enabled') as HTMLInputElement).checked;
    body.ytPainPointsLimit = Number((document.getElementById('yt-limit') as HTMLInputElement).value);
    body.ytPainPointsMinIntensity = Number((document.getElementById('yt-intensity') as HTMLInputElement).value);
  } else if (stage === 2) {
    body.gapsEnabled = (document.getElementById('gaps-enabled') as HTMLInputElement).checked;
    body.gapsLimit = Number((document.getElementById('gaps-limit') as HTMLInputElement).value);
    body.gapsModel = (document.getElementById('gaps-model') as HTMLSelectElement).value;
  } else if (stage === 3) {
    body.autoPublishEnabled = (document.getElementById('publish-enabled') as HTMLInputElement).checked;
    body.autoPublishLimit = Number((document.getElementById('publish-limit') as HTMLInputElement).value);
  }
  const res = await fetch('/api/yolo/settings', {
    method: 'PUT',
    headers: { 'content-type': 'application/json' },
    body: JSON.stringify(body),
  });
  const log = document.getElementById(`log-${stage}`)!;
  if (res.ok) {
    log.textContent = '✓ Settings saved';
    log.className = 'stage-log log-ok';
  } else {
    log.textContent = '✗ Save failed';
    log.className = 'stage-log log-err';
  }
  setTimeout(() => { log.textContent = ''; log.className = 'stage-log'; }, 3000);
}

async function runStage(stageName: string, logEl: HTMLElement, overrides: Record<string, unknown> = {}) {
  logEl.textContent = '⏳ Running…';
  logEl.className = 'stage-log log-running';
  try {
    const res = await fetch(`/api/yolo/run/${stageName}`, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(overrides),
    });
    const data = await res.json();
    if (res.ok) {
      const details = JSON.stringify(data, null, 2);
      logEl.textContent = `✓ Done\n${details}`;
      logEl.className = 'stage-log log-ok';
    } else {
      logEl.textContent = `✗ Error: ${data.error ?? res.status}`;
      logEl.className = 'stage-log log-err';
    }
  } catch (e: any) {
    logEl.textContent = `✗ ${e.message}`;
    logEl.className = 'stage-log log-err';
  }
  await refreshPreview();
}

async function refreshPreview() {
  try {
    const res = await fetch('/api/yolo/preview');
    if (!res.ok) return;
    const data = await res.json();
    const pp = document.getElementById('cnt-pp');
    const gaps = document.getElementById('cnt-gaps');
    const drafts = document.getElementById('cnt-drafts');
    if (pp) pp.textContent = String(data.ytPainPointsPending ?? 0);
    if (gaps) gaps.textContent = String(data.gapsNew ?? 0);
    if (drafts) drafts.textContent = String(data.draftsReady ?? 0);
  } catch {}
}

document.querySelectorAll('.btn-save').forEach((btn) => {
  btn.addEventListener('click', () => {
    const stage = Number((btn as HTMLButtonElement).dataset.stage);
    saveSettings(stage);
  });
});

document.querySelectorAll('.btn-run').forEach((btn) => {
  btn.addEventListener('click', () => {
    const stageName = (btn as HTMLButtonElement).dataset.stage!;
    const stageNum = stageName === 'pain-points' ? 1 : stageName === 'gaps' ? 2 : 3;
    const logEl = document.getElementById(`log-${stageNum}`)!;
    runStage(stageName, logEl);
  });
});

document.getElementById('btn-run-all')?.addEventListener('click', async () => {
  const logEl = document.getElementById('log-all')!;
  logEl.textContent = '⏳ Running all stages…';
  logEl.className = 'stage-log log-running';

  const ppEnabled = (document.getElementById('yt-enabled') as HTMLInputElement).checked;
  const gapsEnabled = (document.getElementById('gaps-enabled') as HTMLInputElement).checked;
  const publishEnabled = (document.getElementById('publish-enabled') as HTMLInputElement).checked;

  const results: string[] = [];

  if (ppEnabled) {
    const res = await fetch('/api/yolo/run/pain-points', { method: 'POST', headers: { 'content-type': 'application/json' }, body: '{}' });
    const d = await res.json();
    results.push(`Stage 1 (pain points): created ${d.created ?? 0} gaps from ${d.processed ?? 0} pain points`);
  }
  if (gapsEnabled) {
    const res = await fetch('/api/yolo/run/gaps', { method: 'POST', headers: { 'content-type': 'application/json' }, body: '{}' });
    const d = await res.json();
    results.push(`Stage 2 (gaps): enqueued ${d.enqueued ?? 0} draft jobs (skipped ${d.skipped ?? 0})`);
  }
  if (publishEnabled) {
    const res = await fetch('/api/yolo/run/publish', { method: 'POST', headers: { 'content-type': 'application/json' }, body: '{}' });
    const d = await res.json();
    results.push(`Stage 3 (publish): published ${d.published ?? 0} articles`);
  }

  if (results.length === 0) {
    logEl.textContent = 'No stages enabled. Enable stages above first.';
    logEl.className = 'stage-log log-err';
  } else {
    logEl.textContent = `✓ Pipeline complete\n${results.join('\n')}`;
    logEl.className = 'stage-log log-ok';
  }
  await refreshPreview();
});
</script>

<style>
  .yolo-layout { min-height: 100vh; background: var(--bg-base); padding-top: 3.5rem; }
  .yolo-header { background: var(--bg-surface); border-bottom: 1px solid var(--border); padding: 1.5rem; }
  .yolo-header-inner { max-width: 900px; margin: 0 auto; }
  .yolo-title { font-family: var(--font-mono); font-size: var(--text-xl); color: var(--text-primary); display: flex; align-items: center; gap: 0.75rem; }
  .yolo-badge { background: var(--teal); color: var(--bg-base); font-size: var(--text-xs); padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-family: var(--font-mono); }
  .yolo-subtitle { color: var(--text-muted); font-size: var(--text-sm); margin-top: 0.25rem; }
  .yolo-main { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }

  .pipeline-preview { display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 1.5rem; background: var(--bg-surface); border: 1px solid var(--border); border-radius: 0.5rem; }
  .preview-card { text-align: center; flex: 1; }
  .preview-card-link { text-decoration: none; border-radius: 0.375rem; padding: 0.5rem; transition: background 0.15s; display: block; }
  .preview-card-link:hover { background: color-mix(in srgb, var(--teal) 8%, transparent); }
  .preview-num { font-family: var(--font-mono); font-size: 2.5rem; font-weight: 700; color: var(--teal); }
  .preview-label { font-size: var(--text-xs); color: var(--text-muted); margin-top: 0.25rem; }
  .preview-action { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); margin-top: 0.25rem; opacity: 0.7; }
  .preview-arrow { font-size: 1.5rem; color: var(--text-muted); }

  .stage-card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1.5rem; }
  .stage-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
  .stage-info { display: flex; align-items: flex-start; gap: 1rem; }
  .stage-num { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); background: color-mix(in srgb, var(--teal) 15%, transparent); padding: 0.25rem 0.5rem; border-radius: 0.25rem; white-space: nowrap; margin-top: 0.1rem; }
  .stage-title { font-family: var(--font-mono); font-size: var(--text-base); color: var(--text-primary); margin-bottom: 0.25rem; }
  .stage-desc { font-size: var(--text-sm); color: var(--text-muted); }
  .stage-config { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem; }
  .cfg-field { display: flex; flex-direction: column; gap: 0.3rem; font-size: var(--text-sm); color: var(--text-secondary); flex: 1; min-width: 180px; }
  .cfg-field input, .cfg-field select { background: var(--bg-base); border: 1px solid var(--border); border-radius: 0.375rem; padding: 0.375rem 0.625rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm); width: 100%; }
  .cfg-field input:focus, .cfg-field select:focus { outline: none; border-color: var(--teal); }
  .stage-actions { display: flex; gap: 0.75rem; }

  .toggle { position: relative; display: inline-flex; cursor: pointer; flex-shrink: 0; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-track { width: 2.5rem; height: 1.375rem; background: var(--border); border-radius: 9999px; transition: background 0.2s; }
  .toggle input:checked + .toggle-track { background: var(--teal); }
  .toggle-track::after { content: ''; position: absolute; top: 0.1875rem; left: 0.1875rem; width: 1rem; height: 1rem; background: white; border-radius: 50%; transition: transform 0.2s; }
  .toggle input:checked ~ .toggle-track::after { transform: translateX(1.125rem); }

  .btn-save { background: transparent; border: 1px solid var(--border); color: var(--text-secondary); font-family: var(--font-mono); font-size: var(--text-sm); padding: 0.4rem 0.9rem; border-radius: 0.375rem; cursor: pointer; transition: all 0.15s; }
  .btn-save:hover { border-color: var(--text-secondary); color: var(--text-primary); }
  .btn-run { background: var(--teal); border: none; color: var(--bg-base); font-family: var(--font-mono); font-size: var(--text-sm); padding: 0.4rem 0.9rem; border-radius: 0.375rem; cursor: pointer; transition: opacity 0.15s; }
  .btn-run:hover { opacity: 0.85; }

  .stage-log { margin-top: 0.75rem; font-family: var(--font-mono); font-size: var(--text-xs); white-space: pre-wrap; border-radius: 0.375rem; padding: 0; max-height: 12rem; overflow-y: auto; }
  .log-ok { color: var(--teal); background: color-mix(in srgb, var(--teal) 8%, transparent); padding: 0.5rem 0.75rem; }
  .log-err { color: #e87878; background: color-mix(in srgb, #e87878 8%, transparent); padding: 0.5rem 0.75rem; }
  .log-running { color: var(--gold); background: color-mix(in srgb, var(--gold) 8%, transparent); padding: 0.5rem 0.75rem; }

  .run-all-card { background: var(--bg-surface); border: 1px solid var(--teal); border-radius: 0.5rem; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
  .btn-run-all { align-self: flex-start; background: var(--gold); border: none; color: var(--bg-base); font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 700; padding: 0.6rem 1.25rem; border-radius: 0.375rem; cursor: pointer; transition: opacity 0.15s; }
  .btn-run-all:hover { opacity: 0.85; }

  @media (max-width: 600px) {
    .pipeline-preview { flex-direction: column; }
    .preview-arrow { transform: rotate(90deg); }
  }
</style>
