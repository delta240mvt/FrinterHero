---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';
import { parseMarkdown } from '@/utils/markdown';

const { id: idParam } = Astro.params;
const id = parseInt(idParam || '0', 10);

if (isNaN(id) || id <= 0) {
  return Astro.redirect('/admin/knowledge-base');
}

let entry: any = null;
let projects: string[] = [];

async function apiFetch(path: string) {
  const response = await fetch(new URL(path, Astro.request.url).toString(), {
    headers: { cookie: Astro.request.headers.get('cookie') || '' },
  });
  if (!response.ok) throw new Error(`${path} -> ${response.status}`);
  return response.json();
}

try {
  const [entryData, entriesData] = await Promise.all([
    apiFetch(`/api/knowledge-base/${id}`),
    apiFetch('/api/knowledge-base?limit=500'),
  ]);
  entry = entryData || null;
  projects = [...new Set((entriesData.entries || []).map((item: any) => item.projectName).filter(Boolean))].sort() as string[];
} catch (e) {
  console.error('[KB View]', e);
}

if (!entry) {
  return Astro.redirect('/admin/knowledge-base');
}

const renderedContent = parseMarkdown(entry.content || '');

const TYPE_LABELS: Record<string, string> = {
  project_spec      : 'Project Spec',
  published_article : 'Published Article',
  external_research : 'External Research',
  personal_note     : 'Personal Note',
};

const createdDate = new Date(entry.createdAt).toLocaleDateString('en-US', {
  day: '2-digit', month: 'long', year: 'numeric',
});
const updatedDate = new Date(entry.updatedAt).toLocaleDateString('en-US', {
  day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit',
});

const wordCount = (entry.content || '').trim().split(/\s+/).filter(Boolean).length;
const readingMin = Math.max(1, Math.ceil(wordCount / 200));
---

<Base title={`${entry.title} — KB Admin`}>
<div class="admin-layout">

  <!-- HEADER -->
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">/</span>
      <a href="/admin/knowledge-base" class="bc-link">Knowledge Base</a>
      <span class="bc-sep">/</span>
      <span class="bc-current">#{entry.id}</span>
    </nav>
    <div class="header-actions">
      <button id="toggle-edit-btn" class="btn-edit">✏️ Edit</button>
      <button id="delete-btn" class="btn-danger-sm" data-entry-title={entry.title}>🗑 Delete</button>
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="page-main">
    <div class="view-layout">

      <!-- ====== LEFT: METADATA SIDEBAR ====== -->
      <aside class="meta-sidebar">

        <div class={`type-banner type-banner--${entry.type}`}>
          <span class={`type-badge type-${entry.type}`}>{TYPE_LABELS[entry.type] || entry.type}</span>
        </div>

        <div class="meta-section">
          <div class="meta-label">Importance</div>
          <div class="score-display">
            <div class="score-bar-lg">
              <div class="score-fill-lg" style={`width:${entry.importanceScore}%`}></div>
            </div>
            <span class="score-number">{entry.importanceScore}<span class="score-max">/100</span></span>
          </div>
        </div>

        {entry.projectName && (
          <div class="meta-section">
            <div class="meta-label">Folder / Project</div>
            <a href={`/admin/knowledge-base?tab=kb&project=${encodeURIComponent(entry.projectName)}`} class="folder-chip">
              📁 {entry.projectName}
            </a>
          </div>
        )}

        {entry.tags?.length > 0 && (
          <div class="meta-section">
            <div class="meta-label">Tags</div>
            <div class="tags-list">
              {entry.tags.map((t: string) => <span class="tag">{t}</span>)}
            </div>
          </div>
        )}

        {entry.sourceUrl && (
          <div class="meta-section">
            <div class="meta-label">Source</div>
            <a href={entry.sourceUrl} target="_blank" rel="noopener" class="source-link">{entry.sourceUrl}</a>
          </div>
        )}

        <div class="meta-section">
          <div class="meta-label">Content Stats</div>
          <div class="content-stats">
            <div class="content-stat">{wordCount.toLocaleString()} words</div>
            <div class="content-stat">~{readingMin} min read</div>
            <div class="content-stat">{(entry.content || '').length.toLocaleString()} chars</div>
          </div>
        </div>

        <div class="meta-section">
          <div class="meta-label">Dates</div>
          <div class="date-list">
            <div class="date-item"><span class="date-label">Created</span><span class="date-val">{createdDate}</span></div>
            <div class="date-item"><span class="date-label">Updated</span><span class="date-val">{updatedDate}</span></div>
          </div>
        </div>

        <div class="meta-section">
          <div class="meta-label">Entry ID</div>
          <code class="entry-id">#{entry.id}</code>
        </div>

        <div class="meta-nav">
          <a href="/admin/knowledge-base" class="btn-back">← Back to list</a>
        </div>

      </aside>

      <!-- ====== RIGHT: CONTENT + EDIT ====== -->
      <div class="content-area">

        <!-- ENTRY TITLE -->
        <h1 class="entry-title">{entry.title}</h1>

        <!-- ─── VIEW MODE ─── -->
        <div id="view-mode">
          <div class="content-label">
            <span>Entry content</span>
            <span class="content-label-type">(Markdown)</span>
          </div>
          <div class="markdown-content" set:html={renderedContent}></div>
        </div>

        <!-- ─── EDIT MODE ─── -->
        <div id="edit-mode" style="display:none">
          <div id="edit-message" class="edit-message" style="display:none"></div>
          <form id="edit-form" class="edit-form" novalidate>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="edit-type">Type</label>
                <select id="edit-type" name="type" class="form-input" required>
                  <option value="project_spec"      selected={entry.type === 'project_spec'}>Project Spec</option>
                  <option value="published_article" selected={entry.type === 'published_article'}>Published Article</option>
                  <option value="external_research" selected={entry.type === 'external_research'}>External Research</option>
                  <option value="personal_note"     selected={entry.type === 'personal_note'}>Personal Note</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="edit-score">Importance: <span id="score-display">{entry.importanceScore}</span>/100</label>
                <input type="range" id="edit-score" name="importance_score" min="0" max="100" value={entry.importanceScore} class="range-input" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="edit-title">Title</label>
              <input type="text" id="edit-title" name="title" class="form-input" value={entry.title} required />
            </div>

            <div class="form-group">
              <label class="form-label" for="edit-project">Folder / Project</label>
              <div class="project-input-row">
                <select id="edit-project-select" class="form-input" style="flex:1">
                  <option value="">— none / new folder —</option>
                  {projects.map(p => (
                    <option value={p} selected={entry.projectName === p}>{p}</option>
                  ))}
                </select>
                <span class="project-or">or type:</span>
                <input type="text" id="edit-project" name="project_name" class="form-input" style="flex:1"
                  placeholder="New folder..." value={entry.projectName || ''} />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="edit-content">Content (Markdown, min 50 chars)</label>
              <textarea id="edit-content" name="content" class="form-textarea" rows="18" required>{entry.content}</textarea>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="edit-url">Source URL (optional)</label>
                <input type="url" id="edit-url" name="source_url" class="form-input" value={entry.sourceUrl || ''} placeholder="https://..." />
              </div>
              <div class="form-group">
                <label class="form-label" for="edit-tags">Tags (comma-separated, lowercase)</label>
                <input type="text" id="edit-tags" name="tags" class="form-input"
                  value={(entry.tags || []).join(', ')} placeholder="deep-work, ai, frinter" />
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn-save" id="save-btn">Save Changes</button>
              <button type="button" id="cancel-edit-btn" class="btn-ghost-sm">Cancel</button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </main>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div id="delete-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true">
  <div class="modal-box">
    <h3 class="modal-title">Delete KB Entry</h3>
    <p class="modal-desc">Are you sure you want to delete this entry:</p>
    <p class="modal-entry-name">"{entry.title}"</p>
    <p class="modal-warn">This action cannot be undone.</p>
    <div class="modal-actions">
      <button id="delete-confirm-btn" class="btn-danger">Delete permanently</button>
      <button id="delete-cancel-btn"  class="btn-ghost-sm">Cancel</button>
    </div>
  </div>
</div>

<script define:vars={{ entryId: entry.id }}>
  // ---- EDIT TOGGLE ----
  const toggleBtn   = document.getElementById('toggle-edit-btn');
  const viewMode    = document.getElementById('view-mode');
  const editMode    = document.getElementById('edit-mode');
  const cancelBtn   = document.getElementById('cancel-edit-btn');

  function showEdit() {
    viewMode.style.display = 'none';
    editMode.style.display = 'block';
    toggleBtn.textContent  = '👁 Preview';
    toggleBtn.onclick      = showView;
  }
  function showView() {
    viewMode.style.display = 'block';
    editMode.style.display = 'none';
    toggleBtn.textContent  = '✏️ Edit';
    toggleBtn.onclick      = showEdit;
  }

  toggleBtn.onclick = showEdit;
  cancelBtn?.addEventListener('click', showView);

  // Sync project select → text input
  const projectSelect = document.getElementById('edit-project-select');
  const projectInput  = document.getElementById('edit-project');
  projectSelect?.addEventListener('change', () => {
    if (projectSelect.value) projectInput.value = projectSelect.value;
  });

  // Score slider display
  document.getElementById('edit-score')?.addEventListener('input', (e) => {
    const el = document.getElementById('score-display');
    if (el) el.textContent = e.target.value;
  });

  // ---- SAVE ----
  document.getElementById('edit-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form    = e.target;
    const data    = Object.fromEntries(new FormData(form));
    const msg     = document.getElementById('edit-message');
    const saveBtn = document.getElementById('save-btn');

    saveBtn.textContent = 'Saving…';
    saveBtn.disabled    = true;

    const body = {
      type            : data.type,
      title           : data.title,
      content         : data.content,
      source_url      : data.source_url || undefined,
      tags            : (data.tags || '').split(',').map(t => t.trim().toLowerCase()).filter(Boolean),
      importance_score: parseInt(data.importance_score, 10),
      project_name    : data.project_name?.trim() || null,
    };

    try {
      const res = await fetch(`/api/knowledge-base/${entryId}`, {
        method : 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body   : JSON.stringify(body),
      });

      if (res.ok) {
        msg.className   = 'edit-message msg-success';
        msg.textContent = 'Saved. Refreshing…';
        msg.style.display = 'block';
        setTimeout(() => window.location.reload(), 900);
      } else {
        const err = await res.json();
        msg.className   = 'edit-message msg-error';
        msg.textContent = err.error + (err.fields
          ? ': ' + Object.entries(err.fields).map(([k,v]) => `${k}: ${v}`).join(', ')
          : '');
        msg.style.display = 'block';
        saveBtn.textContent = 'Save Changes';
        saveBtn.disabled    = false;
      }
    } catch {
      msg.className   = 'edit-message msg-error';
      msg.textContent = 'Network error. Please try again.';
      msg.style.display = 'block';
      saveBtn.textContent = 'Save Changes';
      saveBtn.disabled    = false;
    }
  });

  // ---- DELETE ----
  const deleteBtn     = document.getElementById('delete-btn');
  const deleteModal   = document.getElementById('delete-modal');
  const deleteConfirm = document.getElementById('delete-confirm-btn');
  const deleteCancel  = document.getElementById('delete-cancel-btn');

  deleteBtn?.addEventListener('click', () => { deleteModal.style.display = 'flex'; });
  deleteCancel?.addEventListener('click', () => { deleteModal.style.display = 'none'; });

  deleteConfirm?.addEventListener('click', async () => {
    deleteConfirm.textContent = 'Deleting…';
    deleteConfirm.disabled    = true;
    try {
      const res = await fetch(`/api/knowledge-base/${entryId}`, { method: 'DELETE' });
      if (res.ok) {
        window.location.href = '/admin/knowledge-base';
      } else {
        const err = await res.json();
        alert('Error: ' + (err.error || 'Unknown error'));
        deleteConfirm.textContent = 'Delete permanently';
        deleteConfirm.disabled    = false;
      }
    } catch {
      alert('Network error.');
      deleteConfirm.textContent = 'Delete permanently';
      deleteConfirm.disabled    = false;
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && deleteModal.style.display !== 'none') {
      deleteModal.style.display = 'none';
    }
  });
</script>

<style>
/* ─── LAYOUT ─────────────────────────────────────────────── */
.admin-layout { min-height: 100vh; background: var(--bg-base); }

.admin-header {
  display: flex; align-items: center; gap: 1.25rem;
  padding: 0.875rem 1.5rem; background: var(--bg-elevated);
  border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20;
}
.admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; flex-shrink: 0; }
.breadcrumb { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--text-xs); }
.bc-link    { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep     { color: var(--border); }
.bc-current { color: var(--text-secondary); }
.header-actions { margin-left: auto; display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0; }

.btn-edit       { padding: 0.4rem 0.875rem; background: rgba(74,141,131,0.15); color: var(--teal); border: 1px solid rgba(74,141,131,0.3); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-edit:hover { background: rgba(74,141,131,0.25); }
.btn-danger-sm  { padding: 0.4rem 0.875rem; background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.25); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-danger-sm:hover { background: rgba(239,68,68,0.2); }
.btn-logout     { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }

.page-main { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem 3rem; }

/* ─── TWO-COLUMN LAYOUT ──────────────────────────────────── */
.view-layout { display: grid; grid-template-columns: 260px 1fr; gap: 2rem; align-items: start; }

/* ─── META SIDEBAR ───────────────────────────────────────── */
.meta-sidebar {
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: 0.625rem; overflow: hidden; position: sticky; top: 5rem;
  display: flex; flex-direction: column; gap: 0;
}
.type-banner { padding: 0.875rem 1rem; border-bottom: 1px solid var(--border); }
.type-banner--project_spec      { background: rgba(74,141,131,0.1); }
.type-banner--published_article { background: rgba(138,78,100,0.1); }
.type-banner--external_research { background: rgba(214,183,121,0.1); }
.type-banner--personal_note     { background: rgba(148,163,184,0.06); }

.type-badge { padding: 0.25rem 0.625rem; border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.04em; }
.type-project_spec      { background: rgba(74,141,131,0.2); color: var(--teal); }
.type-published_article { background: rgba(138,78,100,0.2); color: var(--violet); }
.type-external_research { background: rgba(214,183,121,0.2); color: var(--gold); }
.type-personal_note     { background: rgba(148,163,184,0.12); color: var(--text-secondary); }

.meta-section { padding: 0.875rem 1rem; border-bottom: 1px solid var(--border); }
.meta-section:last-child { border-bottom: none; }
.meta-label { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.5rem; }

.score-display { display: flex; flex-direction: column; gap: 0.35rem; }
.score-bar-lg  { height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; width: 100%; }
.score-fill-lg { height: 100%; background: var(--teal); border-radius: 3px; transition: width 0.3s; }
.score-number  { font-family: var(--font-mono); font-size: 1.125rem; font-weight: 700; color: var(--text-primary); }
.score-max     { font-size: 0.7rem; color: var(--text-muted); }

.folder-chip { display: inline-flex; align-items: center; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); background: rgba(74,141,131,0.1); border: 1px solid rgba(74,141,131,0.2); padding: 0.3rem 0.625rem; border-radius: 0.3rem; text-decoration: none; }
.folder-chip:hover { background: rgba(74,141,131,0.18); }

.tags-list { display: flex; flex-wrap: wrap; gap: 0.25rem; }
.tag { padding: 0.15rem 0.4rem; background: rgba(255,255,255,0.06); border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); }

.source-link { font-family: var(--font-mono); font-size: 0.65rem; color: var(--teal); word-break: break-all; }

.content-stats { display: flex; flex-direction: column; gap: 0.25rem; }
.content-stat  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); }

.date-list  { display: flex; flex-direction: column; gap: 0.35rem; }
.date-item  { display: flex; flex-direction: column; gap: 0.1rem; }
.date-label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; }
.date-val   { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-secondary); }

.entry-id { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); background: rgba(255,255,255,0.05); padding: 0.2rem 0.5rem; border-radius: 0.2rem; }

.meta-nav { padding: 0.875rem 1rem; }
.btn-back { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); text-decoration: none; }
.btn-back:hover { text-decoration: underline; }

/* ─── CONTENT AREA ───────────────────────────────────────── */
.content-area { display: flex; flex-direction: column; gap: 1.25rem; }

.entry-title {
  font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700;
  color: var(--text-primary); line-height: 1.35; margin: 0;
}

.content-label {
  display: flex; align-items: center; gap: 0.5rem;
  font-family: var(--font-mono); font-size: 0.65rem;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--text-muted); margin-bottom: 0.75rem;
  padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
}
.content-label-type { color: rgba(148,163,184,0.4); }

/* Markdown rendered content */
.markdown-content {
  font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary);
  line-height: 1.75; background: rgba(0,0,0,0.12); border: 1px solid var(--border);
  border-radius: 0.5rem; padding: 1.5rem;
}
.markdown-content :global(h1),
.markdown-content :global(h2),
.markdown-content :global(h3),
.markdown-content :global(h4) {
  font-family: var(--font-mono); color: var(--text-primary); margin-top: 1.5em; margin-bottom: 0.5em;
}
.markdown-content :global(h1) { font-size: 1.2rem; }
.markdown-content :global(h2) { font-size: 1.05rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3em; }
.markdown-content :global(h3) { font-size: 0.95rem; }
.markdown-content :global(p)  { margin: 0.75em 0; }
.markdown-content :global(ul),
.markdown-content :global(ol) { padding-left: 1.5rem; margin: 0.75em 0; }
.markdown-content :global(li) { margin: 0.3em 0; }
.markdown-content :global(code) {
  background: rgba(255,255,255,0.07); border: 1px solid var(--border);
  border-radius: 0.2rem; padding: 0.1rem 0.35rem; font-size: 0.85em;
}
.markdown-content :global(pre) {
  background: rgba(0,0,0,0.2); border: 1px solid var(--border); border-radius: 0.375rem;
  padding: 1rem; overflow-x: auto; margin: 1em 0;
}
.markdown-content :global(pre code) { background: none; border: none; padding: 0; }
.markdown-content :global(blockquote) {
  border-left: 3px solid var(--teal); margin-left: 0; padding-left: 1rem;
  color: var(--text-muted); font-style: italic;
}
.markdown-content :global(a) { color: var(--teal); }
.markdown-content :global(strong) { color: var(--text-primary); }
.markdown-content :global(hr) { border: none; border-top: 1px solid var(--border); margin: 1.5em 0; }
.markdown-content :global(table) { width: 100%; border-collapse: collapse; margin: 1em 0; }
.markdown-content :global(th),
.markdown-content :global(td) { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
.markdown-content :global(th) { background: rgba(255,255,255,0.04); color: var(--text-primary); font-weight: 600; }

/* ─── EDIT FORM ──────────────────────────────────────────── */
.edit-message { padding: 0.875rem 1rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); margin-bottom: 1rem; }
.msg-success { background: rgba(74,141,131,0.15); color: var(--teal); border: 1px solid rgba(74,141,131,0.3); }
.msg-error   { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }

.edit-form { display: flex; flex-direction: column; gap: 1.125rem; background: rgba(0,0,0,0.1); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1.5rem; }
.form-row  { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.35rem; }
.form-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; }
.form-input, .form-textarea {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem;
  color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm);
  padding: 0.6rem 0.875rem; outline: none; transition: border-color 0.15s; width: 100%;
}
.form-input:focus, .form-textarea:focus { border-color: var(--teal); }
.form-textarea { resize: vertical; line-height: 1.6; font-size: var(--text-xs); }
.range-input   { width: 100%; accent-color: var(--teal); margin-top: 0.4rem; }
.project-input-row { display: flex; align-items: center; gap: 0.5rem; }
.project-or { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); white-space: nowrap; flex-shrink: 0; }

.form-actions { display: flex; gap: 0.75rem; padding-top: 0.25rem; }
.btn-save     { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
.btn-save:disabled { opacity: 0.6; cursor: not-allowed; }
.btn-ghost-sm { padding: 0.5rem 1rem; background: none; color: var(--text-secondary); border: 1px solid var(--border); border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); text-decoration: none; cursor: pointer; }

/* ─── DELETE MODAL ───────────────────────────────────────── */
.modal-backdrop {
  position: fixed; inset: 0; background: rgba(0,0,0,0.65); z-index: 200;
  display: flex; align-items: center; justify-content: center; backdrop-filter: blur(2px);
}
.modal-box {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.625rem;
  padding: 2rem; max-width: 420px; width: 90%; display: flex; flex-direction: column; gap: 0.75rem;
}
.modal-title      { font-family: var(--font-mono); font-size: 1.1rem; color: var(--text-primary); margin: 0; }
.modal-desc       { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); margin: 0; }
.modal-entry-name { font-family: var(--font-mono); font-size: var(--text-sm); color: #ef4444; font-weight: 600; margin: 0; }
.modal-warn       { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.modal-actions    { display: flex; gap: 0.75rem; padding-top: 0.5rem; }
.btn-danger       { padding: 0.5rem 1.25rem; background: #ef4444; color: #fff; border: none; border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
.btn-danger:disabled { opacity: 0.6; cursor: not-allowed; }

/* ─── RESPONSIVE ─────────────────────────────────────────── */
@media (max-width: 900px) {
  .view-layout { grid-template-columns: 1fr; }
  .meta-sidebar { position: static; }
  .form-row     { grid-template-columns: 1fr; }
  .project-input-row { flex-wrap: wrap; }
}
@media (max-width: 480px) {
  .page-main    { padding: 1.25rem 1rem 2rem; }
  .entry-title  { font-size: 1.2rem; }
  .header-actions .btn-logout { display: none; }
}
</style>
</Base>
