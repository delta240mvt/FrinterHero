---
import Base from '@/components/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import BlogCard from '@/components/BlogCard.astro';
import { db } from '@/db/client';
import { articles, sites } from '@/db/schema';
import { getCurrentSiteSlug, getSitePresentation } from '@/lib/site-config';
import { eq, desc, and, sql, or, isNull } from 'drizzle-orm';

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const tag = Astro.url.searchParams.get('tag') || '';
const LIMIT = 10;
const offset = (page - 1) * LIMIT;
const site = getSitePresentation();
const siteSlug = getCurrentSiteSlug();

let posts: any[] = [];
let totalCount = 0;

try {
  const [siteRow] = await db.select({ id: sites.id }).from(sites).where(eq(sites.slug, siteSlug)).limit(1);
  const siteCondition = siteRow
    ? (siteSlug === 'przemyslawfilipiak'
        ? or(eq(articles.siteId, siteRow.id), isNull(articles.siteId))
        : eq(articles.siteId, siteRow.id))
    : isNull(articles.siteId);
  let query = db.select().from(articles).$dynamic();
  let countQuery = db.select({ count: sql<number>`count(*)::int` }).from(articles).$dynamic();

  const conditions = [eq(articles.status, 'published'), siteCondition];
  if (tag) {
    conditions.push(sql`${articles.tags} @> ARRAY[${tag}]::text[]`);
  }

  if (conditions.length === 1) {
    query = query.where(conditions[0]);
    countQuery = countQuery.where(conditions[0]);
  } else {
    query = query.where(and(...conditions));
    countQuery = countQuery.where(and(...conditions));
  }

  posts = await query.orderBy(desc(articles.publishedAt)).limit(LIMIT).offset(offset);
  const countResult = await countQuery;
  totalCount = countResult[0]?.count ?? 0;
} catch (e) {
  // DB not available
}

const totalPages = Math.ceil(totalCount / LIMIT);
---

<Base
  title={site.blogTitle}
  description={site.blogDescription}
>
  <Nav />
  <main class="blog-list-main" aria-label="Blog posts">
    <div class="blog-list-container">
      <header class="blog-list-header">
        <h1 class="blog-list-title">/blog</h1>
        {tag && (
          <div class="tag-filter">
            <span>Filtered by: <strong class="tag-name">{tag}</strong></span>
            <a href="/blog" class="clear-filter">✕ Clear filter</a>
          </div>
        )}
      </header>

      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post, i) => (
            <BlogCard
              title={post.title}
              description={post.description}
              date={post.publishedAt}
              readingTime={post.readingTime}
              tags={post.tags || []}
              slug={post.slug}
              featured={post.featured && i === 0}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No articles found. Check back soon.</p>
      )}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Blog pagination">
          {page > 1 && (
            <a href={`/blog?page=${page - 1}${tag ? `&tag=${tag}` : ''}`} class="page-btn">← Previous</a>
          )}
          <span class="page-info">Page {page} of {totalPages}</span>
          {page < totalPages && (
            <a href={`/blog?page=${page + 1}${tag ? `&tag=${tag}` : ''}`} class="page-btn">Next →</a>
          )}
        </nav>
      )}
    </div>
  </main>
  <Footer />
</Base>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${site.canonicalBaseUrl}/blog/#webpage`,
      "url": `${site.canonicalBaseUrl}/blog`,
      "name": site.blogTitle,
      "description": site.blogDescription,
      "isPartOf": { "@id": `${site.canonicalBaseUrl}/#website` },
      "author": { "@id": `${site.canonicalBaseUrl}/#entity` },
      "inLanguage": "en-US",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": site.canonicalBaseUrl },
          { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${site.canonicalBaseUrl}/blog` }
        ]
      }
    }
  ]
})} />

<style>
  .blog-list-main {
    padding-top: 3.5rem;
    min-height: 100vh;
    background-color: var(--bg-base);
  }
  .blog-list-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }
  .blog-list-header {
    margin-bottom: 2.5rem;
  }
  .blog-list-title {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--teal);
    margin-bottom: 0.75rem;
  }
  .tag-filter {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .tag-name { color: var(--violet); }
  .clear-filter {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .clear-filter:hover { color: var(--text-primary); }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .empty-state {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 3rem 0;
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .page-btn {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--teal);
    text-decoration: none;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    transition: all 0.15s;
  }
  .page-btn:hover { border-color: var(--teal); }
  .page-info {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
