---
import BlogPost from '@/components/layouts/BlogPost.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCurrentSiteSlug } from '@/lib/site-config';
import { getInternalApiBaseUrl } from '@/lib/internal-api';

const siteSlug = getCurrentSiteSlug();
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

let article: any = null;
let relatedArticles: any[] = [];

try {
  const apiBase = getInternalApiBaseUrl();
  const articleParams = new URLSearchParams({ siteSlug });
  const articleResponse = await fetch(`${apiBase}/v1/articles/${encodeURIComponent(slug)}?${articleParams}`);

  if (articleResponse.ok) {
    article = await articleResponse.json();
  }

  if (article?.tags?.length > 0) {
    const listParams = new URLSearchParams({ siteSlug, status: 'published', limit: '20' });
    const listResponse = await fetch(`${apiBase}/v1/articles?${listParams}`);
    if (listResponse.ok) {
      const listData = await listResponse.json();
      const articleTags = new Set(article.tags as string[]);
      relatedArticles = (listData.results ?? [])
        .filter((a: any) => a.id !== article.id && a.tags?.some((t: string) => articleTags.has(t)))
        .slice(0, 3);
    }
  }
} catch {
  // API not available
}

if (!article) {
  return Astro.redirect('/404');
}
---

<BlogPost
  title={article.title}
  description={article.description}
  publishedAt={article.publishedAt}
  updatedAt={article.updatedAt}
  readingTime={article.readingTime}
  tags={article.tags || []}
  author={article.author}
  slug={article.slug}
>
  <div set:html={article.content} />

  {relatedArticles.length > 0 && (
    <aside class="related-articles">
      <h2 class="related-title">Related Articles</h2>
      <div class="related-grid">
        {relatedArticles.map(related => (
          <BlogCard
            title={related.title}
            description={related.description}
            date={related.publishedAt}
            readingTime={related.readingTime}
            tags={related.tags || []}
            slug={related.slug}
          />
        ))}
      </div>
    </aside>
  )}
</BlogPost>

<style>
  .related-articles {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .related-title {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--teal);
    margin-bottom: 1.25rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
</style>
