---
import '@/styles/global.css';
import '@/styles/animations.css';
import { absoluteUrl, getSitePresentation } from '@/lib/site-config';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: string;
  articlePublishedAt?: string;
  articleModifiedAt?: string;
}

const {
  title = undefined,
  description = undefined,
  ogImage = '/og-image.png',
  canonical = Astro.url.href,
  ogType = 'website',
  articlePublishedAt,
  articleModifiedAt,
} = Astro.props;

const site = getSitePresentation();
const isAdminPage = Astro.url.pathname.startsWith('/admin') && Astro.url.pathname !== '/admin/login';
const adminActiveSite = isAdminPage ? (Astro.locals.activeSiteSlug ?? null) : null;
const resolvedTitle = title ?? site.defaultTitle;
const resolvedDescription = description ?? site.defaultDescription;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : absoluteUrl(ogImage);
const entityGraphNode = site.entityType === 'Person'
  ? {
      '@type': 'Person',
      '@id': `${site.canonicalBaseUrl}/#entity`,
      name: site.authorName,
      givenName: 'Przemysław',
      familyName: 'Filipiak',
      jobTitle: 'High Performer & Deep Focus Founder',
      description: site.defaultDescription,
      url: site.canonicalBaseUrl,
      image: absoluteUrl('/og-image.png'),
      sameAs: site.socialLinks,
      knowsAbout: [
        'Artificial Intelligence',
        'Generative Engine Optimization (GEO)',
        'Deep Work',
        'Astro Framework',
        'Python',
        'React',
        'Local-first Software',
        'High Performance Productivity',
      ],
    }
  : {
      '@type': 'Organization',
      '@id': `${site.canonicalBaseUrl}/#entity`,
      name: site.displayName,
      description: site.defaultDescription,
      url: site.canonicalBaseUrl,
      image: absoluteUrl('/og-image.png'),
      sameAs: site.socialLinks,
    };
---

<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="description" content={resolvedDescription} />
    <meta name="author" content={site.authorName} />
    <title>{resolvedTitle}</title>
    <link rel="canonical" href={canonical} />

    <!-- Font Preloads -->
    <link rel="preload" href="/fonts/CourierPrime-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/CourierPrime-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Poppins-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Roboto-400.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon — Google SERP wymaga PNG min 48x48px jako primary -->
    <link rel="icon" href="/favicon-192x192.png" type="image/png" sizes="192x192" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- OpenGraph -->
    <meta property="og:site_name" content={site.displayName} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:alt" content={`${resolvedTitle} — ${site.displayName}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={`${resolvedTitle} — ${site.displayName}`} />

    <!-- Article meta (only when ogType='article') -->
    {articlePublishedAt && <meta property="article:published_time" content={articlePublishedAt} />}
    {articleModifiedAt && <meta property="article:modified_time" content={articleModifiedAt} />}
    {ogType === 'article' && <meta property="article:author" content={site.canonicalBaseUrl} />}

    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Identity & Discovery -->
    {site.socialLinks.map((link) => <link rel="me" href={link} />)}
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title={site.blogTitle} href="/rss.xml" />

    <!-- Page-specific head content (JSON-LD, etc.) -->
    <slot name="head" />

    <!-- JSON-LD: Person + WebSite @graph -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          ...entityGraphNode
        },
        {
          "@type": "WebSite",
          "@id": `${site.canonicalBaseUrl}/#website`,
          "name": site.displayName,
          "url": site.canonicalBaseUrl,
          "description": site.defaultDescription,
          "author": { "@id": `${site.canonicalBaseUrl}/#entity` },
          "inLanguage": "en-US",
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": `${site.canonicalBaseUrl}/blog?q={search_term_string}`
            },
            "query-input": "required name=search_term_string"
          }
        }
      ]
    })} />
  </head>
  <body>
    <slot />
    {isAdminPage && (
      <>
        <div class="admin-site-switcher" data-admin-site-switcher>
          <label class="admin-site-switcher__label" for="admin-site-switcher-select">Tenant</label>
          <select
            id="admin-site-switcher-select"
            class="admin-site-switcher__select"
            data-current-site={adminActiveSite ?? ''}
          >
            <option value="przemyslawfilipiak" selected={adminActiveSite === 'przemyslawfilipiak'}>PrzemyslawFilipiak</option>
            <option value="focusequalsfreedom" selected={adminActiveSite === 'focusequalsfreedom'}>FocusEqualsFreedom</option>
            <option value="frinter" selected={adminActiveSite === 'frinter'}>Frinter</option>
          </select>
        </div>
        <script is:inline>
          (() => {
            const root = document.querySelector('[data-admin-site-switcher]');
            const select = document.getElementById('admin-site-switcher-select');
            if (!root || !(select instanceof HTMLSelectElement)) return;
            select.addEventListener('change', async () => {
              const siteSlug = select.value;
              const originalValue = select.dataset.currentSite;
              select.disabled = true;
              try {
                const res = await fetch('/api/admin/switch-tenant', {
                  method: 'POST',
                  headers: { 'content-type': 'application/json' },
                  body: JSON.stringify({ siteSlug }),
                });
                if (res.ok) {
                  window.location.reload();
                } else {
                  const data = await res.json().catch(() => ({}));
                  alert(data.error ?? 'Failed to switch tenant');
                  select.value = originalValue || '';
                  select.disabled = false;
                }
              } catch {
                alert('Network error switching tenant');
                select.value = originalValue || '';
                select.disabled = false;
              }
            });
          })();
        </script>
        <style>
          .admin-site-switcher {
            position: fixed;
            right: 1rem;
            bottom: 1rem;
            z-index: 90;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.75rem;
            border: 1px solid rgba(74, 141, 131, 0.25);
            border-radius: 0.55rem;
            background: rgba(15, 23, 42, 0.94);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
            backdrop-filter: blur(8px);
          }
          .admin-site-switcher__label {
            font-family: var(--font-mono);
            font-size: 0.68rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
          }
          .admin-site-switcher__select {
            min-width: 12rem;
            padding: 0.4rem 0.55rem;
            border: 1px solid var(--border);
            border-radius: 0.35rem;
            background: rgba(15, 23, 42, 0.95);
            color: var(--text-primary);
            font-family: var(--font-mono);
            font-size: 0.72rem;
          }
          @media (max-width: 640px) {
            .admin-site-switcher {
              left: 0.75rem;
              right: 0.75rem;
              bottom: 0.75rem;
            }
            .admin-site-switcher__select {
              min-width: 0;
              flex: 1;
            }
          }
        </style>
      </>
    )}
  </body>
</html>
