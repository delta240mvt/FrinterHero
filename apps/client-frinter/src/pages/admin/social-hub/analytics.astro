---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';

const daysParam = Astro.url.searchParams.get('days');
const days = daysParam && ['7', '30', '90'].includes(daysParam) ? parseInt(daysParam, 10) : 30;

interface Summary {
  totalPosts: number;
  totalImpressions: number;
  avgEngagementRate: number;
  totalLikes: number;
  totalComments: number;
  totalShares: number;
}

interface PlatformRow {
  platform: string;
  postsCount: number;
  totalViews: number;
  totalLikes: number;
  avgEngagement: number;
}

interface TopPost {
  briefId: number;
  platform: string;
  hookLine: string;
  externalPostUrl: string;
  views: number;
  likes: number;
  engagementRate: number;
  publishedAt: string;
}

interface ActivityItem {
  briefId: number;
  sourceType: string;
  sourceTitle: string;
  status: string;
  createdAt: string;
}

interface BriefsStatusSummary {
  draft: number;
  generating: number;
  copy_review: number;
  rendering: number;
  render_review: number;
  published: number;
  done: number;
}

interface AnalyticsData {
  summary: Summary;
  byPlatform: PlatformRow[];
  topPosts: TopPost[];
  recentActivity: ActivityItem[];
  briefsStatusSummary: BriefsStatusSummary;
}

let data: AnalyticsData | null = null;
let fetchError = false;

try {
  const baseUrl = Astro.url.origin;
  const res = await fetch(`${baseUrl}/api/social-hub/analytics?days=${days}`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
  if (res.ok) {
    data = await res.json() as AnalyticsData;
  } else {
    fetchError = true;
  }
} catch (e) {
  console.error('[SH Analytics] fetch error:', e);
  fetchError = true;
}

const summary: Summary = data?.summary ?? {
  totalPosts: 0, totalImpressions: 0, avgEngagementRate: 0,
  totalLikes: 0, totalComments: 0, totalShares: 0,
};
const byPlatform: PlatformRow[] = data?.byPlatform ?? [];
const topPosts: TopPost[]       = data?.topPosts ?? [];
const recentActivity: ActivityItem[] = data?.recentActivity ?? [];
const bss: BriefsStatusSummary  = data?.briefsStatusSummary ?? {
  draft: 0, generating: 0, copy_review: 0,
  rendering: 0, render_review: 0, published: 0, done: 0,
};

// Compute max views for bar chart scaling
const maxViews = byPlatform.reduce((m, r) => Math.max(m, r.totalViews), 1);

// Status bar chart
const statusKeys: Array<keyof BriefsStatusSummary> = [
  'draft', 'generating', 'copy_review', 'rendering', 'render_review', 'published', 'done',
];
const maxStatusCount = Math.max(1, ...statusKeys.map(k => bss[k]));

const statusColors: Record<string, string> = {
  draft:         'var(--text-muted)',
  generating:    'var(--gold)',
  copy_review:   '#a78bfa',
  rendering:     'var(--gold)',
  render_review: '#a78bfa',
  published:     'var(--teal)',
  done:          'var(--teal)',
};

const activityStatusColors: Record<string, string> = {
  ...statusColors,
};

const platformColors: Record<string, string> = {
  instagram: '#e1306c',
  tiktok:    '#69c9d0',
  threads:   '#a78bfa',
  twitter:   '#1d9bf0',
  linkedin:  'var(--teal)',
};

function fmtDate(iso: string) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: '2-digit' });
}

function fmtNum(n: number) {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000)     return (n / 1_000).toFixed(1) + 'K';
  return String(n);
}

function truncate(s: string, max: number) {
  if (!s) return '—';
  return s.length > max ? s.slice(0, max) + '…' : s;
}
---

<Base title="Social Hub — Analytics" description="SocialHub performance analytics dashboard">
<div class="admin-layout">

  <!-- HEADER -->
  <header class="admin-header">
    <a href="/admin" class="admin-logo">FR</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/social-hub" class="bc-link">Social Hub</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">Analytics</span>
    </nav>
    <div class="header-actions">
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">

    <!-- Quick nav -->
    <nav class="quick-nav">
      <a href="/admin/social-hub" class="qnav-pill">Posts</a>
      <a href="/admin/social-hub/accounts" class="qnav-pill">Accounts</a>
      <a href="/admin/social-hub/templates" class="qnav-pill">Templates</a>
      <a href="/admin/social-hub/analytics" class="qnav-pill qnav-pill--active">Analytics</a>
      <a href="/admin/social-hub/settings" class="qnav-pill">Settings</a>
    </nav>

    <!-- Days filter -->
    <div class="days-filter">
      <span class="days-label">Period:</span>
      {[7, 30, 90].map(d => (
        <a
          href={`/admin/social-hub/analytics?days=${d}`}
          class={`days-btn ${days === d ? 'days-btn--active' : ''}`}
        >
          {d}d
        </a>
      ))}
    </div>

    {fetchError && (
      <div class="alert-error">
        Failed to load analytics data. Check server logs.
      </div>
    )}

    <!-- ===== SUMMARY CARDS ===== -->
    <section class="summary-grid">
      <div class="summary-card summary-card--teal">
        <span class="sc-label">Posts Published</span>
        <span class="sc-value">{fmtNum(summary.totalPosts)}</span>
      </div>
      <div class="summary-card summary-card--gold">
        <span class="sc-label">Views / Impressions</span>
        <span class="sc-value">{fmtNum(summary.totalImpressions)}</span>
      </div>
      <div class="summary-card summary-card--violet">
        <span class="sc-label">Total Likes</span>
        <span class="sc-value">{fmtNum(summary.totalLikes)}</span>
      </div>
      <div class="summary-card summary-card--engagement">
        <span class="sc-label">Avg Engagement</span>
        <span class="sc-value">{summary.avgEngagementRate.toFixed(2)}%</span>
      </div>
      <div class="summary-card">
        <span class="sc-label">Total Shares</span>
        <span class="sc-value">{fmtNum(summary.totalShares)}</span>
      </div>
    </section>

    <!-- ===== PLATFORM PERFORMANCE TABLE ===== -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Platform Performance</h2>
          <p class="section-subtitle">Last {days} days · grouped by platform</p>
        </div>
      </div>

      {byPlatform.length === 0 ? (
        <div class="empty-state">No published posts in this period.</div>
      ) : (
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Platform</th>
                <th class="th-num">Posts</th>
                <th>Views</th>
                <th class="th-num">Likes</th>
                <th class="th-num">Avg Engagement</th>
              </tr>
            </thead>
            <tbody>
              {byPlatform.map(row => {
                const barPct = maxViews > 0 ? Math.round((row.totalViews / maxViews) * 100) : 0;
                const color  = platformColors[row.platform] ?? 'var(--text-muted)';
                return (
                  <tr>
                    <td>
                      <span class="platform-pill" style={`background:${color}22;color:${color};border-color:${color}55`}>
                        {row.platform}
                      </span>
                    </td>
                    <td class="td-num">{row.postsCount}</td>
                    <td class="td-bar-cell">
                      <div class="bar-track">
                        <div class="bar-fill" style={`width:${barPct}%;background:${color}`}></div>
                      </div>
                      <span class="bar-label">{fmtNum(row.totalViews)}</span>
                    </td>
                    <td class="td-num">{fmtNum(row.totalLikes)}</td>
                    <td class="td-num">
                      <span class={row.avgEngagement >= 3 ? 'eng-good' : row.avgEngagement >= 1 ? 'eng-mid' : 'eng-low'}>
                        {row.avgEngagement.toFixed(2)}%
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- ===== TOP 10 POSTS ===== -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Top 10 Posts</h2>
          <p class="section-subtitle">Sorted by views DESC</p>
        </div>
      </div>

      {topPosts.length === 0 ? (
        <div class="empty-state">No posts with metrics in this period.</div>
      ) : (
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th class="th-sm">Brief</th>
                <th class="th-sm">Platform</th>
                <th>Hook</th>
                <th class="th-num">Views</th>
                <th class="th-num">Likes</th>
                <th class="th-num">Engagement</th>
                <th class="th-date">Date</th>
                <th class="th-sm">Link</th>
              </tr>
            </thead>
            <tbody>
              {topPosts.map((post, i) => {
                const color = platformColors[post.platform] ?? 'var(--text-muted)';
                return (
                  <tr>
                    <td class="td-muted">#{post.briefId}</td>
                    <td>
                      <span class="platform-pill platform-pill--sm" style={`background:${color}22;color:${color};border-color:${color}55`}>
                        {post.platform}
                      </span>
                    </td>
                    <td class="td-hook" title={post.hookLine}>{truncate(post.hookLine, 60)}</td>
                    <td class="td-num td-bold">{fmtNum(post.views)}</td>
                    <td class="td-num">{fmtNum(post.likes)}</td>
                    <td class="td-num">
                      <span class={post.engagementRate >= 3 ? 'eng-good' : post.engagementRate >= 1 ? 'eng-mid' : 'eng-low'}>
                        {post.engagementRate.toFixed(2)}%
                      </span>
                    </td>
                    <td class="td-date">{fmtDate(post.publishedAt)}</td>
                    <td>
                      {post.externalPostUrl ? (
                        <a href={post.externalPostUrl} target="_blank" rel="noopener" class="link-ext">
                          ↗
                        </a>
                      ) : (
                        <span class="td-muted">—</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- ===== RECENT ACTIVITY ===== -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Recent Activity</h2>
          <p class="section-subtitle">Last 20 content briefs</p>
        </div>
      </div>

      {recentActivity.length === 0 ? (
        <div class="empty-state">No recent activity.</div>
      ) : (
        <div class="timeline">
          {recentActivity.map(item => {
            const color = activityStatusColors[item.status] ?? 'var(--text-muted)';
            return (
              <div class="timeline-row">
                <div class="tl-dot" style={`background:${color}`}></div>
                <div class="tl-body">
                  <div class="tl-head">
                    <span class="tl-id">#{item.briefId}</span>
                    <span class="tl-source-type">{item.sourceType}</span>
                    <span class="tl-title">{truncate(item.sourceTitle, 72)}</span>
                  </div>
                  <div class="tl-meta">
                    <span class="status-badge" style={`color:${color}`}>{item.status}</span>
                    <span class="tl-date">{fmtDate(item.createdAt)}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    <!-- ===== BRIEFS STATUS DISTRIBUTION ===== -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">Briefs Status Distribution</h2>
          <p class="section-subtitle">All-time count per pipeline stage</p>
        </div>
      </div>

      <div class="status-bars">
        {statusKeys.map(key => {
          const count = bss[key];
          const pct   = maxStatusCount > 0 ? Math.round((count / maxStatusCount) * 100) : 0;
          const color = statusColors[key] ?? 'var(--text-muted)';
          return (
            <div class="sbar-row">
              <span class="sbar-label">{key.replace('_', ' ')}</span>
              <div class="sbar-track">
                <div class="sbar-fill" style={`width:${pct}%;background:${color}`}></div>
              </div>
              <span class="sbar-count" style={`color:${color}`}>{count}</span>
            </div>
          );
        })}
      </div>
    </section>

  </main>
</div>
</Base>

<style>
/* ── LAYOUT ─────────────────────────────────────────────── */
.admin-layout  { min-height: 100vh; background: var(--bg-base); }

.admin-header  {
  display: flex; align-items: center; gap: 1.25rem;
  padding: 0.875rem 1.5rem; background: var(--bg-elevated);
  border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20;
}
.admin-logo    { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
.breadcrumb    { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--text-xs); }
.bc-link       { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep        { color: var(--text-muted); }
.bc-current    { color: var(--text-secondary); }
.header-actions { margin-left: auto; display: flex; gap: 0.5rem; }
.btn-logout    { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.btn-logout:hover { color: var(--text-secondary); border-color: var(--text-muted); }

.admin-main    { max-width: 1200px; margin: 0 auto; padding: 1.75rem 1.5rem 3rem; display: flex; flex-direction: column; gap: 1.75rem; }

/* ── QUICK NAV ───────────────────────────────────────────── */
.quick-nav     { display: flex; gap: 0.375rem; flex-wrap: wrap; }
.qnav-pill     { padding: 0.375rem 0.875rem; font-family: var(--font-mono); font-size: var(--text-xs); border: 1px solid var(--border); border-radius: 999px; background: none; color: var(--text-secondary); text-decoration: none; transition: all 0.15s; white-space: nowrap; }
.qnav-pill:hover     { border-color: rgba(74,141,131,0.4); color: var(--teal); }
.qnav-pill--active   { background: rgba(74,141,131,0.12); border-color: rgba(74,141,131,0.4); color: var(--teal); }

/* ── DAYS FILTER ─────────────────────────────────────────── */
.days-filter   { display: flex; align-items: center; gap: 0.5rem; }
.days-label    { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.days-btn      { padding: 0.25rem 0.75rem; font-family: var(--font-mono); font-size: var(--text-xs); border: 1px solid var(--border); border-radius: 0.25rem; background: none; color: var(--text-secondary); text-decoration: none; transition: all 0.15s; }
.days-btn:hover       { border-color: var(--gold); color: var(--gold); }
.days-btn--active     { background: rgba(214,183,121,0.12); border-color: var(--gold); color: var(--gold); font-weight: 600; }

/* ── ALERT ───────────────────────────────────────────────── */
.alert-error   { padding: 0.75rem 1rem; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-xs); color: #ef4444; }

/* ── SUMMARY CARDS ───────────────────────────────────────── */
.summary-grid  { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
.summary-card  {
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: 0.625rem; padding: 1rem 1.25rem;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.summary-card--teal       { border-top: 3px solid var(--teal); }
.summary-card--gold       { border-top: 3px solid var(--gold); }
.summary-card--violet     { border-top: 3px solid #a78bfa; }
.summary-card--engagement { border-top: 3px solid #38bdf8; }
.sc-label   { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }
.sc-value   { font-family: var(--font-mono); font-size: 1.75rem; font-weight: 700; color: var(--text-primary); line-height: 1; }
.summary-card--teal .sc-value       { color: var(--teal); }
.summary-card--gold .sc-value       { color: var(--gold); }
.summary-card--violet .sc-value     { color: #a78bfa; }
.summary-card--engagement .sc-value { color: #38bdf8; }

/* ── SECTION ─────────────────────────────────────────────── */
.admin-section { display: flex; flex-direction: column; gap: 1rem; }
.section-header-row {
  display: flex; align-items: center; justify-content: space-between;
  padding-bottom: 0.875rem; border-bottom: 1px solid var(--border);
}
.section-title-block { display: flex; flex-direction: column; gap: 0.2rem; }
.section-title    { font-family: var(--font-mono); font-size: 1rem; color: var(--text-primary); font-weight: 700; margin: 0; }
.section-subtitle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.empty-state      { padding: 2rem; text-align: center; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-muted); }

/* ── TABLE ───────────────────────────────────────────────── */
.table-wrap  { overflow-x: auto; border: 1px solid var(--border); border-radius: 0.625rem; }
.data-table  { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: var(--text-xs); }
.data-table thead { background: rgba(255,255,255,0.02); }
.data-table th    { padding: 0.625rem 0.875rem; text-align: left; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); font-weight: 600; border-bottom: 1px solid var(--border); white-space: nowrap; }
.data-table td    { padding: 0.625rem 0.875rem; border-bottom: 1px solid rgba(255,255,255,0.035); vertical-align: middle; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td      { background: rgba(255,255,255,0.018); }
.th-num   { text-align: right; }
.th-sm    { width: 60px; }
.th-date  { width: 90px; }
.td-num   { text-align: right; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); }
.td-bold  { font-weight: 700; color: var(--text-primary) !important; }
.td-date  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); white-space: nowrap; }
.td-muted { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
.td-hook  { max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-secondary); }
.td-bar-cell { display: flex; align-items: center; gap: 0.625rem; min-width: 160px; }

/* ── BAR CHARTS (platform table) ─────────────────────────── */
.bar-track   { flex: 1; height: 6px; background: rgba(255,255,255,0.06); border-radius: 999px; overflow: hidden; }
.bar-fill    { height: 100%; border-radius: 999px; transition: width 0.4s ease; min-width: 2px; }
.bar-label   { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); min-width: 3.5rem; text-align: right; white-space: nowrap; }

/* ── PLATFORM PILLS ──────────────────────────────────────── */
.platform-pill    { padding: 0.2rem 0.5rem; border-radius: 0.25rem; border: 1px solid; font-family: var(--font-mono); font-size: var(--text-xs); white-space: nowrap; font-weight: 600; }
.platform-pill--sm { padding: 0.1rem 0.35rem; font-size: 0.6rem; }

/* ── ENGAGEMENT COLOUR SCALE ─────────────────────────────── */
.eng-good { color: var(--teal); font-weight: 600; }
.eng-mid  { color: var(--gold); }
.eng-low  { color: var(--text-muted); }

/* ── EXTERNAL LINK ───────────────────────────────────────── */
.link-ext { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--teal); text-decoration: none; }
.link-ext:hover { opacity: 0.75; }

/* ── TIMELINE (Recent Activity) ──────────────────────────── */
.timeline     { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--border); border-radius: 0.625rem; overflow: hidden; }
.timeline-row {
  display: flex; align-items: flex-start; gap: 0.875rem;
  padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background 0.12s;
}
.timeline-row:last-child { border-bottom: none; }
.timeline-row:hover { background: rgba(255,255,255,0.02); }
.tl-dot       { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 0.35rem; }
.tl-body      { flex: 1; display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
.tl-head      { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
.tl-id        { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); flex-shrink: 0; }
.tl-source-type { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); flex-shrink: 0; padding: 0.1rem 0.35rem; background: rgba(255,255,255,0.05); border-radius: 0.2rem; }
.tl-title     { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 480px; }
.tl-meta      { display: flex; align-items: center; gap: 0.75rem; }
.tl-date      { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); }
.status-badge { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }

/* ── STATUS BARS (distribution) ──────────────────────────── */
.status-bars  { display: flex; flex-direction: column; gap: 0.75rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.625rem; padding: 1.25rem 1.5rem; }
.sbar-row     { display: flex; align-items: center; gap: 1rem; }
.sbar-label   { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); min-width: 9rem; text-transform: capitalize; }
