.meta-value { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-primary); }
.source-type-badge { color: var(--gold); }
.source-title-block { display: flex; flex-direction: column; gap: 0.25rem; }
.source-title-text { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-primary); margin: 0; line-height: 1.5; }
.suggestion-block { display: flex; flex-direction: column; gap: 0.25rem; padding: 0.75rem 1rem; background: rgba(214,183,121,0.06); border: 1px solid rgba(214,183,121,0.2); border-radius: 0.375rem; }
.suggestion-text { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary); margin: 0; line-height: 1.6; }

/* ── VIRAL ENGINE audit ────────────────────────────────────── */
.viral-engine-card { display: flex; flex-direction: column; gap: 0.85rem; padding: 1rem 1.1rem; background: linear-gradient(180deg, rgba(214,183,121,0.08), rgba(74,141,131,0.04)); border: 1px solid rgba(214,183,121,0.22); border-radius: 0.5rem; }
.viral-engine-card__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; }
.viral-engine-title-wrap { display: flex; flex-direction: column; gap: 0.15rem; }
.viral-engine-title { margin: 0; font-family: var(--font-mono); font-size: 0.92rem; color: var(--text-primary); font-weight: 700; }
.viral-engine-badge { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.2rem 0.45rem; border-radius: 999px; border: 1px solid; white-space: nowrap; }
.viral-engine-badge--on { color: var(--teal); border-color: rgba(74,141,131,0.35); background: rgba(74,141,131,0.12); }
.viral-engine-badge--off { color: #ef4444; border-color: rgba(239,68,68,0.35); background: rgba(239,68,68,0.1); }
.viral-engine-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 0.6rem; }
.viral-engine-item { display: flex; flex-direction: column; gap: 0.18rem; padding: 0.65rem 0.75rem; background: rgba(0,0,0,0.12); border: 1px solid rgba(255,255,255,0.06); border-radius: 0.375rem; }
.viral-engine-item-label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
.viral-engine-item-value { font-family: var(--font-mono); font-size: 0.74rem; color: var(--text-primary); line-height: 1.45; }
.viral-engine-panel { display: flex; flex-direction: column; gap: 0.5rem; padding-top: 0.25rem; }
.viral-engine-panel__top { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
.viral-engine-panel__label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--gold); text-transform: uppercase; letter-spacing: 0.06em; }
.viral-engine-panel__hint { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-muted); }
.viral-engine-pcm-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.5rem; }
.viral-engine-pcm-item { display: flex; flex-direction: column; gap: 0.18rem; padding: 0.6rem 0.7rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.35rem; }
.viral-engine-pcm-key { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.viral-engine-pcm-value { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-primary); line-height: 1.45; }
.viral-engine-copy { margin: 0; font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-secondary); line-height: 1.7; white-space: pre-wrap; }
.viral-engine-prompt { margin: 0; padding: 0.8rem 0.9rem; background: #0b1220; border: 1px solid rgba(148,163,184,0.2); border-radius: 0.4rem; color: #dbe4f0; font-family: var(--font-mono); font-size: 0.68rem; line-height: 1.7; white-space: pre-wrap; overflow-x: auto; }

/* ── Generate panel (SSE console) ────────────────────────────── */
.generate-panel { background: var(--bg-elevated); border: 1px solid rgba(74,141,131,0.3); border-radius: 0.5rem; overflow: hidden; }
.generate-panel-top { display: flex; align-items: center; justify-content: space-between; padding: 0.625rem 1rem; background: rgba(74,141,131,0.05); border-bottom: 1px solid rgba(74,141,131,0.15); }
.generate-status { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); }
.generate-status.running { color: var(--teal); }
.generate-status.done { color: #10b981; }
.generate-status.error { color: #ef4444; }
