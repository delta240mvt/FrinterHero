.btn-ghost:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-teal { padding: 0.4rem 1rem; background: none; border: 1px solid var(--teal); color: var(--teal); border-radius: 0.3rem; font-family: var(--font-mono); font-size: 0.72rem; cursor: pointer; }
