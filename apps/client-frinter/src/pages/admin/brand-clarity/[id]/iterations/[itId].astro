---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';

const { id, itId } = Astro.params;
const projectId   = parseInt(id   || '0', 10);
const iterationId = parseInt(itId || '0', 10);
const headers = { cookie: Astro.request.headers.get('cookie') ?? '' };
const detailResponse = await fetch(new URL(`/api/brand-clarity/${projectId}/iterations/${iterationId}/detail`, Astro.url), { headers });
const detailData = detailResponse.ok ? await detailResponse.json() : null;
const project = detailData?.project ?? null;
const iteration = detailData?.iteration ?? null;
const selections = detailData?.selections ?? [];
const clusters = detailData?.clusters ?? [];
const approvedCount = detailData?.approvedCount ?? 0;

if (!project || !iteration) return Astro.redirect(`/admin/brand-clarity/${projectId}/scrape`);

const categoryColors: Record<string, string> = {
  focus: 'var(--teal)', energy: 'var(--gold)', burnout: '#ef4444',
  relationships: 'var(--violet)', systems: '#8b5cf6', tech: '#06b6d4',
  mindset: '#f59e0b', health: '#10b981',
};
---

<Base title={`${iteration.name} — ${project.name}`} description="Iteration pain point selection and LP generation">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">FR</a>
    <nav class="breadcrumb">
      <a href="/admin/brand-clarity" class="bc-link">Brand Clarity</a>
      <span class="bc-sep">›</span>
      <a href={`/admin/brand-clarity/${projectId}/channels`} class="bc-link">{project.name}</a>
      <span class="bc-sep">›</span>
      <a href={`/admin/brand-clarity/${projectId}/scrape`} class="bc-link">Pain Points Base</a>
      <span class="bc-sep">›</span>
      <span class="bc-current" id="iter-name-display">{iteration.name}</span>
    </nav>
    <div class="header-actions">
      <span class="project-status" id="iter-status-badge">{iteration.status}</span>
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <!-- Stage bar -->
    <div class="stage-bar">
      <a href={`/admin/brand-clarity/${projectId}/docs`} class="stage done stage-link">1. LP Parsed</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/channels`} class="stage done stage-link">2. Channels</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/videos`} class="stage done stage-link">3. Videos</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/scrape`} class="stage done stage-link">4–5. Pain Points Base</a>
      <span class="stage-arrow">→</span>
      <span class="stage active">Iteracja</span>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/variants`} class="stage stage-link">6. LP Variants</a>
    </div>

    <!-- Intencja -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title" id="iter-title">{iteration.name}</h2>
          <p class="section-subtitle">Intencja określa, które pain pointy z bazy zostaną wybrane przez AI</p>
        </div>
        <div class="header-btns">
          <button id="btn-rename" class="btn-ghost">Zmień nazwę</button>
          <button id="btn-delete-iter" class="btn-danger-ghost">Usuń iterację</button>
        </div>
      </div>

      <div class="intention-block">
        <label class="intention-label">Intencja iteracji</label>
        <textarea
          id="intention-input"
          class="intention-textarea"
          placeholder="Opisz cel tej iteracji: dla kogo, jaki ból chcesz zaadresować, jaki kąt narracyjny. Przykład: 'LP skierowane do przedsiębiorców 35-50 lat, którzy tracą produktywność przez rozproszenie uwagi i szukają systemu do deep work.'"
          rows="4"
        >{iteration.intention || ''}</textarea>
        <div class="intention-actions">
          <button id="btn-save-intention" class="btn-ghost">Zapisz intencję</button>
          <button
            id="btn-select"
            class="btn-primary"
            disabled={approvedCount === 0}
            title={approvedCount === 0 ? 'Brak approved pain pointów w bazie' : `Wybierz top 30 z ${approvedCount} approved PP`}
          >
            {selections.length > 0 ? '↺ Wybierz ponownie top 30' : `Wybierz top 30 z bazy (${approvedCount} PP)`}
          </button>
        </div>
      </div>

      <!-- Selector console -->
      <div id="selector-panel" class="selector-panel" style="display:none">
        <div class="selector-panel-top">
          <span id="selector-status" class="selector-status">Inicjalizacja…</span>
          <div class="selector-panel-actions">
            <span id="selector-elapsed" class="selector-elapsed"></span>
            <button id="selector-close" class="scrape-close-btn" style="display:none">✕ Zamknij</button>
          </div>
        </div>
        <div class="selector-metrics">
          <span class="metric">Wybrano: <strong id="selected-count">0</strong></span>
        </div>
        <div id="selector-log" class="scrape-log"></div>
      </div>
    </section>

    <!-- Selekcja — lista 30 PP + Klastry (jedna sekcja per stan) -->
    {selections.length > 0 && (
      <section class="admin-section">
        <div class="section-header-row">
          <div class="section-title-block">
            <h2 class="section-title">Wybrane Pain Pointy</h2>
            <p class="section-subtitle">{selections.length} pain pointów wybranych przez AI · posortowane wg rankingu</p>
          </div>
          <div class="header-btns">
            <button id="cluster-btn" class="btn-cluster">
              {clusters.length > 0 ? '↺ Re-cluster' : 'Klastruj te PP'}
            </button>
          </div>
        </div>

        <div class="selections-list">
          {selections.map((sel: any) => {
            const intensity = sel.pp.emotionalIntensity;
            const intensityColor = intensity >= 8 ? '#ef4444' : intensity >= 5 ? 'var(--gold)' : 'var(--text-muted)';
            const catColor = categoryColors[sel.pp.category] || 'var(--text-muted)';
            return (
              <div class="sel-card">
                <div class="sel-rank">#{sel.rank}</div>
                <div class="sel-body">
                  <div class="sel-header">
                    <span class="sel-title">{sel.pp.painPointTitle}</span>
                    <div class="sel-badges">
                      <span class="sel-badge" style={`color: ${intensityColor}; border-color: ${intensityColor}30`}>{intensity}/10</span>
                      <span class="sel-badge" style={`color: ${catColor}; border-color: ${catColor}30`}>{sel.pp.category}</span>
                    </div>
                  </div>
                  {sel.selectionReason && (
                    <div class="sel-reason">AI: {sel.selectionReason}</div>
                  )}
                  {sel.pp.customerLanguage && (
                    <div class="sel-customer-lang">{sel.pp.customerLanguage}</div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Klastry — jeden blok, zawsze te same IDs -->
    {selections.length > 0 && (
      <section class="admin-section">
        <div class="section-header-row">
          <div class="section-title-block">
            <h2 class="section-title">Klastry</h2>
            <p class="section-subtitle">
              {clusters.length > 0
                ? `${clusters.length} klastrów · syntetyzowane z wybranych pain pointów`
                : 'Jeszcze nie wygenerowane dla tej iteracji'}
            </p>
          </div>
          {clusters.length > 0 && (
            <div class="header-btns">
              <a href={`/admin/brand-clarity/${projectId}/variants?iterationId=${iterationId}`} class="btn-primary">Generuj LP →</a>
            </div>
          )}
        </div>

        {clusters.length > 0 && (
          <div class="clusters-grid">
            {clusters.map((c: any) => (
              <div class="cluster-card">
                <div class="cluster-header">
                  <span class="cluster-emotion">{c.dominantEmotion}</span>
                  <span class="cluster-intensity">{c.aggregateIntensity?.toFixed(1)}/10</span>
                </div>
                <div class="cluster-theme">{c.clusterTheme}</div>
                {c.synthesizedProblemLabel && (
                  <div class="cluster-label">Customer calls it: <em>"{c.synthesizedProblemLabel}"</em></div>
                )}
                {c.synthesizedSuccessVision && (
                  <div class="cluster-vision">They want: <em>"{c.synthesizedSuccessVision}"</em></div>
                )}
                {Array.isArray(c.bestQuotes) && c.bestQuotes.length > 0 && (
                  <div class="cluster-quotes">
                    {c.bestQuotes.slice(0, 2).map((q: string) => (
                      <div class="cluster-quote">"{q}"</div>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}

        <details id="cluster-log-panel" class="run-logs-section" style="display:none">
          <summary class="run-logs-toggle">
            <span class="logs-toggle-label">📋 Cluster Run Log</span>
            <span id="cluster-log-count" class="logs-count">0 lines</span>
            <button id="btn-download-cluster-logs" class="btn-download-logs" onclick="event.stopPropagation()">Download .txt</button>
          </summary>
          <div id="cluster-log-container" class="run-logs-container"></div>
        </details>
      </section>
    )}
  </main>
</div>

<script define:vars={{ projectId, iterationId, approvedCount: approvedCount }}>
  const PROJECT_ID   = projectId;
  const ITERATION_ID = iterationId;

  // ── Rename ─────────────────────────────────────────────────
  document.getElementById('btn-rename')?.addEventListener('click', async () => {
    const current = document.getElementById('iter-title')?.textContent || '';
    const name = prompt('Nowa nazwa iteracji:', current);
    if (!name || name === current) return;
    const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations/${ITERATION_ID}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name }),
    });
    if (res.ok) {
      const data = await res.json();
      const t = document.getElementById('iter-title');
      const d = document.getElementById('iter-name-display');
      if (t) t.textContent = data.iteration.name;
      if (d) d.textContent = data.iteration.name;
    }
  });

  // ── Delete ─────────────────────────────────────────────────
  document.getElementById('btn-delete-iter')?.addEventListener('click', async () => {
    if (!confirm('Usuń iterację? Selekcje, klastry i warianty tej iteracji zostaną usunięte.')) return;
    const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations/${ITERATION_ID}`, { method: 'DELETE' });
    if (res.ok) window.location.href = `/admin/brand-clarity/${PROJECT_ID}/scrape`;
    else alert('Błąd podczas usuwania');
  });

  // ── Save intention ─────────────────────────────────────────
  document.getElementById('btn-save-intention')?.addEventListener('click', async () => {
    const intention = document.getElementById('intention-input')?.value || '';
    const btn = document.getElementById('btn-save-intention');
    btn.disabled = true;
    btn.textContent = 'Zapisano ✓';
    await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations/${ITERATION_ID}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intention }),
    });
    setTimeout(() => {
      btn.disabled = false;
      btn.textContent = 'Zapisz intencję';
    }, 2000);
  });

  // ── Selector console helpers ───────────────────────────────
  const selectorPanel   = document.getElementById('selector-panel');
  const selectorLog     = document.getElementById('selector-log');
  const selectorStatus  = document.getElementById('selector-status');
  const selectorClose   = document.getElementById('selector-close');
  const selectorElapsed = document.getElementById('selector-elapsed');
  const selectedCountEl = document.getElementById('selected-count');

  let elapsedTimer = null;
  let elapsedStart = 0;

  function startElapsed() {
    elapsedStart = Date.now();
    elapsedTimer = setInterval(() => {
      if (selectorElapsed) selectorElapsed.textContent = `${Math.floor((Date.now() - elapsedStart) / 1000)}s`;
    }, 1000);
  }

  function stopElapsed() { clearInterval(elapsedTimer); elapsedTimer = null; }

  selectorClose?.addEventListener('click', () => {
    selectorPanel.style.display = 'none';
    stopElapsed();
  });

  function appendSelectorLog(line) {
    const el = document.createElement('div');
    el.className = 'scrape-log-line';
    if (line.includes('[ERROR]') || line.includes('[FATAL]') || line.includes('[WARN]')) el.classList.add('error');
    else if (line.includes('Selecting') || line.includes('Done') || line.includes('Inserted')) el.classList.add('highlight');
    el.textContent = line;
    selectorLog.appendChild(el);
    selectorLog.scrollTop = selectorLog.scrollHeight;
  }

  function showSelectorPanel() {
    selectorLog.innerHTML = '';
    if (selectedCountEl) selectedCountEl.textContent = '0';
    if (selectorElapsed) selectorElapsed.textContent = '';
    selectorStatus.textContent = 'Selekcja AI w toku…';
    selectorStatus.className = 'selector-status running';
    selectorClose.style.display = 'none';
    selectorPanel.style.display = 'block';
    selectorPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    startElapsed();
  }

  async function connectSelectorStream(fromIndex) {
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations/${ITERATION_ID}/select-stream?from=${fromIndex}`);
      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop() ?? '';
        for (const part of parts) {
          const dataLine = part.split('\n').find(l => l.startsWith('data: '));
          if (!dataLine) continue;
          let payload;
          try { payload = JSON.parse(dataLine.slice(6)); } catch { continue; }
          if (payload.line) appendSelectorLog(payload.line);
          if (payload.done) {
            stopElapsed();
            selectorClose.style.display = 'inline-block';
            if (payload.code === 0) {
              selectorStatus.textContent = `Selekcja gotowa ✓ — wybrano ${payload.selectedCount} PP`;
              selectorStatus.className = 'selector-status done';
              if (selectedCountEl) selectedCountEl.textContent = payload.selectedCount;
              setTimeout(() => window.location.reload(), 2000);
            } else {
              selectorStatus.textContent = 'Błąd selekcji ✗';
              selectorStatus.className = 'selector-status error';
            }
            return;
          }
        }
      }
    } catch (e) {
      stopElapsed();
      selectorStatus.textContent = `Stream error: ${e.message}`;
      selectorStatus.className = 'selector-status error';
      selectorClose.style.display = 'inline-block';
    }
  }

  // ── Select top 30 ─────────────────────────────────────────
  document.getElementById('btn-select')?.addEventListener('click', async () => {
    const intention = (document.getElementById('intention-input')?.value || '').trim();
    if (!intention) { alert('Wpisz intencję przed selekcją.'); return; }
    if (!confirm(`Wywołaj AI (Claude Sonnet) do selekcji top 30 z ${approvedCount} approved pain pointów?\n\n~1 call API, ~10-20s`)) return;

    // Auto-save intention first
    await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations/${ITERATION_ID}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intention }),
    });

    showSelectorPanel();

    const startRes = await fetch(`/api/brand-clarity/${PROJECT_ID}/iterations/${ITERATION_ID}/select`, { method: 'POST' });
    if (startRes.status === 409) {
      connectSelectorStream(0);
      return;
    }
    if (!startRes.ok) {
      const err = await startRes.json();
      stopElapsed();
      selectorStatus.textContent = `Błąd: ${err.error}`;
      selectorStatus.className = 'selector-status error';
      selectorClose.style.display = 'inline-block';
      return;
    }
    connectSelectorStream(0);
  });

  // ── Cluster ────────────────────────────────────────────────
  const clusterLogPanel     = document.getElementById('cluster-log-panel');
  const clusterLogContainer = document.getElementById('cluster-log-container');
  const clusterLogCount     = document.getElementById('cluster-log-count');

  function renderClusterLogs(logs) {
    if (!logs || !logs.length) return;
    clusterLogPanel.style.display = 'block';
    clusterLogPanel.open = true;
    clusterLogCount.textContent = `${logs.length} lines`;
    clusterLogContainer.innerHTML = logs.map(line => {
      let cls = 'log-line';
      if (line.includes('[WARN]') || line.includes('[FATAL]') || line.includes('[ERROR]')) cls += ' log-line--warn';
      else if (line.includes('CLUSTERS_CREATED') || line.includes('Done') || line.includes('Inserted')) cls += ' log-line--done';
      else if (line.includes('[LLM]') || line.includes('cluster')) cls += ' log-line--llm';
      return `<div class="${cls}">${line}</div>`;
    }).join('');
  }

  document.getElementById('btn-download-cluster-logs')?.addEventListener('click', () => {
    const text = Array.from(clusterLogContainer.querySelectorAll('.log-line')).map(el => el.textContent).join('\n');
    const blob = new Blob([text], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `bc-cluster-iter-${ITERATION_ID}-logs.txt`;
    document.body.appendChild(a); a.click();
    document.body.removeChild(a); URL.revokeObjectURL(url);
  });

  document.getElementById('cluster-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('cluster-btn');
    if (!btn) return;
    if (!confirm('Klastruj wybrane pain pointy używając Claude Sonnet? (~1 call API, ~10s)')) return;
    btn.disabled = true;
    btn.textContent = 'Klastrowanie…';
    if (clusterLogPanel) clusterLogPanel.style.display = 'none';
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/cluster-pain-points`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ iterationId: ITERATION_ID }),
      });
      const data = await res.json();
      if (clusterLogPanel && data.logs) renderClusterLogs(data.logs);
      if (!res.ok) throw new Error(data.error || 'Failed');
      setTimeout(() => window.location.reload(), 2500);
    } catch (e) {
      if (clusterLogPanel) { clusterLogPanel.style.display = 'block'; clusterLogPanel.open = true; }
      if (clusterLogContainer) {
        const errEl = document.createElement('div');
        errEl.className = 'log-line log-line--warn';
        errEl.textContent = `[ERROR] ${e.message}`;
        clusterLogContainer.appendChild(errEl);
      }
      btn.disabled = false;
      btn.textContent = 'Klastruj te PP';
    }
  });
</script>

<style>
.admin-layout { min-height: 100vh; background: var(--bg-base); }
.admin-header { display: flex; align-items: center; gap: 1.25rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20; }
.admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
.breadcrumb { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); display: flex; gap: 0.4rem; align-items: center; }
.bc-link { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep { color: var(--text-muted); }
.bc-current { color: var(--text-secondary); }
.header-actions { margin-left: auto; display: flex; gap: 0.5rem; align-items: center; }
.project-status { font-family: var(--font-mono); font-size: 0.65rem; color: var(--gold); padding: 0.2rem 0.5rem; background: rgba(214,183,121,0.1); border-radius: 0.2rem; }
.btn-logout { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.btn-primary { padding: 0.4rem 1rem; background: var(--teal); color: #fff; border: none; border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; text-decoration: none; }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-ghost { padding: 0.4rem 0.875rem; background: none; border: 1px solid var(--border); color: var(--text-secondary); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-ghost:hover { border-color: var(--text-secondary); }
.btn-ghost:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-danger-ghost { padding: 0.4rem 0.875rem; background: none; border: 1px solid rgba(239,68,68,0.35); color: #ef4444; border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-danger-ghost:hover { background: rgba(239,68,68,0.06); }
.btn-cluster { padding: 0.4rem 1rem; background: none; border: 1px solid var(--teal); color: var(--teal); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-cluster:hover { background: rgba(74,141,131,0.08); }
.btn-cluster:disabled { opacity: 0.5; cursor: not-allowed; }
.admin-main { max-width: 900px; margin: 0 auto; padding: 1.75rem 1.5rem 3rem; display: flex; flex-direction: column; gap: 2rem; }
.stage-bar { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.65rem; padding: 0.625rem 1rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; overflow-x: auto; }
.stage { color: var(--text-muted); white-space: nowrap; }
.stage.done { color: var(--teal); }
.stage.active { color: var(--gold); font-weight: 700; }
.stage-link { text-decoration: none; padding: 0.1rem 0.3rem; border-radius: 0.2rem; }
.stage-link:hover { background: rgba(255,255,255,0.06); }
.stage-link.done { color: var(--teal); }
.stage-arrow { color: var(--border); }
.admin-section { display: flex; flex-direction: column; gap: 0.875rem; }
.section-header-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-bottom: 0.875rem; border-bottom: 1px solid var(--border); }
.section-title-block { display: flex; flex-direction: column; gap: 0.2rem; }
.section-title { font-family: var(--font-mono); font-size: 1rem; color: var(--text-primary); font-weight: 700; margin: 0; }
.section-subtitle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.header-btns { display: flex; gap: 0.5rem; flex-wrap: wrap; }

/* Intention */
.intention-block { display: flex; flex-direction: column; gap: 0.5rem; }
.intention-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); }
.intention-textarea { width: 100%; padding: 0.75rem 1rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-xs); resize: vertical; line-height: 1.6; box-sizing: border-box; }
.intention-textarea:focus { outline: none; border-color: var(--teal); }
.intention-actions { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }

/* Selector console */
.selector-panel { background: var(--bg-elevated); border: 1px solid rgba(74,141,131,0.3); border-radius: 0.5rem; overflow: hidden; }
.selector-panel-top { display: flex; align-items: center; justify-content: space-between; padding: 0.625rem 1rem; background: rgba(74,141,131,0.05); border-bottom: 1px solid rgba(74,141,131,0.15); }
