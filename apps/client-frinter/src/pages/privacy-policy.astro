---
export const prerender = true;

import Base from '@/components/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { getSiteConfig } from '@/config/site';
import { getPrivacyPolicyDocument } from '@/lib/privacy-policy';

const site = getSiteConfig();
const doc = getPrivacyPolicyDocument('en');
---

<Base title={`${doc.title} — ${site.displayName}`} description={doc.lead}>
  <Nav />
  <main class="legal-main">
    <div class="legal-container">
      <header class="legal-header">
        <p class="legal-meta">{doc.lastUpdatedLabel}</p>
        <h1>{doc.title}</h1>
        <p class="legal-lead">{doc.lead}</p>
        <a href={doc.languageSwitchHref} class="legal-switch">{doc.languageSwitchLabel}</a>
      </header>

      {doc.sections.map((section) => (
        <section class="legal-section">
          <h2>{section.title}</h2>
          {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
          {section.bullets && (
            <ul>
              {section.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
        </section>
      ))}
    </div>
  </main>
  <Footer />
</Base>

<style>
  .legal-main { min-height: 100vh; background: var(--bg-base); padding-top: 3rem; }
  .legal-container { max-width: 860px; margin: 0 auto; padding: 4rem 1.5rem; }
  .legal-header { margin-bottom: 2.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .legal-meta { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  h1 { font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); color: var(--text-primary); }
  .legal-lead { color: var(--text-secondary); line-height: 1.75; font-size: var(--text-base); }
  .legal-switch { width: fit-content; color: var(--teal); text-decoration: none; font-family: var(--font-mono); font-size: var(--text-sm); }
  .legal-switch:hover { color: var(--gold); }
  .legal-section { margin-top: 2rem; }
  .legal-section h2 { font-family: var(--font-mono); font-size: var(--text-base); color: var(--teal); margin-bottom: 0.75rem; }
  .legal-section p, .legal-section li { color: var(--text-secondary); line-height: 1.8; }
  .legal-section ul { padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
</style>
