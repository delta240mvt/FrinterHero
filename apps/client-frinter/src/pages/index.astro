        });
      }

      function createRetroPixelAnimation(canvas) {
        const category = canvas.dataset.category;
        const variant = canvas.dataset.variant || 'bar';
        const ctx = canvas.getContext('2d');
        if (!ctx || !category) return null;

        const renderWidth = 192;
        const renderHeight = variant === 'portal' ? 192 : variant === 'sprint' ? 96 : 64;
        canvas.width = renderWidth;
        canvas.height = renderHeight;

        const state = {
          offset: 0,
          items: [],
          bgItems: [],
          frame: 0,
          category,
          variant,
        };

        const itemCount = variant === 'bar' ? 4 : variant === 'sprint' ? 10 : 12;
        for (let i = 0; i < itemCount; i += 1) {
          state.items.push({
            x: Math.random() * renderWidth,
            y:
              variant === 'bar'
                ? Math.random() * (renderHeight * 0.4) + renderHeight * 0.3
                : Math.random() * (renderHeight * 0.7) + renderHeight * 0.15,
            speed: 0.1 + Math.random() * 0.15,
          });
        }

        const bgCount = variant === 'bar' ? 8 : variant === 'sprint' ? 20 : 25;
        for (let i = 0; i < bgCount; i += 1) {
          state.bgItems.push({
            x: Math.random() * renderWidth,
            y: Math.random() * (renderHeight * 0.8),
            size: Math.random() > 0.5 ? 1 : 2,
            speed: 0.05 + Math.random() * 0.05,
          });
        }

        function render(timestamp) {
          const activeCategory = state.category;
          const mainColor = CATEGORY_COLORS[activeCategory];
          const sprite = spriteForCategory(activeCategory);

          state.offset += 0.2;

          state.items.forEach((item) => {
            item.x -= item.speed;
            if (item.x < -20) {
              item.x = renderWidth + 20;
              item.y =
                state.variant === 'bar'
                  ? Math.random() * (renderHeight * 0.4) + renderHeight * 0.3
                  : Math.random() * (renderHeight * 0.7) + renderHeight * 0.15;
            }
          });

          state.bgItems.forEach((item) => {
            item.x -= item.speed;
            if (item.x < -5) {
              item.x = renderWidth + 5;
              item.y = Math.random() * (renderHeight * 0.8);
            }
          });

          ctx.clearRect(0, 0, renderWidth, renderHeight);
          ctx.fillStyle = mainColor + '30';
          state.bgItems.forEach((item) => {
            ctx.fillRect(Math.floor(item.x), Math.floor(item.y), item.size, item.size);
          });

          const floorY = renderHeight - 4;
          ctx.fillStyle = mainColor + '10';
          ctx.fillRect(0, floorY, renderWidth, 4);

          const gridSpacing = 24;
          const gridOffset = state.offset % gridSpacing;
          ctx.fillStyle = mainColor + '40';
          for (let i = -gridOffset; i < renderWidth; i += gridSpacing) {
            ctx.fillRect(Math.floor(i), floorY, 1, 4);
          }
          ctx.fillRect(0, floorY, renderWidth, 1);

          state.items.forEach((item) => {
            const bob = Math.sin(timestamp * 0.002 + item.x * 0.1) * 2;
            drawSprite(ctx, sprite, item.x, item.y + bob, mainColor, true);
          });

          state.frame = requestAnimationFrame(render);
        }

        state.frame = requestAnimationFrame(render);

        return {
          setCategory(nextCategory) {
            state.category = nextCategory;
          },
          canvas,
        };
      }

      function createPixelChar(sprite, color, accent, px) {
        const wrapper = document.createElement('div');
        wrapper.className = 'pixel-char';
        sprite.forEach((row) => {
          const rowEl = document.createElement('div');
          rowEl.className = 'pixel-row';
          row.forEach((cell) => {
            const cellEl = document.createElement('div');
            cellEl.className = 'pixel-cell';
            cellEl.style.width = px + 'px';
            cellEl.style.height = px + 'px';
            if (cell === 1) cellEl.style.backgroundColor = color;
            if (cell === 2) cellEl.style.backgroundColor = accent;
            rowEl.appendChild(cellEl);
          });
          wrapper.appendChild(rowEl);
        });
        return wrapper;
      }

      function createHealthBar(value, color) {
        const bar = document.createElement('div');
        bar.className = 'hp-bar';
        for (let i = 0; i < 10; i += 1) {
          const unit = document.createElement('div');
          unit.className = 'hp-unit';
          if (i < value) unit.style.backgroundColor = color;
          bar.appendChild(unit);
        }
        return bar;
      }

      function renderBattleRow(category, hp, size) {
        const row = document.createElement('div');
        row.className = 'battle-row';
        row.appendChild(
          createPixelChar(
            BATTLE_SPRITES[category],
            CATEGORY_COLORS[category],
            CATEGORY_ACCENTS[category],
            size
          )
        );

        const meta = document.createElement('div');
        meta.className = 'battle-meta';

        const label = document.createElement('span');
        label.className = 'battle-label';
        label.style.color = CATEGORY_COLORS[category];
        label.textContent = CATEGORY_LABELS[category];

        meta.appendChild(label);
        meta.appendChild(createHealthBar(hp, CATEGORY_COLORS[category]));
        row.appendChild(meta);
        return row;
      }

      function initBattleStars(container) {
        for (let i = 0; i < 24; i += 1) {
          const star = document.createElement('div');
          const size = Math.random() > 0.6 ? 3 : 2;
          star.style.position = 'absolute';
          star.style.left = Math.random() * 100 + '%';
          star.style.top = Math.random() * 100 + '%';
          star.style.width = size + 'px';
          star.style.height = size + 'px';
          star.style.background = 'rgba(148, 163, 184, 0.75)';
          star.style.animation = `pulse ${1.6 + Math.random() * 0.5}s ease-in-out ${Math.random() * 2}s infinite`;
          container.appendChild(star);
        }
      }

      function initHeroBattle() {
        const losersRoot = document.getElementById('battle-losers');
        const winnerRoot = document.getElementById('battle-winner');
        const fightText = document.getElementById('battle-fight-text');
        const winText = document.getElementById('battle-win-text');
        const starsRoot = document.getElementById('hero-battle-stars');
        if (!losersRoot || !winnerRoot || !fightText || !winText || !starsRoot) return;

        initBattleStars(starsRoot);

        const sequence = ['rozkwit', 'relacje', 'praca-gleboka'];
        let step = 0;
        let phase = 'enter';
        let hp = {
          rozkwit: 10,
          relacje: 10,
          'praca-gleboka': 10,
        };

        function renderBattle() {
          const winner = sequence[step];
          const losers = sequence.filter((category) => category !== winner);

          losersRoot.innerHTML = '';
          losers.forEach((category) => {
            const row = renderBattleRow(category, hp[category], 4);
            if (phase === 'attack') row.classList.add('hit');
            losersRoot.appendChild(row);
          });

          winnerRoot.innerHTML = '';
          winnerRoot.className = 'battle-winner';
          if (phase === 'attack') winnerRoot.classList.add('attack');
          if (phase === 'win') winnerRoot.classList.add('win');

          const crown = document.createElement('div');
          crown.className = 'battle-crown';
          crown.textContent = '👑';
          winnerRoot.appendChild(crown);

          const spriteWrap = document.createElement('div');
          spriteWrap.className = 'winner-sprite-wrap';
          spriteWrap.appendChild(
            createPixelChar(
              BATTLE_SPRITES[winner],
              CATEGORY_COLORS[winner],
              CATEGORY_ACCENTS[winner],
              8
            )
          );
          winnerRoot.appendChild(spriteWrap);

          const meta = document.createElement('div');
          meta.className = 'battle-meta';
          meta.style.alignItems = 'center';

          const label = document.createElement('span');
          label.className = 'battle-label';
          label.textContent = CATEGORY_LABELS[winner];
          label.style.color = CATEGORY_COLORS[winner];
          label.style.fontSize = '8px';
          label.style.textShadow = `0 0 6px ${CATEGORY_COLORS[winner]}99`;

          meta.appendChild(label);
          meta.appendChild(createHealthBar(hp[winner], CATEGORY_COLORS[winner]));
          winnerRoot.appendChild(meta);

          fightText.classList.toggle('active', phase === 'attack');
          winText.classList.toggle('active', phase === 'win');
          winText.textContent = `${CATEGORY_LABELS[winner]} WINS!`;
          winText.style.color = CATEGORY_ACCENTS[winner];
          winText.style.textShadow = `0 0 10px ${CATEGORY_COLORS[winner]}`;
        }

        function cycle() {
          phase = 'attack';
          renderBattle();

          setTimeout(() => {
            const winner = sequence[step];
            const losers = sequence.filter((category) => category !== winner);
            losers.forEach((loser) => {
              hp[loser] = Math.max(0, hp[loser] - Math.floor(Math.random() * 3 + 1));
            });

            phase = 'win';
            renderBattle();

            setTimeout(() => {
              step = (step + 1) % sequence.length;
              hp = {
                rozkwit: 10,
                relacje: 10,
                'praca-gleboka': 10,
              };
              phase = 'enter';
              renderBattle();
              setTimeout(cycle, 2200);
            }, 2200);
          }, 2200);
        }

        renderBattle();
        setTimeout(cycle, 2200);
      }

      function initPortalCycle(instance) {
        const order = ['praca-gleboka', 'rozkwit', 'relacje'];
        const portalLabel = document.getElementById('portal-label');
        if (!instance || !portalLabel) return;

        let index = 0;
        setInterval(() => {
          index = (index + 1) % order.length;
          const category = order[index];
          instance.setCategory(category);
          portalLabel.textContent = CATEGORY_LABELS[category];
          portalLabel.style.color = CATEGORY_COLORS[category];
        }, 4000);
      }

      const retroInstances = [];
      document.querySelectorAll('[data-retro-pixel]').forEach((canvas) => {
        const instance = createRetroPixelAnimation(canvas);
        if (instance) retroInstances.push(instance);
      });

      const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenuPanel = document.getElementById('mobile-menu-panel');
      const mobileOpenIcon = document.getElementById('mobile-menu-open-icon');
      const mobileCloseIcon = document.getElementById('mobile-menu-close-icon');

      function setMobileMenu(open) {
        if (!mobileMenuToggle || !mobileMenuPanel || !mobileOpenIcon || !mobileCloseIcon) return;
        mobileMenuPanel.classList.toggle('open', open);
        mobileMenuToggle.setAttribute('aria-expanded', String(open));
        mobileOpenIcon.style.display = open ? 'none' : 'block';
        mobileCloseIcon.style.display = open ? 'block' : 'none';
      }

      if (mobileMenuToggle && mobileMenuPanel) {
        mobileMenuToggle.addEventListener('click', () => {
          const isOpen = mobileMenuPanel.classList.contains('open');
          setMobileMenu(!isOpen);
        });

        mobileMenuPanel.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => setMobileMenu(false));
        });
      }

      // Header scroll border — matches React Header.tsx (border-b only when scrollY > 10)
      const siteHeader = document.querySelector('.site-header');
      if (siteHeader) {
        const onScroll = () => siteHeader.classList.toggle('scrolled', window.scrollY > 10);
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      initHeroBattle();

      const portalCanvas = document.querySelector('.portal-canvas[data-retro-pixel]');
      if (portalCanvas) {
        const portalInstance = retroInstances.find((instance) => instance.canvas === portalCanvas);
        if (portalInstance) initPortalCycle(portalInstance);
      }
    </script>
  </body>
</html>
