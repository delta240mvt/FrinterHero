---
export const prerender = true;

const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://app.frinter.app';
const year = new Date().getFullYear();

const content = {
  badge: 'High-Performance System',
  heroTitle1: 'Wholebeing',
  heroTitleMid: 'for',
  heroTitle2: 'High Performers',
  heroSubtitle:
    'Deep sleep, uninterrupted focus. Optimize 3 spheres of your life based on hard data.',
  ctaPrimary: 'Unlock Wholebeing',
  ctaSecondary: 'For High Performers: $0',
  heroMicroCopy: 'Fully ready in 3 minutes. Zero risk.',
  sphereLabels: {
    rozkwit: 'FLOURISHING',
    relacje: 'RELATIONSHIPS',
    'praca-gleboka': 'DEEP WORK',
  },
  problemTitle: 'Your calendar is perfect. Why are you exhausted?',
  problemText1:
    'Shallow work. Messengers and notifications drain your nervous system, blocking entry into deep focus.',
  problemText2:
    'Disrupted recovery. Overstimulation prevents deep rest, leading to sleep deficit and a drastic drop in focus.',
  problemText3:
    'Traditional time management is an outdated model that leads to burnout.',
  problemCta: 'See how High-Performance optimization works.',
  featuresTitle: 'Achieve Wholebeing',
  featuresSubtitle: 'Optimized focus, recovery and deep work based on data.',
  featureCards: [
    {
      category: 'rozkwit',
      title: 'Flourishing (You)',
      mechanism: 'Timer for sports, reading, meditation.',
      goal: 'Recharging. Because an exhausted High Performer makes stupid decisions.',
      color: '#4a8d83',
      offsetClass: '',
    },
    {
      category: 'relacje',
      title: 'Relationships (Loved Ones)',
      mechanism: 'Yes, we measure time with loved ones.',
      goal:
        "So you see in black and white if you're neglecting those you're building all this for.",
      color: '#8a4e64',
      offsetClass: 'feature-card-offset-large',
    },
    {
      category: 'praca-gleboka',
      title: 'Deep Work (World)',
      mechanism: 'Start a Frint. Phone goes away.',
      goal: "Measure only pure creation time (coding, writing, strategy). Zero 'admin'.",
      color: '#d6b779',
      offsetClass: 'feature-card-offset-small',
    },
  ],
  energy: {
    badge: 'New',
    title: 'Your Energy Bar',
    subtitle: 'No more driving on reserve.',
    description:
      "You wouldn't start a car without fuel.\nWhy do you expect that from yourself?\nFrinter algorithm converts your sleep into battery %.",
    statLabel: 'Energy Level',
    statValue: '78%',
  },
  quote: {
    line1: 'I expand in abundance, success, and love',
    line2: 'every day, as I inspire those around me,',
    line3: 'to do the same.',
    author: 'Gay Hendricks',
  },
  socialProof: {
    title: 'A tool built\nby a High Performer\nfor High Performers.',
    story:
      '"I built Frinter because other apps wanted me to do MORE tasks. I wanted to do the key ones BETTER. I needed a whip for my own distraction and a mirror to show me the truth about my relationships, health and sleep quality. Now I give this tool to you."',
    author: '— Przemysław Filipiak, Founder of Frinter.app',
  },
  faqTitle: 'Frequently Asked Questions',
  faqSubtitle: 'Answers before you even ask.',
  faqs: [
    {
      q: 'What is "Wholebeing"?',
      a: "Wholebeing is a condition where your biological energy (measured by Sleep Bank and Deep Sleep Bank) and focus quality (measured across 3 Spheres: Flourishing, Relationships, Deep Work) operate in full synchronization. It's not about doing more. It's about doing the things that truly matter BETTER.",
    },
    {
      q: 'How is Frinter different from Notion, Todoist or other productivity apps?',
      a: "Those apps manage your TASKS. Frinter manages your ENERGY and FOCUS. We have no to-do lists. We have a timer that measures pure time across 3 key life spheres, and an algorithm that converts your sleep into a battery percentage. If your Energy Bar is at 40%, it's not time for deep work — it's time to recover.",
    },
    {
      q: 'What is the "Sleep Bank" and "Deep Sleep Bank"?',
      a: 'Your Sleep Bank is a 30-day balance of sleep surpluses and deficits. If you sleep 5 hours for a week, your bank is in the red — and it shows on your Energy Bar. The Deep Sleep Bank measures the N3 phase — the only phase where your brain truly recovers and clears toxins. One lost hour of sleep affects 3 hours of your functioning (multiplier × 3).',
    },
    {
      q: "Is this another tool I don't have time for?",
      a: 'Setup takes 3 minutes. Daily use is literally one click — "Start Frint" and begin measuring. Log sleep once a day (30 seconds). The rest runs automatically. Frinter is designed for people who do not have time to configure tools.',
    },
    {
      q: 'Who is Frinter for?',
      a: "For High Performers — founders, CEOs, creators, leaders, anyone building something with passion who doesn't want to burn out in the process. If you feel that 'time management' isn't enough because the real problem is your energy and focus — Frinter is for you.",
    },
    {
      q: 'How much does it cost?',
      a: "In Beta: $0. No card required, no hidden fees. We're looking for Founding Members who want to co-create the tool and influence its development. Your spot in this group is yours forever.",
    },
    {
      q: 'What devices does Frinter work on?',
      a: 'The web app (PWA) works on desktop and mobile in any browser. The mobile app (Expo) is in development. Your data syncs across devices in real time.',
    },
  ],
  offerTitle: 'Join the High Performers',
  benefits: [
    'Wholebeing Ecosystem: Measure energy and focus on desktop and mobile.',
    '3 Spheres Method: Ready-made framework for Flourishing, Relationships and Deep Work.',
    'Founding Member Status: $0 forever (no card required).',
    'Impact on development: Your suggestions really change the app.',
  ],
  offerScarcity: 'Join the group of leaders who have optimized their work time.',
  finalCtaTitle: 'Your ultimate state of mind',
  finalCtaSubtitle: 'is a matter of the right system.',
  finalCtaButton: 'Unlock Wholebeing',
  finalCtaFooter: 'Last chance for Founding Member status.',
};

const organizationJsonLd = [
  {
    '@type': 'Organization',
    '@id': 'https://frinter.app/#organization',
    name: 'frinter.',
    url: 'https://frinter.app',
    logo: { '@type': 'ImageObject', url: 'https://frinter.app/favicon.png' },
    sameAs: [
      'https://github.com/delta240mvt',
      'https://www.linkedin.com/in/przemyslaw-filipiak-8a9b77113/',
    ],
  },
  {
    '@type': 'Person',
    '@id': 'https://frinter.app/#person',
    name: 'Przemysław Filipiak',
    url: 'https://przemyslawfilipiak.com',
    jobTitle: 'Deep Focus Founder',
    worksFor: { '@id': 'https://frinter.app/#organization' },
  },
  {
    '@type': 'WebSite',
    '@id': 'https://frinter.app/#website',
    name: 'frinter.',
    url: 'https://frinter.app',
    publisher: { '@id': 'https://frinter.app/#organization' },
    inLanguage: ['pl-PL', 'en-US'],
  },
  {
    '@type': 'WebPage',
    '@id': 'https://frinter.app/en/#webpage',
    url: 'https://frinter.app/en/',
    name: 'frinter. — WholeBeing for Founders | Focus System',
    isPartOf: { '@id': 'https://frinter.app/#website' },
    about: { '@id': 'https://frinter.app/#organization' },
    description:
      'frinter is the operating system for Founders building in deep focus.',
    inLanguage: 'en-US',
  },
  {
    '@type': 'SoftwareApplication',
    '@id': 'https://frinter.app/#software',
    name: 'frinter.',
    applicationCategory: 'ProductivityApplication',
    operatingSystem: 'Web, iOS, Android',
    url: 'https://frinter.app',
    description:
      'Focus timer, activity tracker, bullet journal and gamification system for High Performers.',
    author: { '@id': 'https://frinter.app/#person' },
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    featureList: [
      'Focus Timer (Frint)',
      'Activity Tracker (3 spheres)',
      'Energy Bar',
      'Bullet Journal',
      'Gamification & rankings',
      'FRINT Check-in',
    ],
    inLanguage: 'en-US',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};

const ldString = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': organizationJsonLd,
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>frinter. — WholeBeing for Founders | Focus System</title>
    <meta
      name="description"
      content="frinter is the operating system for Founders building in deep focus. Focus timer (Frint), Energy Bar, Activity Tracker and 3 life spheres in one app."
    />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <link rel="canonical" href="https://frinter.app/en/" />
    <link rel="alternate" hreflang="pl" href="https://frinter.app/" />
    <link rel="alternate" hreflang="en" href="https://frinter.app/en/" />
    <link rel="alternate" hreflang="x-default" href="https://frinter.app/" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://frinter.app/en/" />
    <meta property="og:title" content="frinter. — WholeBeing for Founders | Focus System" />
    <meta
      property="og:description"
      content="frinter is the operating system for Founders building in deep focus."
    />
    <meta property="og:image" content="https://frinter.app/og-image.svg" />
    <meta property="og:image:alt" content="frinter. — WholeBeing for Founders | Focus System" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:site_name" content="frinter." />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="frinter. — WholeBeing for Founders | Focus System" />
    <meta
      name="twitter:description"
      content="frinter is the operating system for Founders building in deep focus."
    />
    <meta name="twitter:image" content="https://frinter.app/og-image.svg" />
    <meta name="twitter:image:alt" content="frinter. — WholeBeing for Founders | Focus System" />
    <link rel="me" href="https://github.com/delta240mvt" />
    <link rel="me" href="https://www.linkedin.com/in/przemyslaw-filipiak-8a9b77113/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/icon-180.png" />
    <meta name="theme-color" content="#4a8d83" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&family=Poppins:wght@400;500;600;700;800&family=Roboto:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={ldString}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
    <style is:global>
      :root {
        --bg: #ffffff;
        --panel: #f9fafb;
        --panel-strong: #ffffff;
        --text: #111827;
        --text-soft: #6b7280;
        --text-faint: #9ca3af;
        --border: #e5e7eb;
        --border-strong: #d1d5db;
        --shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
        --green: #4a8d83;
        --rose: #8a4e64;
        --gold: #d6b779;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Poppins', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      canvas,
      svg {
        display: block;
      }

      .page-shell {
        /* overflow-x on body instead — overflow:hidden on a parent breaks position:sticky */
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .narrow-container {
        max-width: 768px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .mono {
        font-family: 'Courier Prime', monospace;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 60;
        background: #ffffff;
      }

      .site-header.scrolled {
        border-bottom: 1px solid #e5e7eb;
      }

      .site-header-inner {
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .logo {
        font-family: 'Poppins', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1;
        color: #111827;
      }

      .site-footer .logo {
        font-size: 1.875rem;
      }

      @media (min-width: 768px) {
        .site-header .logo {
          font-size: 1.875rem;
        }
      }

      .logo-dot {
        background: linear-gradient(90deg, var(--green), var(--rose), var(--gold));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 900;
      }

      .header-nav {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      /* Plain text link — matches React: text-base text-gray-700 font-medium font-heading */
      .header-link {
        font-family: 'Poppins', sans-serif;
        font-size: 1rem;
        font-weight: 500;
        color: #374151;
        cursor: pointer;
        transition: color 0.2s ease;
      }

      .header-link:hover {
        color: #111827;
      }

      .header-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.625rem 0.9rem;
        border-radius: 0.75rem;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        color: #111827;
        font-family: 'Poppins', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        transition: background 0.2s ease, transform 0.2s ease;
      }

      .header-chip:hover {
        background: #f9fafb;
        transform: translateY(-1px);
      }

      .header-chip svg {
        width: 16px;
        height: 16px;
        color: #6b7280;
      }

      /* Gradient border button — matches React: rounded-lg (8px) p-[3px] */
      .header-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 3px;
        border-radius: 0.5rem;
        position: relative;
        overflow: hidden;
      }

      .header-button::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--green), var(--rose), var(--gold));
        background-size: 200% 100%;
        animation: gradientShift 5s linear infinite;
      }

      /* Inner button — matches React: bg-white font-bold border-0 hover:bg-gray-50 text-gray-900 */
      .header-button-inner {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        padding: 0.625rem 1rem;
        border-radius: calc(0.5rem - 3px);
        background: #ffffff;
        color: #111827;
        font-family: 'Poppins', sans-serif;
        font-size: 0.875rem;
        font-weight: 700;
        transition: background 0.2s ease;
      }

      .header-button:hover .header-button-inner {
        background: #f9fafb;
      }

      /* Mobile Login — matches React: outlined button border-2 border-gray-200 bg-white */
      .mobile-login-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 52px;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        border: 2px solid #e5e7eb;
        background: #ffffff;
        color: #374151;
        font-family: 'Poppins', sans-serif;
        font-size: 1rem;
        font-weight: 500;
        transition: background 0.2s ease;
      }

      .mobile-login-button:hover {
        background: #f9fafb;
      }

      .mobile-header-controls {
        display: none;
        align-items: center;
        gap: 8px;
      }

      .mobile-menu-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 0.75rem;
        border: 0;
        background: transparent;
        color: var(--text-soft);
      }

      .mobile-menu-toggle:hover {
        background: color-mix(in srgb, var(--panel) 78%, transparent);
        color: var(--text);
      }

      .mobile-menu-panel {
        display: none;
        border-top: 1px solid var(--border);
        background: var(--panel-strong);
      }

      .mobile-menu-panel.open {
        display: block;
      }

      .mobile-menu-inner {
        padding: 24px 0;
      }

      .mobile-menu-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 24px;
      }

      .mobile-menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0.95rem 1rem;
        border-radius: 0.875rem;
        color: var(--text-soft);
        font-weight: 500;
        transition: background 0.2s ease, transform 0.2s ease, color 0.2s ease;
      }

      .mobile-menu-link:hover {
        background: color-mix(in srgb, var(--panel) 78%, transparent);
        color: var(--text);
        transform: translateX(4px);
      }

      .mobile-menu-divider {
        border-top: 1px solid var(--border);
        padding-top: 24px;
      }

      .hero {
        min-height: 90vh;
        display: flex;
        align-items: center;
        padding: 96px 0 0;
      }

      .hero-inner {
        position: relative;
        min-height: calc(90vh - 96px);
      }

      .hero-copy {
        width: min(60%, 820px);
        padding: 0 0 64px;
        position: relative;
        z-index: 2;
      }

      .hero-badge-panel {
        margin-bottom: 24px;
        max-width: 520px;
        min-height: 110px;
        border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        border-radius: 1rem;
        overflow: hidden;
        background: color-mix(in srgb, var(--panel) 92%, transparent);
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.07);
      }

      .hero-battle {
        width: 100%;
        min-height: 110px;
        position: relative;
        overflow: hidden;
        font-family: 'Courier Prime', monospace;
      }

      .scanlines {
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.15) 0,
          rgba(0, 0, 0, 0.15) 1px,
          transparent 1px,
          transparent 3px
        );
        opacity: 0.05;
        pointer-events: none;
      }

      .stars-layer {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
      }

      .battle-inner {
        position: relative;
        z-index: 2;
        padding: 18px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .battle-side {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .battle-row {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .battle-row.hit {
        animation: enemyHit 0.4s ease;
      }

      .pixel-char {
        display: inline-flex;
        flex-direction: column;
        line-height: 0;
        image-rendering: pixelated;
        flex-shrink: 0;
      }

      .pixel-row {
        display: flex;
      }

      .pixel-cell {
        background: transparent;
        flex-shrink: 0;
      }

      .battle-meta {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .battle-label {
        font-size: 7px;
        letter-spacing: 2px;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .hp-bar {
        display: flex;
        gap: 2px;
      }

      .hp-unit {
        width: 8px;
        height: 8px;
        background: rgba(148, 163, 184, 0.35);
      }

      .battle-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        flex-shrink: 0;
      }

      .battle-vs {
        font-size: 11px;
        letter-spacing: 4px;
        font-weight: 700;
        animation: pulse 1.2s ease-in-out infinite;
      }

      .battle-sword {
        font-size: 11px;
      }

      .battle-winner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        min-width: 110px;
      }

      .battle-winner.attack .winner-sprite-wrap {
        animation: winnerAttack 0.4s ease;
      }

      .battle-winner.win .winner-sprite-wrap {
        animation: winnerWin 0.4s ease;
      }

      .battle-crown {
        font-size: 16px;
      }

      .battle-overlay-text {
        position: absolute;
        left: 50%;
        bottom: 4px;
        transform: translateX(-50%);
        z-index: 3;
        font-family: 'Courier Prime', monospace;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 4px;
        opacity: 0;
        transition: opacity 0.2s ease;
        pointer-events: none;
        white-space: nowrap;
      }

      .battle-overlay-text.active {
        opacity: 1;
      }

      .battle-overlay-text.fight {
        color: #ea580c;
        text-shadow: 0 0 8px #f97316, 0 0 16px #f97316;
        font-size: 14px;
      }

      .battle-overlay-text.win {
        font-size: 12px;
      }

      .hero-title {
        margin: 0;
        font-weight: 700;
        letter-spacing: -0.06em;
        line-height: 1;
        font-size: clamp(3.6rem, 7vw, 8rem);
      }

      .hero-title-line,
      .hero-title-sub {
        display: block;
      }

      .hero-title-mid {
        display: block;
        margin-top: 0.3em;
        font-family: 'Roboto', sans-serif;
        font-size: 0.22em;
        line-height: 1.8;
        letter-spacing: 0.4em;
        font-weight: 300;
        text-transform: uppercase;
        color: var(--text-soft);
      }

      .hero-title-sub {
        font-size: 0.72em;
        line-height: 1.05;
        white-space: nowrap;
      }

      .gradient-dot {
        display: inline-block;
        width: 0.22em;
        height: 0.22em;
        margin-left: 0.1em;
        border-radius: 999px;
        vertical-align: -0.05em;
        background: linear-gradient(90deg, var(--green), var(--rose), var(--gold));
      }

      .hero-subtitle {
        max-width: 800px;
        margin: 28px 0 0;
        font-family: 'Roboto', sans-serif;
        font-size: clamp(1.2rem, 2vw, 2rem);
        line-height: 1.55;
        font-weight: 300;
        color: var(--text-soft);
      }

      .hero-actions {
        display: flex;
        align-items: flex-start;
        gap: 24px;
        margin-top: 28px;
        flex-wrap: wrap;
      }

      .primary-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        min-height: 72px;
        padding: 1rem 3rem;
        border-radius: 1rem;
        background: var(--text);
        color: var(--bg);
        font-size: clamp(1rem, 1.3vw, 1.25rem);
        font-weight: 600;
        box-shadow: var(--shadow);
        transition: transform 0.25s ease, opacity 0.25s ease;
      }

      .primary-button:hover {
        transform: translateY(-2px);
        opacity: 0.94;
      }

      .button-arrow {
        width: 24px;
        height: 24px;
        transition: transform 0.25s ease;
      }

      .primary-button:hover .button-arrow {
        transform: translateX(6px);
      }

      .secondary-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 72px;
        padding: 1rem 0.25rem;
        font-size: clamp(1rem, 1.3vw, 1.25rem);
        color: var(--text-soft);
      }

      .hero-microcopy {
        margin-top: 18px;
        font-family: 'Roboto', sans-serif;
        font-size: 0.95rem;
        color: var(--text-soft);
      }

      .hero-portal {
        position: absolute;
        right: 2%;
        top: 50%;
        transform: translateY(-50%);
        width: min(35%, 500px);
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
      }

      .portal-shell {
        position: relative;
        width: 100%;
        height: 100%;
        border: 6px solid var(--text);
        border-radius: 999px;
        background: var(--panel);
        overflow: hidden;
        box-shadow: var(--shadow);
      }

      .portal-canvas {
        width: 100%;
        height: 100%;
      }

      .portal-vignette {
        position: absolute;
        inset: 0;
        border-radius: 999px;
        box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.3);
        pointer-events: none;
      }

      .portal-label {
        position: absolute;
        left: 50%;
        bottom: 48px;
        transform: translateX(-50%);
        padding: 0.7rem 1.5rem;
        border-radius: 999px;
        border: 1px solid var(--border-strong);
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.14);
      }

      .portal-label span {
        font-family: 'Courier Prime', monospace;
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .gradient-bar {
        position: relative;
        height: 64px;
        overflow: hidden;
      }

      .gradient-bar::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, var(--gold), var(--rose), var(--green));
        background-size: 200% 100%;
        animation: gradientShift 10s linear infinite;
      }

      .gradient-bar::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12), transparent);
        animation: shineSweep 3s ease-in-out infinite;
      }

      .problem-section {
        padding: 8rem 0 10rem;
        background: var(--panel);
      }

      .section-title {
        margin: 0;
        font-size: clamp(2.8rem, 4vw, 4.5rem);
        line-height: 1.1;
        font-weight: 700;
      }

      .problem-grid {
        margin-top: 5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }

      .problem-highlight {
        position: relative;
        padding-left: 32px;
      }

      .problem-highlight::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 6px;
        border-radius: 999px;
        background: linear-gradient(180deg, var(--green), var(--rose), var(--gold));
      }

      .problem-lead {
        margin: 0;
        font-size: clamp(1.6rem, 2.8vw, 2.5rem);
        line-height: 1.22;
        font-weight: 500;
      }

      .problem-copy {
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .problem-copy p {
        margin: 0;
      }

      .problem-copy .soft {
        font-family: 'Roboto', sans-serif;
        font-size: 1.25rem;
        line-height: 1.65;
        color: var(--text-soft);
        font-weight: 300;
      }

      .problem-copy .strong {
        font-size: 1.25rem;
        line-height: 1.65;
        font-weight: 600;
      }

      .problem-jump {
        font-weight: 500;
        color: var(--green);
      }

      .features-section {
        padding: 8rem 0 0;
      }

      .features-lead {
        max-width: 48rem;
      }

      .section-accent {
        width: 96px;
        height: 4px;
        background: var(--green);
        margin: 32px 0;
      }

      .section-subtitle {
        margin: 0;
        font-family: 'Roboto', sans-serif;
        font-size: clamp(1.15rem, 1.9vw, 2rem);
        font-weight: 300;
        color: var(--text-soft);
      }

      .feature-grid {
        margin-top: 4rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 32px;
        align-items: start;
      }

      .feature-card {
        position: relative;
        transition: transform 0.5s ease;
      }

      .feature-card:hover {
        transform: translateY(-8px);
      }

      .feature-card-offset-large {
        margin-top: 8rem;
      }

      .feature-card-offset-small {
        margin-top: 4rem;
      }

      .feature-card-inner {
        height: 100%;
        padding: 40px;
        background: var(--panel-strong);
        border: 1px solid var(--border);
        border-radius: 2rem;
        box-shadow: 0 18px 44px rgba(15, 23, 42, 0.06);
        transition: transform 0.5s ease, border-color 0.3s ease, box-shadow 0.3s ease;
      }

      .feature-card:hover .feature-card-inner {
        transform: scale(1.03);
        border-color: var(--border-strong);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
      }

      .feature-animation-frame {
        margin-bottom: 24px;
        border-radius: 1rem;
        overflow: hidden;
        border: 2px solid rgba(74, 141, 131, 0.38);
      }

      .feature-card h3 {
        margin: 0 0 24px;
        font-size: 1.5rem;
        line-height: 1.3;
      }

      .feature-meta {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      .feature-meta-label {
        margin: 0 0 4px;
        font-size: 0.75rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--text-faint);
      }

      .feature-meta p {
        margin: 0;
      }

      .feature-meta .mechanism {
        font-size: 1rem;
        line-height: 1.55;
        font-weight: 500;
      }

      .feature-meta .goal {
        font-family: 'Roboto', sans-serif;
        font-size: 1.05rem;
        line-height: 1.7;
        font-weight: 300;
        color: var(--text-soft);
      }

      .energy-panel {
        margin: 8rem auto 0;
        max-width: 64rem;
        position: relative;
      }

      .energy-panel-inner {
        position: relative;
        overflow: hidden;
        border-radius: 2rem;
        padding: 32px 40px;
        background: var(--panel);
        border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
        box-shadow: var(--shadow);
      }

      .energy-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
      }

      .energy-display {
        padding: 24px;
        border-radius: 1rem;
        border: 2px solid rgba(74, 141, 131, 0.38);
        background: linear-gradient(135deg, #0d0d1a 0%, #1a0d2e 50%, #0d1a1a 100%);
        image-rendering: pixelated;
        font-family: 'Courier Prime', monospace;
      }

      .energy-display-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
      }

      .energy-display-head span:first-child {
        color: var(--green);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.3em;
        text-transform: uppercase;
      }

      .energy-value {
        color: var(--green);
        font-size: 2rem;
        font-weight: 700;
        text-shadow: 0 0 10px rgba(74, 141, 131, 0.6);
      }

      .energy-bar {
        display: flex;
        gap: 3px;
      }

      .energy-segment {
        flex: 1;
        height: 18px;
        background: #1a2a1a;
      }

      .energy-segment.active-low {
        background: var(--green);
      }

      .energy-segment.active-high {
        background: #7bc4ba;
      }

      .energy-scale {
        display: flex;
        justify-content: space-between;
        margin-top: 12px;
        color: rgba(74, 141, 131, 0.56);
        font-size: 10px;
        letter-spacing: 0.04em;
      }

      .energy-copy {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .mini-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: fit-content;
        padding: 0.4rem 0.75rem;
        border-radius: 0.125rem;
        border: 1px solid rgba(214, 183, 121, 0.38);
        background: rgba(214, 183, 121, 0.07);
      }

      .mini-badge span {
        font-family: 'Courier Prime', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--gold);
      }

      .energy-copy h3 {
        margin: 0;
        font-size: clamp(2rem, 3vw, 2.5rem);
        line-height: 1.15;
      }

      .energy-copy .headline {
        margin: 0;
        font-size: 1.25rem;
        line-height: 1.5;
        font-weight: 500;
      }

      .energy-copy .description {
        margin: 0;
        white-space: pre-line;
        font-family: 'Roboto', sans-serif;
        font-size: 1.125rem;
        line-height: 1.7;
        font-weight: 300;
        color: var(--text-soft);
      }

      .quote-section {
        margin-top: 4rem;
        padding: 6rem 0 8rem;
        position: relative;
        overflow: hidden;
      }

      .quote-background {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          90deg,
          rgba(74, 141, 131, 0.1),
          rgba(138, 78, 100, 0.1),
          rgba(214, 183, 121, 0.1)
        );
        background-size: 200% auto;
        animation: gradientShift 5s linear infinite;
      }

      .quote-shell {
        position: relative;
        max-width: 64rem;
        margin: 0 auto;
        padding: 0 24px;
        text-align: center;
      }

      .quote-mark {
        position: absolute;
        opacity: 0.1;
        width: 160px;
        height: 160px;
        color: var(--text);
      }

      .quote-mark-left {
        left: 0;
        top: -48px;
        transform: scaleX(-1);
      }

      .quote-mark-right {
        right: 0;
        bottom: -48px;
      }

      .quote-shell h3 {
        position: relative;
        z-index: 2;
        margin: 0;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        line-height: 1.28;
      }

      .quote-green {
        color: var(--green);
      }

      .quote-rose {
        color: var(--rose);
      }

      .quote-author {
        margin-top: 24px;
        font-family: 'Roboto', sans-serif;
        font-size: 1rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--text-faint);
        font-weight: 300;
      }

      .social-proof {
        background: var(--panel);
        padding: 1rem 0 10rem;
      }

      .social-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8rem;
        align-items: start;
      }

      .icon-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        color: var(--green);
      }

      .icon-row svg {
        width: 32px;
        height: 32px;
      }

      .social-title {
        margin: 0;
        font-size: clamp(2.5rem, 4vw, 4rem);
        line-height: 1.2;
        white-space: pre-line;
      }

      .social-story-wrap {
        position: relative;
        padding-left: 40px;
        padding-top: 40px;
      }

      .social-story-wrap::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: var(--border);
      }

      .social-story {
        margin: 0;
        font-family: 'Roboto', sans-serif;
        font-size: clamp(1.25rem, 2vw, 1.65rem);
        line-height: 1.7;
        font-style: italic;
        color: var(--text-soft);
      }

      .social-author-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-top: 32px;
        padding-top: 32px;
        border-top: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
      }

      .social-author {
        margin: 0;
        font-size: 1.125rem;
        font-weight: 700;
        white-space: pre-line;
      }

      .author-badge {
        width: 72px;
        height: 72px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: color-mix(in srgb, var(--panel-strong) 92%, transparent);
        color: var(--text-faint);
        font-size: 1.25rem;
        font-weight: 700;
        border: 1px solid var(--border);
      }

      .faq-section {
        padding: 8rem 0 6rem;
      }

      .faq-head {
        text-align: center;
        margin-bottom: 4rem;
      }

      .faq-head p {
        margin: 16px 0 0;
        font-family: 'Roboto', sans-serif;
        font-size: 1.25rem;
        font-weight: 300;
        color: var(--text-soft);
      }

      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .faq-item {
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        background: var(--panel-strong);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
        overflow: hidden;
      }

      .faq-item summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 24px;
        font-size: 1.125rem;
        font-weight: 600;
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item p {
        margin: 0;
        padding: 0 24px 24px;
        font-family: 'Roboto', sans-serif;
        font-size: 1rem;
        line-height: 1.75;
        color: var(--text-soft);
      }

      .faq-chevron {
        width: 20px;
        height: 20px;
        color: var(--text-faint);
        transition: transform 0.2s ease;
        flex-shrink: 0;
      }

      .faq-item[open] .faq-chevron {
        transform: rotate(180deg);
      }

      .final-cta {
        background: var(--panel);
        padding: 8rem 0 10rem;
      }

      .final-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
      }

      .offer-card {
        overflow: hidden;
        padding: 40px 48px;
        border-radius: 1.5rem;
        background: var(--panel-strong);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
      }

      .offer-card h3 {
        margin: 0 0 32px;
        font-size: 2rem;
        line-height: 1.2;
      }

      .offer-list {
        display: flex;
        flex-direction: column;
        gap: 24px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .offer-list li {
        display: flex;
        align-items: flex-start;
        gap: 16px;
      }

      .offer-check {
        width: 24px;
        height: 24px;
        border-radius: 999px;
        background: rgba(74, 141, 131, 0.12);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
      }

      .offer-check svg {
        width: 16px;
        height: 16px;
        color: var(--green);
      }

      .offer-list span {
        font-size: 1.125rem;
        line-height: 1.6;
        font-weight: 500;
        color: var(--text-soft);
      }

      .offer-note {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-top: 40px;
        padding: 16px;
        border-radius: 1rem;
        border: 1px solid rgba(74, 141, 131, 0.18);
        background: rgba(74, 141, 131, 0.03);
      }

      .offer-note svg {
        width: 20px;
        height: 20px;
        color: var(--green);
        flex-shrink: 0;
        margin-top: 2px;
      }

      .offer-note p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.65;
        font-weight: 500;
        color: var(--text-soft);
      }

      .final-copy {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 24px;
      }

      .final-copy h2 {
        margin: 0;
        font-size: clamp(3rem, 4.6vw, 4.5rem);
        line-height: 1.1;
      }

      .final-copy .sub {
        margin: 0;
        font-family: 'Roboto', sans-serif;
        font-size: clamp(1.4rem, 2vw, 2rem);
        line-height: 1.4;
        color: var(--text-soft);
        font-weight: 300;
      }

      .final-copy .foot {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-soft);
      }

      .site-footer {
        margin-top: auto;
        background: #ffffff;
        padding: 4rem 0;
        color: #111827;
      }


      .footer-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 48px;
        margin-bottom: 3rem;
      }

      .footer-tagline {
        margin: 16px 0 0;
        font-family: 'Roboto', sans-serif;
        font-size: 0.875rem;
        line-height: 1.7;
        font-weight: 300;
        color: #4b5563;
        white-space: pre-line;
      }

      .footer-heading {
        margin: 0 0 16px;
        font-family: 'Poppins', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .footer-list a {
        font-family: 'Roboto', sans-serif;
        font-size: 0.875rem;
        color: #4b5563;
        font-weight: 300;
      }

      .footer-list a:hover {
        color: #111827;
      }

      .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 2rem 0 0;
        border-top: 1px solid #e5e7eb;
        color: #6b7280;
        font-size: 0.875rem;
        font-family: 'Roboto', sans-serif;
        font-weight: 300;
      }

      .footer-heart-row {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .footer-heart {
        width: 16px;
        height: 16px;
        color: #ef4444;
        fill: currentColor;
        animation: footerHeartBeat 2s ease-in-out infinite;
      }

      .fade-in-up {
        opacity: 0;
        transform: translateY(16px);
        animation: fadeInUp 0.55s ease-out forwards;
      }

      .delay-1 { animation-delay: 0.15s; }
      .delay-2 { animation-delay: 0.3s; }
      .delay-3 { animation-delay: 0.45s; }
      .delay-4 { animation-delay: 0.6s; }
      .delay-5 { animation-delay: 0.75s; }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes gradientShift {
        0% { background-position: 100% 50%; }
        50% { background-position: 0% 50%; }
        100% { background-position: 100% 50%; }
      }

      @keyframes shineSweep {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }

      @keyframes pulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
      }

      @keyframes enemyHit {
        0% { transform: translateX(0); opacity: 1; }
        40% { transform: translateX(8px); opacity: 0.45; }
        70% { transform: translateX(-4px); opacity: 1; }
        100% { transform: translateX(0); opacity: 1; }
      }

      @keyframes winnerAttack {
        0% { transform: translateX(0) rotate(0deg); }
        35% { transform: translateX(-6px) rotate(-5deg); }
        70% { transform: translateX(6px) rotate(5deg); }
        100% { transform: translateX(0) rotate(0deg); }
      }

      @keyframes winnerWin {
        0% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-6px) scale(1.15); }
        100% { transform: translateY(0) scale(1); }
      }

      @keyframes footerHeartBeat {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.2); }
      }

      @media (max-width: 1200px) {
        .hero-copy { width: 100%; }
        .hero-portal {
          position: relative;
          top: auto;
          right: auto;
          transform: none;
          width: min(420px, 100%);
          margin: 48px auto 0;
        }
        .feature-grid,
        .social-grid,
        .final-grid,
        .problem-grid,
        .energy-grid {
          grid-template-columns: 1fr;
        }
        .feature-card-offset-large,
        .feature-card-offset-small {
          margin-top: 0;
        }
        .social-grid,
        .final-grid {
          gap: 48px;
        }
      }

      @media (max-width: 768px) {
        .container,
        .narrow-container {
          padding: 0 16px;
        }
        .header-nav {
          display: none;
        }
        .mobile-header-controls {
          display: flex;
        }
        .hero { min-height: auto; padding-top: 72px; }
        .hero-copy { padding-bottom: 24px; }
        .hero-actions {
          flex-direction: column;
          gap: 16px;
          align-items: stretch;
