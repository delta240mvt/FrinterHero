---
import Base from '@/components/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import BlogCard from '@/components/BlogCard.astro';
import { BLOG_PAGE_SIZE, getPaginatedPosts } from '@/lib/blog';
import { getSitePresentation } from '@/lib/site';

export async function getStaticPaths() {
  const { totalPages } = await getPaginatedPosts(1, BLOG_PAGE_SIZE);
  const paths = [];

  for (let page = 2; page <= totalPages; page += 1) {
    paths.push({ params: { page: String(page) } });
  }

  return paths;
}

const requestedPage = Number(Astro.params.page);
const site = getSitePresentation();
const { posts, page, totalPages } = await getPaginatedPosts(requestedPage, BLOG_PAGE_SIZE);
const prevHref = page === 2 ? '/blog' : `/blog/${page - 1}`;
const nextHref = `/blog/${page + 1}`;
---

<Base
  title={`${site.blogTitle} — Page ${page}`}
  description={site.blogDescription}
>
  <Nav />
  <main class="blog-list-main" aria-label="Blog posts">
    <div class="blog-list-container">
      <header class="blog-list-header">
        <h1 class="blog-list-title">/blog</h1>
      </header>

      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post, i) => (
            <BlogCard
              title={post.title}
              description={post.description}
              date={post.pubDate}
              readingTime={post.readingTime}
              tags={post.tags}
              slug={post.slug}
              featured={i === 0}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No articles found. Check back soon.</p>
      )}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Blog pagination">
          <a href={prevHref} class="page-btn">← Previous</a>
          <span class="page-info">Page {page} of {totalPages}</span>
          {page < totalPages && (
            <a href={nextHref} class="page-btn">Next →</a>
          )}
        </nav>
      )}
    </div>
  </main>
  <Footer />
</Base>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${site.canonicalBaseUrl}/blog/${page}/#webpage`,
      "url": `${site.canonicalBaseUrl}/blog/${page}`,
      "name": `${site.blogTitle} — Page ${page}`,
      "description": site.blogDescription,
      "isPartOf": { "@id": `${site.canonicalBaseUrl}/#website` },
      "author": { "@id": `${site.canonicalBaseUrl}/#entity` },
      "inLanguage": "en-US",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": site.canonicalBaseUrl },
          { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${site.canonicalBaseUrl}/blog` },
          { "@type": "ListItem", "position": 3, "name": `Page ${page}`, "item": `${site.canonicalBaseUrl}/blog/${page}` }
        ]
      }
    }
  ]
})} />

<style>
  .blog-list-main {
    padding-top: 3.5rem;
    min-height: 100vh;
    background-color: var(--bg-base);
  }
  .blog-list-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }
  .blog-list-header {
    margin-bottom: 2.5rem;
  }
  .blog-list-title {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--teal);
    margin-bottom: 0.75rem;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .empty-state {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 3rem 0;
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .page-btn {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--teal);
    text-decoration: none;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    transition: all 0.15s;
  }
  .page-btn:hover { border-color: var(--teal); }
  .page-info {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
