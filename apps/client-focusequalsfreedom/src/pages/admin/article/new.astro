---
import Base from '@/components/layouts/Base.astro';
---

<Base title="New Article — Admin">
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">New Article</h1>
      <a href="/api/logout" class="logout-btn">Logout</a>
    </header>
    <main class="editor-main">
      <form id="article-form" class="article-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="title">Title</label>
            <input type="text" id="title" name="title" class="form-input" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="slug">Slug (auto-generated)</label>
            <input type="text" id="slug" name="slug" class="form-input" placeholder="auto-generated-from-title" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="description">Description (max 160 chars)</label>
          <input type="text" id="description" name="description" class="form-input" maxlength="160" />
        </div>

        <div class="form-group">
          <label class="form-label" for="content">Content (Markdown)</label>
          <textarea id="content" name="content" class="form-textarea" rows="24" placeholder="# Your article title&#10;&#10;Write your article in Markdown..."></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="tags">Tags (comma-separated)</label>
            <input type="text" id="tags" name="tags" class="form-input" placeholder="deep-work, ai-dev, productivity" />
          </div>
          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select id="status" name="status" class="form-input">
              <option value="draft" selected>Draft</option>
              <option value="published">Published</option>
              <option value="archived">Archived</option>
            </select>
          </div>
        </div>

        <div class="form-check">
          <input type="checkbox" id="featured" name="featured" class="check-input" />
          <label for="featured" class="check-label">Featured article</label>
        </div>

        <div class="editor-actions">
          <button type="submit" class="btn-save">Save Article</button>
          <a href="/admin" class="btn-cancel">Cancel</a>
          <span class="autosave-indicator" id="autosave-status"></span>
        </div>
      </form>

      <div class="preview-panel" id="preview-panel" style="display:none">
        <h3 class="preview-title">Preview</h3>
        <div class="preview-content" id="preview-content"></div>
      </div>
    </main>
  </div>
</Base>

<script>
  // Slug generation from title
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;

  titleInput?.addEventListener('input', () => {
    if (!slugInput.dataset.manual) {
      slugInput.value = titleInput.value
        .toLowerCase()
        .replace(/[łĺ]/g, 'l').replace(/[ąà]/g, 'a').replace(/[ęè]/g, 'e')
        .replace(/[óò]/g, 'o').replace(/[śš]/g, 's').replace(/[źž]/g, 'z')
        .replace(/[żž]/g, 'z').replace(/[ćč]/g, 'c').replace(/[ńñ]/g, 'n')
        .replace(/[^a-z0-9\s-]/g, '').trim()
        .replace(/\s+/g, '-').replace(/-+/g, '-').slice(0, 80);
    }
  });

  slugInput?.addEventListener('input', () => {
    slugInput.dataset.manual = 'true';
  });

  // Form submission
  const form = document.getElementById('article-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    data.featured = (document.getElementById('featured') as HTMLInputElement).checked ? 'true' : 'false';

    const res = await fetch('/api/articles', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({...data, featured: data.featured === 'true'}),
    });

    if (res.ok) {
      const { id } = await res.json();
      window.location.href = `/admin/article/${id}`;
    } else {
      alert('Failed to save article');
    }
  });

  // Autosave (drafts only) every 30s
  let autosaveTimer: ReturnType<typeof setInterval>;
  const status = document.getElementById('autosave-status') as HTMLElement;

  function scheduleAutosave() {
    clearInterval(autosaveTimer);
    autosaveTimer = setInterval(async () => {
      if (!form) return;
      const statusSelect = (form.querySelector('#status') as HTMLSelectElement).value;
      if (statusSelect !== 'draft') return;

      status.textContent = 'Saving...';
      const data = Object.fromEntries(new FormData(form));
      data.featured = (document.getElementById('featured') as HTMLInputElement).checked ? 'true' : 'false';

      const res = await fetch('/api/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({...data, featured: data.featured === 'true', status: 'draft'}),
      });

      if (res.ok) {
        status.textContent = 'Autosaved';
        setTimeout(() => { status.textContent = ''; }, 2000);
      }
    }, 30000);
  }

  document.getElementById('content')?.addEventListener('input', scheduleAutosave);
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header {
    display: flex; align-items: center; gap: 1.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 10;
  }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); flex: 1; }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .editor-main { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
  .article-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .form-input, .form-textarea {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.6rem 0.875rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  .form-input:focus, .form-textarea:focus { border-color: var(--teal); }
  .form-textarea { resize: vertical; font-size: var(--text-sm); line-height: 1.6; }
  .form-check { display: flex; align-items: center; gap: 0.5rem; }
  .check-input { width: 1rem; height: 1rem; accent-color: var(--teal); cursor: pointer; }
  .check-label { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); cursor: pointer; }
  .editor-actions { display: flex; gap: 1rem; align-items: center; padding-top: 0.5rem; }
  .btn-save { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; transition: opacity 0.15s; }
  .btn-save:hover { opacity: 0.9; }
  .btn-cancel { padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-secondary); text-decoration: none; font-family: var(--font-mono); font-size: var(--text-sm); transition: all 0.15s; }
  .btn-cancel:hover { border-color: var(--border-hover); color: var(--text-primary); }
  .autosave-indicator { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
</style>
