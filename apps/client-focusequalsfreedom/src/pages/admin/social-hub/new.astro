---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';
const headers = { cookie: Astro.request.headers.get('cookie') ?? '' };
const [accountsResponse, templatesResponse] = await Promise.all([
  fetch(new URL('/api/social-hub/accounts', Astro.url), { headers }),
  fetch(new URL('/api/social-hub/templates', Astro.url), { headers }),
]);
const allAccounts = accountsResponse.ok ? await accountsResponse.json() : [];
const accounts = allAccounts.filter((account: any) => account.isActive);
const templates = templatesResponse.ok ? await templatesResponse.json() : [];
---

<Base title="New Post — Social Hub" description="Create a new social media post with the 5-step wizard">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/social-hub" class="bc-link">Social Hub</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">New Post</span>
    </nav>
    <div class="header-actions">
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <!-- Progress bar -->
    <div class="wizard-progress">
      <div class="progress-steps">
        {[1, 2, 3, 4, 5].map((n) => (
          <div class="progress-step" data-step={n}>
            <div class="step-dot">{n}</div>
            <span class="step-label">
              {n === 1 && 'Source'}
              {n === 2 && 'Preview'}
              {n === 3 && 'Prompt'}
              {n === 4 && 'Format'}
              {n === 5 && 'Platforms'}
            </span>
          </div>
        ))}
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill" id="progress-bar-fill"></div>
      </div>
    </div>

    <!-- ─── STEP 1: Choose Source ──────────────────────────────────────────── -->
    <section class="wizard-step" id="step-1" data-step="1">
      <div class="step-header">
        <h2 class="step-title">Choose Source</h2>
        <p class="step-subtitle">Select the content you want to turn into a social post.</p>
      </div>

      <div class="source-controls">
        <div class="source-type-wrap">
          <label class="field-label" for="source-type">Source Type</label>
          <select id="source-type" class="field-select">
            <option value="article">Articles</option>
            <option value="pain_point">Pain Points</option>
            <option value="pain_cluster">Pain Clusters</option>
            <option value="content_gap">Content Gaps</option>
            <option value="kb_entry">KB Entries</option>
            <option value="reddit_gap">Reddit Gaps</option>
            <option value="yt_gap">YouTube Gaps</option>
          </select>
        </div>
        <div class="source-search-wrap">
          <label class="field-label" for="source-search">Search</label>
          <input type="text" id="source-search" class="field-input" placeholder="Search by title or keyword…" autocomplete="off" />
        </div>
      </div>

      <div id="source-results" class="source-results">
        <div class="source-empty" id="source-empty">
          <span class="source-empty-icon">⌕</span>
          <span>Choose a source type to load results.</span>
        </div>
        <div class="source-loading" id="source-loading" style="display:none">
          <span class="spinner"></span> Loading…
        </div>
        <div id="source-list" class="source-list"></div>
      </div>
    </section>

    <!-- ─── STEP 2: Source Preview ─────────────────────────────────────────── -->
    <section class="wizard-step" id="step-2" data-step="2" style="display:none">
      <div class="step-header">
        <h2 class="step-title">Source Preview</h2>
        <p class="step-subtitle">Review the selected content before proceeding.</p>
      </div>

      <div class="preview-card" id="preview-card">
        <div class="preview-meta-row">
          <span class="preview-badge" id="preview-badge">—</span>
          <span class="preview-meta" id="preview-meta"></span>
        </div>
        <h3 class="preview-title" id="preview-title">—</h3>
        <div class="preview-text-wrap">
          <p class="preview-text" id="preview-text">—</p>
        </div>
        <div class="preview-hint">💡 This is the content that will be used as the base for AI-generated copy.</div>
      </div>

      <div class="step-actions">
        <button type="button" class="btn-back" id="back-2">← Back</button>
        <button type="button" class="btn-next" id="continue-2">Continue →</button>
      </div>
    </section>

    <!-- ─── STEP 3: Suggestion Prompt ──────────────────────────────────────── -->
    <section class="wizard-step" id="step-3" data-step="3" style="display:none">
      <div class="step-header">
        <h2 class="step-title">Suggestion Prompt</h2>
        <p class="step-subtitle">Optional: guide the AI with a tone, angle, or focus for the post.</p>
      </div>

      <div class="form-group">
        <label class="field-label" for="suggestion-prompt">Direction for AI (optional)</label>
        <textarea
          id="suggestion-prompt"
          class="field-textarea"
          rows={5}
          placeholder="Skup się na aspekcie ADHD i digital minimalism, ton ironiczny"
        ></textarea>
        <span class="field-hint">Leave blank to let the AI decide based on source content.</span>
      </div>

      <div class="step-actions">
        <button type="button" class="btn-back" id="back-3">← Back</button>
        <button type="button" class="btn-next" id="continue-3">Continue →</button>
      </div>
    </section>

    <!-- ─── STEP 4: Format Selection ───────────────────────────────────────── -->
    <section class="wizard-step" id="step-4" data-step="4" style="display:none">
      <div class="step-header">
        <h2 class="step-title">Format Selection</h2>
        <p class="step-subtitle">Choose how the post will be rendered.</p>
      </div>

      <div class="format-grid" role="group" aria-label="Output format">
        <label class="format-card" id="fmt-image-label">
          <input type="radio" name="output-format" value="image" class="format-radio" id="fmt-image" />
          <span class="format-icon">📷</span>
          <span class="format-name">Image</span>
          <span class="format-desc">Static graphic via Satori</span>
        </label>
        <label class="format-card" id="fmt-video-label">
          <input type="radio" name="output-format" value="video" class="format-radio" id="fmt-video" />
          <span class="format-icon">🎬</span>
          <span class="format-name">Video</span>
          <span class="format-desc">Short video via WaveSpeed</span>
        </label>
        <label class="format-card" id="fmt-text-label">
          <input type="radio" name="output-format" value="text" class="format-radio" id="fmt-text" />
          <span class="format-icon">📝</span>
          <span class="format-name">Text only</span>
          <span class="format-desc">Copy only, no media</span>
        </label>
      </div>

      <!-- Image sub-options -->
      <div id="image-options" class="format-suboptions" style="display:none">
        <label class="field-label" for="template-select">Satori Template</label>
        {templates.length > 0 ? (
          <select id="template-select" class="field-select">
            {templates.map((t) => (
              <option value={t.id}>{t.name} — {t.aspectRatio} · {t.category}</option>
            ))}
          </select>
        ) : (
          <p class="field-hint field-hint--warn">No active templates found. Add templates in Social Hub settings.</p>
        )}
      </div>

      <!-- Video sub-options -->
      <div id="video-options" class="format-suboptions" style="display:none">
        <label class="field-label" for="video-model-select">Video Model</label>
        <select id="video-model-select" class="field-select">
          <option value="wan-2.2-ultra-fast">wan-2.2-ultra-fast (fast, lower cost)</option>
          <option value="InfiniteTalk">InfiniteTalk (talking head, portrait)</option>
        </select>
      </div>

      <!-- VIRAL ENGINE overrides -->
      <div class="viral-engine-panel">
        <div class="viral-engine-panel__header">
          <div>
            <h3 class="viral-engine-title">VIRAL ENGINE Override</h3>
            <p class="viral-engine-subtitle">Optional per-brief strategy layer. Defaults can be inherited from Social Hub settings.</p>
          </div>
        </div>

        <div class="viral-engine-grid">
          <label class="viral-toggle-row">
            <input type="checkbox" id="viral-engine-enabled" />
            <span class="viral-toggle-copy">
              <span class="viral-toggle-label">Enable for this brief</span>
              <span class="viral-toggle-hint">When off, the brief uses the normal SocialHub flow.</span>
            </span>
          </label>

          <div class="viral-field-group">
            <label class="field-label" for="viral-engine-mode">Override Mode</label>
            <select id="viral-engine-mode" class="field-select">
              <option value="default">Inherit default settings</option>
              <option value="personalized">Personalized for this brief</option>
            </select>
          </div>

          <div class="viral-field-group">
            <label class="field-label" for="pcm-profile-select">PCM Override</label>
            <select id="pcm-profile-select" class="field-select">
              <option value="">Inherit PCM profile</option>
              <option value="harmonizer">Harmonizer</option>
              <option value="thinker">Thinker</option>
              <option value="persister">Persister</option>
              <option value="rebel">Rebel</option>
              <option value="promoter">Promoter</option>
              <option value="imaginer">Imaginer</option>
            </select>
          </div>

          <div class="viral-field-group viral-field-group--wide" id="viral-personalization-group">
            <label class="field-label" for="viral-engine-personalization">Personalization Input</label>
            <textarea
              id="viral-engine-personalization"
              class="field-textarea"
              rows={4}
              placeholder="Describe the desired viral angle, audience nuance, risk level, tone, or forbidden patterns for this brief."
            ></textarea>
            <span class="field-hint">Used only when VIRAL ENGINE is enabled. Leave blank to keep default behavior.</span>
          </div>

          <div class="viral-field-group viral-field-group--wide" id="viral-video-format-group" style="display:none">
            <label class="field-label" for="viral-video-format-select">Video Format Selection</label>
            <select id="viral-video-format-select" class="field-select">
              <option value="">Inherit video format</option>
              <option value="talking_head_authority">Talking head authority</option>
              <option value="problem_agitation_solution">Problem agitation solution</option>
              <option value="storytime_confession">Storytime confession</option>
              <option value="contrarian_hot_take">Contrarian hot take</option>
              <option value="listicle_fast_cuts">Listicle fast cuts</option>
              <option value="myth_vs_reality">Myth vs reality</option>
              <option value="screen_demo_explainer">Screen demo explainer</option>
              <option value="ugc_testimonial_style">UGC testimonial style</option>
            </select>
            <span class="field-hint">Applied only when output format is video.</span>
          </div>
        </div>
      </div>

      <div class="step-actions">
        <button type="button" class="btn-back" id="back-4">← Back</button>
        <button type="button" class="btn-next" id="continue-4">Continue →</button>
      </div>
    </section>

    <!-- ─── STEP 5: Platforms & Accounts ──────────────────────────────────── -->
    <section class="wizard-step" id="step-5" data-step="5" style="display:none">
      <div class="step-header">
        <h2 class="step-title">Platforms &amp; Accounts</h2>
        <p class="step-subtitle">Select which accounts should receive this post.</p>
      </div>

      <div id="accounts-grid" class="accounts-grid">
        <!-- TASK-11: Dry-run / test mode card (always visible) -->
        <div class="platform-group">
          <div class="platform-group-header">
            <span class="platform-name">Test Mode</span>
          </div>
          <div class="platform-accounts">
            <label class="account-card account-card--dryrun" id="dryrun-card">
              <input
                type="checkbox"
                class="account-checkbox"
                value="__dry_run__"
                data-platform="dry_run"
                id="dryrun-checkbox"
              />
              <div class="account-info">
                <span class="account-name">🧪 Tryb testowy</span>
                <span class="account-handle">Bez publikowania — tylko podgląd pipeline'u</span>
              </div>
            </label>
          </div>
        </div>

        {accounts.length > 0 && (() => {
          const platforms = [...new Set(accounts.map(a => a.platform))].sort();
          return platforms.map((platform) => {
            const platformAccounts = accounts.filter(a => a.platform === platform);
            return (
              <div class="platform-group" key={platform}>
                <div class="platform-group-header">
                  <span class="platform-icon" data-platform={platform}></span>
                  <span class="platform-name">{platform}</span>
                </div>
                <div class="platform-accounts">
                  {platformAccounts.map((acc) => (
                    <label class="account-card" key={acc.id}>
                      <input
                        type="checkbox"
                        class="account-checkbox"
                        value={acc.id}
                        data-platform={acc.platform}
                      />
                      <div class="account-info">
                        <span class="account-name">{acc.accountName}</span>
                        {acc.accountHandle && (
                          <span class="account-handle">@{acc.accountHandle}</span>
                        )}
                      </div>
                    </label>
                  ))}
                </div>
              </div>
            );
          });
        })()}
      </div>

      <div class="step-actions step-actions--submit">
        <button type="button" class="btn-back" id="back-5">← Back</button>
        <button type="button" class="btn-submit" id="submit-btn">
          Generate Copy →
        </button>
      </div>

      <div id="submit-status" class="submit-status" style="display:none"></div>
    </section>

  </main>
</div>

<script define:vars={{ templatesData: templates, accountsData: accounts }}>
  // ── State ────────────────────────────────────────────────────────────────
  let currentStep = 1;
  const TOTAL_STEPS = 5;

  const state = {
    sourceType: 'article',
    selectedSource: null,   // { id, title, preview, meta }
    suggestionPrompt: '',
    outputFormat: null,     // 'image' | 'video' | 'text'
    templateId: null,
    videoModel: null,
    selectedAccountIds: [],
    viralEngineEnabled: false,
    viralEngineMode: 'default',
    viralEnginePersonalization: '',
    pcmProfileOverride: '',
    videoFormatSlug: '',
  };

  // ── Step navigation ──────────────────────────────────────────────────────
  function showStep(n) {
    document.querySelectorAll('.wizard-step').forEach((el) => {
      el.style.display = el.dataset.step == n ? 'block' : 'none';
    });

    document.querySelectorAll('.progress-step').forEach((el) => {
      const s = parseInt(el.dataset.step, 10);
      el.classList.toggle('active', s === n);
      el.classList.toggle('done', s < n);
    });

    const fill = document.getElementById('progress-bar-fill');
    if (fill) fill.style.width = ((n - 1) / (TOTAL_STEPS - 1) * 100) + '%';

    currentStep = n;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Source search (debounced) ────────────────────────────────────────────
  let searchTimer = null;

  const sourceTypeEl = document.getElementById('source-type');
  const sourceSearchEl = document.getElementById('source-search');
  const sourceList = document.getElementById('source-list');
  const sourceEmpty = document.getElementById('source-empty');
  const sourceLoading = document.getElementById('source-loading');

  function debounce(fn, ms) {
    return (...args) => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => fn(...args), ms);
    };
  }

  // AbortController for cancelling in-flight source requests (TASK-07)
  let fetchAbortController = null;

  async function fetchSources() {
    // Cancel any pending request
    if (fetchAbortController) fetchAbortController.abort();
    fetchAbortController = new AbortController();
    const { signal } = fetchAbortController;

    const type = sourceTypeEl.value;
    const search = sourceSearchEl.value.trim();

    sourceList.innerHTML = '';
    sourceEmpty.style.display = 'none';
    sourceLoading.style.display = 'flex';

    try {
      const params = new URLSearchParams({ type });
      if (search) params.set('search', search);
      const res = await fetch('/api/social-hub/sources?' + params.toString(), { signal });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();

      sourceLoading.style.display = 'none';

      const items = Array.isArray(data) ? data : (data.items ?? []);
      if (items.length === 0) {
        sourceEmpty.style.display = 'flex';
        sourceEmpty.querySelector('span:last-child').textContent = 'No results found.';
        return;
      }

      items.forEach((item) => {
        const card = document.createElement('div');
        card.className = 'source-card';
        card.dataset.id = item.sourceId ?? item.id;
        card.dataset.title = item.title;
        card.dataset.preview = item.preview || '';
        card.dataset.fullText = item.fullText || '';
        // TASK-05: extract readable badge text from metadata instead of raw JSON
        const meta = item.metadata ?? {};
        const metaBadge = item.meta ?? meta.status ?? meta.category ?? meta.emotionalIntensity ?? meta.type ?? '';
        card.dataset.meta = String(metaBadge);
        card.innerHTML = `
          <div class="source-card-top">
            <span class="source-card-title">${escapeHtml(item.title)}</span>
            ${metaBadge ? `<span class="source-card-badge">${escapeHtml(String(metaBadge))}</span>` : ''}
          </div>
          ${item.preview ? `<p class="source-card-preview">${escapeHtml(item.preview)}</p>` : ''}
        `;
        card.addEventListener('click', () => selectSource(card));
        sourceList.appendChild(card);
      });
    } catch (err) {
      if (err.name === 'AbortError') return; // cancelled — ignore
      sourceLoading.style.display = 'none';
      sourceEmpty.style.display = 'flex';
      sourceEmpty.querySelector('span:last-child').textContent = 'Error loading sources: ' + err.message;
    }
  }

  function selectSource(card) {
    document.querySelectorAll('.source-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');

    state.sourceType = sourceTypeEl.value;
    state.selectedSource = {
      id: parseInt(card.dataset.id, 10),
      title: card.dataset.title,
      preview: card.dataset.preview,
      fullText: card.dataset.fullText,
      meta: card.dataset.meta,    // human-readable tag string
    };

    // Populate step 2 preview
    document.getElementById('preview-badge').textContent = formatSourceType(state.sourceType);
    document.getElementById('preview-meta').textContent  = state.selectedSource.meta || '';
    document.getElementById('preview-title').textContent = state.selectedSource.title;
    
    // Zmiana: Pokaż pełny tekst w kroku 2 zamiast uciętego preview
    const fullContent = state.selectedSource.fullText || state.selectedSource.preview || '(no source content available)';
    document.getElementById('preview-text').textContent  = fullContent;

    setTimeout(() => showStep(2), 150);
  }

  function formatSourceType(type) {
    const map = {
      article: 'Article',
      pain_point: 'Pain Point',
      pain_cluster: 'Pain Cluster',
      content_gap: 'Content Gap',
      kb_entry: 'KB Entry',
      reddit_gap: 'Reddit Gap',
      yt_gap: 'YT Gap',
    };
    return map[type] || type;
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  sourceTypeEl.addEventListener('change', () => {
    sourceList.innerHTML = '';
    sourceEmpty.style.display = 'flex';
    sourceEmpty.querySelector('span:last-child').textContent = 'Choose a source type to load results.';
    fetchSources();
  });

  sourceSearchEl.addEventListener('input', debounce(fetchSources, 300));

  // Initial load
  fetchSources();

  // ── Step 2 buttons ───────────────────────────────────────────────────────
  document.getElementById('back-2').addEventListener('click', () => showStep(1));
  document.getElementById('continue-2').addEventListener('click', () => {
    if (!state.selectedSource) return;
    showStep(3);
  });

  // ── Step 3 buttons ───────────────────────────────────────────────────────
  document.getElementById('back-3').addEventListener('click', () => showStep(2));
  document.getElementById('continue-3').addEventListener('click', () => {
    state.suggestionPrompt = document.getElementById('suggestion-prompt').value.trim();
    showStep(4);
  });

  // ── Step 4: format radio + sub-options ──────────────────────────────────
  const formatRadios = document.querySelectorAll('input[name="output-format"]');
  const imageOptions = document.getElementById('image-options');
  const videoOptions = document.getElementById('video-options');
  const viralEngineEnabledEl = document.getElementById('viral-engine-enabled');
  const viralEngineModeEl = document.getElementById('viral-engine-mode');
  const pcmProfileSelectEl = document.getElementById('pcm-profile-select');
  const viralPersonalizationEl = document.getElementById('viral-engine-personalization');
  const viralPersonalizationGroupEl = document.getElementById('viral-personalization-group');
  const viralVideoFormatGroupEl = document.getElementById('viral-video-format-group');
  const viralVideoFormatSelectEl = document.getElementById('viral-video-format-select');

  function updateFormatOptions() {
    const selected = [...formatRadios].find(r => r.checked)?.value;
    imageOptions.style.display = selected === 'image' ? 'block' : 'none';
    videoOptions.style.display = selected === 'video' ? 'block' : 'none';
    viralVideoFormatGroupEl.style.display = selected === 'video' ? 'block' : 'none';

    // Update card highlight
    document.querySelectorAll('.format-card').forEach(card => {
      const radio = card.querySelector('input[type="radio"]');
      card.classList.toggle('selected', radio?.checked ?? false);
    });
  }

  function updateViralEngineOptions() {
    const enabled = viralEngineEnabledEl?.checked ?? false;
    const mode = viralEngineModeEl?.value ?? 'default';
    const selectedFormat = [...formatRadios].find(r => r.checked)?.value;

    if (viralPersonalizationGroupEl) {
      viralPersonalizationGroupEl.style.opacity = enabled && mode === 'personalized' ? '1' : '0.55';
    }
    if (viralPersonalizationEl) {
      viralPersonalizationEl.disabled = !enabled || mode !== 'personalized';
    }
    if (pcmProfileSelectEl) {
      pcmProfileSelectEl.disabled = !enabled;
    }
    if (viralVideoFormatSelectEl) {
      viralVideoFormatSelectEl.disabled = !enabled || selectedFormat !== 'video';
    }
  }

  formatRadios.forEach(r => r.addEventListener('change', updateFormatOptions));
  viralEngineEnabledEl?.addEventListener('change', () => {
    state.viralEngineEnabled = viralEngineEnabledEl.checked;
    updateViralEngineOptions();
  });
  viralEngineModeEl?.addEventListener('change', () => {
    state.viralEngineMode = viralEngineModeEl.value;
    updateViralEngineOptions();
  });
  pcmProfileSelectEl?.addEventListener('change', () => {
    state.pcmProfileOverride = pcmProfileSelectEl.value;
  });
  viralPersonalizationEl?.addEventListener('input', () => {
    state.viralEnginePersonalization = viralPersonalizationEl.value;
  });
  viralVideoFormatSelectEl?.addEventListener('change', () => {
    state.videoFormatSlug = viralVideoFormatSelectEl.value;
  });

  document.getElementById('back-4').addEventListener('click', () => showStep(3));
  document.getElementById('continue-4').addEventListener('click', () => {
    const selected = [...formatRadios].find(r => r.checked)?.value;
    if (!selected) {
      // Flash an error hint
      document.querySelectorAll('.format-card').forEach(c => c.classList.add('shake'));
      setTimeout(() => document.querySelectorAll('.format-card').forEach(c => c.classList.remove('shake')), 400);
      return;
    }
    state.outputFormat = selected;
    const templateEl = document.getElementById('template-select');
    const videoModelEl = document.getElementById('video-model-select');
    state.templateId = templateEl ? parseInt(templateEl.value, 10) || null : null;
    state.videoModel = videoModelEl ? videoModelEl.value || null : null;
    state.viralEngineEnabled = viralEngineEnabledEl?.checked ?? false;
    state.viralEngineMode = viralEngineModeEl?.value || 'default';
    state.viralEnginePersonalization = viralPersonalizationEl?.value.trim() || '';
    state.pcmProfileOverride = pcmProfileSelectEl?.value || '';
    state.videoFormatSlug = viralVideoFormatSelectEl?.value || '';
    showStep(5);
  });

  // ── Step 5 buttons + submit ──────────────────────────────────────────────
  document.getElementById('back-5').addEventListener('click', () => showStep(4));

  document.getElementById('submit-btn').addEventListener('click', async () => {
    const checkedBoxes = [...document.querySelectorAll('.account-checkbox:checked')];
    const rawValues = checkedBoxes.map(cb => cb.value);

    if (rawValues.length === 0) {
      const statusEl = document.getElementById('submit-status');
      statusEl.style.display = 'block';
      statusEl.className = 'submit-status submit-status--error';
      statusEl.textContent = 'Select at least one account (or "Tryb testowy").';
      return;
    }

    const submitBtn = document.getElementById('submit-btn');
    const statusEl = document.getElementById('submit-status');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Generating…';
    statusEl.style.display = 'none';

    // ── Dry-run detection ───────────────────────────────────────────────────
    const isDryRun = rawValues.includes('__dry_run__');

    let targetAccountIds, targetPlatforms;
    if (isDryRun) {
      targetAccountIds = ['__dry_run__'];
      targetPlatforms  = ['dry_run'];
    } else {
      const numericIds = rawValues.map(v => parseInt(v, 10)).filter(n => !isNaN(n));
      targetAccountIds = numericIds;
      targetPlatforms  = [...new Set(
        numericIds
          .map(id => (accountsData.find(a => a.id === id) || {}).platform)
          .filter(Boolean)
      )];
    }

    const payload = {
      sourceType:      state.sourceType,
      sourceId:        state.selectedSource.id,
      sourceTitle:     state.selectedSource.title,
      sourceSnapshot:  state.selectedSource.preview || null,
      suggestionPrompt: state.suggestionPrompt || null,
      outputFormat:    state.outputFormat,
      templateId:      state.outputFormat === 'image' ? state.templateId : null,
      videoModel:      state.outputFormat === 'video' ? state.videoModel : null,
      targetPlatforms,
      targetAccountIds,
      viralEngineEnabled: state.viralEngineEnabled,
      viralEngineMode: state.viralEngineMode,
      viralEnginePersonalization: state.viralEnginePersonalization,
      pcmProfileOverride: state.pcmProfileOverride,
      videoFormatSlug: state.outputFormat === 'video' ? state.videoFormatSlug : null,
    };

    try {
      const res = await fetch('/api/social-hub/briefs', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || 'HTTP ' + res.status);
      }

      const result = await res.json();
      window.location.href = '/admin/social-hub/' + result.id;
    } catch (err) {
      statusEl.style.display = 'block';
      statusEl.className = 'submit-status submit-status--error';
      statusEl.textContent = 'Error: ' + err.message;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Generate Copy →';
    }
  });

  // Initialize first step
  async function loadViralEngineDefaults() {
    try {
      const res = await fetch('/api/social-hub/settings');
      if (!res.ok) return;
      const data = await res.json();
      const viralEngine = data?.viralEngine ?? {};

      const enabled = Boolean(viralEngine.enabled);
      const mode = viralEngine.mode || 'default';
      const personalization =
        viralEngine.personalizationNotes ||
        viralEngine.personalization ||
        '';
      const pcmProfile = viralEngine.written?.defaultPcmProfile || viralEngine.defaultPcmProfile || '';
      const videoFormat = viralEngine.video?.preferredPrimaryFormat || viralEngine.preferredPrimaryFormat || '';

      if (viralEngineEnabledEl) viralEngineEnabledEl.checked = enabled;
      if (viralEngineModeEl) viralEngineModeEl.value = mode;
      if (viralPersonalizationEl) viralPersonalizationEl.value = personalization;
      if (pcmProfileSelectEl && pcmProfile) pcmProfileSelectEl.value = pcmProfile;
      if (viralVideoFormatSelectEl && videoFormat) viralVideoFormatSelectEl.value = videoFormat;

      state.viralEngineEnabled = enabled;
      state.viralEngineMode = mode;
      state.viralEnginePersonalization = personalization;
      state.pcmProfileOverride = pcmProfile;
      state.videoFormatSlug = videoFormat;
    } catch (_) {
      // leave defaults
    } finally {
      updateViralEngineOptions();
    }
  }

  loadViralEngineDefaults();
  showStep(1);
</script>

