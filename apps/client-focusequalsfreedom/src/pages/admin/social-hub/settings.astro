---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';
---

<Base title="Settings — Social Hub" description="Configure LLM copywriter, video generation, distribution, and brand voice for Social Hub">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/social-hub" class="bc-link">Social Hub</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">Settings</span>
    </nav>
    <div class="header-actions">
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">⚙ Social Hub Settings</h2>
          <p class="section-subtitle">LLM Copywriter · Video Generation · Distribution · Brand Voice — API keys stay in <code>.env</code></p>
        </div>
      </div>

      <form id="settings-form" class="settings-form" novalidate>

        <!-- Section 1 — LLM Copywriter -->
        <div class="settings-card">
          <h3 class="card-title">LLM Copywriter</h3>

          <div class="field-grid">
            <div class="field-row">
              <select name="copywriterModel" id="llm-model" class="field-select">
                <option value="claude-opus-4-6">claude-opus-4-6 (max quality)</option>
                <option value="claude-sonnet-4-6">claude-sonnet-4-6 ★ (recommended)</option>
                <option value="claude-haiku-4-5-20251001">claude-haiku-4-5-20251001 (fast, cheap)</option>
              </select>
            </div>
            <div class="field-row">
              <label class="field-label">Extended Thinking Budget</label>
              <input type="number" name="copywriterThinkingBudget" id="llm-thinking-budget" class="field-input-num" min="1000" max="64000" step="1000" value="10000" />
              <span class="field-unit">tokens</span>
            </div>
            <div class="field-row field-row--textarea">
              <label class="field-label field-label--top">Default Suggestion Prompt</label>
              <textarea name="defaultSuggestionPrompt" id="llm-default-prompt" class="field-textarea" rows="4" placeholder="e.g. Write a compelling LinkedIn post about {topic} for high performers. Focus on actionable insight."></textarea>
            </div>
            <div class="field-row field-row--textarea">
              <label class="field-label field-label--top">Tone Overrides</label>
              <textarea name="toneOverrides" id="llm-tone-overrides" class="field-textarea" rows="3" placeholder="e.g. Always use second person. Avoid corporate jargon. Lead with a bold claim."></textarea>
            </div>
          </div>
        </div>

        <!-- Section 2 — Video Generation -->
        <div class="settings-card">
          <h3 class="card-title">Video Generation</h3>

          <div class="field-grid">
            <div class="field-row field-row--radio-group">
              <label class="field-label">Provider</label>
              <div class="radio-inline-group">
                <label class="radio-card">
                  <input type="radio" name="videoProvider" value="wavespeed" checked />
                  <div class="radio-card-content">
                    <span class="radio-card-label">WaveSpeed <span class="badge badge--star">★ default</span></span>
                    <span class="radio-card-desc">Fast AI video generation via WaveSpeed API.</span>
                  </div>
                </label>
              </div>
            </div>

            <div class="field-row">
              <label class="field-label">Video Model</label>
              <select name="videoModel" id="video-model" class="field-select">
                <option value="wan-2.2-ultra-fast" selected>wan-2.2-ultra-fast ★ (recommended)</option>
                <option value="InfiniteTalk">InfiniteTalk (talking head)</option>
              </select>
            </div>

            <div class="field-row field-row--radio-group">
              <label class="field-label">TTS Provider</label>
              <div class="radio-inline-group">
                <label class="radio-card">
                  <input type="radio" name="ttsProvider" value="elevenlabs" checked />
                  <div class="radio-card-content">
                    <span class="radio-card-label">ElevenLabs <span class="badge badge--star">★ default</span></span>
                    <span class="radio-card-desc">High-quality neural TTS. Requires ELEVENLABS_API_KEY.</span>
                  </div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="ttsProvider" value="kokoro" />
                  <div class="radio-card-content">
                    <span class="radio-card-label">Kokoro</span>
                    <span class="radio-card-desc">Local open-source TTS. No API key required.</span>
                  </div>
                </label>
              </div>
            </div>

            <div class="field-row" id="elevenlabs-voice-row">
              <label class="field-label">ElevenLabs Voice ID</label>
              <input type="text" name="elevenlabsVoiceId" id="elevenlabs-voice-id" class="field-input-text" placeholder="e.g. pNInz6obpgDQGcFmaJgB" />
            </div>

            <div class="field-row">
              <label class="field-label">Avatar Image URL</label>
              <input type="text" name="avatarImageUrl" id="avatar-image-url" class="field-input-text" placeholder="https://example.com/avatar.png" />
            </div>
          </div>
        </div>

        <!-- Section 3 — VIRAL ENGINE -->
        <div class="settings-card settings-card--viral" id="viral-engine-card">
          <div class="card-heading-row">
            <h3 class="card-title">VIRAL ENGINE</h3>
            <label class="toggle-row toggle-row--compact">
              <input type="checkbox" id="viral-engine-enabled" checked />
              <span class="toggle-slider"></span>
              <span class="toggle-label">Enabled</span>
            </label>
          </div>

          <p class="card-note">Strategy layer applied before AI generation. When disabled, SocialHub falls back to the base prompt flow.</p>

          <div class="field-grid">
            <div class="viral-subcard" id="viral-personalization-card">
              <div class="card-heading-row card-heading-row--sub">
                <h4 class="subcard-title">Personalization</h4>
                <label class="toggle-row toggle-row--compact">
                  <input type="checkbox" id="viral-personalization-enabled" checked />
                  <span class="toggle-slider"></span>
                  <span class="toggle-label">Allow personalization</span>
                </label>
              </div>

              <div class="field-grid">
                <div class="field-row">
                  <label class="field-label" for="viral-engine-mode">Mode</label>
                  <select id="viral-engine-mode" class="field-select">
                    <option value="default">Default</option>
                    <option value="personalized" selected>Personalized</option>
                  </select>
                </div>
                <div class="field-row field-row--textarea">
                  <label class="field-label field-label--top" for="viral-personalization-label">Label</label>
                  <input type="text" id="viral-personalization-label" class="field-input-text" placeholder="e.g. Founder-led direct response, calm authority" />
                </div>
                <div class="field-row field-row--textarea">
                  <label class="field-label field-label--top" for="viral-personalization-notes">Personalization Notes</label>
                  <textarea id="viral-personalization-notes" class="field-textarea" rows="4" placeholder="Describe how VIRAL ENGINE should adapt to this brand, audience and channel."></textarea>
                </div>
              </div>
            </div>

            <div class="viral-subcard" id="viral-written-card">
              <div class="card-heading-row card-heading-row--sub">
                <h4 class="subcard-title">Written Content</h4>
                <label class="toggle-row toggle-row--compact">
                  <input type="checkbox" id="viral-written-enabled" checked />
                  <span class="toggle-slider"></span>
                  <span class="toggle-label">Apply to written</span>
                </label>
              </div>

              <div class="field-grid">
                <div class="field-row">
                  <label class="field-label" for="viral-pcm-profile-mode">PCM Mode</label>
                  <select id="viral-pcm-profile-mode" class="field-select">
                    <option value="manual">Manual</option>
                    <option value="auto" selected>Auto</option>
                  </select>
                </div>
                <div class="field-row">
                  <label class="field-label" for="viral-pcm-profile">Default PCM Profile</label>
                  <select id="viral-pcm-profile" class="field-select">
                    <option value="harmonizer">Harmonizer</option>
                    <option value="thinker" selected>Thinker</option>
                    <option value="persister">Persister</option>
                    <option value="rebel">Rebel</option>
                    <option value="promoter">Promoter</option>
                    <option value="imaginer">Imaginer</option>
                  </select>
                </div>
                <div class="field-row">
                  <label class="field-label">Enforce 5 points</label>
                  <label class="toggle-row">
                    <input type="checkbox" id="viral-enforce-five-points" checked />
                    <span class="toggle-slider"></span>
                    <span class="toggle-label">Always include all 5 PCM points</span>
                  </label>
                </div>
                <div class="field-row">
                  <label class="field-label" for="viral-hook-intensity">Hook Intensity</label>
                  <select id="viral-hook-intensity" class="field-select">
                    <option value="low">Low</option>
                    <option value="medium" selected>Medium</option>
                    <option value="high">High</option>
                  </select>
                </div>
                <div class="field-row">
                  <label class="field-label" for="viral-cta-intensity">CTA Intensity</label>
                  <select id="viral-cta-intensity" class="field-select">
                    <option value="soft">Soft</option>
                    <option value="medium" selected>Medium</option>
                    <option value="hard">Hard</option>
                  </select>
                </div>
                <div class="field-row field-row--textarea">
                  <label class="field-label field-label--top" for="viral-written-notes">Written Rules</label>
                  <textarea id="viral-written-notes" class="field-textarea" rows="3" placeholder="Extra written-content constraints, hook patterns, tone rules."></textarea>
                </div>
              </div>
            </div>

            <div class="viral-subcard" id="viral-video-card">
              <div class="card-heading-row card-heading-row--sub">
                <h4 class="subcard-title">Video Content</h4>
                <label class="toggle-row toggle-row--compact">
                  <input type="checkbox" id="viral-video-enabled" checked />
                  <span class="toggle-slider"></span>
                  <span class="toggle-label">Apply to video</span>
                </label>
              </div>

              <div class="field-grid">
                <div class="field-row">
                  <label class="field-label" for="viral-video-format-mode">Format Mode</label>
                  <select id="viral-video-format-mode" class="field-select">
                    <option value="manual">Manual</option>
                    <option value="auto" selected>Auto</option>
                  </select>
                </div>
                <div class="field-row field-row--textarea field-row--checkbox-grid">
                  <label class="field-label field-label--top">Allowed Formats</label>
                  <div class="checkbox-grid" id="viral-video-format-grid">
                    <label class="checkbox-card"><input type="checkbox" value="talking_head_authority" checked /><span>Talking head authority</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="problem_agitation_solution" checked /><span>Problem agitation solution</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="storytime_confession" checked /><span>Storytime confession</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="contrarian_hot_take" checked /><span>Contrarian hot take</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="listicle_fast_cuts" checked /><span>Listicle fast cuts</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="myth_vs_reality" checked /><span>Myth vs reality</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="screen_demo_explainer" checked /><span>Screen demo explainer</span></label>
                    <label class="checkbox-card"><input type="checkbox" value="ugc_testimonial_style" checked /><span>UGC testimonial style</span></label>
                  </div>
                </div>
                <div class="field-row">
                  <label class="field-label" for="viral-video-primary-format">Preferred Primary Format</label>
                  <select id="viral-video-primary-format" class="field-select"></select>
                </div>
                <div class="field-row">
                  <label class="field-label" for="viral-video-pacing">Pacing</label>
                  <select id="viral-video-pacing" class="field-select">
                    <option value="calm">Calm</option>
                    <option value="medium" selected>Medium</option>
                    <option value="fast">Fast</option>
                  </select>
                </div>
                <div class="field-row">
                  <label class="field-label" for="viral-video-density">Visual Density</label>
                  <select id="viral-video-density" class="field-select">
                    <option value="low">Low</option>
                    <option value="medium" selected>Medium</option>
                    <option value="high">High</option>
                  </select>
                </div>
                <div class="field-row field-row--textarea">
                  <label class="field-label field-label--top" for="viral-video-notes">Video Rules</label>
                  <textarea id="viral-video-notes" class="field-textarea" rows="3" placeholder="Extra video format, pacing, scene or hook rules."></textarea>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3 — Distribution -->
        <div class="settings-card">
          <h3 class="card-title">Distribution</h3>
          <p class="card-note">Automated cross-platform publishing via Upload-Post.com. Set <code>UPLOADPOST_API_KEY</code> in <code>.env</code> — not stored here.</p>

          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">Provider</label>
              <span class="field-static">Upload-Post.com</span>
            </div>

            <div class="field-row field-row--textarea">
              <label class="field-label field-label--top">Default Hashtags</label>
              <textarea name="defaultHashtags" id="default-hashtags" class="field-textarea" rows="5" placeholder="#FrinterApp&#10;#DeepWork&#10;#HighPerformance&#10;#FocusSprint&#10;#WholeBeing"></textarea>
              <span class="field-hint">One hashtag per line. Will be joined and appended to posts.</span>
            </div>

            <div class="field-row">
              <label class="field-label">Auto-schedule</label>
              <label class="toggle-row">
                <input type="checkbox" name="autoSchedule" id="auto-schedule" />
                <span class="toggle-slider"></span>
                <span class="toggle-label">Automatically schedule posts after generation</span>
              </label>
            </div>
          </div>
        </div>

        <!-- Section 4 — Brand Voice -->
        <div class="settings-card">
          <h3 class="card-title">Brand Voice</h3>
          <p class="card-note">The LLM copywriter uses your brand voice file as system context. The default route is served from <code>/llms-full.txt</code> so each client can expose tenant-specific brand context.</p>

          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">Brand Voice File</label>
              <input type="text" class="field-input-text field-input-text--readonly" value="/llms-full.txt" readonly />
              <span class="field-hint-inline">Default runtime route: <code>/llms-full.txt</code>. Long-term source of truth should move into site config or DB-backed assets.</span>
            </div>
          </div>
        </div>

        <div class="settings-actions">
          <button type="submit" class="btn-primary" id="save-btn">Save Settings</button>
          <span id="save-status" class="save-status"></span>
        </div>
      </form>
    </section>
  </main>
</div>
</Base>

<script>
  const form = document.getElementById('settings-form') as HTMLFormElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const saveStatus = document.getElementById('save-status') as HTMLSpanElement;
  const ttsRadios = document.querySelectorAll('input[name="ttsProvider"]') as NodeListOf<HTMLInputElement>;
  const elevenLabsVoiceRow = document.getElementById('elevenlabs-voice-row') as HTMLElement;
  const viralStorageKey = 'social-hub-viral-engine-settings';

  const viralEngineEnabled = document.getElementById('viral-engine-enabled') as HTMLInputElement;
  const viralPersonalizationEnabled = document.getElementById('viral-personalization-enabled') as HTMLInputElement;
  const viralWrittenEnabled = document.getElementById('viral-written-enabled') as HTMLInputElement;
  const viralVideoEnabled = document.getElementById('viral-video-enabled') as HTMLInputElement;
  const viralEngineCard = document.getElementById('viral-engine-card') as HTMLElement;
  const viralPersonalizationCard = document.getElementById('viral-personalization-card') as HTMLElement;
  const viralWrittenCard = document.getElementById('viral-written-card') as HTMLElement;
  const viralVideoCard = document.getElementById('viral-video-card') as HTMLElement;
  const viralEngineMode = document.getElementById('viral-engine-mode') as HTMLSelectElement;
  const viralPersonalizationLabel = document.getElementById('viral-personalization-label') as HTMLInputElement;
  const viralPersonalizationNotes = document.getElementById('viral-personalization-notes') as HTMLTextAreaElement;
  const viralPcmProfileMode = document.getElementById('viral-pcm-profile-mode') as HTMLSelectElement;
  const viralPcmProfile = document.getElementById('viral-pcm-profile') as HTMLSelectElement;
  const viralEnforceFivePoints = document.getElementById('viral-enforce-five-points') as HTMLInputElement;
  const viralHookIntensity = document.getElementById('viral-hook-intensity') as HTMLSelectElement;
  const viralCtaIntensity = document.getElementById('viral-cta-intensity') as HTMLSelectElement;
  const viralWrittenNotes = document.getElementById('viral-written-notes') as HTMLTextAreaElement;
  const viralVideoFormatMode = document.getElementById('viral-video-format-mode') as HTMLSelectElement;
  const viralVideoFormatGrid = document.getElementById('viral-video-format-grid') as HTMLElement;
  const viralVideoPrimaryFormat = document.getElementById('viral-video-primary-format') as HTMLSelectElement;
  const viralVideoPacing = document.getElementById('viral-video-pacing') as HTMLSelectElement;
  const viralVideoDensity = document.getElementById('viral-video-density') as HTMLSelectElement;
  const viralVideoNotes = document.getElementById('viral-video-notes') as HTMLTextAreaElement;

  const allowedVideoFormats = [
    'talking_head_authority',
    'problem_agitation_solution',
    'storytime_confession',
    'contrarian_hot_take',
    'listicle_fast_cuts',
    'myth_vs_reality',
    'screen_demo_explainer',
    'ugc_testimonial_style',
  ];

  type ViralEngineSettings = {
    enabled: boolean;
    mode: 'default' | 'personalized';
    personalizationEnabled: boolean;
    personalizationLabel: string;
    personalizationNotes: string;
    writtenEnabled: boolean;
    pcmProfileMode: 'manual' | 'auto';
    defaultPcmProfile: string;
    enforceFivePoints: boolean;
    hookIntensity: 'low' | 'medium' | 'high';
    ctaIntensity: 'soft' | 'medium' | 'hard';
    writtenNotes: string;
    videoEnabled: boolean;
    formatMode: 'manual' | 'auto';
    allowedFormats: string[];
    preferredPrimaryFormat: string;
    pacing: 'calm' | 'medium' | 'fast';
    visualDensity: 'low' | 'medium' | 'high';
    videoNotes: string;
  };

  const defaultViralEngineSettings: ViralEngineSettings = {
    enabled: true,
    mode: 'personalized',
    personalizationEnabled: true,
    personalizationLabel: '',
    personalizationNotes: '',
    writtenEnabled: true,
    pcmProfileMode: 'auto',
    defaultPcmProfile: 'thinker',
    enforceFivePoints: true,
    hookIntensity: 'medium',
    ctaIntensity: 'medium',
    writtenNotes: '',
    videoEnabled: true,
    formatMode: 'auto',
    allowedFormats: [...allowedVideoFormats],
    preferredPrimaryFormat: 'problem_agitation_solution',
    pacing: 'medium',
    visualDensity: 'medium',
    videoNotes: '',
  };

  let viralEngineSettings: ViralEngineSettings = { ...defaultViralEngineSettings };

  function getAllowedVideoFormats(): string[] {
    return [...viralVideoFormatGrid.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked')].map((input) => input.value);
  }

  function setAllowedVideoFormats(formats: string[]) {
    viralVideoFormatGrid.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((input) => {
      input.checked = formats.includes(input.value);
    });
  }

  function buildPrimaryFormatOptions(selected?: string) {
    const activeFormats = getAllowedVideoFormats();
    const formats = activeFormats.length > 0 ? activeFormats : [...allowedVideoFormats];
    viralVideoPrimaryFormat.innerHTML = '';
    formats.forEach((format) => {
      viralVideoPrimaryFormat.add(new Option(format.replace(/_/g, ' '), format));
    });
    const preferred = selected ?? defaultViralEngineSettings.preferredPrimaryFormat;
    if ([...viralVideoPrimaryFormat.options].some((o) => o.value === preferred)) {
      viralVideoPrimaryFormat.value = preferred;
    } else if (formats.length > 0) {
      viralVideoPrimaryFormat.value = formats[0];
    }
  }

  function syncViralStateFromUI(): ViralEngineSettings {
    return {
      enabled: viralEngineEnabled.checked,
      mode: (viralEngineMode.value as ViralEngineSettings['mode']) || 'default',
      personalizationEnabled: viralPersonalizationEnabled.checked,
      personalizationLabel: viralPersonalizationLabel.value.trim(),
      personalizationNotes: viralPersonalizationNotes.value.trim(),
      writtenEnabled: viralWrittenEnabled.checked,
      pcmProfileMode: (viralPcmProfileMode.value as ViralEngineSettings['pcmProfileMode']) || 'manual',
      defaultPcmProfile: viralPcmProfile.value,
      enforceFivePoints: viralEnforceFivePoints.checked,
      hookIntensity: (viralHookIntensity.value as ViralEngineSettings['hookIntensity']) || 'medium',
      ctaIntensity: (viralCtaIntensity.value as ViralEngineSettings['ctaIntensity']) || 'medium',
      writtenNotes: viralWrittenNotes.value.trim(),
      videoEnabled: viralVideoEnabled.checked,
      formatMode: (viralVideoFormatMode.value as ViralEngineSettings['formatMode']) || 'manual',
      allowedFormats: getAllowedVideoFormats(),
      preferredPrimaryFormat: viralVideoPrimaryFormat.value,
      pacing: (viralVideoPacing.value as ViralEngineSettings['pacing']) || 'medium',
      visualDensity: (viralVideoDensity.value as ViralEngineSettings['visualDensity']) || 'medium',
      videoNotes: viralVideoNotes.value.trim(),
    };
  }

  function applyViralStateToUI(settings: Partial<ViralEngineSettings>) {
    viralEngineEnabled.checked = settings.enabled ?? defaultViralEngineSettings.enabled;
    viralEngineMode.value = settings.mode ?? defaultViralEngineSettings.mode;
    viralPersonalizationEnabled.checked = settings.personalizationEnabled ?? defaultViralEngineSettings.personalizationEnabled;
    viralPersonalizationLabel.value = settings.personalizationLabel ?? defaultViralEngineSettings.personalizationLabel;
    viralPersonalizationNotes.value = settings.personalizationNotes ?? defaultViralEngineSettings.personalizationNotes;
    viralWrittenEnabled.checked = settings.writtenEnabled ?? defaultViralEngineSettings.writtenEnabled;
    viralPcmProfileMode.value = settings.pcmProfileMode ?? defaultViralEngineSettings.pcmProfileMode;
    viralPcmProfile.value = settings.defaultPcmProfile ?? defaultViralEngineSettings.defaultPcmProfile;
    viralEnforceFivePoints.checked = settings.enforceFivePoints ?? defaultViralEngineSettings.enforceFivePoints;
    viralHookIntensity.value = settings.hookIntensity ?? defaultViralEngineSettings.hookIntensity;
    viralCtaIntensity.value = settings.ctaIntensity ?? defaultViralEngineSettings.ctaIntensity;
    viralWrittenNotes.value = settings.writtenNotes ?? defaultViralEngineSettings.writtenNotes;
    viralVideoEnabled.checked = settings.videoEnabled ?? defaultViralEngineSettings.videoEnabled;
    viralVideoFormatMode.value = settings.formatMode ?? defaultViralEngineSettings.formatMode;
    setAllowedVideoFormats(settings.allowedFormats?.length ? settings.allowedFormats : defaultViralEngineSettings.allowedFormats);
    buildPrimaryFormatOptions(settings.preferredPrimaryFormat ?? defaultViralEngineSettings.preferredPrimaryFormat);
    viralVideoPacing.value = settings.pacing ?? defaultViralEngineSettings.pacing;
    viralVideoDensity.value = settings.visualDensity ?? defaultViralEngineSettings.visualDensity;
    viralVideoNotes.value = settings.videoNotes ?? defaultViralEngineSettings.videoNotes;
  }

  function loadViralSettingsFromStorage(): ViralEngineSettings | null {
    try {
      const raw = localStorage.getItem(viralStorageKey);
      if (!raw) return null;
      return { ...defaultViralEngineSettings, ...JSON.parse(raw) };
    } catch {
      return null;
    }
  }

  function persistViralSettings() {
    viralEngineSettings = syncViralStateFromUI();
    localStorage.setItem(viralStorageKey, JSON.stringify(viralEngineSettings));
  }

  function updateViralVisibility() {
    const engineOn = viralEngineEnabled.checked;
    const personalizationOn = engineOn && viralPersonalizationEnabled.checked;
    const writtenOn = engineOn && viralWrittenEnabled.checked;
    const videoOn = engineOn && viralVideoEnabled.checked;

    viralEngineCard.classList.toggle('is-disabled', !engineOn);
    viralPersonalizationCard.classList.toggle('is-disabled', !personalizationOn);
    viralWrittenCard.classList.toggle('is-disabled', !writtenOn);
    viralVideoCard.classList.toggle('is-disabled', !videoOn);

    viralEngineMode.disabled = !engineOn;
    viralPersonalizationEnabled.disabled = !engineOn;
    viralPersonalizationLabel.disabled = !personalizationOn;
    viralPersonalizationNotes.disabled = !personalizationOn;

    viralWrittenEnabled.disabled = !engineOn;
    viralPcmProfileMode.disabled = !writtenOn;
    viralPcmProfile.disabled = !writtenOn;
    viralEnforceFivePoints.disabled = !writtenOn;
    viralHookIntensity.disabled = !writtenOn;
    viralCtaIntensity.disabled = !writtenOn;
    viralWrittenNotes.disabled = !writtenOn;

    viralVideoEnabled.disabled = !engineOn;
    viralVideoFormatMode.disabled = !videoOn;
    viralVideoFormatGrid.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((input) => {
      input.disabled = !videoOn;
    });
    viralVideoPrimaryFormat.disabled = !videoOn;
    viralVideoPacing.disabled = !videoOn;
    viralVideoDensity.disabled = !videoOn;
    viralVideoNotes.disabled = !videoOn;

    buildPrimaryFormatOptions(viralVideoPrimaryFormat.value);
  }

  function updateTtsVisibility() {
    const ttsVal = [...ttsRadios].find((r) => r.checked)?.value;
    elevenLabsVoiceRow.style.opacity = ttsVal === 'elevenlabs' ? '1' : '0.4';
    (elevenLabsVoiceRow.querySelector('input') as HTMLInputElement).disabled = ttsVal !== 'elevenlabs';
  }

  ttsRadios.forEach((r) => r.addEventListener('change', updateTtsVisibility));
  viralEngineEnabled.addEventListener('change', () => { updateViralVisibility(); persistViralSettings(); });
  viralPersonalizationEnabled.addEventListener('change', () => { updateViralVisibility(); persistViralSettings(); });
  viralWrittenEnabled.addEventListener('change', () => { updateViralVisibility(); persistViralSettings(); });
  viralVideoEnabled.addEventListener('change', () => { updateViralVisibility(); persistViralSettings(); });
  viralEngineMode.addEventListener('change', persistViralSettings);
  viralPersonalizationLabel.addEventListener('input', persistViralSettings);
  viralPersonalizationNotes.addEventListener('input', persistViralSettings);
  viralPcmProfileMode.addEventListener('change', persistViralSettings);
  viralPcmProfile.addEventListener('change', persistViralSettings);
  viralEnforceFivePoints.addEventListener('change', persistViralSettings);
  viralHookIntensity.addEventListener('change', persistViralSettings);
  viralCtaIntensity.addEventListener('change', persistViralSettings);
  viralWrittenNotes.addEventListener('input', persistViralSettings);
  viralVideoFormatMode.addEventListener('change', persistViralSettings);
  viralVideoPacing.addEventListener('change', persistViralSettings);
  viralVideoDensity.addEventListener('change', persistViralSettings);
  viralVideoNotes.addEventListener('input', persistViralSettings);
  viralVideoPrimaryFormat.addEventListener('change', persistViralSettings);
  viralVideoFormatGrid.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((input) => {
    input.addEventListener('change', () => {
      buildPrimaryFormatOptions(viralVideoPrimaryFormat.value);
      persistViralSettings();
    });
  });

  // Load settings on page load
  async function loadSettings() {
    try {
      const res = await fetch('/api/social-hub/settings');
      if (!res.ok) return;
      const data = await res.json();

      const fd = (name: string, value: any) => {
        const el = form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
        if (!el) return;
        if (el instanceof HTMLInputElement && el.type === 'checkbox') {
          el.checked = Boolean(value);
        } else if (el instanceof HTMLInputElement && el.type === 'radio') {
          // handled separately
        } else {
          el.value = value ?? '';
        }
      };

      if (data.copywriterModel) {
        const select = form.elements.namedItem('copywriterModel') as HTMLSelectElement;
        if (![...select.options].some((o) => o.value === data.copywriterModel)) {
          select.add(new Option(`${data.copywriterModel} (custom)`, data.copywriterModel));
        }
      }
      if (data.videoModel) {
        const select = form.elements.namedItem('videoModel') as HTMLSelectElement;
        if (![...select.options].some((o) => o.value === data.videoModel)) {
          select.add(new Option(`${data.videoModel} (custom)`, data.videoModel));
        }
      }

      fd('copywriterModel', data.copywriterModel);
      fd('copywriterThinkingBudget', data.copywriterThinkingBudget);
      fd('defaultSuggestionPrompt', data.defaultSuggestionPrompt);
      fd('toneOverrides', data.toneOverrides);
      fd('videoModel', data.videoModel);
      fd('elevenlabsVoiceId', data.elevenlabsVoiceId);
      fd('avatarImageUrl', data.avatarImageUrl);
      fd('defaultHashtags', Array.isArray(data.defaultHashtags) ? data.defaultHashtags.join('\n') : (data.defaultHashtags ?? ''));
      fd('autoSchedule', data.autoSchedule);

      const localViral = loadViralSettingsFromStorage();
      applyViralStateToUI((data.viralEngine && typeof data.viralEngine === 'object' ? data.viralEngine : null) ?? localViral ?? defaultViralEngineSettings);

      if (data.videoProvider) {
        const vr = form.querySelector(`input[name="videoProvider"][value="${data.videoProvider}"]`) as HTMLInputElement | null;
        if (vr) vr.checked = true;
      }
      if (data.ttsProvider) {
        const tr = form.querySelector(`input[name="ttsProvider"][value="${data.ttsProvider}"]`) as HTMLInputElement | null;
        if (tr) tr.checked = true;
      }
    } catch (_) {
      // silently ignore — form keeps defaults
      applyViralStateToUI(loadViralSettingsFromStorage() ?? defaultViralEngineSettings);
    } finally {
      updateTtsVisibility();
      updateViralVisibility();
    }
  }

  loadSettings();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…';
    saveStatus.className = 'save-status saving';

    const fd = new FormData(form);

    const hashtagsRaw = String(fd.get('defaultHashtags') ?? '');
    const defaultHashtags = hashtagsRaw
      .split('\n')
      .map((h) => h.trim())
      .filter((h) => h.length > 0);

    const viralEngine = syncViralStateFromUI();
    const payload = {
      copywriterModel: fd.get('copywriterModel'),
      copywriterThinkingBudget: parseInt(String(fd.get('copywriterThinkingBudget') ?? '10000'), 10),
      defaultSuggestionPrompt: fd.get('defaultSuggestionPrompt'),
      toneOverrides: fd.get('toneOverrides'),
      videoProvider: fd.get('videoProvider'),
      videoModel: fd.get('videoModel'),
      ttsProvider: fd.get('ttsProvider'),
      elevenlabsVoiceId: fd.get('elevenlabsVoiceId'),
      avatarImageUrl: fd.get('avatarImageUrl'),
      defaultHashtags,
      autoSchedule: (form.elements.namedItem('autoSchedule') as HTMLInputElement)?.checked ?? false,
      viralEngine,
    };

    try {
      localStorage.setItem(viralStorageKey, JSON.stringify(viralEngine));
      const res = await fetch('/api/social-hub/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        saveStatus.textContent = '✓ Saved';
        saveStatus.className = 'save-status ok';
      } else {
        const err = await res.json().catch(() => ({}));
        saveStatus.textContent = `Error: ${(err as any).error || res.status}`;
        saveStatus.className = 'save-status error';
      }
    } catch (err: any) {
      saveStatus.textContent = `Error: ${err.message}`;
      saveStatus.className = 'save-status error';
    } finally {
      saveBtn.disabled = false;
      setTimeout(() => { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }, 4000);
    }
  });
</script>

<style>
