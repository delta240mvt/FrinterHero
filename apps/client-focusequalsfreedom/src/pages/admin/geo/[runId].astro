---
import Base from '@/components/layouts/Base.astro';

const { runId } = Astro.params;

let run: any = null;
let queries: any[] = [];
let drafts: any[] = [];

async function apiFetch(path: string) {
  const response = await fetch(new URL(path, Astro.request.url).toString(), {
    headers: { cookie: Astro.request.headers.get('cookie') || '' },
  });
  if (!response.ok) throw new Error(`${path} -> ${response.status}`);
  return response.json();
}

try {
  const data = await apiFetch(`/api/admin/geo/runs/${runId}`);
  run = data.run ?? null;
  queries = data.queries ?? [];
  drafts = data.drafts ?? [];
} catch (e) {
  console.error('[GEO Details]', e);
}

if (!run) return Astro.redirect('/admin');

const showGapsOnly = Astro.url.searchParams.get('gaps') === 'true';
const displayedQueries = showGapsOnly ? queries.filter(q => q.gapDetected) : queries;
---

<Base title={`GEO Run ${runId} — Admin`}>
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">GEO Run Details — {new Date(run.runAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</h1>
      <a href="/api/logout" class="logout-btn">Logout</a>
    </header>

    <main class="admin-main">
      <div class="run-stats">
        <div class="run-stat"><span class="stat-val">{run.queriesCount}</span><span class="stat-lbl">Queries Run</span></div>
        <div class="run-stat"><span class="stat-val" style="color:var(--gold)">{run.gapsFound}</span><span class="stat-lbl">Gaps Found</span></div>
        <div class="run-stat"><span class="stat-val" style="color:var(--teal)">{run.draftsGenerated}</span><span class="stat-lbl">Drafts Generated</span></div>
      </div>

      <section class="admin-section">
        <div class="section-header">
          <h2 class="admin-section-title">Queries ({displayedQueries.length})</h2>
          <a href={`?gaps=${showGapsOnly ? 'false' : 'true'}`} class="toggle-btn">
            {showGapsOnly ? 'Show All' : 'Show Gaps Only'}
          </a>
        </div>

        <div class="table-wrapper">
          <table class="articles-table">
            <thead>
              <tr>
                <th>Query</th>
                <th>Model</th>
                <th>Mention?</th>
                <th>Gap?</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              {displayedQueries.map(q => (
                <tr>
                  <td class="query-cell">{q.query}</td>
                  <td><span class="model-badge">{q.model}</span></td>
                  <td><span class={q.hasMention ? 'badge-yes' : 'badge-no'}>{q.hasMention ? '✓' : '✗'}</span></td>
                  <td><span class={q.gapDetected ? 'badge-gap' : 'badge-ok'}>{q.gapDetected ? '⚠ Gap' : '✓ OK'}</span></td>
                  <td class="date-cell">{new Date(q.createdAt).toLocaleTimeString('en-US')}</td>
                </tr>
              ))}
              {displayedQueries.length === 0 && (
                <tr><td colspan="5" class="empty-row">No queries found for this run.</td></tr>
              )}
            </tbody>
          </table>
        </div>
      </section>

      {drafts.length > 0 && (
        <section class="admin-section">
          <h2 class="admin-section-title">Generated Drafts ({drafts.length})</h2>
          <div class="drafts-grid">
            {drafts.map(draft => (
              <div class="draft-card">
                <h3 class="draft-title">{draft.title}</h3>
                <p class="draft-desc">{draft.description}</p>
                <div class="draft-tags">
                  {(draft.tags || []).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
                <a href={`/admin/article/${draft.id}`} class="action-btn action-btn--edit">Edit & Publish →</a>
              </div>
            ))}
          </div>
        </section>
      )}
    </main>
  </div>
</Base>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); flex: 1; }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .admin-main { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
  .run-stats { display: flex; gap: 2rem; margin-bottom: 2rem; padding: 1.25rem 1.5rem; background: var(--bg-surface); border: 1px solid var(--border); border-radius: 0.5rem; }
  .run-stat { display: flex; flex-direction: column; align-items: center; }
  .stat-val { font-family: var(--font-mono); font-size: 1.75rem; font-weight: 700; color: var(--text-primary); }
  .stat-lbl { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .admin-section { margin-bottom: 2.5rem; }
  .section-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .admin-section-title { font-family: var(--font-mono); font-size: var(--text-base); color: var(--teal); }
  .toggle-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); text-decoration: none; padding: 0.3rem 0.6rem; border: 1px solid var(--border); border-radius: 0.25rem; transition: all 0.15s; }
  .toggle-btn:hover { border-color: var(--teal); color: var(--teal); }
  .table-wrapper { overflow-x: auto; border: 1px solid var(--border); border-radius: 0.5rem; }
  .articles-table { width: 100%; border-collapse: collapse; }
  .articles-table th { padding: 0.7rem 1rem; background: var(--bg-elevated); text-align: left; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); }
  .articles-table td { padding: 0.6rem 1rem; border-bottom: 1px solid var(--border); font-size: var(--text-sm); }
  .articles-table tr:last-child td { border-bottom: none; }
  .query-cell { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-secondary); }
  .model-badge { font-family: var(--font-mono); font-size: var(--text-xs); padding: 0.15rem 0.5rem; background: var(--bg-elevated); border-radius: 9999px; color: var(--text-muted); }
  .badge-yes { color: var(--teal); font-family: var(--font-mono); font-size: var(--text-sm); }
  .badge-no { color: var(--text-muted); font-family: var(--font-mono); font-size: var(--text-sm); }
  .badge-gap { color: var(--gold); font-family: var(--font-mono); font-size: var(--text-xs); }
  .badge-ok { color: var(--teal); font-family: var(--font-mono); font-size: var(--text-xs); }
  .date-cell { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); white-space: nowrap; }
  .empty-row { text-align: center; color: var(--text-muted); font-family: var(--font-mono); padding: 2rem; }
  .drafts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .draft-card { padding: 1.25rem; background: var(--bg-surface); border: 1px solid rgba(214,183,121,0.2); border-radius: 0.5rem; }
  .draft-title { font-family: var(--font-heading); font-size: var(--text-base); font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
  .draft-desc { color: var(--text-secondary); font-size: var(--text-sm); margin-bottom: 0.75rem; }
  .draft-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1rem; }
  .tag { font-size: var(--text-xs); padding: 0.15rem 0.5rem; border-radius: 9999px; background: var(--violet-glow); color: var(--violet); }
  .action-btn { font-family: var(--font-mono); font-size: var(--text-xs); padding: 0.35rem 0.7rem; border: 1px solid var(--border); border-radius: 0.25rem; text-decoration: none; color: var(--text-secondary); transition: all 0.15s; display: inline-block; }
  .action-btn--edit:hover { border-color: var(--teal); color: var(--teal); }
</style>
