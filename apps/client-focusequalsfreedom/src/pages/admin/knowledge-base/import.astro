---
import Base from '@/components/layouts/Base.astro';
---

<Base title="Import KB Entries — Admin">
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">Import Knowledge Entries</h1>
      <div style="margin-left:auto">
        <a href="/admin/knowledge-base" class="logout-btn">← Back to KB</a>
      </div>
    </header>
    <main class="page-main">
      <div class="info-box">
        <p class="info-text">Import multiple knowledge entries from Markdown files with YAML frontmatter.</p>
        <pre class="code-example">---
type: external_research
title: "Your Entry Title"
tags: [deep-work, ai, productivity]
importance_score: 75
source_url: https://example.com/source
---

Content here (minimum 50 characters)...</pre>
      </div>
      
      <div class="folder-selection">
        <label for="folder-input" class="folder-label">Assign to Project / Folder (Optional):</label>
        <input type="text" id="folder-input" class="filter-input folder-input" placeholder="e.g. Frinter, Personal Brand, Demos" />
        <p class="drop-hint">If left empty, the system will use the `projectName` from frontmatter or none at all.</p>
      </div>

      <label class="drop-zone" id="drop-zone">
        <input type="file" id="file-input" accept=".md" multiple style="display:none" />
        <div class="drop-icon">📄</div>
        <p class="drop-text">Drop .md files here or click to select</p>
        <p class="drop-hint">Accepts multiple .md files</p>
      </label>

      <div id="preview-section" style="display:none" class="preview-section">
        <h2 class="section-title">Preview (<span id="preview-count">0</span> files)</h2>
        <div id="preview-list" class="preview-list"></div>
        <div class="import-actions">
          <button id="import-btn" class="btn-save">Import All</button>
          <button id="clear-btn" class="btn-cancel-btn">Clear</button>
        </div>
      </div>

      <div id="result-section" style="display:none" class="result-section">
        <h2 class="section-title">Import Result</h2>
        <div id="result-content"></div>
        <a href="/admin/knowledge-base" class="btn-save" style="margin-top:1rem;display:inline-block">View Knowledge Base</a>
      </div>
    </main>
  </div>
</Base>

<script>
  let selectedFiles: File[] = [];

  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    handleFiles(Array.from((e as DragEvent).dataTransfer?.files || []));
  });
  fileInput.addEventListener('change', () => handleFiles(Array.from(fileInput.files || [])));

  function parseFrontmatterPreview(content: string) {
    const match = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
    if (!match) return { title: '(no frontmatter)', type: 'unknown', score: '50' };
    const yaml = match[1];
    return {
      title: yaml.match(/title:\s*["']?(.+?)["']?\s*$/m)?.[1] || '(no title)',
      type: yaml.match(/type:\s*(.+?)\s*$/m)?.[1] || 'unknown',
      score: yaml.match(/importance_score:\s*(\d+)/m)?.[1] || '50',
    };
  }

  function handleFiles(files: File[]) {
    selectedFiles = files.filter(f => f.name.endsWith('.md'));
    if (selectedFiles.length === 0) return;

    const previewList = document.getElementById('preview-list')!;
    const previewCount = document.getElementById('preview-count')!;
    const previewSection = document.getElementById('preview-section')!;

    previewCount.textContent = String(selectedFiles.length);
    previewList.innerHTML = '';
    previewSection.style.display = 'block';

    for (const file of selectedFiles) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const { title, type, score } = parseFrontmatterPreview(e.target?.result as string);
        const row = document.createElement('div');
        row.className = 'preview-row';
        row.innerHTML = `<span class="preview-file">${file.name}</span><span class="preview-title">${title}</span><span class="preview-type">${type}</span><span class="preview-score">${score}</span>`;
        previewList.appendChild(row);
      };
      reader.readAsText(file);
    }
  }

  document.getElementById('clear-btn')?.addEventListener('click', () => {
    selectedFiles = [];
    document.getElementById('preview-section')!.style.display = 'none';
    fileInput.value = '';
  });

  document.getElementById('import-btn')?.addEventListener('click', async () => {
    if (selectedFiles.length === 0) return;
    const btn = document.getElementById('import-btn') as HTMLButtonElement;
    btn.textContent = 'Importing...';
    btn.disabled = true;

    const formData = new FormData();
    const folderInput = document.getElementById('folder-input') as HTMLInputElement;
    if (folderInput.value.trim()) {
      formData.append('folderName', folderInput.value.trim());
    }

    for (const file of selectedFiles) formData.append('files', file, file.name);

    const res = await fetch('/api/kb-import', { method: 'POST', body: formData });
    const result = await res.json();

    document.getElementById('preview-section')!.style.display = 'none';
    const resultSection = document.getElementById('result-section')!;
    const resultContent = document.getElementById('result-content')!;
    resultSection.style.display = 'block';

    if (res.ok) {
      resultContent.innerHTML = `
        <div class="result-stats">
          <div class="result-stat"><span class="stat-num">${result.total_files}</span><span class="stat-label">Total</span></div>
          <div class="result-stat success"><span class="stat-num">${result.successful}</span><span class="stat-label">Imported</span></div>
          <div class="result-stat ${result.failed > 0 ? 'error' : ''}"><span class="stat-num">${result.failed}</span><span class="stat-label">Failed</span></div>
        </div>
        ${result.errors?.length > 0 ? `<div class="error-list">${result.errors.map((e: any) => `<div class="error-item"><strong>${e.filename}</strong>: ${e.reason}</div>`).join('')}</div>` : ''}
      `;
    } else {
      resultContent.innerHTML = `<div class="msg-error">${result.error || 'Import failed'}</div>`;
    }
  });
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .page-main { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .info-box { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1.25rem; }
  .info-text { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: 0.75rem; }
  .code-example { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); background: rgba(0,0,0,0.2); padding: 0.875rem; border-radius: 0.375rem; overflow-x: auto; white-space: pre; }
  .folder-selection { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1.25rem; }
  .folder-label { display: block; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-primary); margin-bottom: 0.5rem; }
  .folder-input { width: 100%; max-width: 400px; padding: 0.6rem 0.8rem; border-radius: 0.375rem; border: 1px solid var(--border); background: var(--bg-surface); color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm); margin-bottom: 0.5rem; }
  .drop-zone { display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed var(--border); border-radius: 0.5rem; padding: 3rem; cursor: pointer; transition: border-color 0.15s, background 0.15s; }
  .drop-zone:hover, .drop-zone.drag-over { border-color: var(--teal); background: rgba(74,141,131,0.05); }
  .drop-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .drop-text { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: 0.25rem; }
  .drop-hint { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .section-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .preview-list { border: 1px solid var(--border); border-radius: 0.375rem; overflow: hidden; margin-bottom: 1rem; }
  .preview-row { display: grid; grid-template-columns: 1fr 2fr 1fr 0.5fr; gap: 1rem; padding: 0.625rem 0.875rem; border-bottom: 1px solid rgba(255,255,255,0.04); font-family: var(--font-mono); font-size: var(--text-xs); }
  .preview-row:last-child { border-bottom: none; }
  .preview-file { color: var(--text-muted); }
  .preview-title { color: var(--text-primary); }
  .preview-type { color: var(--teal); }
  .preview-score { color: var(--gold); text-align: right; }
  .import-actions { display: flex; gap: 0.75rem; }
  .btn-save { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; text-decoration: none; display: inline-block; }
  .btn-save:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-cancel-btn { padding: 0.625rem 1.25rem; background: none; border: 1px solid var(--border); color: var(--text-secondary); border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
  .result-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  .result-stat { text-align: center; padding: 1rem; background: var(--bg-elevated); border-radius: 0.375rem; border: 1px solid var(--border); }
  .result-stat.success { border-color: rgba(74,141,131,0.4); }
  .result-stat.error { border-color: rgba(239,68,68,0.4); }
  .stat-num { display: block; font-family: var(--font-mono); font-size: 1.75rem; font-weight: 700; color: var(--text-primary); }
  .stat-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; }
  .error-list { margin-top: 1rem; }
  .error-item { padding: 0.5rem 0.75rem; border-left: 2px solid rgba(239,68,68,0.5); margin-bottom: 0.5rem; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); }
  .msg-error { padding: 0.875rem; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); }
</style>
