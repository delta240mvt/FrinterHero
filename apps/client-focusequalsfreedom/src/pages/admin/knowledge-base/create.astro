---
export const prerender = false;
import Base from '@/components/layouts/Base.astro';
---

<Base title="Create KB Entry — Admin">
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">Create Knowledge Entry</h1>
      <div style="margin-left:auto">
        <a href="/admin/knowledge-base" class="logout-btn">← Back to KB</a>
      </div>
    </header>
    <main class="page-main">
      <div id="message" class="message" style="display:none"></div>
      <form id="create-form" class="entry-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="type">Type</label>
            <select id="type" name="type" class="form-input" required>
              <option value="">Select type...</option>
              <option value="project_spec">Project Spec</option>
              <option value="published_article">Published Article</option>
              <option value="external_research">External Research</option>
              <option value="personal_note">Personal Note</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="importance_score">Importance Score: <span id="score-display">50</span>/100</label>
            <input type="range" id="importance_score" name="importance_score" min="0" max="100" value="50" class="range-input" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="title">Title</label>
          <input type="text" id="title" name="title" class="form-input" placeholder="Knowledge entry title..." required />
        </div>

        <div class="form-group">
          <label class="form-label" for="content">Content (Markdown, min 50 chars)</label>
          <textarea id="content" name="content" class="form-textarea" rows="12" placeholder="Full knowledge content in Markdown..." required></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="source_url">Source URL (optional)</label>
            <input type="url" id="source_url" name="source_url" class="form-input" placeholder="https://..." />
          </div>
          <div class="form-group">
            <label class="form-label" for="tags">Tags (comma-separated, lowercase)</label>
            <input type="text" id="tags" name="tags" class="form-input" placeholder="deep-work, ai-dev, productivity" />
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Create Entry</button>
          <a href="/admin/knowledge-base" class="btn-cancel">Cancel</a>
        </div>
      </form>
    </main>
  </div>
</Base>

<script>
  document.getElementById('importance_score')?.addEventListener('input', (e) => {
    const el = document.getElementById('score-display');
    if (el) el.textContent = (e.target as HTMLInputElement).value;
  });

  document.getElementById('create-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form));
    const msg = document.getElementById('message')!;

    const body = {
      type: data.type,
      title: data.title,
      content: data.content,
      source_url: data.source_url || undefined,
      tags: (data.tags as string).split(',').map(t => t.trim().toLowerCase()).filter(Boolean),
      importance_score: parseInt(data.importance_score as string, 10),
    };

    const res = await fetch('/api/knowledge-base', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) {
      msg.className = 'message msg-success';
      msg.textContent = 'Entry created! Redirecting...';
      msg.style.display = 'block';
      setTimeout(() => { window.location.href = '/admin/knowledge-base'; }, 1200);
    } else {
      const err = await res.json();
      msg.className = 'message msg-error';
      msg.textContent = err.error + (err.fields ? ': ' + Object.entries(err.fields).map(([k,v]) => `${k}: ${v}`).join(', ') : '');
      msg.style.display = 'block';
    }
  });
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .page-main { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
  .message { padding: 0.875rem 1rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); margin-bottom: 1.25rem; }
  .msg-success { background: rgba(74,141,131,0.15); color: var(--teal); border: 1px solid rgba(74,141,131,0.3); }
  .msg-error { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
  .entry-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .form-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; }
  .form-input, .form-textarea { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm); padding: 0.6rem 0.875rem; outline: none; transition: border-color 0.15s; width: 100%; }
  .form-input:focus, .form-textarea:focus { border-color: var(--teal); }
  .form-textarea { resize: vertical; line-height: 1.6; }
  .range-input { width: 100%; accent-color: var(--teal); margin-top: 0.5rem; }
  .form-actions { display: flex; gap: 1rem; padding-top: 0.5rem; }
  .btn-save { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
  .btn-cancel { padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-secondary); text-decoration: none; font-family: var(--font-mono); font-size: var(--text-sm); }
  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
</style>
