---
export interface Props {
  runs: any[];
}
const { runs } = Astro.props;
---
<div class="runs-table-wrapper">
  {runs.length === 0 ? (
    <p class="empty">No GEO runs yet. Run <code>npm run geo:monitor</code> to start.</p>
  ) : (
    <p>{runs.length} run(s) found.</p>
  )}
</div>
<style>
  .empty { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-muted); }
  code { color: var(--gold); }
</style>
