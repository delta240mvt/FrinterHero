{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "target": "ES2020",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/db/*": ["../../src/db/*"],
      "@/lib/*": ["../../src/lib/*"],
      "@/utils/*": ["../../src/utils/*"],
      "@/*": ["./src/*"]
    }
  }
}
