{
  "name": "premium-personal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:legacy",
    "dev:legacy": "astro dev",
    "start": "npm run start:legacy",
    "start:legacy": "drizzle-kit push && HOST=0.0.0.0 node ./dist/server/entry.mjs",
    "build": "npm run build:legacy",
    "build:legacy": "astro build",
    "preview": "npm run preview:legacy",
    "preview:legacy": "astro preview",
    "migrate": "npm run db:push && npm run seed:sites",
    "dev:api": "npm --workspace apps/api run dev",
    "build:api": "npm --workspace apps/api run build",
    "start:api": "npm --workspace apps/api run start",
    "dev:client1": "npm --workspace apps/client-przemyslawfilipiak run dev",
    "build:client1": "npm --workspace apps/client-przemyslawfilipiak run build",
    "start:client1": "npm --workspace apps/client-przemyslawfilipiak run start",
    "preview:client1": "npm --workspace apps/client-przemyslawfilipiak run preview",
    "dev:client2": "npm --workspace apps/client-focusequalsfreedom run dev",
    "build:client2": "npm --workspace apps/client-focusequalsfreedom run build",
    "start:client2": "npm --workspace apps/client-focusequalsfreedom run start",
    "preview:client2": "npm --workspace apps/client-focusequalsfreedom run preview",
    "dev:client3": "npm --workspace apps/client-frinter run dev",
    "build:client3": "npm --workspace apps/client-frinter run build",
    "start:client3": "npm --workspace apps/client-frinter run start",
    "preview:client3": "npm --workspace apps/client-frinter run preview",
    "build:workers": "npm --workspaces --if-present run build",
    "start:worker": "npm --workspace workers/runner run start",
    "start:worker:geo-drafts": "npm --workspace workers/worker-geo-drafts run start",
    "start:worker:reddit": "npm --workspace workers/worker-reddit run start",
    "start:worker:youtube": "npm --workspace workers/worker-youtube run start",
    "start:worker:bc": "npm --workspace workers/worker-bc run start",
    "start:worker:sh-copy": "npm --workspace workers/worker-sh-copy run start",
    "start:worker:sh-video": "npm --workspace workers/worker-sh-video run start",
    "start:migrate": "node scripts/railway/migrate.mjs",
    "smoke:http": "node scripts/railway/smoke-http.mjs",
    "db:push": "drizzle-kit push",
    "geo:monitor": "tsx scripts/geo-monitor.ts",
    "geo:daily": "node --loader tsx ./scripts/geo-monitor.ts",
    "gap:analyze": "node --loader tsx ./scripts/gap-analysis.ts",
    "db:seed": "tsx scripts/seed-articles.ts",
    "seed:sites": "tsx scripts/seed-sites.ts",
    "scrape:reddit": "tsx scripts/scrape-reddit.ts",
    "scrape:reddit:run": "npx tsx scripts/reddit-scraper.ts",
    "reddit:seed": "npx tsx scripts/seed-reddit-targets.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/node": "^8.3.0",
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.0",
    "apify-client": "^2.22.2",
    "astro": "^4.16.0",
    "bcrypt": "^5.1.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "feed": "^4.2.0",
    "marked": "^14.0.0",
    "pg": "^8.13.0",
    "satori": "^0.25.0",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bcrypt": "^5.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "openai": "^4.73.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
