{
  "name": "premium-personal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/client-przemyslawfilipiak run dev",
    "start": "npm --workspace apps/client-przemyslawfilipiak run start",
    "build": "npm --workspace apps/client-przemyslawfilipiak run build",
    "preview": "npm --workspace apps/client-przemyslawfilipiak run preview",
    "setup:hooks": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-git-hooks.ps1",
    "migrate": "npm run db:push && npm run seed:sites && npm run backfill:sh-site-scope",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:api:cf": "npm --workspace apps/api run dev:cf",
    "build:api": "npm --workspace apps/api run build",
    "start:api": "npm --workspace apps/api run start",
    "check:api:cf": "npm --workspace apps/api run check:cf",
    "deploy:api:cf": "npm --workspace apps/api run deploy:cf",
    "test:api:cf": "npm --workspace apps/api run test:cf",
    "dev:web": "npm --workspace apps/client-przemyslawfilipiak run dev",
    "build:web": "npm --workspace apps/client-przemyslawfilipiak run build",
    "start:web": "npm --workspace apps/client-przemyslawfilipiak run start",
    "preview:web": "npm --workspace apps/client-przemyslawfilipiak run preview",
    "build:workers": "npm --workspace workers/runner run build && npm --workspace workers/worker-geo-drafts run build && npm --workspace workers/worker-reddit run build && npm --workspace workers/worker-youtube run build && npm --workspace workers/worker-bc run build && npm --workspace workers/worker-sh-copy run build && npm --workspace workers/worker-sh-video run build",
    "start:worker": "npm run start:worker:general",
    "start:worker:general": "npm --workspace workers/runner run start -- geo,draft,reddit,youtube,sh-publish",
    "start:worker:geo-drafts": "npm --workspace workers/worker-geo-drafts run start",
    "start:worker:reddit": "npm --workspace workers/worker-reddit run start",
    "start:worker:youtube": "npm --workspace workers/worker-youtube run start",
    "start:worker:bc": "npm run start:worker:bc-scrape",
    "start:worker:bc-scrape": "npm --workspace workers/worker-bc run start",
    "start:worker:sh-copy": "npm --workspace workers/worker-sh-copy run start",
    "start:worker:sh-video": "npm --workspace workers/worker-sh-video run start",
    "start:migrate": "node scripts/railway/migrate.mjs",
    "smoke:http": "node scripts/railway/smoke-http.mjs",
    "db:push": "drizzle-kit push",
    "geo:monitor": "tsx scripts/geo-monitor.ts",
    "geo:daily": "node --loader tsx ./scripts/geo-monitor.ts",
    "gap:analyze": "node --loader tsx ./scripts/gap-analysis.ts",
    "db:seed": "tsx scripts/seed-articles.ts",
    "seed:sites": "tsx scripts/seed-sites.ts",
    "backfill:sh-site-scope": "tsx scripts/backfill-sh-site-scope.ts",
    "scrape:reddit": "tsx scripts/scrape-reddit.ts",
    "scrape:reddit:run": "npx tsx scripts/reddit-scraper.ts",
    "reddit:seed": "npx tsx scripts/seed-reddit-targets.ts",
    "discord:setup": "npm --workspace workers/discord-bot run setup",
    "discord:bot": "npm --workspace workers/discord-bot run start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.0",
    "apify-client": "^2.22.2",
    "astro": "^4.16.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.4",
    "feed": "^4.2.0",
    "marked": "^14.0.0",
    "openai": "^5.20.3",
    "pg": "^8.13.0",
    "satori": "^0.25.0",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bcrypt": "^5.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.29.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
