#!/bin/sh
set -eu

if command -v ggshield >/dev/null 2>&1; then
  exec ggshield secret scan pre-commit "$@"
fi

WIN_GGSHIELD="/c/Users/delta/AppData/Roaming/Python/Python310/Scripts/ggshield.exe"
if [ -x "$WIN_GGSHIELD" ]; then
  exec "$WIN_GGSHIELD" secret scan pre-commit "$@"
fi

echo "GitGuardian hook blocked the commit: ggshield is not available." >&2
echo "Install ggshield or add it to PATH before committing." >&2
exit 1
