---
export interface Props {
  title: string;
  description?: string | null;
  date?: Date | null;
  readingTime?: number | null;
  tags?: string[];
  slug: string;
  featured?: boolean;
}

const { title, description, date, readingTime, tags = [], slug, featured = false } = Astro.props;

const formattedDate = date
  ? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(date)
  : null;
---

<article class={`blog-card${featured ? ' blog-card--featured' : ''}`}>
  {featured && <span class="featured-label">★ Featured</span>}
  <a href={`/blog/${slug}`} class="blog-card-link">
    <h3 class="blog-card-title">{title}</h3>
    {description && <p class="blog-card-description">{description}</p>}
    <div class="blog-card-meta">
      {formattedDate && <time datetime={date?.toISOString()}>{formattedDate}</time>}
      {readingTime && <span>{readingTime} min read</span>}
    </div>
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </a>
</article>

<style>
  .blog-card {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--bg-surface);
    transition: border-color 0.15s, box-shadow 0.15s;
    overflow: hidden;
  }
  .blog-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 16px rgba(255,255,255,0.04);
  }
  .blog-card--featured {
    border-color: rgba(214, 183, 121, 0.3);
    background: linear-gradient(to bottom, rgba(214,183,121,0.05), var(--bg-surface));
  }
  .featured-label {
    display: block;
    padding: 0.35rem 1.25rem;
    background: var(--gold-glow);
    color: var(--gold);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    border-bottom: 1px solid rgba(214,183,121,0.2);
  }
  .blog-card-link {
    display: block;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
  }
  .blog-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .blog-card-description {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-meta {
    display: flex;
    gap: 1rem;
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }
  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-size: var(--text-xs);
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    background: var(--violet-glow);
    color: #ffffff;
    border: 1px solid rgba(138,78,100,0.2);
    font-family: var(--font-mono);
  }
</style>
