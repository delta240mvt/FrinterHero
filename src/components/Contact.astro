<section class="contact reveal" id="contact">
  <div class="contact-container">
    <h2 class="section-heading">/contact</h2>
    <p class="contact-text">
      Building something interesting with AI or have a question about deep work systems — reach out.
    </p>
    <div class="contact-links">
      <a href="https://linkedin.com/in/przemyslaw-filipiak" target="_blank" rel="noopener noreferrer" class="contact-btn">
        LinkedIn ↗
      </a>
      <a href="https://github.com/delta240mvt" target="_blank" rel="noopener noreferrer" class="contact-btn">
        GitHub ↗
      </a>
      <a href="mailto:contact@przemyslawfilipiak.com" class="contact-btn">
        Email ↗
      </a>
      <a href="https://twitter.com/przemfilipiak" target="_blank" rel="noopener noreferrer" class="contact-btn">
        Twitter/X ↗
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 5rem 1.5rem;
    background-color: var(--bg-elevated);
  }
  .contact-container {
    max-width: 720px;
    margin: 0 auto;
  }
  .contact-text {
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .contact-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    transition: all 0.15s;
  }
  .contact-btn:hover {
    border-color: var(--teal);
    color: var(--teal);
  }
</style>
