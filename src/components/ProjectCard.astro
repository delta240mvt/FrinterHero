---
export interface Props {
  name: string;
  tagline: string;
  description: string;
  stack: string[];
  links: { label: string; url: string }[];
  featured?: boolean;
}

const { name, tagline, description, stack, links, featured = false } = Astro.props;
---

<article class={`project-card${featured ? ' project-card--featured' : ''}`}>
  {featured && <span class="featured-badge">★ Featured</span>}
  <h3 class="project-name">{name}</h3>
  <p class="project-tagline">{tagline}</p>
  <p class="project-description">{description}</p>
  <div class="project-stack">
    {stack.map(tech => <span class="tech-tag">{tech}</span>)}
  </div>
  <div class="project-links">
    {links.map(link => (
      <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn-ghost project-link">
        {link.label} ↗
      </a>
    ))}
  </div>
</article>

<style>
  .project-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--bg-surface);
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 24px var(--teal-glow);
  }
  .project-card--featured {
    border-color: var(--gold);
    box-shadow: 0 0 16px var(--gold-glow);
  }
  .featured-badge {
    color: var(--gold);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    margin-bottom: 0.5rem;
    display: block;
  }
  .project-name {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .project-tagline {
    color: var(--teal);
    font-size: var(--text-sm);
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }
  .project-description {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .tech-tag {
    font-size: var(--text-xs);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    background: var(--violet-glow);
    color: var(--violet);
    border: 1px solid rgba(138, 78, 100, 0.3);
    font-family: var(--font-mono);
  }
  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .project-link {
    font-size: var(--text-sm);
    padding: 0.4rem 0.9rem;
  }
</style>
