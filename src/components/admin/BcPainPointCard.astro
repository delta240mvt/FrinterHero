---
interface Props {
  pp: {
    id: number;
    painPointTitle: string;
    painPointDescription: string;
    emotionalIntensity: number;
    frequency: number;
    vocabularyQuotes: string[];
    category: string;
    customerLanguage: string | null;
    desiredOutcome: string | null;
    status: string;
    createdAt: Date;
  };
  projectId: number;
}

const { pp, projectId } = Astro.props;

const intensityColor = pp.emotionalIntensity >= 8 ? '#ef4444' : pp.emotionalIntensity >= 5 ? 'var(--gold)' : 'var(--text-muted)';
const categoryColors: Record<string, string> = {
  focus: 'var(--teal)', energy: 'var(--gold)', burnout: '#ef4444',
  relationships: 'var(--violet)', systems: '#60a5fa', tech: '#a78bfa',
  mindset: '#34d399', health: '#f472b6',
};
const categoryColor = categoryColors[pp.category] || 'var(--text-muted)';

const timeAgo = (() => {
  const diff = Date.now() - new Date(pp.createdAt).getTime();
  const h = Math.floor(diff / 3600000);
  if (h < 1) return 'just now';
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
})();
---

<div class="bcpp-card" id={`bcpp-${pp.id}`} data-status={pp.status}>
  <div class="bcpp-header">
    <div class="bcpp-badges">
      <span class="bcpp-intensity" style={`background:${intensityColor}22;color:${intensityColor};border-color:${intensityColor}44`}>
        {pp.emotionalIntensity}/10
      </span>
      <span class="bcpp-category" style={`background:${categoryColor}22;color:${categoryColor}`}>
        {pp.category}
      </span>
      <span class="bcpp-status bcpp-status--{pp.status}">{pp.status}</span>
    </div>
    <h3 class="bcpp-title">{pp.painPointTitle}</h3>
    <div class="bcpp-meta">
      <span>{pp.frequency} mentions</span>
      <span>·</span>
      <span>{timeAgo}</span>
    </div>
  </div>

  <div class="bcpp-actions-row">
    <button class="btn-bcpp-expand" onclick={`bcppToggle(${pp.id})`}>▼ Expand</button>
    {pp.status !== 'approved' && (
      <button class="btn-bcpp-approve" onclick={`bcppSetStatus(${pp.id}, ${projectId}, 'approved')`}>✓ Approve</button>
    )}
    {pp.status !== 'rejected' && (
      <button class="btn-bcpp-reject" onclick={`bcppSetStatus(${pp.id}, ${projectId}, 'rejected')`}>✕ Reject</button>
    )}
    {pp.status !== 'pending' && (
      <button class="btn-bcpp-pending" onclick={`bcppSetStatus(${pp.id}, ${projectId}, 'pending')`}>↺ Reset</button>
    )}
  </div>

  <div class="bcpp-expanded" id={`bcpp-expanded-${pp.id}`} style="display:none">
    <div class="bcpp-section">
      <div class="bcpp-label">Pain Point Description</div>
      <p class="bcpp-desc">{pp.painPointDescription}</p>
    </div>

    {pp.customerLanguage && (
      <div class="bcpp-section">
        <div class="bcpp-label">How They Talk About It</div>
        <p class="bcpp-customer-lang">{pp.customerLanguage}</p>
      </div>
    )}

    {pp.desiredOutcome && (
      <div class="bcpp-section highlight-section">
        <div class="bcpp-label">Desired Outcome</div>
        <p class="bcpp-outcome">{pp.desiredOutcome}</p>
      </div>
    )}

    {pp.vocabularyQuotes.length > 0 && (
      <div class="bcpp-section">
        <div class="bcpp-label">Voice of Customer</div>
        <div class="vocab-chips">
          {pp.vocabularyQuotes.map(q => <span class="vocab-chip">"{q}"</span>)}
        </div>
      </div>
    )}

    <div class="bcpp-exp-actions">
      {pp.status !== 'approved' && (
        <button class="btn-bcpp-approve-full" onclick={`bcppSetStatus(${pp.id}, ${projectId}, 'approved')`}>
          ✓ Approve for LP Generation
        </button>
      )}
      {pp.status !== 'rejected' && pp.status !== 'approved' && (
        <button class="btn-bcpp-reject-full" onclick={`bcppSetStatus(${pp.id}, ${projectId}, 'rejected')`}>✕ Reject</button>
      )}
      <button class="btn-bcpp-close" onclick={`bcppToggle(${pp.id})`}>✕ Close</button>
    </div>
  </div>
</div>

<style>
  .bcpp-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; overflow: hidden; margin-bottom: 0.75rem; }
  .bcpp-card[data-status="approved"] { border-color: rgba(74,141,131,0.3); }
  .bcpp-card[data-status="rejected"] { opacity: 0.55; }
  .bcpp-header { padding: 0.875rem 1.25rem 0.5rem; }
  .bcpp-badges { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .bcpp-intensity { padding: 0.15rem 0.5rem; border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; border: 1px solid; }
  .bcpp-category  { padding: 0.15rem 0.5rem; border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; }
  .bcpp-status    { padding: 0.15rem 0.5rem; border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; background: rgba(148,163,184,0.08); color: var(--text-muted); }
  .bcpp-title { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); margin-bottom: 0.375rem; }
  .bcpp-meta  { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); display: flex; gap: 0.4rem; }
  .bcpp-actions-row { padding: 0.5rem 1.25rem 0.75rem; display: flex; gap: 0.5rem; }
  .btn-bcpp-expand  { padding: 0.3rem 0.75rem; background: none; border: 1px solid var(--border); color: var(--text-secondary); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
  .btn-bcpp-expand:hover  { border-color: var(--teal); color: var(--teal); }
  .btn-bcpp-approve { padding: 0.3rem 0.75rem; background: rgba(74,141,131,0.15); border: 1px solid rgba(74,141,131,0.3); color: var(--teal); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
  .btn-bcpp-reject  { padding: 0.3rem 0.75rem; background: none; border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.7); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; margin-left: auto; }
  .btn-bcpp-pending { padding: 0.3rem 0.75rem; background: none; border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
  .bcpp-expanded { border-top: 1px solid var(--border); }
  .bcpp-section { padding: 0.75rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .bcpp-section.highlight-section { background: rgba(74,141,131,0.04); }
  .bcpp-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.4rem; }
  .bcpp-desc  { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.6; }
  .bcpp-customer-lang { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--gold); line-height: 1.6; font-style: italic; }
  .bcpp-outcome { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--teal); line-height: 1.6; }
  .vocab-chips { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .vocab-chip  { padding: 0.2rem 0.5rem; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.8); border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; font-style: italic; }
  .bcpp-exp-actions { padding: 0.75rem 1.25rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn-bcpp-approve-full { padding: 0.4rem 1rem; background: var(--teal); border: none; color: #fff; border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; font-weight: 600; }
  .btn-bcpp-reject-full  { padding: 0.4rem 0.875rem; background: none; border: 1px solid rgba(239,68,68,0.3); color: rgba(239,68,68,0.8); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
  .btn-bcpp-close { padding: 0.4rem 0.75rem; background: none; border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; margin-left: auto; }
</style>
