---
interface Props {
  gap: {
    id: number;
    gapTitle: string;
    gapDescription: string;
    confidenceScore: number;
    suggestedAngle?: string | null;
    relatedQueries?: string[];
    sourceModels?: string[];
    status: string;
    createdAt: Date;
    knowledge_base_hints?: Array<{ id: number; title: string; importanceScore: number; type: string }>;
  };
}

const { gap } = Astro.props;
const kbHints = gap.knowledge_base_hints || [];
const relatedQueries = gap.relatedQueries || [];
const sourceModels = gap.sourceModels || [];
const truncatedDesc = gap.gapDescription.length > 180 ? gap.gapDescription.slice(0, 180) + '...' : gap.gapDescription;
const confidenceColor = gap.confidenceScore >= 70 ? 'var(--teal)' : gap.confidenceScore >= 40 ? 'var(--gold)' : 'var(--violet)';
const timeAgo = (() => {
  const diff = Date.now() - new Date(gap.createdAt).getTime();
  const h = Math.floor(diff / 3600000);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h/24)}d ago`;
})();
---

<div class="gap-card" id={`gap-${gap.id}`} data-gap-id={gap.id}>
  <div class="card-header">
    <div class="card-title-row">
      <h3 class="gap-title">{gap.gapTitle}</h3>
      <div class="confidence-block">
        <div class="confidence-bar">
          <div class="confidence-fill" style={`width:${gap.confidenceScore}%;background:${confidenceColor}`}></div>
        </div>
        <span class="confidence-label" style={`color:${confidenceColor}`}>{gap.confidenceScore}%</span>
      </div>
    </div>
    <p class="gap-desc">{truncatedDesc}</p>
  </div>

  {gap.suggestedAngle && (
    <div class="card-section">
      <span class="section-label">Suggested Angle</span>
      <p class="suggested-angle">{gap.suggestedAngle.slice(0, 140)}{gap.suggestedAngle.length > 140 ? '...' : ''}</p>
    </div>
  )}

  <div class="card-meta">
    {sourceModels.length > 0 && (
      <div class="meta-row">
        <span class="meta-label">From:</span>
        {sourceModels.map(m => <span class="model-badge">{m.split('/').pop()}</span>)}
      </div>
    )}
    {relatedQueries.length > 0 && (
      <div class="meta-row">
        <span class="meta-label">Queries:</span>
        <span class="query-text">"{relatedQueries[0]}{relatedQueries.length > 1 ? `" +${relatedQueries.length-1} more` : '"'}</span>
      </div>
    )}
    <div class="meta-row">
      <span class="meta-time">{timeAgo}</span>
      <span class={`status-badge status-${gap.status}`}>{gap.status.replace('_',' ')}</span>
    </div>
  </div>

  <div class="card-actions">
    <button class="btn-expand" onclick={`expandGap(${gap.id})`}>Expand</button>
    <button class="btn-approve" onclick={`approveGap(${gap.id})`} disabled={gap.status === 'in_progress'}>
      {gap.status === 'in_progress' ? 'In Progress...' : 'Approve & Generate'}
    </button>
    <button class="btn-archive" onclick={`archiveGap(${gap.id})`}>Archive</button>
  </div>
</div>

<style>
  .gap-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; overflow: hidden; transition: border-color 0.15s; }
  .gap-card:hover { border-color: rgba(74,141,131,0.3); }
  .card-header { padding: 1rem 1.25rem 0.75rem; }
  .card-title-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem; }
  .gap-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-primary); font-weight: 600; flex: 1; line-height: 1.4; }
  .confidence-block { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .confidence-bar { width: 80px; height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; }
  .confidence-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
  .confidence-label { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; width: 2.5rem; text-align: right; }
  .gap-desc { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); line-height: 1.5; }
  .card-section { padding: 0.625rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.04); }
  .section-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; display: block; margin-bottom: 0.25rem; }
  .suggested-angle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); line-height: 1.5; font-style: italic; }
  .card-meta { padding: 0.625rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.04); display: flex; flex-direction: column; gap: 0.3rem; }
  .meta-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .meta-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; }
  .model-badge { padding: 0.1rem 0.35rem; background: rgba(74,141,131,0.15); color: var(--teal); border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; }
  .query-text { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); font-style: italic; }
  .meta-time { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); margin-left: auto; }
  .status-badge { padding: 0.1rem 0.4rem; border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; }
  .status-new { background: rgba(214,183,121,0.15); color: var(--gold); }
  .status-in_progress { background: rgba(74,141,131,0.15); color: var(--teal); }
  .status-acknowledged { background: rgba(138,78,100,0.15); color: var(--violet); }
  .status-archived { background: rgba(255,255,255,0.06); color: var(--text-muted); }
  .card-actions { padding: 0.75rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.04); display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn-expand { padding: 0.4rem 0.875rem; background: none; border: 1px solid var(--border); color: var(--text-secondary); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; transition: all 0.15s; }
  .btn-expand:hover { border-color: var(--teal); color: var(--teal); }
  .btn-approve { padding: 0.4rem 0.875rem; background: var(--teal); border: none; color: #fff; border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; transition: opacity 0.15s; }
  .btn-approve:hover:not(:disabled) { opacity: 0.85; }
  .btn-approve:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-archive { padding: 0.4rem 0.875rem; background: none; border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.7); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; transition: all 0.15s; margin-left: auto; }
  .btn-archive:hover { border-color: rgba(239,68,68,0.5); color: #ef4444; background: rgba(239,68,68,0.06); }
</style>
