---
import Base from '@/components/layouts/Base.astro';
import GapStatsWidget from '@/components/admin/GapStatsWidget.astro';
import GapCard from '@/components/admin/GapCard.astro';
import GapExpandedCard from '@/components/admin/GapExpandedCard.astro';
import { db } from '@/db/client';
import { contentGaps, geoRuns } from '@/db/schema';
import { desc, eq, and, gte, lte, inArray, sql, ilike, or } from 'drizzle-orm';

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'new,in_progress';
const confidenceMin = parseInt(url.searchParams.get('confidence_min') || '0', 10);
const confidenceMax = parseInt(url.searchParams.get('confidence_max') || '100', 10);
const sortBy = url.searchParams.get('sort_by') || 'confidence';

let gaps: any[] = [];
let recentRun: any = null;
let stats = { total_new: 0, total_acknowledged: 0, total_archived: 0 };

try {
  const response = await fetch(new URL('/api/content-gaps', Astro.request.url).toString(), {
    headers: { cookie: Astro.request.headers.get('cookie') || '' },
  });
  if (response.ok) {
    const data = await response.json();
    gaps = data.gaps || [];
    recentRun = data.recent_run;
    stats = data.stats || stats;
  }
} catch {}

// Calculate next run countdown (daily at 7 AM UTC+1 = 6 AM UTC)
const now = new Date();
const nextRun = new Date(now);
nextRun.setUTCHours(6, 0, 0, 0);
if (nextRun <= now) nextRun.setDate(nextRun.getDate() + 1);
const countdownMinutes = Math.max(0, Math.floor((nextRun.getTime() - now.getTime()) / 60000));
---

<Base title="Content Gaps — Admin">
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">Content Gaps</h1>
      <div style="margin-left:auto;display:flex;gap:0.75rem;align-items:center">
        <a href="/admin/knowledge-base" class="btn-ghost-sm">Knowledge Base</a>
        <a href="/api/logout" class="logout-btn">Logout</a>
      </div>
    </header>

    <main class="page-main">
      <div class="layout-grid">
        <div class="sidebar">
          <GapStatsWidget
            lastRunAt={recentRun?.runAt ? new Date(recentRun.runAt) : null}
            totalGapsInRun={recentRun?.gapsFound || 0}
            gapsAcknowledged={stats.total_acknowledged}
            gapsArchived={stats.total_archived}
            nextRunCountdownMinutes={countdownMinutes}
          />

          <div class="filter-panel">
            <h3 class="panel-title">Filters</h3>
            <form method="GET" id="filter-form">
              <div class="filter-group">
                <label class="filter-label">Status</label>
                <select name="status" class="filter-select" onchange="this.form.submit()">
                  <option value="new,in_progress" selected={statusFilter==='new,in_progress'}>Active (New + In Progress)</option>
                  <option value="new" selected={statusFilter==='new'}>New Only</option>
                  <option value="in_progress" selected={statusFilter==='in_progress'}>In Progress</option>
                  <option value="acknowledged" selected={statusFilter==='acknowledged'}>Acknowledged</option>
                  <option value="archived" selected={statusFilter==='archived'}>Archived</option>
                </select>
              </div>
              <div class="filter-group">
                <label class="filter-label">Min Confidence: <span id="conf-min-label">{confidenceMin}</span></label>
                <input type="range" name="confidence_min" min="0" max="100" value={confidenceMin}
                  class="range-input" oninput="document.getElementById('conf-min-label').textContent=this.value" />
              </div>
              <div class="filter-group">
                <label class="filter-label">Sort by</label>
                <select name="sort_by" class="filter-select" onchange="this.form.submit()">
                  <option value="confidence" selected={sortBy==='confidence'}>Confidence (high&rarr;low)</option>
                  <option value="recency" selected={sortBy==='recency'}>Newest First</option>
                </select>
              </div>
              <button type="submit" class="btn-filter">Apply Filters</button>
            </form>
          </div>
        </div>

        <div class="gap-feed">
          <div class="feed-header">
            <h2 class="feed-title">Content Gaps <span class="feed-count">({gaps.length})</span></h2>
            <button class="btn-refresh" id="refresh-btn" onclick="refreshFeed()">&#x21BB; Refresh</button>
          </div>

          <div id="gap-list">
            {gaps.length === 0 ? (
              <div class="empty-state">
                <p class="empty-text">No gaps found with current filters.</p>
                <p class="empty-hint">Run GEO Monitor to detect content gaps, or adjust filters.</p>
                <a href="/admin" class="btn-ghost-sm">&#x2190; Back to Dashboard</a>
              </div>
            ) : (
              gaps.map(gap => (
                <div class="gap-entry" id={`entry-${gap.id}`}>
                  <GapCard gap={gap} />
                  <div id={`expanded-container-${gap.id}`} style="display:none;margin-top:0.5rem">
                    <GapExpandedCard gap={gap} />
                  </div>
                </div>
              ))
            )}
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Modal overlay for draft generation status -->
  <div id="gen-modal" class="modal-overlay" style="display:none">
    <div class="modal-box">
      <div class="modal-spinner"></div>
      <h3 class="modal-title" id="modal-title">Generating draft...</h3>
      <p class="modal-desc" id="modal-desc">This may take up to 60 seconds. Please wait.</p>
      <div id="modal-result" style="display:none">
        <a id="modal-link" href="#" class="btn-modal-cta">Open in Editor</a>
      </div>
    </div>
  </div>
</Base>

<script>
  // Gap interaction functions
  function expandGap(gapId: number) {
    const container = document.getElementById(`expanded-container-${gapId}`);
    if (!container) return;
    container.style.display = container.style.display === 'none' ? 'block' : 'none';
  }

  async function archiveGap(gapId: number) {
    if (!confirm('Archive this gap?')) return;
    const res = await fetch(`/api/content-gaps/${gapId}/archive`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}) });
    if (res.ok) {
      const entry = document.getElementById(`entry-${gapId}`);
      if (entry) { entry.style.opacity = '0.5'; entry.style.pointerEvents = 'none'; }
    }
  }

  async function snoozeGap(gapId: number) {
    const res = await fetch(`/api/content-gaps/${gapId}/acknowledge`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'snooze' }),
    });
    if (res.ok) { const entry = document.getElementById(`entry-${gapId}`); if (entry) entry.style.display = 'none'; }
  }

  function approveGap(gapId: number) {
    const container = document.getElementById(`expanded-container-${gapId}`);
    if (container) container.style.display = 'block';
    document.getElementById(`notes-${gapId}`)?.focus();
  }

  function closeExpanded(gapId: number) {
    const container = document.getElementById(`expanded-container-${gapId}`);
    if (container) container.style.display = 'none';
  }

  async function generateDraft(gapId: number) {
    const notes = (document.getElementById(`notes-${gapId}`) as HTMLTextAreaElement)?.value || '';
    const modelInput = document.querySelector(`input[name="model-${gapId}"]:checked`) as HTMLInputElement;
    const model = modelInput?.value || 'anthropic/claude-sonnet-4-6';
    const btn = document.getElementById(`gen-btn-${gapId}`) as HTMLButtonElement;

    // First acknowledge the gap
    await fetch(`/api/content-gaps/${gapId}/acknowledge`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'generate_draft', author_notes: notes, selected_models: [model] }),
    });

    // Show modal
    const modal = document.getElementById('gen-modal')!;
    modal.style.display = 'flex';
    if (btn) { btn.textContent = 'Generating...'; btn.disabled = true; }

    // Call generate-draft API
    const res = await fetch('/api/generate-draft', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ gap_id: gapId, author_notes: notes, model }),
    });

    const modalResult = document.getElementById('modal-result')!;
    const modalTitle = document.getElementById('modal-title')!;
    const modalDesc = document.getElementById('modal-desc')!;
    const modalLink = document.getElementById('modal-link') as HTMLAnchorElement;

    if (res.ok) {
      const data = await res.json();
      modalTitle.textContent = 'Draft Generated!';
      modalDesc.textContent = `"${data.title}" — ${data.reading_time || '?'} min read`;
      modalLink.href = `/admin/article/${data.article_id}`;
      modalResult.style.display = 'block';
      document.querySelector('.modal-spinner')!.remove();
    } else {
      const err = await res.json();
      modalTitle.textContent = 'Generation Failed';
      modalDesc.textContent = err.error || 'Unknown error. Please try again.';
      if (btn) { btn.textContent = 'Retry'; btn.disabled = false; }
    }

    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.style.display = 'none';
    });
  }

  // Auto-refresh every 30 seconds
  let pollInterval = setInterval(async () => {
    try {
      const url = new URL(window.location.href);
      const res = await fetch(`/api/content-gaps?status=${url.searchParams.get('status')||'new,in_progress'}&limit=20`);
      if (res.ok) {
        // Silently update count badge
        const data = await res.json();
        const countEl = document.querySelector('.feed-count');
        if (countEl) countEl.textContent = `(${data.gaps?.length || 0})`;
      }
    } catch {}
  }, 30000);

  function refreshFeed() { window.location.reload(); }

  // Expose functions to window
  (window as any).expandGap = expandGap;
  (window as any).archiveGap = archiveGap;
  (window as any).snoozeGap = snoozeGap;
  (window as any).approveGap = approveGap;
  (window as any).closeExpanded = closeExpanded;
  (window as any).generateDraft = generateDraft;
  (window as any).refreshFeed = refreshFeed;
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .btn-ghost-sm { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .page-main { max-width: 1300px; margin: 0 auto; padding: 1.5rem; }
  .layout-grid { display: grid; grid-template-columns: 280px 1fr; gap: 1.5rem; align-items: start; }
  .sidebar { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 4rem; }
  .filter-panel { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem; }
  .panel-title { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.875rem; }
  .filter-group { margin-bottom: 0.875rem; }
  .filter-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); display: block; margin-bottom: 0.35rem; }
  .filter-select { width: 100%; background: var(--bg-base); border: 1px solid var(--border); border-radius: 0.25rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-xs); padding: 0.4rem 0.625rem; outline: none; }
  .range-input { width: 100%; accent-color: var(--teal); }
  .btn-filter { width: 100%; padding: 0.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
  .gap-feed { display: flex; flex-direction: column; gap: 0.875rem; }
  .feed-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.25rem; }
  .feed-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; }
  .feed-count { color: var(--text-muted); }
  .btn-refresh { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); background: none; border: 1px solid rgba(74,141,131,0.3); border-radius: 0.25rem; padding: 0.25rem 0.625rem; cursor: pointer; }
  .gap-entry { display: flex; flex-direction: column; }
  .empty-state { text-align: center; padding: 3rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; }
  .empty-text { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: 0.5rem; }
  .empty-hint { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-bottom: 1rem; }
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px); }
  .modal-box { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.75rem; padding: 2rem; max-width: 400px; width: 90%; text-align: center; }
  .modal-spinner { width: 2rem; height: 2rem; border: 3px solid rgba(74,141,131,0.3); border-top-color: var(--teal); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .modal-title { font-family: var(--font-mono); font-size: var(--text-base); color: var(--text-primary); margin-bottom: 0.5rem; }
  .modal-desc { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: 1.25rem; }
  .btn-modal-cta { display: inline-block; padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); text-decoration: none; }
  @media (max-width: 900px) { .layout-grid { grid-template-columns: 1fr; } .sidebar { position: static; } }
</style>
