---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { articles, contentGaps, articleGenerations, knowledgeEntries } from '@/db/schema';
import { eq } from 'drizzle-orm';

const { id } = Astro.params;
const articleId = parseInt(id || '0');

let article: any = null;
let sourceGap: any = null;
let generation: any = null;
let kbHints: any[] = [];

try {
  const [result] = await db.select().from(articles).where(eq(articles.id, articleId)).limit(1);
  article = result;

  if (article?.sourceGapId) {
    const [gap] = await db.select().from(contentGaps).where(eq(contentGaps.id, article.sourceGapId)).limit(1);
    sourceGap = gap;

    const [gen] = await db.select().from(articleGenerations).where(eq(articleGenerations.articleId, articleId)).limit(1);
    generation = gen;

    if (gen?.kbEntriesUsed?.length > 0) {
      kbHints = await db.select({ id: knowledgeEntries.id, title: knowledgeEntries.title, importanceScore: knowledgeEntries.importanceScore })
        .from(knowledgeEntries)
        .where(eq(knowledgeEntries.id, gen.kbEntriesUsed[0]))
        .limit(3);
    }
  }
} catch {}

if (!article) return Astro.redirect('/admin');

const isAIGenerated = !!article.sourceGapId;
---

<Base title={`Edit: ${article.title} — Admin`}>
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">Edit Article</h1>
      <div style="margin-left: auto; display: flex; gap: 0.75rem; align-items: center;">
        <a href={`/blog/${article.slug}`} target="_blank" class="preview-link">Preview ↗</a>
        <a href="/admin/content-gaps" class="preview-link">← Gaps</a>
        <a href="/api/logout" class="logout-btn">Logout</a>
      </div>
    </header>

    <main class="editor-main">
      <!-- Generation metadata banner -->
      {isAIGenerated ? (
        <div class="gen-banner gen-banner-ai">
          <div class="banner-header">
            <span class="banner-icon">🎯</span>
            <span class="banner-title">Generated from Gap</span>
            {article.generatedByModel && <span class="banner-model">{article.generatedByModel.split('/').pop()}</span>}
          </div>
          {sourceGap && (
            <div class="banner-body">
              <div class="banner-row">
                <span class="banner-label">Gap:</span>
                <a href="/admin/content-gaps" class="banner-link">{sourceGap.gapTitle}</a>
                {sourceGap.confidenceScore && <span class="banner-score">({sourceGap.confidenceScore}% confidence)</span>}
              </div>
              {article.generationTimestamp && (
                <div class="banner-row">
                  <span class="banner-label">Generated:</span>
                  <span class="banner-value">{new Date(article.generationTimestamp).toLocaleString('en-GB')}</span>
                </div>
              )}
              {kbHints.length > 0 && (
                <div class="banner-row">
                  <span class="banner-label">KB Sources:</span>
                  <span class="banner-value">{kbHints.map(h => `${h.title} (${h.importanceScore})`).join(' • ')}</span>
                </div>
              )}
            </div>
          )}
        </div>
      ) : (
        <div class="gen-banner gen-banner-manual">
          <span class="banner-icon">✏️</span>
          <span class="banner-title">Author-Created Article</span>
        </div>
      )}

      <form id="article-form" class="article-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="title">Title</label>
            <input type="text" id="title" name="title" class="form-input" value={article.title} required />
          </div>
          <div class="form-group">
            <label class="form-label" for="slug">Slug</label>
            <input type="text" id="slug" name="slug" class="form-input" value={article.slug} />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="description">Description (100-160 chars)</label>
          <input type="text" id="description" name="description" class="form-input" value={article.description || ''} maxlength="160" />
          <span class="char-count" id="desc-count">{(article.description || '').length}/160</span>
        </div>

        <div class="form-group">
          <label class="form-label" for="content">Content (HTML — edit carefully)</label>
          <textarea id="content" name="content" class="form-textarea" rows="24">{article.content}</textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="tags">Tags (comma-separated)</label>
            <input type="text" id="tags" name="tags" class="form-input" value={(article.tags || []).join(', ')} />
          </div>
          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select id="status" name="status" class="form-input">
              <option value="draft" selected={article.status === 'draft'}>Draft</option>
              <option value="ready-for-review" selected={article.status === 'ready-for-review'}>Ready for Review</option>
              <option value="published" selected={article.status === 'published'}>Published</option>
              <option value="archived" selected={article.status === 'archived'}>Archived</option>
            </select>
          </div>
        </div>

        <div class="form-check">
          <input type="checkbox" id="featured" name="featured" class="check-input" checked={article.featured} />
          <label for="featured" class="check-label">Featured article</label>
        </div>

        <div class="editor-actions">
          <button type="submit" class="btn-save">Save Changes</button>
          {article.status !== 'published' && (
            <button type="button" class="btn-publish" id="publish-btn">Publish Article</button>
          )}
          <button type="button" class="btn-delete" id="delete-btn">Delete</button>
          <a href="/admin" class="btn-cancel">← Admin</a>
          <span class="autosave-indicator" id="autosave-status"></span>
        </div>
      </form>

      {generation && (
        <div class="gen-history">
          <h3 class="gen-history-title">Generation History</h3>
          <div class="gen-record">
            <div class="gen-row"><span class="gen-label">Model:</span><span class="gen-value">{generation.generatedByModel}</span></div>
            <div class="gen-row"><span class="gen-label">Generated:</span><span class="gen-value">{new Date(generation.generationTimestamp).toLocaleString('en-GB')}</span></div>
            {generation.publicationTimestamp && <div class="gen-row"><span class="gen-label">Published:</span><span class="gen-value">{new Date(generation.publicationTimestamp).toLocaleString('en-GB')}</span></div>}
            <div class="gen-row"><span class="gen-label">Content Changed:</span><span class="gen-value">{generation.contentChanged ? 'Yes (author edited)' : 'No (original AI draft)'}</span></div>
            <div class="gen-row"><span class="gen-label">KB Entries Used:</span><span class="gen-value">{generation.kbEntriesUsed?.length || 0}</span></div>
          </div>
        </div>
      )}
    </main>
  </div>

  <!-- Publish confirmation modal -->
  <div id="publish-modal" class="modal-overlay" style="display:none">
    <div class="modal-box">
      <h3 class="modal-title">Publish Article?</h3>
      <p class="modal-desc">This will make the article public and update RSS/sitemap. This action cannot be undone easily.</p>
      <div class="modal-preview">
        <strong id="modal-article-title"></strong>
      </div>
      <div class="modal-actions">
        <button id="confirm-publish-btn" class="btn-confirm-pub">Yes, Publish Now</button>
        <button onclick="document.getElementById('publish-modal').style.display='none'" class="btn-modal-cancel">Cancel</button>
      </div>
    </div>
  </div>
</Base>

<script define:vars={{ articleId: article.id, articleTitle: article.title, articleStatus: article.status }}>
  const form = document.getElementById('article-form');
  const statusEl = document.getElementById('autosave-status');
  const descInput = document.getElementById('description');
  const descCount = document.getElementById('desc-count');

  // Char counter for description
  descInput?.addEventListener('input', () => {
    descCount.textContent = `${descInput.value.length}/160`;
  });

  // Save handler
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    data.featured = document.getElementById('featured').checked;
    data.tags = data.tags.split(',').map(t => t.trim()).filter(Boolean);

    const res = await fetch(`/api/articles/${articleId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      statusEl.textContent = 'Saved!';
      statusEl.style.color = 'var(--teal)';
      setTimeout(() => { statusEl.textContent = ''; }, 2000);
    } else {
      alert('Failed to save');
    }
  });

  // Delete handler
  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    if (!confirm('Delete this article? Cannot be undone.')) return;
    const res = await fetch(`/api/articles/${articleId}`, { method: 'DELETE' });
    if (res.ok) window.location.href = '/admin';
    else alert('Failed to delete');
  });

  // Publish modal
  document.getElementById('publish-btn')?.addEventListener('click', () => {
    document.getElementById('modal-article-title').textContent = articleTitle;
    document.getElementById('publish-modal').style.display = 'flex';
  });

  document.getElementById('confirm-publish-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('confirm-publish-btn');
    btn.textContent = 'Publishing...';
    btn.disabled = true;

    const res = await fetch(`/api/articles/${articleId}/publish`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ add_to_kb: true }),
    });

    if (res.ok) {
      const data = await res.json();
      document.getElementById('publish-modal').style.display = 'none';
      statusEl.textContent = 'Published!';
      statusEl.style.color = 'var(--teal)';
      // Update status selector
      document.getElementById('status').value = 'published';
      document.getElementById('publish-btn')?.remove();
    } else {
      const err = await res.json();
      alert(`Failed to publish: ${err.error}`);
      btn.textContent = 'Yes, Publish Now';
      btn.disabled = false;
    }
  });

  // Autosave every 30s (draft only)
  setInterval(async () => {
    const currentStatus = document.getElementById('status').value;
    if (currentStatus !== 'draft') return;
    const data = Object.fromEntries(new FormData(form));
    data.featured = document.getElementById('featured').checked;
    data.tags = (data.tags || '').split(',').map(t => t.trim()).filter(Boolean);

    const res = await fetch(`/api/articles/${articleId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      const now = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
      statusEl.textContent = `Autosaved at ${now}`;
      statusEl.style.color = 'var(--text-muted)';
      setTimeout(() => { statusEl.textContent = ''; }, 3000);
    } else {
      statusEl.textContent = 'Save failed, retrying...';
      statusEl.style.color = '#ef4444';
    }
  }, 30000);
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); }
  .preview-link { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid rgba(74,141,131,0.3); border-radius: 0.25rem; }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .editor-main { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
  .gen-banner { border-radius: 0.5rem; padding: 0.875rem 1rem; margin-bottom: 1.5rem; }
  .gen-banner-ai { background: rgba(74,141,131,0.08); border: 1px solid rgba(74,141,131,0.25); }
  .gen-banner-manual { background: rgba(255,255,255,0.03); border: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; }
  .banner-header { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.5rem; }
  .banner-icon { font-size: 1rem; }
  .banner-title { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .banner-model { padding: 0.15rem 0.4rem; background: rgba(74,141,131,0.15); color: var(--teal); border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; }
  .banner-body { display: flex; flex-direction: column; gap: 0.25rem; }
  .banner-row { display: flex; gap: 0.5rem; align-items: baseline; font-family: var(--font-mono); font-size: var(--text-xs); }
  .banner-label { color: var(--text-muted); min-width: 80px; }
  .banner-value { color: var(--text-secondary); }
  .banner-link { color: var(--teal); text-decoration: none; }
  .banner-score { color: var(--gold); }
  .article-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .form-input, .form-textarea { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm); padding: 0.6rem 0.875rem; outline: none; transition: border-color 0.15s; width: 100%; }
  .form-input:focus, .form-textarea:focus { border-color: var(--teal); }
  .form-textarea { resize: vertical; line-height: 1.6; }
  .char-count { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); margin-top: 0.2rem; }
  .form-check { display: flex; align-items: center; gap: 0.5rem; }
  .check-input { width: 1rem; height: 1rem; accent-color: var(--teal); cursor: pointer; }
  .check-label { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); cursor: pointer; }
  .editor-actions { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; padding-top: 0.5rem; }
  .btn-save { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
  .btn-publish { padding: 0.625rem 1.25rem; background: var(--gold); color: #1e293b; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; font-weight: 600; }
  .btn-delete { padding: 0.625rem 1.25rem; background: none; border: 1px solid rgba(239,68,68,0.4); color: #ef4444; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
  .btn-cancel { padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-secondary); text-decoration: none; font-family: var(--font-mono); font-size: var(--text-sm); }
  .autosave-indicator { font-family: var(--font-mono); font-size: var(--text-xs); }
  .gen-history { margin-top: 2rem; padding: 1.25rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; }
  .gen-history-title { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.875rem; }
  .gen-record { display: flex; flex-direction: column; gap: 0.375rem; }
  .gen-row { display: flex; gap: 0.75rem; font-family: var(--font-mono); font-size: var(--text-xs); }
  .gen-label { color: var(--text-muted); min-width: 120px; }
  .gen-value { color: var(--text-secondary); }
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px); }
  .modal-box { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.75rem; padding: 2rem; max-width: 420px; width: 90%; }
  .modal-title { font-family: var(--font-mono); font-size: var(--text-base); color: var(--text-primary); margin-bottom: 0.5rem; }
  .modal-desc { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.5; margin-bottom: 1rem; }
  .modal-preview { padding: 0.75rem; background: rgba(214,183,121,0.08); border: 1px solid rgba(214,183,121,0.2); border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--gold); margin-bottom: 1.25rem; }
  .modal-actions { display: flex; gap: 0.75rem; }
  .btn-confirm-pub { padding: 0.625rem 1.25rem; background: var(--gold); color: #1e293b; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; font-weight: 600; }
  .btn-confirm-pub:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-modal-cancel { padding: 0.625rem 1rem; background: none; border: 1px solid var(--border); color: var(--text-secondary); border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer; }
  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
</style>
