---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { articles, geoRuns, contentGaps, knowledgeEntries, redditExtractedGaps } from '@/db/schema';
import { desc, eq, count, sql, isNotNull } from 'drizzle-orm';

let allArticles: any[] = [];
let recentRuns: any[]  = [];
let stats = { draft: 0, published: 0, archived: 0 };
let gapStats = { new: 0, in_progress: 0, proposals: 0 };
let kbTotal       = 0;
let total         = 0;
let redditPending = 0;

const page         = parseInt(Astro.url.searchParams.get('page') || '1');
const search       = Astro.url.searchParams.get('search') || '';
const statusFilter = Astro.url.searchParams.get('status') || '';
const LIMIT        = 25;

try {
  const { like, and } = await import('drizzle-orm');
  let query = db.select().from(articles).$dynamic();

  const conditions: any[] = [];
  if (statusFilter) conditions.push(eq(articles.status, statusFilter as any));
  if (search)       conditions.push(like(articles.title, `%${search}%`));
  if (conditions.length === 1) query = query.where(conditions[0]);
  else if (conditions.length > 1) query = query.where(and(...conditions));

  const [
    rows,
    draftCount, pubCount, archCount, totalCount,
    gapNew, gapProg, gapProps,
    kbCount,
    runs,
    redditPendingRes,
  ] = await Promise.all([
    query.orderBy(desc(articles.createdAt)).limit(LIMIT).offset((page - 1) * LIMIT),
    db.select({ c: count() }).from(articles).where(eq(articles.status, 'draft')),
    db.select({ c: count() }).from(articles).where(eq(articles.status, 'published')),
    db.select({ c: count() }).from(articles).where(eq(articles.status, 'archived')),
    db.select({ c: count() }).from(articles),
    db.select({ c: count() }).from(contentGaps).where(eq(contentGaps.status, 'new')),
    db.select({ c: count() }).from(contentGaps).where(eq(contentGaps.status, 'in_progress')),
    db.select({ c: count() }).from(contentGaps).where(isNotNull(contentGaps.suggestedAngle)),
    db.select({ c: count() }).from(knowledgeEntries),
    db.select().from(geoRuns).orderBy(desc(geoRuns.runAt)).limit(8),
    db.select({ c: count() }).from(redditExtractedGaps).where(eq(redditExtractedGaps.status, 'pending')),
  ]);

  allArticles  = rows;
  stats        = { draft: draftCount[0].c, published: pubCount[0].c, archived: archCount[0].c };
  total        = totalCount[0].c;
  gapStats     = { new: gapNew[0].c, in_progress: gapProg[0].c, proposals: gapProps[0].c };
  kbTotal      = kbCount[0].c;
  recentRuns   = runs;
  redditPending = redditPendingRes[0].c;
} catch (e) {
  console.error('[Admin]', e);
}

const totalPages = Math.ceil(total / LIMIT);

function pageUrl(p: number) {
  const u = new URL(Astro.url.toString());
  u.searchParams.set('page', String(p));
  return u.pathname + u.search;
}
---

<Base title="Admin Dashboard — Przemysław Filipiak" description="Admin panel">
<div class="admin-layout">

  <!-- HEADER -->
  <header class="admin-header">
    <a href="/" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <span class="bc-current">Admin Dashboard</span>
    </nav>
    <div class="header-actions">
      <a href="/admin/article/new" class="btn-primary">+ New Article</a>
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">

    <!-- ===== STATS BANNER ===== -->
    <section class="stats-banner" aria-label="Stats">
      <div class="stat-card stat-card--published">
        <span class="stat-number">{stats.published}</span>
        <span class="stat-label">Published</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-card stat-card--draft">
        <span class="stat-number">{stats.draft}</span>
        <span class="stat-label">Drafts</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-card stat-card--archived">
        <span class="stat-number">{stats.archived}</span>
        <span class="stat-label">Archived</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-card">
        <span class="stat-number">{total}</span>
        <span class="stat-label">Total Articles</span>
      </div>
    </section>

    <!-- ===== HUB NAVIGATION ===== -->
    <section class="hub-grid" aria-label="Module Navigation">
      <a href="/admin/content-gaps" class="hub-card hub-card--gaps">
        <div class="hub-icon">🔍</div>
        <div class="hub-body">
          <div class="hub-title">Content Gaps</div>
          <div class="hub-meta">
            <span class="hub-badge hub-badge--gold">{gapStats.new} new</span>
            {gapStats.in_progress > 0 && <span class="hub-badge hub-badge--teal">{gapStats.in_progress} in progress</span>}
          </div>
          <div class="hub-desc">AI visibility gaps — generate articles from gaps</div>
        </div>
        <span class="hub-arrow">→</span>
      </a>
      <a href="/admin/content-gaps?has_proposal=true" class="hub-card hub-card--proposals">
        <div class="hub-icon">💡</div>
        <div class="hub-body">
          <div class="hub-title">Proposals</div>
          <div class="hub-meta">
            <span class="hub-badge hub-badge--teal">{gapStats.proposals} ready</span>
          </div>
          <div class="hub-desc">Review and approve AI-generated mini-drafts</div>
        </div>
        <span class="hub-arrow">→</span>
      </a>
      <a href="/admin/knowledge-base" class="hub-card hub-card--kb">
        <div class="hub-icon">🧠</div>
        <div class="hub-body">
          <div class="hub-title">Knowledge Base</div>
          <div class="hub-meta">
            <span class="hub-badge hub-badge--violet">{kbTotal} entries</span>
          </div>
          <div class="hub-desc">Knowledge Base — context for AI article generation</div>
        </div>
        <span class="hub-arrow">→</span>
      </a>
      <a href="/admin/reddit" class="hub-card hub-card--reddit">
        <div class="hub-icon">🎯</div>
        <div class="hub-body">
          <div class="hub-title">Reddit Intelligence</div>
          <div class="hub-meta">
            <span class="hub-badge hub-badge--reddit">{redditPending} pending</span>
          </div>
          <div class="hub-desc">Pain Point Discovery · WebScraping via Apify</div>
        </div>
        <span class="hub-arrow">→</span>
      </a>
      <a href="/admin/youtube" class="hub-card hub-card--youtube">
        <div class="hub-icon">▶</div>
        <div class="hub-body">
          <div class="hub-title">YouTube Intelligence</div>
          <div class="hub-meta">
            <span class="hub-badge hub-badge--youtube">comments</span>
          </div>
          <div class="hub-desc">Pain Point Discovery · YouTube Comments via Apify</div>
        </div>
        <span class="hub-arrow">→</span>
      </a>
      <a href="/admin/brand-clarity" class="hub-card hub-card--bc">
        <div class="hub-icon">🎯</div>
        <div class="hub-body">
          <div class="hub-title">Brand Clarity</div>
          <div class="hub-meta">
            <span class="hub-badge hub-badge--bc">LP Analysis</span>
          </div>
          <div class="hub-desc">LP Analysis · Channel Discovery · Pain Points → LP Variants</div>
        </div>
        <span class="hub-arrow">→</span>
      </a>
    </section>

    <!-- ===== GEO MONITOR ===== -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">🛰 GEO Monitor</h2>
          <p class="section-subtitle">Reverse RAG Loop — AI visibility analysis for Frinter</p>
        </div>
        <button id="run-geo-btn" class="btn-geo">Run GEO Monitor</button>
      </div>

      <!-- GEO streaming panel (hidden by default) -->
      <div id="geo-panel" class="geo-panel" style="display:none">
        <div class="geo-panel-top">
          <span id="geo-status" class="geo-status">Initializing...</span>
          <button id="geo-panel-close" class="geo-close-btn" style="display:none">✕ Close</button>
        </div>
        <div class="geo-progress-row">
          <div class="geo-track">
            <div id="geo-progress-bar" class="geo-bar" style="width:0%"></div>
          </div>
          <span id="geo-progress-text" class="geo-progress-text">0 / 45</span>
        </div>
        <div id="geo-log" class="geo-log"></div>
      </div>
    </section>

    <!-- ===== ARTICLES ===== -->
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">📰 Articles</h2>
        </div>
        <form method="GET" class="filter-row">
          <input type="text" name="search" value={search} placeholder="Search by title…" class="filter-input" />
          <select name="status" class="filter-input">
            <option value="" selected={!statusFilter}>All statuses</option>
            <option value="draft"     selected={statusFilter==='draft'}>Drafts</option>
            <option value="published" selected={statusFilter==='published'}>Published</option>
            <option value="archived"  selected={statusFilter==='archived'}>Archived</option>
          </select>
          <button type="submit" class="btn-filter">Filter</button>
          {(search || statusFilter) && <a href="/admin" class="btn-ghost-sm">Clear</a>}
        </form>
      </div>

      <!-- Bulk toolbar -->
      <div id="bulk-toolbar" class="bulk-toolbar" style="display:none">
        <span id="bulk-count" class="bulk-count">0 selected</span>
        <button id="bulk-delete-btn" class="btn-bulk-delete">Delete selected</button>
        <button id="bulk-cancel-btn" class="btn-bulk-cancel">Cancel</button>
      </div>

      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th class="th-check"><input type="checkbox" id="select-all" class="row-checkbox" /></th>
              <th class="th-title">Title</th>
              <th class="th-slug">Slug</th>
              <th class="th-status">Status</th>
              <th class="th-date">Date</th>
              <th class="th-actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            {allArticles.length === 0 ? (
              <tr>
                <td colspan="6" class="td-empty">
                  {search || statusFilter
                    ? <>No articles for these filters. <a href="/admin">Clear</a></>
                    : <>No articles. <a href="/admin/article/new">Create first</a></>
                  }
                </td>
              </tr>
            ) : allArticles.map(a => (
              <tr class={`article-row article-row--${a.status}`} data-id={a.id}>
                <td class="td-check">
                  <input type="checkbox" class="row-checkbox article-checkbox" data-id={a.id} />
                </td>
                <td class="td-title">
                  <a href={`/admin/article/${a.id}`} class="article-link">{a.title}</a>
                  {a.featured && <span class="featured-badge">⭐</span>}
                </td>
                <td class="td-slug"><code class="slug-code">{a.slug}</code></td>
                <td class="td-status">
                  <span class={`status-badge status-badge--${a.status}`}>{a.status}</span>
                </td>
                <td class="td-date">
                  {new Date(a.createdAt).toLocaleDateString('en-US', { day:'2-digit', month:'2-digit', year:'2-digit' })}
                </td>
                <td class="td-actions">
                  <a href={`/admin/article/${a.id}`} class="action-btn action-btn--edit">✏️ Edit</a>
                  {a.status !== 'published' && (
                    <button class="action-btn action-btn--publish"
                      data-publish-id={a.id} data-publish-title={a.title}>
                      🚀 Publish
                    </button>
                  )}
                  <button class="action-btn action-btn--delete"
                    data-delete-id={a.id} data-delete-title={a.title}>
                    🗑 Delete
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {totalPages > 1 && (
        <nav class="pagination">
          {page > 1 && <a href={pageUrl(page - 1)} class="page-btn">‹ Previous</a>}
          <span class="page-info">Page {page} of {totalPages}</span>
          {page < totalPages && <a href={pageUrl(page + 1)} class="page-btn">Next ›</a>}
        </nav>
      )}
    </section>

    <!-- ===== GEO RUNS ===== -->
    {recentRuns.length > 0 && (
      <section class="admin-section">
        <div class="section-header-row">
          <div class="section-title-block">
            <h2 class="section-title">📊 Recent GEO Runs</h2>
          </div>
        </div>
        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Queries</th>
                <th>Gaps Found</th>
                <th>Proposals Generated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {recentRuns.map(run => (
                <tr>
                  <td class="td-date">
                    {new Date(run.runAt).toLocaleString('en-US', { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' })}
                  </td>
                  <td class="td-num">{run.queriesCount}</td>
                  <td class="td-num">
                    <span style={run.gapsFound > 0 ? 'color:var(--gold);font-weight:600' : ''}>{run.gapsFound}</span>
                  </td>
                  <td class="td-num">
                    <span style={run.draftsGenerated > 0 ? 'color:var(--teal);font-weight:600' : ''}>{run.draftsGenerated}</span>
                  </td>
                  <td class="td-actions">
                    <a href={`/admin/geo/${run.id}`} class="action-btn action-btn--edit">Details</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

  </main>
</div>

<!-- DELETE MODAL -->
<div id="delete-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true">
  <div class="modal-box">
    <h3 class="modal-title">Delete Article</h3>
    <p class="modal-desc">Are you sure you want to delete:</p>
    <p id="delete-modal-name" class="modal-item-name"></p>
    <p class="modal-warn">This action cannot be undone.</p>
    <div class="modal-actions">
      <button id="delete-confirm-btn" class="btn-danger">Delete</button>
      <button id="delete-cancel-btn"  class="btn-ghost-sm">Cancel</button>
    </div>
  </div>
</div>

<!-- PUBLISH MODAL -->
<div id="publish-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true">
  <div class="modal-box">
    <h3 class="modal-title">Publish Article</h3>
    <p class="modal-desc">Publish this article:</p>
    <p id="publish-modal-name" class="modal-item-name"></p>
    <div class="modal-actions">
      <button id="publish-confirm-btn" class="btn-publish">🚀 Publish</button>
      <button id="publish-cancel-btn"  class="btn-ghost-sm">Cancel</button>
    </div>
  </div>
</div>

<script>
  const TOTAL_STEPS = 45;

  // ─── GEO Monitor ───────────────────────────────────────────
  const geoBtn      = document.getElementById('run-geo-btn')       as HTMLButtonElement;
  const geoPanel    = document.getElementById('geo-panel')         as HTMLElement;
  const geoLog      = document.getElementById('geo-log')           as HTMLElement;
  const geoStatus   = document.getElementById('geo-status')        as HTMLElement;
  const geoBar      = document.getElementById('geo-progress-bar')  as HTMLElement;
  const geoBarText  = document.getElementById('geo-progress-text') as HTMLElement;
  const geoClose    = document.getElementById('geo-panel-close')   as HTMLElement;

  geoClose?.addEventListener('click', () => { geoPanel.style.display = 'none'; });

  // ─── log helpers ────────────────────────────────────────────
  function classifyLine(line: string): string {
    if (line.includes('✓ Mention found'))  return 'success';
    if (line.includes('Gap detected'))     return 'gap';
    if (line.includes('Error') || line.includes('Failed') || line.includes('error')) return 'error';
    if (line.includes('Proposal created')) return 'draft';
    if (line.includes('Run complete') || line.includes('Proposals generated')) return 'done';
    return 'info';
  }

  function appendLog(line: string) {
    const el = document.createElement('div');
    el.className  = `geo-log-line geo-log-line--${classifyLine(line)}`;
    el.textContent = line.replace(/^\[GEO\]\s*/, '').replace(/^\[DraftGen\]\s*/, '');
    geoLog.appendChild(el);
    geoLog.scrollTop = geoLog.scrollHeight;
  }

  // ─── UI state helpers ────────────────────────────────────────
  function setRunningUI(queryCount: number = 0) {
    geoPanel.style.display = 'block';
    geoClose.style.display = 'none';
    geoBtn.textContent     = 'Running...';
    geoBtn.disabled        = true;
    geoStatus.className    = 'geo-status geo-status--running';
    geoStatus.textContent  = queryCount > 0
      ? `Querying models… (${queryCount}/${TOTAL_STEPS})`
      : 'Starting…';
    const pct = Math.min(90, Math.round((queryCount / TOTAL_STEPS) * 90));
    geoBar.style.width     = `${pct}%`;
    geoBarText.textContent = `${queryCount} / ${TOTAL_STEPS}`;
  }

  function setDoneUI(code: number | null) {
    geoBar.style.width     = '100%';
    geoBarText.textContent = 'Done';
    geoClose.style.display = 'inline-block';
    geoBtn.textContent     = 'Run GEO Monitor';
    geoBtn.disabled        = false;
    const ok = code === 0;
    geoStatus.className   = `geo-status geo-status--${ok ? 'done' : 'error'}`;
    geoStatus.textContent = ok ? 'Completed successfully' : `Error (code ${code})`;
  }

  // ─── SSE stream (reconnectable) ─────────────────────────────
  let activeReader: ReadableStreamDefaultReader<Uint8Array> | null = null;
  let localQueryCount = 0;

  async function connectStream(fromIndex: number = 0) {
    if (activeReader) {
      try { activeReader.cancel(); } catch {}
      activeReader = null;
    }
    try {
      const res = await fetch(`/api/geo/stream?from=${fromIndex}`);
      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

      const reader  = res.body.getReader();
      activeReader  = reader;
      const decoder = new TextDecoder();
      let buf = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop() ?? '';

        for (const part of parts) {
          const dataLine = part.split('\n').find(l => l.startsWith('data: '));
          if (!dataLine) continue;
          let payload: any;
          try { payload = JSON.parse(dataLine.slice(6)); } catch { continue; }

          if (payload.line) {
            appendLog(payload.line);
            if (payload.line.includes('[GEO] Querying')) {
              localQueryCount++;
              const pct = Math.min(90, Math.round((localQueryCount / TOTAL_STEPS) * 90));
              geoBar.style.width     = `${pct}%`;
              geoBarText.textContent = `${localQueryCount} / ${TOTAL_STEPS}`;
              geoStatus.textContent  = `Querying models… (${localQueryCount}/${TOTAL_STEPS})`;
            } else if (payload.line.includes('Running gap analysis')) {
              geoBar.style.width    = '92%';
              geoStatus.textContent = 'Analyzing gaps…';
            } else if (payload.line.includes('Generating proposals')) {
              geoBar.style.width    = '95%';
              geoStatus.textContent = 'Generating proposals…';
            }
          }

          if (payload.done) {
            setDoneUI(payload.code ?? 0);
            activeReader = null;
            return;
          }
        }
      }
    } catch (e: any) {
      geoStatus.textContent  = `Connection error: ${e.message}`;
      geoStatus.className    = 'geo-status geo-status--error';
      geoClose.style.display = 'inline-block';
      geoBtn.textContent     = 'Run GEO Monitor';
      geoBtn.disabled        = false;
      activeReader           = null;
    }
  }

  // ─── Page init — restore panel after tab switch ──────────────
  (async () => {
    try {
      const res = await fetch('/api/geo/status');
      if (!res.ok) return;
      const data = await res.json();
      if (data.status === 'idle') return;

      geoLog.innerHTML = '';
      localQueryCount  = data.queryCount ?? 0;

      for (const entry of (data.lines as { line: string }[])) {
        appendLog(entry.line);
      }

      if (data.status === 'running') {
        setRunningUI(localQueryCount);
        connectStream(data.lines.length); // skip already-displayed lines
      } else {
        setDoneUI(data.exitCode ?? 0);
      }
    } catch { /* non-critical */ }
  })();

  // ─── Run button ──────────────────────────────────────────────
  geoBtn?.addEventListener('click', async () => {
    if (!confirm('Run GEO Monitor? This will take a few minutes.')) return;

    const startRes = await fetch('/api/geo/start', { method: 'POST' });

    if (startRes.status === 409) {
      // Already running — reconnect to see live stream
      geoLog.innerHTML = '';
      localQueryCount  = 0;
      setRunningUI(0);
      connectStream(0);
      return;
    }
    if (!startRes.ok) {
      alert('Failed to start GEO Monitor');
      return;
    }

    geoLog.innerHTML       = '';
    localQueryCount        = 0;
    geoBar.style.width     = '0%';
    geoBarText.textContent = `0 / ${TOTAL_STEPS}`;
    setRunningUI(0);
    connectStream(0);
  });

  // ─── Delete Modal ──────────────────────────────────────────
  let pendingDeleteId: number | null = null;
  const deleteModal   = document.getElementById('delete-modal')!;
  const deleteConfirm = document.getElementById('delete-confirm-btn')!;
  const deleteCancel  = document.getElementById('delete-cancel-btn')!;
  const deleteNameEl  = document.getElementById('delete-modal-name')!;

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-delete-id]') as HTMLElement | null;
    if (btn) {
      pendingDeleteId      = parseInt(btn.dataset.deleteId || '0');
      deleteNameEl.textContent = `"${btn.dataset.deleteTitle || ''}"`;
      deleteModal.style.display = 'flex';
    }
  });
  deleteCancel.addEventListener('click', () => { deleteModal.style.display = 'none'; pendingDeleteId = null; });
  deleteConfirm.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    deleteConfirm.textContent = 'Deleting…';
    deleteConfirm.setAttribute('disabled', 'true');
    const res = await fetch(`/api/articles/${pendingDeleteId}`, { method: 'DELETE' });
    if (res.ok) window.location.reload();
    else { alert('Failed to delete'); deleteConfirm.textContent = 'Delete'; deleteConfirm.removeAttribute('disabled'); }
  });

  // ─── Publish Modal ─────────────────────────────────────────
  let pendingPublishId: number | null = null;
  const publishModal   = document.getElementById('publish-modal')!;
  const publishConfirm = document.getElementById('publish-confirm-btn')!;
  const publishCancel  = document.getElementById('publish-cancel-btn')!;
  const publishNameEl  = document.getElementById('publish-modal-name')!;

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-publish-id]') as HTMLElement | null;
    if (btn) {
      pendingPublishId      = parseInt(btn.dataset.publishId || '0');
      publishNameEl.textContent = `"${btn.dataset.publishTitle || ''}"`;
      publishModal.style.display = 'flex';
    }
  });
  publishCancel.addEventListener('click', () => { publishModal.style.display = 'none'; pendingPublishId = null; });
  publishConfirm.addEventListener('click', async () => {
    if (!pendingPublishId) return;
    publishConfirm.textContent = 'Publishing…';
    publishConfirm.setAttribute('disabled', 'true');
    const res = await fetch(`/api/articles/${pendingPublishId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: 'published' }),
    });
    if (res.ok) window.location.reload();
    else { alert('Failed to publish'); publishConfirm.textContent = '🚀 Publish'; publishConfirm.removeAttribute('disabled'); }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      deleteModal.style.display  = 'none';
      publishModal.style.display = 'none';
    }
  });

  // ─── Multi-select & bulk delete ───────────────────────────
  const selectAll    = document.getElementById('select-all')    as HTMLInputElement;
  const bulkToolbar  = document.getElementById('bulk-toolbar')  as HTMLElement;
  const bulkCount    = document.getElementById('bulk-count')    as HTMLElement;
  const bulkDeleteBtn= document.getElementById('bulk-delete-btn') as HTMLButtonElement;
  const bulkCancelBtn= document.getElementById('bulk-cancel-btn') as HTMLButtonElement;

  function getChecked(): number[] {
    return [...document.querySelectorAll<HTMLInputElement>('.article-checkbox:checked')]
      .map(cb => parseInt(cb.dataset.id || '0')).filter(Boolean);
  }

  function updateToolbar() {
    const ids = getChecked();
    if (ids.length > 0) {
      bulkToolbar.style.display = 'flex';
      bulkCount.textContent = `${ids.length} selected`;
    } else {
      bulkToolbar.style.display = 'none';
    }
  }

  selectAll?.addEventListener('change', () => {
    document.querySelectorAll<HTMLInputElement>('.article-checkbox').forEach(cb => { cb.checked = selectAll.checked; });
    updateToolbar();
  });

  document.querySelectorAll<HTMLInputElement>('.article-checkbox').forEach(cb => {
    cb.addEventListener('change', () => {
      const all = document.querySelectorAll<HTMLInputElement>('.article-checkbox');
      selectAll.checked       = [...all].every(c => c.checked);
      selectAll.indeterminate = !selectAll.checked && [...all].some(c => c.checked);
      updateToolbar();
    });
  });

  bulkCancelBtn?.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.article-checkbox, #select-all').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
      (cb as HTMLInputElement).indeterminate = false;
    });
    bulkToolbar.style.display = 'none';
  });

  bulkDeleteBtn?.addEventListener('click', async () => {
    const ids = getChecked();
    if (!confirm(`Delete ${ids.length} article(s)? This cannot be undone.`)) return;
    bulkDeleteBtn.disabled    = true;
    bulkDeleteBtn.textContent = 'Deleting…';
    const res = await fetch('/api/articles/bulk-delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids }),
    });
    if (res.ok) window.location.reload();
    else {
      alert('Failed to delete');
      bulkDeleteBtn.disabled    = false;
      bulkDeleteBtn.textContent = 'Delete selected';
    }
  });
</script>

