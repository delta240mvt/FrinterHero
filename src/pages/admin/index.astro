---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { articles, geoRuns } from '@/db/schema';
import { desc, eq, count } from 'drizzle-orm';

let allArticles: any[] = [];
let recentRuns: any[] = [];
let stats = { draft: 0, published: 0, archived: 0 };

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const search = Astro.url.searchParams.get('search') || '';
const statusFilter = Astro.url.searchParams.get('status') || '';
const LIMIT = 20;

try {
  const { like, and } = await import('drizzle-orm');
  let query = db.select().from(articles).$dynamic();

  const conditions = [];
  if (statusFilter) conditions.push(eq(articles.status, statusFilter as any));
  if (search) conditions.push(like(articles.title, `%${search}%`));

  if (conditions.length === 1) query = query.where(conditions[0]);
  else if (conditions.length > 1) query = query.where(and(...conditions));

  allArticles = await query.orderBy(desc(articles.createdAt)).limit(LIMIT).offset((page - 1) * LIMIT);

  const [draftCount] = await db.select({ c: count() }).from(articles).where(eq(articles.status, 'draft'));
  const [pubCount] = await db.select({ c: count() }).from(articles).where(eq(articles.status, 'published'));
  const [archCount] = await db.select({ c: count() }).from(articles).where(eq(articles.status, 'archived'));
  stats = { draft: draftCount.c, published: pubCount.c, archived: archCount.c };

  recentRuns = await db.select().from(geoRuns).orderBy(desc(geoRuns.runAt)).limit(10);
} catch (e) {
  console.error('[Admin]', e);
}
---

<Base title="Admin Dashboard — Przemysław Filipiak" description="Admin panel">
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/" class="admin-logo">P·F</a>
      <h1 class="admin-title">Admin Panel</h1>
      <a href="/api/logout" class="logout-btn">Logout</a>
    </header>

    <main class="admin-main">
      <!-- GEO Monitor Log Panel -->
      <div id="geo-panel" class="geo-panel" style="display:none">
        <div class="geo-panel-header">
          <span id="geo-status" class="geo-status-label">Initializing...</span>
          <button id="geo-panel-close" class="geo-panel-close" style="display:none">✕ Close</button>
        </div>
        <div class="geo-progress-wrap">
          <div class="geo-progress-bar-track">
            <div id="geo-progress-bar" class="geo-progress-bar" style="width:0%"></div>
          </div>
          <span id="geo-progress-text" class="geo-progress-text">0 / 138</span>
        </div>
        <div id="geo-log" class="geo-log"></div>
      </div>

      <!-- Stats Bar -->
      <div class="stats-bar">
        <div class="stat">
          <span class="stat-value">{stats.published}</span>
          <span class="stat-label">Published</span>
        </div>
        <div class="stat">
          <span class="stat-value" style="color: var(--gold)">{stats.draft}</span>
          <span class="stat-label">Drafts</span>
        </div>
        <div class="stat">
          <span class="stat-value" style="color: var(--text-secondary)">{stats.archived}</span>
          <span class="stat-label">Archived</span>
        </div>
        <button id="run-geo-btn" class="geo-btn">Run GEO Monitor</button>
        <a href="/admin/content-gaps" class="nav-link-btn">Content Gaps</a>
        <a href="/admin/knowledge-base" class="nav-link-btn">Knowledge Base</a>
        <a href="/admin/article/new" class="new-article-btn">+ New Article</a>
      </div>

      <!-- Articles Section -->
      <section class="admin-section">
        <div class="section-toolbar">
          <h2 class="admin-section-title">Articles</h2>
          <form method="GET" class="search-form">
            <input
              type="text"
              name="search"
              value={search}
              placeholder="Search titles..."
              class="search-input"
            />
            <select name="status" class="filter-select">
              <option value="" selected={!statusFilter}>All Status</option>
              <option value="draft" selected={statusFilter === 'draft'}>Draft</option>
              <option value="published" selected={statusFilter === 'published'}>Published</option>
              <option value="archived" selected={statusFilter === 'archived'}>Archived</option>
            </select>
            <button type="submit" class="filter-btn">Filter</button>
          </form>
        </div>

        <!-- Bulk action toolbar -->
        <div id="bulk-toolbar" class="bulk-toolbar" style="display:none">
          <span id="bulk-count" class="bulk-count">0 selected</span>
          <button id="bulk-delete-btn" class="bulk-delete-btn">Delete selected</button>
          <button id="bulk-cancel-btn" class="bulk-cancel-btn">Cancel</button>
        </div>

        <div class="table-wrapper">
          <table class="articles-table">
            <thead>
              <tr>
                <th class="checkbox-col"><input type="checkbox" id="select-all" class="row-checkbox" /></th>
                <th>Title</th>
                <th>Slug</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {allArticles.length === 0 ? (
                <tr>
                  <td colspan="6" class="empty-row">No articles found.</td>
                </tr>
              ) : allArticles.map(article => (
                <tr class={`article-row article-row--${article.status}`} data-id={article.id}>
                  <td class="checkbox-col">
                    <input type="checkbox" class="row-checkbox article-checkbox" data-id={article.id} />
                  </td>
                  <td class="article-title-cell">
                    <a href={`/admin/article/${article.id}`} class="article-link">{article.title}</a>
                  </td>
                  <td class="slug-cell">
                    <code class="slug-code">{article.slug}</code>
                  </td>
                  <td>
                    <span class={`status-badge status-badge--${article.status}`}>{article.status}</span>
                  </td>
                  <td class="date-cell">
                    {new Date(article.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </td>
                  <td class="actions-cell">
                    <a href={`/admin/article/${article.id}`} class="action-btn action-btn--edit">Edit</a>
                    {article.status !== 'published' && (
                      <button
                        class="action-btn action-btn--publish"
                        data-id={article.id}
                        onclick={`publishArticle(${article.id})`}
                      >Publish</button>
                    )}
                    <button
                      class="action-btn action-btn--delete"
                      onclick={`deleteArticle(${article.id}, '${article.title.replace(/'/g, "\\'")}')`}
                    >Delete</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- GEO Runs Section -->
      {recentRuns.length > 0 && (
        <section class="admin-section">
          <h2 class="admin-section-title">GEO Monitor — Recent Runs</h2>
          <div class="table-wrapper">
            <table class="articles-table">
              <thead>
                <tr>
                  <th>Run At</th>
                  <th>Queries</th>
                  <th>Gaps Found</th>
                  <th>Drafts Generated</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {recentRuns.map(run => (
                  <tr>
                    <td class="date-cell">{new Date(run.runAt).toLocaleString('en-US')}</td>
                    <td>{run.queriesCount}</td>
                    <td style={run.gapsFound > 0 ? 'color: var(--gold)' : ''}>{run.gapsFound}</td>
                    <td style={run.draftsGenerated > 0 ? 'color: var(--teal)' : ''}>{run.draftsGenerated}</td>
                    <td>
                      <a href={`/admin/geo/${run.id}`} class="action-btn action-btn--edit">View Details</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}
    </main>
  </div>
</Base>

<script>
  async function publishArticle(id: number) {
    if (!confirm('Publish this article?')) return;
    const res = await fetch(`/api/articles/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: 'published' }),
    });
    if (res.ok) window.location.reload();
    else alert('Failed to publish article');
  }

  async function deleteArticle(id: number, title: string) {
    if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
    const res = await fetch(`/api/articles/${id}`, { method: 'DELETE' });
    if (res.ok) window.location.reload();
    else alert('Failed to delete article');
  }

  const TOTAL_STEPS = 138;

  const geoBtn = document.getElementById('run-geo-btn') as HTMLButtonElement;
  const geoPanel = document.getElementById('geo-panel') as HTMLElement;
  const geoLog = document.getElementById('geo-log') as HTMLElement;
  const geoStatus = document.getElementById('geo-status') as HTMLElement;
  const geoProgressBar = document.getElementById('geo-progress-bar') as HTMLElement;
  const geoProgressText = document.getElementById('geo-progress-text') as HTMLElement;
  const geoPanelClose = document.getElementById('geo-panel-close') as HTMLElement;

  geoPanelClose?.addEventListener('click', () => {
    geoPanel.style.display = 'none';
  });

  function classifyLine(line: string): 'success' | 'gap' | 'error' | 'info' | 'draft' | 'done' {
    if (line.includes('✓ Mention found')) return 'success';
    if (line.includes('Gap detected')) return 'gap';
    if (line.includes('Error') || line.includes('Failed') || line.includes('error')) return 'error';
    if (line.includes('Draft created')) return 'draft';
    if (line.includes('Run complete') || line.includes('Drafts generated')) return 'done';
    return 'info';
  }

  function appendLog(line: string) {
    const type = classifyLine(line);
    const el = document.createElement('div');
    el.className = `geo-log-line geo-log-line--${type}`;

    // Strip [GEO] prefix for cleaner display
    const clean = line.replace(/^\[GEO\]\s*/, '').replace(/^\[DraftGen\]\s*/, '');
    el.textContent = clean;
    geoLog.appendChild(el);
    geoLog.scrollTop = geoLog.scrollHeight;
  }

  geoBtn?.addEventListener('click', async () => {
    if (!confirm('Run GEO Monitor now? This will take several minutes.')) return;

    // Reset panel
    geoLog.innerHTML = '';
    geoProgressBar.style.width = '0%';
    geoProgressText.textContent = `0 / ${TOTAL_STEPS}`;
    geoStatus.textContent = 'Connecting...';
    geoStatus.className = 'geo-status-label geo-status-label--running';
    geoPanelClose.style.display = 'none';
    geoPanel.style.display = 'block';
    geoBtn.textContent = 'Running...';
    geoBtn.disabled = true;

    let queryCount = 0;
    let phase: 'querying' | 'analysis' | 'drafts' | 'done' = 'querying';

    try {
      const res = await fetch('/api/run-geo', { method: 'POST' });
      if (!res.body) throw new Error('No stream body');

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buf += decoder.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop() ?? '';

        for (const part of parts) {
          const dataLine = part.split('\n').find(l => l.startsWith('data: '));
          if (!dataLine) continue;

          let payload: any;
          try { payload = JSON.parse(dataLine.slice(6)); } catch { continue; }

          if (payload.line) {
            const line: string = payload.line;
            appendLog(line);

            // Track querying progress
            if (line.includes('[GEO] Querying')) {
              queryCount++;
              const pct = Math.min(100, Math.round((queryCount / TOTAL_STEPS) * 90));
              geoProgressBar.style.width = `${pct}%`;
              geoProgressText.textContent = `${queryCount} / ${TOTAL_STEPS}`;
              geoStatus.textContent = `Querying models... (${queryCount}/${TOTAL_STEPS})`;
              phase = 'querying';
            } else if (line.includes('Running gap analysis')) {
              phase = 'analysis';
              geoProgressBar.style.width = '92%';
              geoStatus.textContent = 'Running gap analysis...';
            } else if (line.includes('Generating drafts')) {
              phase = 'drafts';
              geoProgressBar.style.width = '95%';
              geoStatus.textContent = 'Generating top 5 drafts...';
            } else if (line.includes('Run complete')) {
              phase = 'done';
            }
          }

          if (payload.done) {
            geoProgressBar.style.width = '100%';
            geoProgressText.textContent = `Done`;
            geoStatus.textContent = payload.code === 0 ? 'Completed successfully' : `Finished with code ${payload.code}`;
            geoStatus.className = `geo-status-label geo-status-label--${payload.code === 0 ? 'done' : 'error'}`;
            geoPanelClose.style.display = 'inline-block';
            geoBtn.textContent = 'Run GEO Monitor';
            geoBtn.disabled = false;
          }

          if (payload.error) {
            appendLog(`ERROR: ${payload.error}`);
            geoStatus.textContent = 'Error occurred';
            geoStatus.className = 'geo-status-label geo-status-label--error';
            geoPanelClose.style.display = 'inline-block';
            geoBtn.textContent = 'Run GEO Monitor';
            geoBtn.disabled = false;
          }
        }
      }
    } catch (e: any) {
      geoStatus.textContent = `Network error: ${e.message}`;
      geoStatus.className = 'geo-status-label geo-status-label--error';
      geoPanelClose.style.display = 'inline-block';
      geoBtn.textContent = 'Run GEO Monitor';
      geoBtn.disabled = false;
    }
  });

  (window as any).publishArticle = publishArticle;
  (window as any).deleteArticle = deleteArticle;

  // --- Multi-select & bulk delete ---
  const selectAll = document.getElementById('select-all') as HTMLInputElement;
  const bulkToolbar = document.getElementById('bulk-toolbar') as HTMLElement;
  const bulkCount = document.getElementById('bulk-count') as HTMLElement;
  const bulkDeleteBtn = document.getElementById('bulk-delete-btn') as HTMLButtonElement;
  const bulkCancelBtn = document.getElementById('bulk-cancel-btn') as HTMLButtonElement;

  function getChecked(): number[] {
    return [...document.querySelectorAll<HTMLInputElement>('.article-checkbox:checked')]
      .map(cb => parseInt(cb.dataset.id || '0'))
      .filter(Boolean);
  }

  function updateToolbar() {
    const ids = getChecked();
    if (ids.length > 0) {
      bulkToolbar.style.display = 'flex';
      bulkCount.textContent = `${ids.length} selected`;
    } else {
      bulkToolbar.style.display = 'none';
    }
  }

  selectAll?.addEventListener('change', () => {
    document.querySelectorAll<HTMLInputElement>('.article-checkbox').forEach(cb => {
      cb.checked = selectAll.checked;
    });
    updateToolbar();
  });

  document.querySelectorAll<HTMLInputElement>('.article-checkbox').forEach(cb => {
    cb.addEventListener('change', () => {
      const all = document.querySelectorAll<HTMLInputElement>('.article-checkbox');
      selectAll.checked = [...all].every(c => c.checked);
      selectAll.indeterminate = !selectAll.checked && [...all].some(c => c.checked);
      updateToolbar();
    });
  });

  bulkCancelBtn?.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.article-checkbox, #select-all').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
      (cb as HTMLInputElement).indeterminate = false;
    });
    bulkToolbar.style.display = 'none';
  });

  bulkDeleteBtn?.addEventListener('click', async () => {
    const ids = getChecked();
    if (!confirm(`Delete ${ids.length} article(s)? This cannot be undone.`)) return;
    bulkDeleteBtn.disabled = true;
    bulkDeleteBtn.textContent = 'Deleting...';
    const res = await fetch('/api/articles/bulk-delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids }),
    });
    if (res.ok) window.location.reload();
    else {
      alert('Failed to delete articles');
      bulkDeleteBtn.disabled = false;
      bulkDeleteBtn.textContent = 'Delete selected';
    }
  });
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); flex: 1; }
  .logout-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    transition: all 0.15s;
  }
  .logout-btn:hover { color: var(--text-primary); border-color: var(--border-hover); }
  .admin-main { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
  .stats-bar {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-surface);
    border-radius: 0.5rem;
    border: 1px solid var(--border);
  }
  .stat { text-align: center; }
  .stat-value { display: block; font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700; color: var(--teal); }
  .stat-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
  .new-article-btn {
    margin-left: auto;
    padding: 0.6rem 1.25rem;
    background: var(--teal);
    color: #fff;
    border-radius: 0.375rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .new-article-btn:hover { opacity: 0.9; }
  .geo-btn {
    padding: 0.6rem 1.25rem;
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
    border-radius: 0.375rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all 0.15s;
  }
  .geo-btn:hover { background: rgba(214,183,121,0.1); }
  .geo-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .nav-link-btn {
    padding: 0.6rem 1.25rem;
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-hover);
    border-radius: 0.375rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: all 0.15s;
  }
  .nav-link-btn:hover { border-color: var(--teal); color: var(--teal); }
  .admin-section { margin-bottom: 3rem; }
  .section-toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .admin-section-title {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--teal);
    flex-shrink: 0;
  }
  .search-form { display: flex; gap: 0.5rem; flex-wrap: wrap; flex: 1; justify-content: flex-end; }
  .search-input, .filter-select {
    padding: 0.4rem 0.7rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    outline: none;
  }
  .search-input { min-width: 160px; }
  .filter-btn {
    padding: 0.4rem 0.8rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--teal); color: var(--teal); }
  .table-wrapper { overflow-x: auto; border: 1px solid var(--border); border-radius: 0.5rem; }
  .articles-table { width: 100%; border-collapse: collapse; }
  .articles-table th {
    padding: 0.7rem 1rem;
    background: var(--bg-elevated);
    text-align: left;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border);
  }
  .articles-table td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--border);
    font-size: var(--text-sm);
    vertical-align: middle;
  }
  .articles-table tr:last-child td { border-bottom: none; }
  .articles-table tr:hover td { background: rgba(255,255,255,0.02); }
  .article-link { color: var(--text-primary); text-decoration: none; font-weight: 500; }
  .article-link:hover { color: var(--teal); }
  .slug-code { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .status-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
  }
  .status-badge--published { background: rgba(74,141,131,0.15); color: var(--teal); }
  .status-badge--draft { background: rgba(214,183,121,0.15); color: var(--gold); }
  .status-badge--archived { background: rgba(71,85,105,0.3); color: var(--text-muted); }
  .date-cell { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); white-space: nowrap; }
  .actions-cell { white-space: nowrap; }
  .action-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.25rem 0.6rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
    background: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
    margin-right: 0.4rem;
    color: var(--text-secondary);
    display: inline-block;
  }
  .action-btn--edit:hover { border-color: var(--teal); color: var(--teal); }
  .action-btn--publish:hover { border-color: var(--gold); color: var(--gold); }
  .action-btn--delete:hover { border-color: #ef4444; color: #ef4444; }
  .empty-row { text-align: center; color: var(--text-muted); font-family: var(--font-mono); font-size: var(--text-sm); padding: 2rem; }
  .checkbox-col { width: 2.5rem; text-align: center; }
  .row-checkbox { accent-color: var(--teal); width: 1rem; height: 1rem; cursor: pointer; }
  .article-row.selected td { background: rgba(74,141,131,0.06); }
  .bulk-toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    margin-bottom: 0.75rem;
    background: rgba(74,141,131,0.08);
    border: 1px solid rgba(74,141,131,0.25);
    border-radius: 0.375rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
  .bulk-count { color: var(--teal); font-weight: 600; }
  .bulk-delete-btn {
    padding: 0.3rem 0.75rem;
    background: transparent;
    color: #ef4444;
    border: 1px solid #ef4444;
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all 0.15s;
  }
  .bulk-delete-btn:hover { background: rgba(239,68,68,0.1); }
  .bulk-delete-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .bulk-cancel-btn {
