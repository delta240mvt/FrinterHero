---
import Base from '@/components/layouts/Base.astro';
---

<Base title="Settings — Social Hub" description="Configure LLM copywriter, video generation, distribution, and brand voice for Social Hub">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/social-hub" class="bc-link">Social Hub</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">Settings</span>
    </nav>
    <div class="header-actions">
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">⚙ Social Hub Settings</h2>
          <p class="section-subtitle">LLM Copywriter · Video Generation · Distribution · Brand Voice — API keys stay in <code>.env</code></p>
        </div>
      </div>

      <form id="settings-form" class="settings-form" novalidate>

        <!-- Section 1 — LLM Copywriter -->
        <div class="settings-card">
          <h3 class="card-title">LLM Copywriter</h3>

          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">Model</label>
              <select name="llmModel" id="llm-model" class="field-select">
                <option value="claude-opus-4-6">claude-opus-4-6 (max quality)</option>
                <option value="claude-sonnet-4-6" selected>claude-sonnet-4-6 ★ (recommended)</option>
                <option value="claude-haiku-4-5-20251001">claude-haiku-4-5-20251001 (fast, cheap)</option>
              </select>
            </div>
            <div class="field-row">
              <label class="field-label">Extended Thinking Budget</label>
              <input type="number" name="llmThinkingBudget" id="llm-thinking-budget" class="field-input-num" min="1000" max="64000" step="1000" value="10000" />
              <span class="field-unit">tokens</span>
            </div>
            <div class="field-row field-row--textarea">
              <label class="field-label field-label--top">Default Suggestion Prompt</label>
              <textarea name="llmDefaultPrompt" id="llm-default-prompt" class="field-textarea" rows="4" placeholder="e.g. Write a compelling LinkedIn post about {topic} for high performers. Focus on actionable insight."></textarea>
            </div>
            <div class="field-row field-row--textarea">
              <label class="field-label field-label--top">Tone Overrides</label>
              <textarea name="llmToneOverrides" id="llm-tone-overrides" class="field-textarea" rows="3" placeholder="e.g. Always use second person. Avoid corporate jargon. Lead with a bold claim."></textarea>
            </div>
          </div>
        </div>

        <!-- Section 2 — Video Generation -->
        <div class="settings-card">
          <h3 class="card-title">Video Generation</h3>

          <div class="field-grid">
            <div class="field-row field-row--radio-group">
              <label class="field-label">Provider</label>
              <div class="radio-inline-group">
                <label class="radio-card">
                  <input type="radio" name="videoProvider" value="wavespeed" checked />
                  <div class="radio-card-content">
                    <span class="radio-card-label">WaveSpeed <span class="badge badge--star">★ default</span></span>
                    <span class="radio-card-desc">Fast AI video generation via WaveSpeed API.</span>
                  </div>
                </label>
              </div>
            </div>

            <div class="field-row">
              <label class="field-label">Video Model</label>
              <select name="videoModel" id="video-model" class="field-select">
                <option value="wan-2.2-ultra-fast" selected>wan-2.2-ultra-fast ★ (recommended)</option>
                <option value="InfiniteTalk">InfiniteTalk (talking head)</option>
              </select>
            </div>

            <div class="field-row field-row--radio-group">
              <label class="field-label">TTS Provider</label>
              <div class="radio-inline-group">
                <label class="radio-card">
                  <input type="radio" name="ttsProvider" value="elevenlabs" checked />
                  <div class="radio-card-content">
                    <span class="radio-card-label">ElevenLabs <span class="badge badge--star">★ default</span></span>
                    <span class="radio-card-desc">High-quality neural TTS. Requires ELEVENLABS_API_KEY.</span>
                  </div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="ttsProvider" value="kokoro" />
                  <div class="radio-card-content">
                    <span class="radio-card-label">Kokoro</span>
                    <span class="radio-card-desc">Local open-source TTS. No API key required.</span>
                  </div>
                </label>
              </div>
            </div>

            <div class="field-row" id="elevenlabs-voice-row">
              <label class="field-label">ElevenLabs Voice ID</label>
              <input type="text" name="elevenLabsVoiceId" id="elevenlabs-voice-id" class="field-input-text" placeholder="e.g. pNInz6obpgDQGcFmaJgB" />
            </div>

            <div class="field-row">
              <label class="field-label">Avatar Image URL</label>
              <input type="text" name="avatarImageUrl" id="avatar-image-url" class="field-input-text" placeholder="https://example.com/avatar.png" />
            </div>
          </div>
        </div>

        <!-- Section 3 — Distribution -->
        <div class="settings-card">
          <h3 class="card-title">Distribution</h3>
          <p class="card-note">Automated cross-platform publishing via Upload-Post.com. Set <code>UPLOADPOST_API_KEY</code> in <code>.env</code> — not stored here.</p>

          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">Provider</label>
              <span class="field-static">Upload-Post.com</span>
            </div>

            <div class="field-row field-row--textarea">
              <label class="field-label field-label--top">Default Hashtags</label>
              <textarea name="defaultHashtags" id="default-hashtags" class="field-textarea" rows="5" placeholder="#FrinterApp&#10;#DeepWork&#10;#HighPerformance&#10;#FocusSprint&#10;#WholeBeing"></textarea>
              <span class="field-hint">One hashtag per line. Will be joined and appended to posts.</span>
            </div>

            <div class="field-row">
              <label class="field-label">Auto-schedule</label>
              <label class="toggle-row">
                <input type="checkbox" name="autoSchedule" id="auto-schedule" />
                <span class="toggle-slider"></span>
                <span class="toggle-label">Automatically schedule posts after generation</span>
              </label>
            </div>
          </div>
        </div>

        <!-- Section 4 — Brand Voice -->
        <div class="settings-card">
          <h3 class="card-title">Brand Voice</h3>
          <p class="card-note">The LLM copywriter uses your brand voice file as system context. Edit the file directly to update tone, style, and positioning.</p>

          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">Brand Voice File</label>
              <input type="text" class="field-input-text field-input-text--readonly" value="public/llms-full.txt" readonly />
              <span class="field-hint-inline">Edit <code>public/llms-full.txt</code> directly to update brand voice.</span>
            </div>
          </div>
        </div>

        <div class="settings-actions">
          <button type="submit" class="btn-primary" id="save-btn">Save Settings</button>
          <span id="save-status" class="save-status"></span>
        </div>
      </form>
    </section>
  </main>
</div>
</Base>

<script>
  const form = document.getElementById('settings-form') as HTMLFormElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const saveStatus = document.getElementById('save-status') as HTMLSpanElement;
  const ttsRadios = document.querySelectorAll('input[name="ttsProvider"]') as NodeListOf<HTMLInputElement>;
  const elevenLabsVoiceRow = document.getElementById('elevenlabs-voice-row') as HTMLElement;

  function updateTtsVisibility() {
    const ttsVal = [...ttsRadios].find(r => r.checked)?.value;
    elevenLabsVoiceRow.style.opacity = ttsVal === 'elevenlabs' ? '1' : '0.4';
    (elevenLabsVoiceRow.querySelector('input') as HTMLInputElement).disabled = ttsVal !== 'elevenlabs';
  }

  ttsRadios.forEach(r => r.addEventListener('change', updateTtsVisibility));

  // Load settings on page load
  async function loadSettings() {
    try {
      const res = await fetch('/api/social-hub/settings');
      if (!res.ok) return;
      const data = await res.json();

      const fd = (name: string, value: any) => {
        const el = form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
        if (!el) return;
        if (el instanceof HTMLInputElement && el.type === 'checkbox') {
          el.checked = Boolean(value);
        } else if (el instanceof HTMLInputElement && el.type === 'radio') {
          // handled separately
        } else {
          el.value = value ?? '';
        }
      };

      // Ensure model appears even if not in hardcoded HTML list
      if (data.llmModel) {
        const select = form.elements.namedItem('llmModel') as HTMLSelectElement;
        if (![...select.options].some(o => o.value === data.llmModel)) {
          select.add(new Option(`${data.llmModel} (custom)`, data.llmModel));
        }
      }
      if (data.videoModel) {
        const select = form.elements.namedItem('videoModel') as HTMLSelectElement;
        if (![...select.options].some(o => o.value === data.videoModel)) {
          select.add(new Option(`${data.videoModel} (custom)`, data.videoModel));
        }
      }

      fd('llmModel', data.llmModel);
      fd('llmThinkingBudget', data.llmThinkingBudget);
      fd('llmDefaultPrompt', data.llmDefaultPrompt);
      fd('llmToneOverrides', data.llmToneOverrides);
      fd('videoModel', data.videoModel);
      fd('elevenLabsVoiceId', data.elevenLabsVoiceId);
      fd('avatarImageUrl', data.avatarImageUrl);
      fd('defaultHashtags', Array.isArray(data.defaultHashtags) ? data.defaultHashtags.join('\n') : (data.defaultHashtags ?? ''));
      fd('autoSchedule', data.autoSchedule);

      // Radio: videoProvider
      if (data.videoProvider) {
        const vr = form.querySelector(`input[name="videoProvider"][value="${data.videoProvider}"]`) as HTMLInputElement | null;
        if (vr) vr.checked = true;
      }
      // Radio: ttsProvider
      if (data.ttsProvider) {
        const tr = form.querySelector(`input[name="ttsProvider"][value="${data.ttsProvider}"]`) as HTMLInputElement | null;
        if (tr) tr.checked = true;
      }
    } catch (_) {
      // silently ignore — form keeps defaults
    } finally {
      updateTtsVisibility();
    }
  }

  loadSettings();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…';
    saveStatus.className = 'save-status saving';

    const fd = new FormData(form);

    const hashtagsRaw = String(fd.get('defaultHashtags') ?? '');
    const defaultHashtags = hashtagsRaw
      .split('\n')
      .map(h => h.trim())
      .filter(h => h.length > 0);

    const payload = {
      llmModel: fd.get('llmModel'),
      llmThinkingBudget: parseInt(String(fd.get('llmThinkingBudget') ?? '10000'), 10),
      llmDefaultPrompt: fd.get('llmDefaultPrompt'),
      llmToneOverrides: fd.get('llmToneOverrides'),
      videoProvider: fd.get('videoProvider'),
      videoModel: fd.get('videoModel'),
      ttsProvider: fd.get('ttsProvider'),
      elevenLabsVoiceId: fd.get('elevenLabsVoiceId'),
      avatarImageUrl: fd.get('avatarImageUrl'),
      defaultHashtags,
      autoSchedule: (form.elements.namedItem('autoSchedule') as HTMLInputElement)?.checked ?? false,
    };

    try {
      const res = await fetch('/api/social-hub/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        saveStatus.textContent = '✓ Saved';
        saveStatus.className = 'save-status ok';
      } else {
        const err = await res.json().catch(() => ({}));
        saveStatus.textContent = `Error: ${(err as any).error || res.status}`;
        saveStatus.className = 'save-status error';
      }
    } catch (err: any) {
      saveStatus.textContent = `Error: ${err.message}`;
      saveStatus.className = 'save-status error';
    } finally {
      saveBtn.disabled = false;
      setTimeout(() => { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }, 4000);
    }
  });
</script>

<style>
.admin-layout { min-height: 100vh; background: var(--bg-base); }
.admin-header { display: flex; align-items: center; gap: 1.25rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20; }
.admin-logo   { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
.breadcrumb   { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); display: flex; gap: 0.4rem; align-items: center; }
.bc-link  { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep   { color: var(--text-muted); }
.bc-current { color: var(--text-secondary); }
.header-actions { margin-left: auto; }
.btn-logout  { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.admin-main  { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

.admin-section { display: flex; flex-direction: column; gap: 1rem; }
.section-header-row { padding-bottom: 0.875rem; border-bottom: 1px solid var(--border); }
.section-title-block { display: flex; flex-direction: column; gap: 0.2rem; }
.section-title { font-family: var(--font-mono); font-size: 1rem; color: var(--text-primary); font-weight: 700; margin: 0; }
.section-subtitle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.section-subtitle code { background: var(--bg-elevated); padding: 1px 5px; border-radius: 3px; }

.settings-form { display: flex; flex-direction: column; gap: 0.75rem; }
.settings-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.625rem; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; }
.card-title { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 700; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 0.5rem; }
.card-note  { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); margin: 0; line-height: 1.5; }
.card-note code { background: var(--bg-base); padding: 1px 4px; border-radius: 3px; }
.badge { background: rgba(74,141,131,0.1); color: var(--teal); font-size: 0.65rem; padding: 1px 6px; border-radius: 0.2rem; font-weight: 500; border: 1px solid rgba(74,141,131,0.2); }
.badge--star { background: rgba(214,183,121,0.1); color: var(--gold); border-color: rgba(214,183,121,0.2); }

.field-grid { display: flex; flex-direction: column; gap: 1rem; }
.field-row  { display: flex; align-items: center; gap: 1.25rem; }
.field-row--textarea { flex-direction: column; align-items: stretch; gap: 0.6rem; }
.field-row--radio-group { align-items: flex-start; }
.field-label { width: 220px; flex-shrink: 0; font-family: var(--font-mono); color: var(--text-secondary); font-size: var(--text-sm); font-weight: 600; }
.field-row--textarea .field-label { width: 100%; padding-top: 0; }

.field-select { flex: 1; background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); padding: 0.625rem 0.75rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); outline: none; }
.field-select:focus { border-color: var(--teal); }

.field-input-num { width: 140px; background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); padding: 0.625rem 0.75rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); outline: none; text-align: right; }
.field-input-num:focus { border-color: var(--gold); }

.field-input-text { flex: 1; background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); padding: 0.625rem 0.75rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); outline: none; }
.field-input-text:focus { border-color: var(--teal); }
.field-input-text--readonly { color: var(--text-muted); cursor: default; background: rgba(0,0,0,0.1); }
.field-input-text--readonly:focus { border-color: var(--border); }

.field-textarea { width: 100%; box-sizing: border-box; background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); padding: 0.75rem 0.875rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); outline: none; resize: vertical; line-height: 1.6; }
.field-textarea:focus { border-color: var(--teal); }

.field-unit { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); flex-shrink: 0; }
.field-hint { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); margin-top: 0.3rem; display: block; }
.field-hint-inline { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); flex-shrink: 0; }
.field-hint-inline code { background: var(--bg-base); padding: 1px 4px; border-radius: 3px; font-size: 0.65rem; }
.field-static { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-primary); padding: 0.4rem 0; font-weight: 500; }

.radio-inline-group { display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
.radio-card { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.65rem 0.75rem; background: var(--bg-base); border: 1px solid var(--border); border-radius: 0.375rem; cursor: pointer; transition: border-color 0.15s; }
.radio-card:has(input:checked) { border-color: var(--gold); background: rgba(214,183,121,0.04); }
.radio-card input { margin-top: 2px; accent-color: var(--gold); flex-shrink: 0; }
.radio-card-label { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); font-size: var(--text-sm); }
.radio-card-desc  { display: block; font-family: var(--font-mono); color: var(--text-muted); font-size: 0.65rem; margin-top: 2px; }
.radio-card-content { display: flex; flex-direction: column; }

.toggle-row { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }
.toggle-row input[type="checkbox"] { width: 15px; height: 15px; accent-color: var(--gold); cursor: pointer; }
.toggle-label { font-family: var(--font-mono); color: var(--text-primary); font-size: var(--text-sm); }
.toggle-slider { display: none; }

.settings-actions { display: flex; align-items: center; gap: 1rem; padding-top: 0.25rem; }
.btn-primary { padding: 0.5rem 1.25rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
.btn-primary:hover { opacity: 0.9; }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
.save-status { font-family: var(--font-mono); font-size: var(--text-xs); }
.save-status.ok     { color: var(--teal); }
.save-status.error  { color: #ef4444; }
.save-status.saving { color: var(--text-muted); }
</style>
