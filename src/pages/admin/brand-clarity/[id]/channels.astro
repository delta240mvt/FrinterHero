---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { bcProjects, bcTargetChannels } from '@/db/schema';
import { eq, asc } from 'drizzle-orm';

const { id } = Astro.params;
const projectId = parseInt(id || '0', 10);

let project: any = null;
let channels: any[] = [];

try {
  const [p] = await db.select().from(bcProjects).where(eq(bcProjects.id, projectId));
  project = p;
  if (p) {
    channels = await db.select().from(bcTargetChannels)
      .where(eq(bcTargetChannels.projectId, projectId))
      .orderBy(asc(bcTargetChannels.sortOrder));
  }
} catch (e) {
  console.error('[BC-Channels]', e);
}

if (!project) {
  return Astro.redirect('/admin/brand-clarity');
}

const confirmedCount = channels.filter(c => c.isConfirmed).length;
const nicheKeywords: string[] = Array.isArray(project.nicheKeywords) ? project.nicheKeywords as string[] : [];
---

<Base title={`Channels — ${project.name}`} description="Brand Clarity channel management">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin/brand-clarity" class="bc-link">Brand Clarity</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">{project.name}</span>
      <span class="bc-sep">›</span>
      <span class="bc-current">Channels</span>
    </nav>
    <div class="header-actions">
      <span class="project-status">{project.status}</span>
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <!-- Clickable stage bar -->
    <div class="stage-bar">
      <a href="/admin/brand-clarity" class="stage done stage-link">1. LP Parsed</a>
      <span class="stage-arrow">→</span>
      <span class="stage active">2. Channels</span>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/videos`} class="stage stage-link">3. Videos</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/scrape`} class="stage stage-link">4. Scrape & Review</a>
      <span class="stage-arrow">→</span>
      <a href={`/admin/brand-clarity/${projectId}/variants`} class="stage stage-link">5. LP Variants</a>
    </div>

    <!-- Niche keywords editor -->
    <section class="admin-section">
      <details class="keywords-editor-details" open>
        <summary class="keywords-editor-summary">
          <span>Niche Keywords</span>
          <span class="kw-count">{nicheKeywords.length} keywords · used for channel & video discovery</span>
        </summary>
        <div class="keywords-editor-body">
          <div id="kw-chips" class="kw-chips-row">
            {nicheKeywords.map((kw, i) => (
              <span class="kw-chip-edit" data-index={i}>
                {kw}
                <button class="kw-remove" onclick={`removeKeyword(${i})`}>×</button>
              </span>
            ))}
          </div>
          <div class="kw-add-row">
            <input type="text" id="kw-input" placeholder="Add keyword…" class="form-input kw-add-input" />
            <button class="btn-kw-add" onclick="addKeyword()">+ Add</button>
            <button class="btn-kw-save" id="kw-save-btn" onclick="saveKeywords()">Save Keywords</button>
          </div>
          <div id="kw-status" class="kw-status" style="display:none"></div>
        </div>
      </details>
    </section>

    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">YouTube Channels</h2>
          <p class="section-subtitle">{confirmedCount}/{channels.length} confirmed · Discover niche channels, then confirm them to proceed</p>
        </div>
        <div class="header-btns">
          <button id="discover-btn" class="btn-discover">Discover Channels</button>
          {confirmedCount > 0 && (
            <button id="confirm-all-btn" class="btn-confirm-all">Confirm All ({channels.length})</button>
          )}
          {confirmedCount > 0 && (
            <a href={`/admin/brand-clarity/${projectId}/videos`} class="btn-primary">Next: Videos →</a>
          )}
        </div>
      </div>

      <div id="discover-status" class="discover-status" style="display:none"></div>

      <!-- Log panel -->
      <details id="log-panel" class="log-panel" style="display:none">
        <summary class="log-panel-summary">
          <span class="log-label">Run Log</span>
          <span id="log-count" class="logs-count">0 lines</span>
        </summary>
        <div id="log-container" class="log-container"></div>
      </details>

      <div id="channels-list">
        {channels.length === 0 ? (
          <div class="empty-state">
            <p>No channels yet. Click "Discover Channels" to auto-discover from niche keywords.</p>
          </div>
        ) : (
          <div class="channels-grid">
            {channels.map(ch => (
              <div class={`channel-card ${ch.isConfirmed ? 'confirmed' : ''}`} id={`ch-${ch.id}`}>
                <div class="ch-header">
                  <span class={`ch-status ${ch.isConfirmed ? 'ch-confirmed' : 'ch-pending'}`}>
                    {ch.isConfirmed ? '✓ Confirmed' : 'Pending'}
                  </span>
                  <span class="ch-method">{ch.discoveryMethod}</span>
                </div>
                <h4 class="ch-name">{ch.channelName}</h4>
                {ch.subscriberCount && (
                  <span class="ch-subs">{(ch.subscriberCount / 1000).toFixed(0)}k subs</span>
                )}
                {ch.description && (
                  <p class="ch-desc">{ch.description.substring(0, 120)}{ch.description.length > 120 ? '…' : ''}</p>
                )}
                <div class="ch-actions">
                  <a href={ch.channelUrl} target="_blank" rel="noopener" class="btn-ch-link">View ↗</a>
                  {!ch.isConfirmed ? (
                    <button class="btn-ch-confirm" onclick={`confirmChannel(${ch.id})`}>✓ Confirm</button>
                  ) : (
                    <button class="btn-ch-unconfirm" onclick={`unconfirmChannel(${ch.id})`}>✕ Remove</button>
                  )}
                  <button class="btn-ch-delete" onclick={`deleteChannel(${ch.id})`}>🗑</button>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Add channel by URL -->
    <section class="admin-section">
      <details class="add-channel-details">
        <summary class="add-channel-summary">+ Add Channel by URL or Handle</summary>
        <div class="add-ch-form">
          <div class="url-row">
            <input type="text" id="ch-url-input" placeholder="https://youtube.com/@channelname  or  @handle  or  UCxxxxxxx" class="form-input url-input" />
            <button id="resolve-btn" class="btn-resolve" onclick="resolveChannel()">Resolve →</button>
          </div>
          <div id="resolve-status" class="resolve-status" style="display:none"></div>
          <div id="channel-preview" class="channel-preview" style="display:none">
            <div class="preview-row">
              <span class="preview-label">Name:</span><span id="preview-name" class="preview-value"></span>
            </div>
            <div class="preview-row">
              <span class="preview-label">Subs:</span><span id="preview-subs" class="preview-value"></span>
            </div>
            <div class="preview-row">
              <span class="preview-label">URL:</span><a id="preview-url" class="preview-link" target="_blank" rel="noopener"></a>
            </div>
            <button id="add-channel-btn" class="btn-add-ch" onclick="addResolvedChannel()">+ Add & Confirm Channel</button>
          </div>
        </div>
      </details>
    </section>
  </main>
</div>

<script define:vars={{ projectId, currentKeywords: nicheKeywords }}>
  const PROJECT_ID = projectId;
  let keywords = [...currentKeywords];
  let resolvedChannel = null;

  // ── Keyword management ───────────────────────────────────────────────────
  function renderKeywords() {
    const container = document.getElementById('kw-chips');
    container.innerHTML = keywords.map((kw, i) =>
      `<span class="kw-chip-edit">${kw}<button class="kw-remove" onclick="removeKeyword(${i})">×</button></span>`
    ).join('');
  }

  window.removeKeyword = function(i) {
    keywords.splice(i, 1);
    renderKeywords();
  };

  window.addKeyword = function() {
    const input = document.getElementById('kw-input');
    const val = input.value.trim();
    if (!val || keywords.includes(val)) { input.value = ''; return; }
    keywords.push(val);
    input.value = '';
    renderKeywords();
  };

  document.getElementById('kw-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); window.addKeyword(); }
  });

  window.saveKeywords = async function() {
    const btn = document.getElementById('kw-save-btn');
    const status = document.getElementById('kw-status');
    btn.disabled = true;
    btn.textContent = 'Saving…';
    try {
      const res = await fetch(`/api/brand-clarity/projects/${PROJECT_ID}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nicheKeywords: keywords }),
      });
      if (!res.ok) throw new Error('Failed');
      status.style.display = 'block';
      status.className = 'kw-status kw-status--ok';
      status.textContent = `Saved ${keywords.length} keywords`;
      setTimeout(() => { status.style.display = 'none'; }, 3000);
    } catch {
      status.style.display = 'block';
      status.className = 'kw-status kw-status--err';
      status.textContent = 'Save failed';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save Keywords';
    }
  };

  // ── Channel actions ──────────────────────────────────────────────────────
  async function confirmChannel(channelId) {
    const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/channels/${channelId}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ isConfirmed: true }),
    });
    if (res.ok) window.location.reload();
    else alert('Failed to confirm channel');
  }

  async function unconfirmChannel(channelId) {
    const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/channels/${channelId}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ isConfirmed: false }),
    });
    if (res.ok) window.location.reload();
    else alert('Failed to update channel');
  }

  async function deleteChannel(channelId) {
    if (!confirm('Delete this channel?')) return;
    const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/channels/${channelId}`, { method: 'DELETE' });
    if (res.ok) window.location.reload();
    else alert('Failed to delete');
  }

  window.confirmChannel = confirmChannel;
  window.unconfirmChannel = unconfirmChannel;
  window.deleteChannel = deleteChannel;

  // ── Discover channels ────────────────────────────────────────────────────
  const discoverBtn = document.getElementById('discover-btn');
  const discoverStatus = document.getElementById('discover-status');
  const logPanel = document.getElementById('log-panel');
  const logContainer = document.getElementById('log-container');
  const logCount = document.getElementById('log-count');

  function renderLogs(logs) {
    if (!logs || !logs.length) return;
    logPanel.style.display = 'block';
    logCount.textContent = `${logs.length} lines`;
    logContainer.innerHTML = logs.map(line => {
      let cls = 'log-line';
      if (line.includes('[WARN]') || line.includes('[FATAL]')) cls += ' log-line--warn';
      else if (line.includes('Done') || line.includes('CHANNELS_FOUND') || line.includes('VIDEOS_FOUND')) cls += ' log-line--done';
      return `<div class="${cls}">${line}</div>`;
    }).join('');
    logContainer.scrollTop = logContainer.scrollHeight;
  }

  discoverBtn?.addEventListener('click', async () => {
    if (!confirm('Discover YouTube channels for this project? (~301 YouTube API quota units)')) return;
    discoverBtn.disabled = true;
    discoverBtn.textContent = 'Discovering…';
    discoverStatus.style.display = 'block';
    discoverStatus.className = 'discover-status discover-status--running';
    discoverStatus.textContent = 'Discovering channels from niche keywords…';
    logPanel.style.display = 'none';

    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/discover-channels`, { method: 'POST' });
      const data = await res.json();
      renderLogs(data.logs);
      if (!res.ok) throw new Error(data.error || 'Failed');
      discoverStatus.className = 'discover-status discover-status--success';
      discoverStatus.textContent = `Found ${data.channelsFound} channels. Reloading…`;
      setTimeout(() => window.location.reload(), 1500);
    } catch (e) {
      discoverStatus.className = 'discover-status discover-status--error';
      discoverStatus.textContent = `Error: ${e.message}`;
      discoverBtn.disabled = false;
      discoverBtn.textContent = 'Discover Channels';
    }
  });

  // ── Confirm all ──────────────────────────────────────────────────────────
  document.getElementById('confirm-all-btn')?.addEventListener('click', async () => {
    if (!confirm('Confirm all channels and proceed to video discovery?')) return;
    const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/channels/confirm-all`, { method: 'POST' });
    if (res.ok) window.location.href = `/admin/brand-clarity/${PROJECT_ID}/videos`;
    else alert('Failed to confirm all');
  });

  // ── Resolve channel URL ──────────────────────────────────────────────────
  window.resolveChannel = async function() {
    const input = document.getElementById('ch-url-input');
    const btn = document.getElementById('resolve-btn');
    const status = document.getElementById('resolve-status');
    const preview = document.getElementById('channel-preview');
    const url = input.value.trim();
    if (!url) return;

    btn.disabled = true;
    btn.textContent = 'Resolving…';
    status.style.display = 'block';
    status.className = 'resolve-status resolve-status--running';
    status.textContent = 'Fetching channel info from YouTube…';
    preview.style.display = 'none';
    resolvedChannel = null;

    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/resolve-channel`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');

      resolvedChannel = data;
      status.style.display = 'none';
      preview.style.display = 'block';
      document.getElementById('preview-name').textContent = data.channelName;
      document.getElementById('preview-subs').textContent = data.subscriberCount
        ? `${(data.subscriberCount / 1000).toFixed(0)}k`
        : '–';
      const previewUrlEl = document.getElementById('preview-url');
      previewUrlEl.textContent = data.channelUrl;
      previewUrlEl.href = data.channelUrl;
    } catch (e) {
      status.className = 'resolve-status resolve-status--error';
      status.textContent = `Error: ${e.message}`;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Resolve →';
    }
  };

  document.getElementById('ch-url-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); window.resolveChannel(); }
  });

  window.addResolvedChannel = async function() {
    if (!resolvedChannel) return;
    const btn = document.getElementById('add-channel-btn');
    btn.disabled = true;
    btn.textContent = 'Adding…';
    try {
      const res = await fetch(`/api/brand-clarity/${PROJECT_ID}/channels`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(resolvedChannel),
      });
      if (res.ok) window.location.reload();
      else {
        const d = await res.json();
        alert(d.error || 'Failed to add channel');
        btn.disabled = false;
        btn.textContent = '+ Add & Confirm Channel';
      }
    } catch (e) {
      alert(e.message);
      btn.disabled = false;
      btn.textContent = '+ Add & Confirm Channel';
    }
  };
</script>

<style>
.admin-layout { min-height: 100vh; background: var(--bg-base); }
.admin-header { display: flex; align-items: center; gap: 1.25rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20; }
.admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
.breadcrumb { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); display: flex; gap: 0.4rem; align-items: center; }
.bc-link { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep { color: var(--text-muted); }
.bc-current { color: var(--text-secondary); }
.header-actions { margin-left: auto; display: flex; gap: 0.5rem; align-items: center; }
.project-status { font-family: var(--font-mono); font-size: 0.65rem; color: var(--gold); padding: 0.2rem 0.5rem; background: rgba(214,183,121,0.1); border-radius: 0.2rem; }
.btn-logout { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.btn-primary { padding: 0.4rem 1rem; background: var(--teal); color: #fff; border: none; border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.admin-main { max-width: 1100px; margin: 0 auto; padding: 1.75rem 1.5rem 3rem; display: flex; flex-direction: column; gap: 2rem; }

/* Stage bar */
.stage-bar { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.65rem; padding: 0.625rem 1rem; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; overflow-x: auto; }
.stage { color: var(--text-muted); white-space: nowrap; }
.stage.done { color: var(--teal); }
.stage.active { color: var(--gold); font-weight: 700; }
.stage-link { text-decoration: none; padding: 0.1rem 0.3rem; border-radius: 0.2rem; transition: background 0.1s; }
.stage-link:hover { background: rgba(255,255,255,0.06); }
.stage-link.done:hover { color: var(--teal); }
.stage-link:not(.done):not(.active) { color: var(--text-muted); }
.stage-link:not(.done):not(.active):hover { color: var(--text-secondary); }
.stage-arrow { color: var(--border); }

/* Keywords editor */
.keywords-editor-details { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; overflow: hidden; }
.keywords-editor-summary { padding: 0.75rem 1.25rem; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; gap: 1rem; list-style: none; }
.keywords-editor-summary::-webkit-details-marker { display: none; }
.kw-count { font-size: 0.65rem; color: var(--text-muted); margin-left: auto; }
.keywords-editor-body { padding: 0.875rem 1.25rem; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.75rem; }
.kw-chips-row { display: flex; flex-wrap: wrap; gap: 0.375rem; min-height: 1.5rem; }
.kw-chip-edit { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.15rem 0.35rem 0.15rem 0.5rem; background: rgba(74,141,131,0.12); border: 1px solid rgba(74,141,131,0.25); color: var(--teal); border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; }
.kw-remove { background: none; border: none; color: rgba(74,141,131,0.5); cursor: pointer; font-size: 0.8rem; line-height: 1; padding: 0; }
.kw-remove:hover { color: #ef4444; }
.kw-add-row { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
.kw-add-input { flex: 1; min-width: 160px; }
.btn-kw-add { padding: 0.35rem 0.75rem; background: none; border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-kw-add:hover { border-color: var(--teal); color: var(--teal); }
.btn-kw-save { padding: 0.35rem 0.875rem; background: rgba(74,141,131,0.12); border: 1px solid rgba(74,141,131,0.3); color: var(--teal); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-kw-save:hover { background: rgba(74,141,131,0.2); }
.kw-status { font-family: var(--font-mono); font-size: var(--text-xs); padding: 0.35rem 0.75rem; border-radius: 0.25rem; }
.kw-status--ok  { background: rgba(74,141,131,0.08); color: var(--teal); border: 1px solid rgba(74,141,131,0.2); }
.kw-status--err { background: rgba(239,68,68,0.08); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }

/* Section */
.admin-section { display: flex; flex-direction: column; gap: 1rem; }
.section-header-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-bottom: 0.875rem; border-bottom: 1px solid var(--border); }
.section-title-block { display: flex; flex-direction: column; gap: 0.2rem; }
.section-title { font-family: var(--font-mono); font-size: 1rem; color: var(--text-primary); font-weight: 700; margin: 0; }
.section-subtitle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.header-btns { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.btn-discover { padding: 0.4rem 1rem; background: none; border: 1px solid var(--gold); color: var(--gold); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-discover:hover { background: rgba(214,183,121,0.08); }
.btn-discover:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-confirm-all { padding: 0.4rem 1rem; background: rgba(74,141,131,0.12); border: 1px solid rgba(74,141,131,0.3); color: var(--teal); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.discover-status { padding: 0.625rem 0.875rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-xs); }
.discover-status--running { background: rgba(214,183,121,0.08); border: 1px solid rgba(214,183,121,0.2); color: var(--gold); }
.discover-status--success { background: rgba(74,141,131,0.08); border: 1px solid rgba(74,141,131,0.2); color: var(--teal); }
.discover-status--error   { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: #ef4444; }

/* Log panel */
.log-panel { border: 1px solid var(--border); border-radius: 0.375rem; overflow: hidden; }
.log-panel-summary { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 1rem; cursor: pointer; background: rgba(255,255,255,0.02); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); list-style: none; }
.log-panel-summary::-webkit-details-marker { display: none; }
.log-label { flex: 1; }
.logs-count { padding: 0.1rem 0.4rem; background: rgba(255,255,255,0.06); border-radius: 0.25rem; font-size: 0.65rem; color: var(--text-muted); }
.log-container { background: #0a0a0f; border-top: 1px solid var(--border); padding: 0.75rem 1rem; max-height: 320px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.1rem; }
.log-line { font-family: var(--font-mono); font-size: 0.68rem; color: #71717a; white-space: pre-wrap; word-break: break-all; line-height: 1.5; }
.log-line--warn { color: #f97316; }
.log-line--done { color: var(--teal); }

/* Channels */
.empty-state { padding: 2.5rem; text-align: center; font-family: var(--font-mono); color: var(--text-muted); }
.channels-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.875rem; }
.channel-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.channel-card.confirmed { border-color: rgba(74,141,131,0.3); }
.ch-header { display: flex; justify-content: space-between; align-items: center; }
.ch-status { font-family: var(--font-mono); font-size: 0.65rem; }
.ch-confirmed { color: var(--teal); }
.ch-pending   { color: var(--text-muted); }
.ch-method { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); }
.ch-name { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); margin: 0; }
.ch-subs { font-family: var(--font-mono); font-size: 0.65rem; color: var(--gold); }
.ch-desc { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); line-height: 1.5; margin: 0; }
.ch-actions { display: flex; gap: 0.375rem; padding-top: 0.375rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
.btn-ch-link    { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.25rem 0.5rem; border: 1px solid var(--border); border-radius: 0.2rem; }
.btn-ch-confirm { padding: 0.25rem 0.5rem; background: rgba(74,141,131,0.12); border: 1px solid rgba(74,141,131,0.3); color: var(--teal); border-radius: 0.2rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-ch-unconfirm { padding: 0.25rem 0.5rem; background: none; border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.7); border-radius: 0.2rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; }
.btn-ch-delete  { padding: 0.25rem 0.4rem; background: none; border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.2rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; margin-left: auto; }

/* Add channel */
.add-channel-details { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; overflow: hidden; }
.add-channel-summary { padding: 0.875rem 1.25rem; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); cursor: pointer; }
.add-ch-form { padding: 1rem 1.25rem; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.75rem; }
.url-row { display: flex; gap: 0.5rem; }
.url-input { flex: 1; }
.btn-resolve { padding: 0.4rem 0.875rem; background: none; border: 1px solid var(--gold); color: var(--gold); border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; white-space: nowrap; }
.btn-resolve:hover { background: rgba(214,183,121,0.08); }
.btn-resolve:disabled { opacity: 0.5; cursor: not-allowed; }
.resolve-status { padding: 0.5rem 0.75rem; border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); }
.resolve-status--running { background: rgba(214,183,121,0.08); border: 1px solid rgba(214,183,121,0.2); color: var(--gold); }
.resolve-status--error   { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: #ef4444; }
.channel-preview { background: rgba(74,141,131,0.06); border: 1px solid rgba(74,141,131,0.2); border-radius: 0.375rem; padding: 0.875rem 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.preview-row { display: flex; gap: 0.75rem; align-items: baseline; }
.preview-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); min-width: 3rem; }
.preview-value { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-primary); }
.preview-link { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--teal); text-decoration: none; }
.preview-link:hover { text-decoration: underline; }
.btn-add-ch { padding: 0.4rem 1rem; background: var(--teal); border: none; color: #fff; border-radius: 0.3rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; width: fit-content; margin-top: 0.25rem; }
.btn-add-ch:disabled { opacity: 0.5; cursor: not-allowed; }
.form-input { background: var(--bg-base); border: 1px solid var(--border); border-radius: 0.3rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-xs); padding: 0.45rem 0.75rem; outline: none; }
.form-input:focus { border-color: var(--teal); }
</style>
</Base>
