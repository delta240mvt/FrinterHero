---
import Base from '@/components/layouts/Base.astro';
---

<Base title="New Brand Clarity Project" description="Create a new Brand Clarity project">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/brand-clarity" class="bc-link">Brand Clarity</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">New Project</span>
    </nav>
    <div class="header-actions">
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <section class="form-section">
      <h2 class="form-title">New Brand Clarity Project</h2>
      <p class="form-subtitle">Stage 1: Paste your landing page and founder description to extract LP structure and niche keywords.</p>

      <form id="new-project-form" class="bc-form">
        <div class="form-group">
          <label class="form-label" for="name">Project Name</label>
          <input type="text" id="name" name="name" class="form-input" placeholder="e.g. Frinter App LP Analysis" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="lpRawInput">Landing Page Content</label>
          <p class="form-hint">Paste your full landing page HTML or text. Used to extract LP structure.</p>
          <textarea id="lpRawInput" name="lpRawInput" class="form-textarea" rows={12} placeholder="Paste your landing page HTML or plain text here..." required></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="founderDescription">How You Feel Your Product Works</label>
          <p class="form-hint">Describe in your own words what your product does and how. Be honest and specific.</p>
          <textarea id="founderDescription" name="founderDescription" class="form-textarea" rows={5} placeholder="My product helps high performers by..." required></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="projectDocumentation">Project Documentation (Optional)</label>
          <p class="form-hint">Paste your README, feature spec, or full product docs. Helps LPs reflect real product facts. You can also add this later.</p>
          <textarea id="projectDocumentation" name="projectDocumentation" class="form-textarea" rows={8} placeholder="Paste README, spec, or feature documentation here..."></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" id="submit-btn" class="btn-submit">Parse LP & Create Project</button>
          <a href="/admin/brand-clarity" class="btn-ghost-sm">Cancel</a>
        </div>
      </form>

      <div id="status-msg" class="status-msg" style="display:none"></div>
    </section>
  </main>
</div>

<script>
  const form = document.getElementById('new-project-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const statusMsg = document.getElementById('status-msg') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating & parsing LP…';
    statusMsg.style.display = 'none';

    const body = {
      name: (document.getElementById('name') as HTMLInputElement).value.trim(),
      lpRawInput: (document.getElementById('lpRawInput') as HTMLTextAreaElement).value.trim(),
      founderDescription: (document.getElementById('founderDescription') as HTMLTextAreaElement).value.trim(),
      projectDocumentation: (document.getElementById('projectDocumentation') as HTMLTextAreaElement).value.trim() || null,
    };

    try {
      const res = await fetch('/api/brand-clarity/projects', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || `HTTP ${res.status}`);
      }

      const data = await res.json();
      statusMsg.style.display = 'block';
      statusMsg.className = 'status-msg status-msg--success';
      statusMsg.textContent = `Project created! LP parsing started. Redirecting to channels…`;

      // Poll until status changes from 'draft'
      const projectId = data.project.id;
      let attempts = 0;
      const poll = setInterval(async () => {
        attempts++;
        try {
          const r = await fetch(`/api/brand-clarity/projects/${projectId}`);
          const p = await r.json();
          if (p.status !== 'draft' || attempts > 30) {
            clearInterval(poll);
            window.location.href = `/admin/brand-clarity/${projectId}/channels`;
          }
        } catch { clearInterval(poll); window.location.href = `/admin/brand-clarity/${projectId}/channels`; }
      }, 3000);

    } catch (err: any) {
      statusMsg.style.display = 'block';
      statusMsg.className = 'status-msg status-msg--error';
      statusMsg.textContent = `Error: ${err.message}`;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Parse LP & Create Project';
    }
  });
</script>

<style>
.admin-layout { min-height: 100vh; background: var(--bg-base); }
.admin-header { display: flex; align-items: center; gap: 1.25rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20; }
.admin-logo  { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
.breadcrumb  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); display: flex; gap: 0.4rem; align-items: center; }
.bc-link  { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep   { color: var(--text-muted); }
.bc-current { color: var(--text-secondary); }
.header-actions { margin-left: auto; }
.btn-logout  { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.btn-ghost-sm { padding: 0.35rem 0.75rem; background: none; color: var(--text-secondary); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; text-decoration: none; }
.admin-main  { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
.form-section { display: flex; flex-direction: column; gap: 1.5rem; }
.form-title  { font-family: var(--font-mono); font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin: 0; }
.form-subtitle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.bc-form { display: flex; flex-direction: column; gap: 1.5rem; }
.form-group { display: flex; flex-direction: column; gap: 0.5rem; }
.form-label { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; }
.form-hint  { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); margin: 0; }
.form-input, .form-textarea {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem;
  color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm);
  padding: 0.625rem 0.875rem; outline: none; width: 100%;
}
.form-input:focus, .form-textarea:focus { border-color: var(--teal); }
.form-textarea { resize: vertical; line-height: 1.5; }
.form-actions { display: flex; gap: 0.75rem; align-items: center; }
.btn-submit { padding: 0.625rem 1.5rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 600; cursor: pointer; }
.btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }
.status-msg { padding: 0.75rem 1rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-xs); }
.status-msg--success { background: rgba(74,141,131,0.1); border: 1px solid rgba(74,141,131,0.3); color: var(--teal); }
.status-msg--error   { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); color: #ef4444; }
</style>
</Base>
