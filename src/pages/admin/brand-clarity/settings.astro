---
import Base from '@/components/layouts/Base.astro';
import { getBcSettings, BC_SETTINGS_DEFAULTS } from '@/lib/bc-settings';

let settings = BC_SETTINGS_DEFAULTS;
try {
  settings = await getBcSettings();
} catch (e) {
  console.error('[BC-Settings]', e);
}
---

<Base title="LLM Settings — Brand Clarity" description="Configure LLM provider and models for Brand Clarity pipeline">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/brand-clarity" class="bc-link">Brand Clarity</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">LLM Settings</span>
    </nav>
    <div class="header-actions">
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="admin-main">
    <section class="admin-section">
      <div class="section-header-row">
        <div class="section-title-block">
          <h2 class="section-title">⚙ LLM Settings</h2>
          <p class="section-subtitle">Provider · Modele · Max Tokens · Extended Thinking — klucze API zostają w <code>.env</code></p>
        </div>
      </div>

      <form id="settings-form" class="settings-form">

        <!-- Provider -->
        <div class="settings-card">
          <h3 class="card-title">Provider</h3>
          <div class="radio-group">
            <label class="radio-card">
              <input type="radio" name="provider" value="openrouter" checked={settings.provider === 'openrouter'} />
              <div class="radio-card-content">
                <span class="radio-card-label">OpenRouter</span>
                <span class="radio-card-desc">Routing przez OpenRouter. Wymaga OPENROUTER_API_KEY.</span>
              </div>
            </label>
            <label class="radio-card">
              <input type="radio" name="provider" value="anthropic" checked={settings.provider === 'anthropic'} />
              <div class="radio-card-content">
                <span class="radio-card-label">Anthropic Direct</span>
                <span class="radio-card-desc">Bezpośrednie Anthropic API. Wymaga ANTHROPIC_API_KEY. Obsługuje Extended Thinking.</span>
              </div>
            </label>
          </div>
        </div>

        <!-- Models -->
        <div class="settings-card" id="models-section">
          <h3 class="card-title">Modele <span class="badge">Anthropic</span></h3>
          <p class="card-note">Używane tylko gdy provider = Anthropic Direct.</p>
          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">LP Parser + Generator</label>
              <select name="lpModel" class="field-select">
                <option value="claude-opus-4-6" selected={settings.lpModel === 'claude-opus-4-6'}>claude-opus-4-6 (max quality, adaptive thinking)</option>
                <option value="claude-sonnet-4-6" selected={settings.lpModel === 'claude-sonnet-4-6'}>claude-sonnet-4-6 ★ (recommended)</option>
                <option value="claude-haiku-4-5-20251001" selected={settings.lpModel === 'claude-haiku-4-5-20251001'}>claude-haiku-4-5-20251001 (fast, cheap)</option>
              </select>
            </div>
            <div class="field-row">
              <label class="field-label">Scraper (bulk extraction)</label>
              <select name="scraperModel" class="field-select">
                <option value="claude-haiku-4-5-20251001" selected={settings.scraperModel === 'claude-haiku-4-5-20251001'}>claude-haiku-4-5-20251001 ★ (recommended)</option>
                <option value="claude-sonnet-4-6" selected={settings.scraperModel === 'claude-sonnet-4-6'}>claude-sonnet-4-6 (better quality)</option>
                <option value="claude-opus-4-6" selected={settings.scraperModel === 'claude-opus-4-6'}>claude-opus-4-6 (expensive for bulk)</option>
              </select>
            </div>
            <div class="field-row">
              <label class="field-label">Pain Clusterer</label>
              <select name="clusterModel" class="field-select">
                <option value="claude-opus-4-6" selected={settings.clusterModel === 'claude-opus-4-6'}>claude-opus-4-6 (max quality)</option>
                <option value="claude-sonnet-4-6" selected={settings.clusterModel === 'claude-sonnet-4-6'}>claude-sonnet-4-6 ★ (recommended)</option>
                <option value="claude-haiku-4-5-20251001" selected={settings.clusterModel === 'claude-haiku-4-5-20251001'}>claude-haiku-4-5-20251001 (fast)</option>
              </select>
            </div>
            <div class="field-row">
              <label class="field-label">LP Generator (HTML variants)</label>
              <select name="generatorModel" class="field-select">
                <option value="claude-opus-4-6" selected={settings.generatorModel === 'claude-opus-4-6'}>claude-opus-4-6 (max quality)</option>
                <option value="claude-sonnet-4-6" selected={settings.generatorModel === 'claude-sonnet-4-6'}>claude-sonnet-4-6 ★ (recommended)</option>
                <option value="claude-haiku-4-5-20251001" selected={settings.generatorModel === 'claude-haiku-4-5-20251001'}>claude-haiku-4-5-20251001 (fast)</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Max Tokens -->
        <div class="settings-card">
          <h3 class="card-title">Max Tokens per krok</h3>
          <p class="card-note">Maksymalna liczba tokenów odpowiedzi. Dotyczy obu providerów. Meta JSON call w generatorze zawsze używa 1000 (niezmienne).</p>
          <div class="field-grid">
            <div class="field-row">
              <label class="field-label">LP Parser</label>
              <input type="number" name="lpMaxTokens" class="field-input-num" min="512" max="16000" step="512" value={settings.lpMaxTokens} />
            </div>
            <div class="field-row">
              <label class="field-label">Scraper (per video)</label>
              <input type="number" name="scraperMaxTokens" class="field-input-num" min="512" max="8192" step="512" value={settings.scraperMaxTokens} />
            </div>
            <div class="field-row">
              <label class="field-label">Pain Clusterer</label>
              <input type="number" name="clusterMaxTokens" class="field-input-num" min="512" max="16000" step="512" value={settings.clusterMaxTokens} />
            </div>
            <div class="field-row">
              <label class="field-label">LP Generator (HTML)</label>
              <input type="number" name="generatorMaxTokens" class="field-input-num" min="512" max="16000" step="512" value={settings.generatorMaxTokens} />
            </div>
          </div>
        </div>

        <!-- Extended Thinking -->
        <div class="settings-card" id="thinking-section">
          <h3 class="card-title">Extended Thinking <span class="badge">Anthropic only</span></h3>
          <p class="card-note">Działa tylko z Anthropic Direct. Zwiększa jakość kosztem latency i tokenów.</p>
          <label class="toggle-row">
            <input type="checkbox" id="et-toggle" name="extendedThinkingEnabled" checked={settings.extendedThinkingEnabled} />
            <span class="toggle-label">Włącz Extended Thinking</span>
          </label>

          <div id="budgets-panel" class="budgets-panel">
            <div class="field-grid">
              <div class="field-row">
                <label class="field-label">LP Parser (budget tokens)</label>
                <input type="number" name="lpThinkingBudget" class="field-input-num" min="1024" max="32000" step="1000" value={settings.lpThinkingBudget} />
              </div>
              <div class="field-row">
                <label class="field-label">Scraper (budget tokens)</label>
                <input type="number" name="scraperThinkingBudget" class="field-input-num" min="1024" max="16000" step="1000" value={settings.scraperThinkingBudget} />
              </div>
              <div class="field-row">
                <label class="field-label">Clusterer (budget tokens)</label>
                <input type="number" name="clusterThinkingBudget" class="field-input-num" min="1024" max="64000" step="1000" value={settings.clusterThinkingBudget} />
              </div>
              <div class="field-row">
                <label class="field-label">Generator HTML (budget tokens)</label>
                <input type="number" name="generatorThinkingBudget" class="field-input-num" min="1024" max="64000" step="1000" value={settings.generatorThinkingBudget} />
              </div>
            </div>
            <p class="card-note" style="margin-top:0.5rem">⚠ Opus 4.6 ignoruje budżet — używa adaptive thinking automatycznie. Min: 1024.</p>
          </div>
        </div>

        <div class="settings-actions">
          <button type="submit" class="btn-primary" id="save-btn">Zapisz ustawienia</button>
          <span id="save-status" class="save-status"></span>
        </div>
      </form>
    </section>
  </main>
</div>
</Base>

<script>
  const form = document.getElementById('settings-form') as HTMLFormElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const saveStatus = document.getElementById('save-status') as HTMLSpanElement;
  const etToggle = document.getElementById('et-toggle') as HTMLInputElement;
  const budgetsPanel = document.getElementById('budgets-panel') as HTMLDivElement;
  const modelsSection = document.getElementById('models-section') as HTMLElement;
  const thinkingSection = document.getElementById('thinking-section') as HTMLElement;
  const providerRadios = document.querySelectorAll('input[name="provider"]') as NodeListOf<HTMLInputElement>;

  function updateVisibility() {
    const isAnthropic = [...providerRadios].find(r => r.checked)?.value === 'anthropic';
    modelsSection.style.opacity = isAnthropic ? '1' : '0.4';
    thinkingSection.style.opacity = isAnthropic ? '1' : '0.4';
    budgetsPanel.style.display = (isAnthropic && etToggle.checked) ? 'flex' : 'none';
  }

  providerRadios.forEach(r => r.addEventListener('change', updateVisibility));
  etToggle.addEventListener('change', updateVisibility);
  updateVisibility();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Zapisywanie…';
    saveStatus.className = 'save-status saving';

    const fd = new FormData(form);
    const payload = {
      provider: fd.get('provider'),
      lpModel: fd.get('lpModel'),
      scraperModel: fd.get('scraperModel'),
      clusterModel: fd.get('clusterModel'),
      generatorModel: fd.get('generatorModel'),
      extendedThinkingEnabled: etToggle.checked,
      lpMaxTokens: parseInt(String(fd.get('lpMaxTokens') || '6000'), 10),
      scraperMaxTokens: parseInt(String(fd.get('scraperMaxTokens') || '4096'), 10),
      clusterMaxTokens: parseInt(String(fd.get('clusterMaxTokens') || '3000'), 10),
      generatorMaxTokens: parseInt(String(fd.get('generatorMaxTokens') || '8192'), 10),
      lpThinkingBudget: parseInt(String(fd.get('lpThinkingBudget') || '10000'), 10),
      scraperThinkingBudget: parseInt(String(fd.get('scraperThinkingBudget') || '5000'), 10),
      clusterThinkingBudget: parseInt(String(fd.get('clusterThinkingBudget') || '16000'), 10),
      generatorThinkingBudget: parseInt(String(fd.get('generatorThinkingBudget') || '16000'), 10),
    };

    try {
      const res = await fetch('/api/brand-clarity/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        saveStatus.textContent = '✓ Zapisano';
        saveStatus.className = 'save-status ok';
      } else {
        const err = await res.json().catch(() => ({}));
        saveStatus.textContent = `Błąd: ${err.error || res.status}`;
        saveStatus.className = 'save-status error';
      }
    } catch (err: any) {
      saveStatus.textContent = `Błąd: ${err.message}`;
      saveStatus.className = 'save-status error';
    } finally {
      saveBtn.disabled = false;
      setTimeout(() => { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }, 4000);
    }
  });
</script>

<style>
.admin-layout { min-height: 100vh; background: var(--bg-base); }
.admin-header { display: flex; align-items: center; gap: 1.25rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 20; }
.admin-logo   { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
.breadcrumb   { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); display: flex; gap: 0.4rem; align-items: center; }
.bc-link  { color: var(--text-muted); text-decoration: none; }
.bc-link:hover { color: var(--teal); }
.bc-sep   { color: var(--text-muted); }
.bc-current { color: var(--text-secondary); }
.header-actions { margin-left: auto; }
.btn-logout  { padding: 0.35rem 0.75rem; color: var(--text-muted); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
.admin-main  { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

.admin-section { display: flex; flex-direction: column; gap: 1rem; }
.section-header-row { padding-bottom: 0.875rem; border-bottom: 1px solid var(--border); }
.section-title-block { display: flex; flex-direction: column; gap: 0.2rem; }
.section-title { font-family: var(--font-mono); font-size: 1rem; color: var(--text-primary); font-weight: 700; margin: 0; }
.section-subtitle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin: 0; }
.section-subtitle code { background: var(--bg-elevated); padding: 1px 5px; border-radius: 3px; }

.settings-form { display: flex; flex-direction: column; gap: 0.75rem; }
.settings-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.625rem; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; }
.card-title { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 700; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 0.5rem; }
.card-note  { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); margin: 0; line-height: 1.5; }
.badge { background: rgba(74,141,131,0.1); color: var(--teal); font-size: 0.65rem; padding: 1px 6px; border-radius: 0.2rem; font-weight: 500; border: 1px solid rgba(74,141,131,0.2); }

.radio-group { display: flex; flex-direction: column; gap: 0.5rem; }
.radio-card { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.75rem; background: var(--bg-base); border: 1px solid var(--border); border-radius: 0.375rem; cursor: pointer; transition: border-color 0.15s; }
.radio-card:has(input:checked) { border-color: var(--gold); background: rgba(214,183,121,0.04); }
.radio-card input { margin-top: 2px; accent-color: var(--gold); flex-shrink: 0; }
.radio-card-label { display: block; font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); font-size: var(--text-sm); }
.radio-card-desc  { display: block; font-family: var(--font-mono); color: var(--text-muted); font-size: 0.65rem; margin-top: 2px; }

.field-grid { display: flex; flex-direction: column; gap: 0.5rem; }
.field-row  { display: flex; align-items: center; gap: 1rem; }
.field-label { width: 200px; flex-shrink: 0; font-family: var(--font-mono); color: var(--text-secondary); font-size: var(--text-xs); }
.field-select { flex: 1; background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); padding: 0.4rem 0.625rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-xs); outline: none; }
.field-select:focus { border-color: var(--teal); }
.field-input-num { width: 110px; background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); padding: 0.4rem 0.625rem; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-xs); outline: none; }
.field-input-num:focus { border-color: var(--gold); }

.toggle-row { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }
.toggle-row input { width: 15px; height: 15px; accent-color: var(--gold); cursor: pointer; }
.toggle-label { font-family: var(--font-mono); color: var(--text-primary); font-size: var(--text-sm); }

.budgets-panel { display: flex; flex-direction: column; gap: 0.5rem; }

.settings-actions { display: flex; align-items: center; gap: 1rem; padding-top: 0.25rem; }
.btn-primary { padding: 0.5rem 1.25rem; background: var(--teal); color: #fff; border: none; border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
.btn-primary:hover { opacity: 0.9; }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
.save-status { font-family: var(--font-mono); font-size: var(--text-xs); }
.save-status.ok     { color: var(--teal); }
.save-status.error  { color: #ef4444; }
.save-status.saving { color: var(--text-muted); }
</style>
