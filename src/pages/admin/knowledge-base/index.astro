---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { knowledgeEntries } from '@/db/schema';
import { desc, asc, and, sql, ilike, or, eq } from 'drizzle-orm';

const url = new URL(Astro.request.url);
const tab       = url.searchParams.get('tab') || 'kb';       // 'kb' | 'articles' | 'folders'
const search    = url.searchParams.get('search') || '';
const typeFilter= url.searchParams.get('type') || '';
const project   = url.searchParams.get('project') || '';
const sort      = url.searchParams.get('sort') || 'importance';
const page      = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
const LIMIT     = 25;
const offset    = (page - 1) * LIMIT;

const KB_TYPES = ['project_spec', 'external_research', 'personal_note'];

const orderByMap: Record<string, any> = {
  importance : desc(knowledgeEntries.importanceScore),
  date_desc  : desc(knowledgeEntries.createdAt),
  date_asc   : asc(knowledgeEntries.createdAt),
  title_asc  : asc(knowledgeEntries.title),
};

let entries: any[]     = [];
let projects: string[] = [];
let total    = 0;
let stats    = { kb: 0, articles: 0, folders: 0 };
let folderStats: { name: string; count: number; topScore: number; types: string[] }[] = [];

try {
  const [kbStat, artStat, folderDistinct] = await Promise.all([
    db.select({ c: sql<number>`count(*)` }).from(knowledgeEntries)
      .where(sql`${knowledgeEntries.type} = ANY(ARRAY['project_spec','external_research','personal_note']::text[])`),
    db.select({ c: sql<number>`count(*)` }).from(knowledgeEntries)
      .where(eq(knowledgeEntries.type, 'published_article')),
    db.selectDistinct({ projectName: knowledgeEntries.projectName }).from(knowledgeEntries)
      .where(sql`${knowledgeEntries.projectName} IS NOT NULL`),
  ]);
  stats.kb       = Number(kbStat[0]?.c  || 0);
  stats.articles = Number(artStat[0]?.c || 0);
  stats.folders  = folderDistinct.length;

  if (tab === 'folders') {
    const [folderCounts, typeDist] = await Promise.all([
      db.select({
        projectName : knowledgeEntries.projectName,
        count       : sql<number>`count(*)`,
        topScore    : sql<number>`max(${knowledgeEntries.importanceScore})`,
      }).from(knowledgeEntries)
        .where(sql`${knowledgeEntries.projectName} IS NOT NULL`)
        .groupBy(knowledgeEntries.projectName)
        .orderBy(asc(knowledgeEntries.projectName)),
      db.selectDistinct({ projectName: knowledgeEntries.projectName, type: knowledgeEntries.type })
        .from(knowledgeEntries)
        .where(sql`${knowledgeEntries.projectName} IS NOT NULL`),
    ]);
    const typeMap: Record<string, Set<string>> = {};
    for (const r of typeDist) {
      if (r.projectName) {
        if (!typeMap[r.projectName]) typeMap[r.projectName] = new Set();
        typeMap[r.projectName].add(r.type);
      }
    }
    folderStats = folderCounts.map(f => ({
      name     : f.projectName!,
      count    : Number(f.count),
      topScore : Number(f.topScore),
      types    : Array.from(typeMap[f.projectName!] || []),
    }));
  } else {
    const conditions: any[] = [];
    if (tab === 'kb') {
      conditions.push(sql`${knowledgeEntries.type} = ANY(ARRAY['project_spec','external_research','personal_note']::text[])`);
      if (typeFilter && KB_TYPES.includes(typeFilter)) conditions.push(eq(knowledgeEntries.type, typeFilter));
    } else if (tab === 'articles') {
      conditions.push(eq(knowledgeEntries.type, 'published_article'));
    }
    if (project) conditions.push(eq(knowledgeEntries.projectName, project));
    if (search)  conditions.push(or(ilike(knowledgeEntries.title, `%${search}%`), ilike(knowledgeEntries.content, `%${search}%`)));

    const where   = conditions.length ? and(...conditions) : undefined;
    const orderBy = orderByMap[sort] || orderByMap.importance;

    const [rows, counts, distinctProjects] = await Promise.all([
      db.select().from(knowledgeEntries).where(where).orderBy(orderBy).limit(LIMIT).offset(offset),
      db.select({ c: sql<number>`count(*)` }).from(knowledgeEntries).where(where),
      db.selectDistinct({ projectName: knowledgeEntries.projectName })
        .from(knowledgeEntries)
        .where(sql`${knowledgeEntries.projectName} IS NOT NULL`)
        .orderBy(asc(knowledgeEntries.projectName)),
    ]);
    entries  = rows;
    total    = Number(counts[0]?.c || 0);
    projects = distinctProjects.map(p => p.projectName).filter(Boolean) as string[];
  }
} catch (e) {
  console.error('[KB Panel]', e);
}

const totalPages = Math.ceil(total / LIMIT);

function buildUrl(overrides: Record<string, string>) {
  const u = new URL(url.toString());
  u.searchParams.delete('page');
  for (const [k, v] of Object.entries(overrides)) {
    if (v) u.searchParams.set(k, v);
    else   u.searchParams.delete(k);
  }
  return u.pathname + u.search;
}

function sortUrl(s: string) {
  return buildUrl({ sort: s, tab, search, type: typeFilter, project });
}

function pageUrl(p: number) {
  const u = new URL(url.toString());
  u.searchParams.set('page', String(p));
  return u.pathname + u.search;
}

const TYPE_LABELS: Record<string, string> = {
  project_spec      : 'Project Spec',
  published_article : 'Publ. Article',
  external_research : 'Ext. Research',
  personal_note     : 'Personal Note',
};

const sortLabel: Record<string, string> = {
  importance : 'Score ↓',
  date_desc  : 'Newest',
  date_asc   : 'Oldest',
  title_asc  : 'Title A-Z',
};

// Serialize entries for client-side preview (truncate content)
const entriesJson = JSON.stringify(entries.map(e => ({
  id            : e.id,
  type          : e.type,
  title         : e.title,
  projectName   : e.projectName,
  importanceScore: e.importanceScore,
  tags          : e.tags,
  sourceUrl     : e.sourceUrl,
  createdAt     : e.createdAt,
  updatedAt     : e.updatedAt,
  preview       : (e.content || '').slice(0, 900),
  contentLength : (e.content || '').length,
})));
---

<Base title="Knowledge Base — Admin">

<!-- ===================== PREVIEW SLIDE-OVER ===================== -->
<div id="preview-backdrop" class="preview-backdrop" style="display:none"></div>
<aside id="preview-panel" class="preview-panel" style="display:none" aria-label="Entry preview">
  <div class="preview-header">
    <div id="prev-type-badge" class="type-badge"></div>
    <div class="preview-header-actions">
      <a id="prev-edit-link" href="#" class="prev-btn-edit">Edit</a>
      <a id="prev-full-link" href="#" class="prev-btn-full">Full view →</a>
      <button id="preview-close" class="preview-close" aria-label="Close">✕</button>
    </div>
  </div>
  <div class="preview-body">
    <h2 id="prev-title" class="prev-title"></h2>
    <div class="prev-meta-row">
      <span id="prev-folder" class="prev-meta-item" style="display:none"></span>
      <span id="prev-score" class="prev-meta-item"></span>
      <span id="prev-date"  class="prev-meta-item"></span>
    </div>
    <div id="prev-tags" class="prev-tags"></div>
    <div id="prev-url-row" class="prev-url-row" style="display:none">
      <span class="prev-meta-label">Source:</span>
      <a id="prev-url" href="#" target="_blank" rel="noopener" class="prev-url-link"></a>
    </div>
    <div class="prev-content-label">Content</div>
    <div id="prev-content" class="prev-content"></div>
    <div id="prev-truncated" class="prev-truncated" style="display:none">
      … <a id="prev-truncated-link" href="#">Open full view</a> to see all content
    </div>
  </div>
</aside>

<!-- ===================== MAIN LAYOUT ===================== -->
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="header-nav" aria-label="breadcrumb">
      <a href="/admin" class="breadcrumb-link">Admin</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">Knowledge Base</span>
    </nav>
    <div class="header-actions">
      <a href="/admin/knowledge-base/create" class="btn-primary">+ New Entry</a>
      <a href="/admin/knowledge-base/import" class="btn-ghost">Import .md</a>
      <a href="/api/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="page-main">

    <!-- STATS BANNER -->
    <section class="stats-banner" aria-label="Knowledge Base Stats">
      <a href={buildUrl({ tab: 'kb', search: '', type: '', project: '' })} class={`stat-card ${tab === 'kb' ? 'stat-card--active-kb' : ''}`}>
        <span class="stat-card-number">{stats.kb}</span>
        <span class="stat-card-label">Knowledge Base</span>
        <span class="stat-card-sub">proj_spec · research · notes</span>
      </a>
      <div class="stat-divider"></div>
      <a href={buildUrl({ tab: 'articles', search: '', type: '', project: '' })} class={`stat-card ${tab === 'articles' ? 'stat-card--active-art' : ''}`}>
        <span class="stat-card-number">{stats.articles}</span>
        <span class="stat-card-label">Published Articles</span>
        <span class="stat-card-sub">published_article in KB</span>
      </a>
      <div class="stat-divider"></div>
      <a href={buildUrl({ tab: 'folders', search: '', type: '', project: '' })} class={`stat-card ${tab === 'folders' ? 'stat-card--active-fold' : ''}`}>
        <span class="stat-card-number">{stats.folders}</span>
        <span class="stat-card-label">Folders</span>
        <span class="stat-card-sub">project groups</span>
      </a>
    </section>

    <!-- TAB BAR -->
    <nav class="tab-bar" role="tablist" aria-label="Knowledge Base views">
      <a href={buildUrl({ tab: 'kb', page: '' })}       role="tab" aria-selected={tab === 'kb'}       class={`tab-link ${tab === 'kb'       ? 'tab-link--active tab-link--kb' : ''}`}>
        📚 Knowledge Base <span class="tab-count">{stats.kb}</span>
      </a>
      <a href={buildUrl({ tab: 'articles', page: '' })} role="tab" aria-selected={tab === 'articles'} class={`tab-link ${tab === 'articles' ? 'tab-link--active tab-link--art' : ''}`}>
        📝 Published <span class="tab-count">{stats.articles}</span>
      </a>
      <a href={buildUrl({ tab: 'folders', page: '' })}  role="tab" aria-selected={tab === 'folders'}  class={`tab-link ${tab === 'folders'  ? 'tab-link--active tab-link--fold' : ''}`}>
        📁 Folders <span class="tab-count">{stats.folders}</span>
      </a>
    </nav>

    <!-- SEPARATOR between KB and Articles tabs (visual) -->
    {tab !== 'folders' && (
      <div class={`section-header ${tab === 'articles' ? 'section-header--articles' : 'section-header--kb'}`}>
        {tab === 'kb' && (
          <div class="section-header-inner">
            <div class="section-badge section-badge--kb">🧠 MY KNOWLEDGE BASE</div>
            <p class="section-desc">Private notes, project specs, external research — context for the AI article generator.</p>
          </div>
        )}
        {tab === 'articles' && (
          <div class="section-header-inner">
            <div class="section-badge section-badge--art">📰 PUBLISHED ARTICLES</div>
            <p class="section-desc">Already published articles — KB entries representing blog/web content.</p>
          </div>
        )}
      </div>
    )}

    <!-- ======= FOLDERS TAB ======= -->
    {tab === 'folders' && (
      <div>
        {folderStats.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon">📁</div>
            <p>No folders. Assign <strong>project_name</strong> to KB entries to see them here.</p>
          </div>
        ) : (
          <div class="folder-grid">
            {folderStats.map(f => (
              <a href={buildUrl({ tab: 'kb', project: f.name, search: '', type: '' })} class="folder-card">
                <div class="folder-card-icon">📁</div>
                <div class="folder-card-name">{f.name}</div>
                <div class="folder-card-count">{f.count} {f.count === 1 ? 'entry' : 'entries'}</div>
                <div class="folder-card-types">
                  {f.types.map(t => (
                    <span class={`type-badge type-badge--xs type-${t}`}>{TYPE_LABELS[t] || t}</span>
                  ))}
                </div>
                <div class="folder-card-score">
                  <div class="score-bar-sm">
                    <div class="score-fill-sm" style={`width:${f.topScore}%`}></div>
                  </div>
                  <span class="score-num-sm">top {f.topScore}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- ======= TABLE TABS (kb / articles) ======= -->
    {tab !== 'folders' && (
      <div>
        <!-- FILTERS ROW -->
        <form method="GET" class="filters-row">
          <input type="hidden" name="tab" value={tab} />
          <input
            type="text" name="search" value={search}
            placeholder={tab === 'kb' ? 'Search KB…' : 'Search articles…'}
            class="filter-input filter-input--search"
          />
          {tab === 'kb' && (
            <select name="type" class="filter-input">
              <option value="">All types</option>
              <option value="project_spec"      selected={typeFilter === 'project_spec'}>Project Spec</option>
              <option value="external_research" selected={typeFilter === 'external_research'}>External Research</option>
              <option value="personal_note"     selected={typeFilter === 'personal_note'}>Personal Note</option>
            </select>
          )}
          <select name="project" class="filter-input">
            <option value="">All folders</option>
            {projects.map(p => (
              <option value={p} selected={project === p}>📁 {p}</option>
            ))}
          </select>
          <select name="sort" class="filter-input">
            <option value="importance" selected={sort === 'importance'}>Sort: Score ↓</option>
            <option value="date_desc"  selected={sort === 'date_desc'}>Sort: Newest</option>
            <option value="date_asc"   selected={sort === 'date_asc'}>Sort: Oldest</option>
            <option value="title_asc"  selected={sort === 'title_asc'}>Sort: Title A-Z</option>
          </select>
          <button type="submit" class="btn-primary-sm">Search</button>
          {(search || typeFilter || project) && (
            <a href={buildUrl({ tab, search: '', type: '', project: '' })} class="btn-ghost-sm">Clear</a>
          )}
        </form>

        <!-- RESULTS META -->
        <div class="results-meta">
          <span class="results-count">
            {total === 0 ? 'No results' : `${total} ${total === 1 ? 'entry' : 'entries'}`}
          </span>
          {project && (
            <span class="filter-badge filter-badge--folder">
              📁 {project}
              <a href={buildUrl({ tab, project: '' })} class="badge-remove" aria-label="Remove folder filter">✕</a>
            </span>
          )}
          {typeFilter && (
            <span class="filter-badge filter-badge--type">
              {TYPE_LABELS[typeFilter] || typeFilter}
              <a href={buildUrl({ tab, type: '' })} class="badge-remove" aria-label="Remove type filter">✕</a>
            </span>
          )}
          {search && (
            <span class="filter-badge filter-badge--search">
              "{search}"
              <a href={buildUrl({ tab, search: '' })} class="badge-remove" aria-label="Remove search filter">✕</a>
            </span>
          )}
          <span class="results-sort">— {sortLabel[sort] || sort}</span>
        </div>

        <!-- DATA TABLE -->
        <div class="table-wrapper">
          <table class="data-table" id="kb-table">
            <thead>
              <tr>
                <th class="th-title">
                  <a href={sortUrl('title_asc')} class={`sort-link ${sort === 'title_asc' ? 'sort-link--active' : ''}`}>Title</a>
                </th>
                {tab === 'kb' && <th class="th-type">Type</th>}
                <th class="th-folder">Folder</th>
                <th class="th-score">
                  <a href={sortUrl('importance')} class={`sort-link ${sort === 'importance' ? 'sort-link--active' : ''}`}>Score</a>
                </th>
                <th class="th-tags">Tags</th>
                <th class="th-date">
                  <a href={sortUrl('date_desc')} class={`sort-link ${sort === 'date_desc' || sort === 'date_asc' ? 'sort-link--active' : ''}`}>Date</a>
                </th>
                <th class="th-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              {entries.map(e => (
                <tr class="entry-row" data-id={e.id}>
                  <td class="td-title">
                    <button class="entry-title-btn" data-preview-id={e.id}>{e.title}</button>
                  </td>
                  {tab === 'kb' && (
                    <td class="td-type">
                      <span class={`type-badge type-${e.type}`}>{TYPE_LABELS[e.type] || e.type}</span>
                    </td>
                  )}
                  <td class="td-folder">
                    {e.projectName
                      ? <a href={buildUrl({ tab, project: e.projectName })} class="folder-link">📁 {e.projectName}</a>
                      : <span class="no-folder">—</span>
                    }
                  </td>
                  <td class="td-score">
                    <div class="score-bar">
                      <div class="score-fill" style={`width:${e.importanceScore}%`}></div>
                    </div>
                    <span class="score-num">{e.importanceScore}</span>
                  </td>
                  <td class="td-tags">
                    {(e.tags || []).slice(0, 3).map((t: string) => (
                      <span class="tag">{t}</span>
                    ))}
                    {(e.tags || []).length > 3 && <span class="tag-more">+{e.tags.length - 3}</span>}
                  </td>
                  <td class="td-date">
                    {new Date(e.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: '2-digit' })}
                  </td>
                  <td class="td-actions">
                    <button class="action-btn action-btn--preview" data-preview-id={e.id} title="Preview">👁</button>
                    <a href={`/admin/knowledge-base/${e.id}`} class="action-btn action-btn--edit" title="Edit / full view">✏️</a>
                    <button class="action-btn action-btn--delete" data-delete-id={e.id} data-delete-title={e.title} title="Delete">🗑</button>
                  </td>
                </tr>
              ))}
              {entries.length === 0 && (
                <tr>
                  <td colspan="7" class="td-empty">
                    <div class="empty-state-inline">
                      {search || typeFilter || project
                        ? <>No results for these filters. <a href={buildUrl({ tab, search: '', type: '', project: '' })}>Clear filters</a></>
                        : <>{tab === 'kb'
                            ? <>Knowledge base is empty. <a href="/admin/knowledge-base/create">Create entry</a> or <a href="/admin/knowledge-base/import">import .md</a></>
                            : <>No entries of type "published_article". <a href="/admin/knowledge-base/create">Add article to KB</a></>
                          }</>
                      }
                    </div>
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        {totalPages > 1 && (
          <nav class="pagination" aria-label="Pagination">
            {page > 1 && <a href={pageUrl(1)}      class="page-btn page-btn--edge">«</a>}
            {page > 1 && <a href={pageUrl(page - 1)} class="page-btn">‹ Previous</a>}
            <span class="page-info">Page {page} of {totalPages} ({total} entries)</span>
            {page < totalPages && <a href={pageUrl(page + 1)} class="page-btn">Next ›</a>}
            {page < totalPages && <a href={pageUrl(totalPages)} class="page-btn page-btn--edge">»</a>}
          </nav>
        )}
      </div>
    )}

  </main>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div id="delete-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
  <div class="modal-box">
    <h3 id="delete-modal-title" class="modal-title">Delete KB Entry</h3>
    <p class="modal-desc">Are you sure you want to delete this entry:</p>
    <p id="delete-modal-entry" class="modal-entry-name"></p>
    <p class="modal-warn">This action cannot be undone.</p>
    <div class="modal-actions">
      <button id="delete-confirm-btn" class="btn-danger">Delete permanently</button>
      <button id="delete-cancel-btn"  class="btn-ghost-sm">Cancel</button>
    </div>
  </div>
</div>

<!-- ====== ENTRIES DATA FOR CLIENT-SIDE PREVIEW ====== -->
<script type="application/json" id="entries-data" set:html={entriesJson}></script>

<script>
  // ---- DATA ----
  const ENTRIES_MAP: Record<number, any> = {};
  try {
    const raw = document.getElementById('entries-data')?.textContent || '[]';
    for (const e of JSON.parse(raw)) ENTRIES_MAP[e.id] = e;
  } catch {}

  const TYPE_LABELS: Record<string, string> = {
    project_spec      : '📐 Project Spec',
    published_article : '📰 Published Article',
    external_research : '🔬 External Research',
    personal_note     : '📓 Personal Note',
  };

  // ---- PREVIEW ----
  const backdrop   = document.getElementById('preview-backdrop')!;
  const panel      = document.getElementById('preview-panel')!;
  const closeBtn   = document.getElementById('preview-close')!;

  function openPreview(id: number) {
    const e = ENTRIES_MAP[id];
    if (!e) return;

    (document.getElementById('prev-title') as HTMLElement).textContent = e.title;

    const typeBadge = document.getElementById('prev-type-badge')!;
    typeBadge.textContent = TYPE_LABELS[e.type] || e.type;
    typeBadge.className = `type-badge type-${e.type}`;

    const folderEl = document.getElementById('prev-folder')!;
    if (e.projectName) {
      folderEl.textContent = `📁 ${e.projectName}`;
      folderEl.style.display = 'inline-flex';
    } else {
      folderEl.style.display = 'none';
    }

    (document.getElementById('prev-score') as HTMLElement).textContent = `Score: ${e.importanceScore}/100`;
    const d = new Date(e.createdAt);
    (document.getElementById('prev-date') as HTMLElement).textContent =
      d.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' });

    const tagsEl = document.getElementById('prev-tags')!;
    tagsEl.innerHTML = (e.tags || []).map((t: string) => `<span class="tag">${t}</span>`).join('');

    const urlRow = document.getElementById('prev-url-row')!;
    const urlLink = document.getElementById('prev-url') as HTMLAnchorElement;
    if (e.sourceUrl) {
      urlLink.href = e.sourceUrl;
      urlLink.textContent = e.sourceUrl;
      urlRow.style.display = 'flex';
    } else {
      urlRow.style.display = 'none';
    }

    const contentEl = document.getElementById('prev-content')!;
    contentEl.textContent = e.preview;

    const truncEl   = document.getElementById('prev-truncated')!;
    const truncLink = document.getElementById('prev-truncated-link') as HTMLAnchorElement;
    if (e.contentLength > 900) {
      truncLink.href = `/admin/knowledge-base/${e.id}`;
      truncEl.style.display = 'block';
    } else {
      truncEl.style.display = 'none';
    }

    (document.getElementById('prev-edit-link') as HTMLAnchorElement).href = `/admin/knowledge-base/${e.id}`;
    (document.getElementById('prev-full-link') as HTMLAnchorElement).href = `/admin/knowledge-base/${e.id}`;

    backdrop.style.display = 'block';
    panel.style.display    = 'flex';
    requestAnimationFrame(() => { panel.classList.add('preview-panel--open'); });
    document.body.style.overflow = 'hidden';
  }

  function closePreview() {
    panel.classList.remove('preview-panel--open');
    setTimeout(() => {
      panel.style.display    = 'none';
      backdrop.style.display = 'none';
    }, 250);
    document.body.style.overflow = '';
  }

  // Preview triggers
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-preview-id]');
    if (btn) {
      const id = parseInt((btn as HTMLElement).dataset.previewId || '0', 10);
      if (id > 0) openPreview(id);
    }
  });
  closeBtn.addEventListener('click', closePreview);
  backdrop.addEventListener('click', closePreview);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePreview(); });

  // ---- DELETE ----
  let pendingDeleteId: number | null = null;
  const deleteModal    = document.getElementById('delete-modal')!;
  const deleteConfirm  = document.getElementById('delete-confirm-btn')!;
  const deleteCancel   = document.getElementById('delete-cancel-btn')!;
  const deleteEntryEl  = document.getElementById('delete-modal-entry')!;

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-delete-id]');
    if (btn) {
      const el = btn as HTMLElement;
      pendingDeleteId = parseInt(el.dataset.deleteId || '0', 10);
      deleteEntryEl.textContent = `"${el.dataset.deleteTitle || 'Ten wpis'}"`;
      deleteModal.style.display = 'flex';
    }
  });

  deleteCancel.addEventListener('click', () => {
    deleteModal.style.display = 'none';
    pendingDeleteId = null;
  });

  deleteConfirm.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    deleteConfirm.textContent = 'Deleting…';
    deleteConfirm.setAttribute('disabled', 'true');
    try {
      const res = await fetch(`/api/knowledge-base/${pendingDeleteId}`, { method: 'DELETE' });
      if (res.ok) {
        const row = document.querySelector(`[data-id="${pendingDeleteId}"]`);
        row?.remove();
        deleteModal.style.display = 'none';
        pendingDeleteId = null;
        deleteConfirm.textContent = 'Delete permanently';
        deleteConfirm.removeAttribute('disabled');
      } else {
        const err = await res.json();
        alert('Delete failed: ' + (err.error || 'Unknown error'));
        deleteConfirm.textContent = 'Delete permanently';
        deleteConfirm.removeAttribute('disabled');
      }
    } catch {
      alert('Network error. Please try again.');
      deleteConfirm.textContent = 'Delete permanently';
      deleteConfirm.removeAttribute('disabled');
    }
  });
</script>

