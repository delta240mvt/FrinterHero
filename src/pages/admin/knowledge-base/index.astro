---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { knowledgeEntries } from '@/db/schema';
import { desc, and, sql, ilike, or } from 'drizzle-orm';

const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const typeFilter = url.searchParams.get('type') || '';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
const limit = 20;
const offset = (page - 1) * limit;

let entries: any[] = [];
let total = 0;

try {
  const conditions: any[] = [];
  if (typeFilter) conditions.push(sql`${knowledgeEntries.type} = ${typeFilter}`);
  if (search) conditions.push(or(
    ilike(knowledgeEntries.title, `%${search}%`),
    ilike(knowledgeEntries.content, `%${search}%`)
  ));
  const where = conditions.length > 0 ? and(...conditions) : undefined;

  const [rows, counts] = await Promise.all([
    db.select().from(knowledgeEntries).where(where).orderBy(desc(knowledgeEntries.importanceScore)).limit(limit).offset(offset),
    db.select({ count: sql<number>`count(*)` }).from(knowledgeEntries).where(where),
  ]);
  entries = rows;
  total = Number(counts[0]?.count || 0);
} catch {}

const totalPages = Math.ceil(total / limit);
---

<Base title="Knowledge Base — Admin">
  <div class="admin-layout">
    <header class="admin-header">
      <a href="/admin" class="admin-logo">P·F</a>
      <h1 class="admin-title">Knowledge Base</h1>
      <div style="margin-left:auto;display:flex;gap:0.75rem">
        <a href="/admin/knowledge-base/create" class="btn-primary-sm">+ New Entry</a>
        <a href="/admin/knowledge-base/import" class="btn-ghost-sm">Import .md</a>
        <a href="/api/logout" class="logout-btn">Logout</a>
      </div>
    </header>
    <main class="page-main">
      <form method="GET" class="filters-row">
        <input type="text" name="search" placeholder="Search entries..." value={search} class="filter-input" />
        <select name="type" class="filter-input">
          <option value="">All types</option>
          <option value="project_spec" selected={typeFilter==='project_spec'}>Project Spec</option>
          <option value="published_article" selected={typeFilter==='published_article'}>Published Article</option>
          <option value="external_research" selected={typeFilter==='external_research'}>External Research</option>
          <option value="personal_note" selected={typeFilter==='personal_note'}>Personal Note</option>
        </select>
        <button type="submit" class="btn-primary-sm">Search</button>
        {(search || typeFilter) && <a href="/admin/knowledge-base" class="btn-ghost-sm">Clear</a>}
      </form>

      <div class="stats-bar">
        <span class="stat">{total} entries total</span>
        {typeFilter && <span class="stat-badge">{typeFilter.replace('_',' ')}</span>}
      </div>

      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Type</th>
              <th>Score</th>
              <th>Tags</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            {entries.map(e => (
              <tr>
                <td class="title-cell">
                  <span class="entry-title">{e.title}</span>
                </td>
                <td><span class={`type-badge type-${e.type}`}>{e.type.replace(/_/g,' ')}</span></td>
                <td>
                  <div class="score-bar">
                    <div class="score-fill" style={`width:${e.importanceScore}%`}></div>
                    <span class="score-label">{e.importanceScore}</span>
                  </div>
                </td>
                <td class="tags-cell">{(e.tags || []).slice(0,3).map((t: string) => <span class="tag">{t}</span>)}</td>
                <td class="date-cell">{new Date(e.createdAt).toLocaleDateString('pl-PL')}</td>
              </tr>
            ))}
            {entries.length === 0 && (
              <tr><td colspan={5} class="empty-state">No entries found. <a href="/admin/knowledge-base/create">Create first entry</a> or <a href="/admin/knowledge-base/import">import .md files</a>.</td></tr>
            )}
          </tbody>
        </table>
      </div>

      {totalPages > 1 && (
        <div class="pagination">
          {page > 1 && <a href={`?page=${page-1}&search=${search}&type=${typeFilter}`} class="page-btn">← Prev</a>}
          <span class="page-info">Page {page} of {totalPages}</span>
          {page < totalPages && <a href={`?page=${page+1}&search=${search}&type=${typeFilter}`} class="page-btn">Next →</a>}
        </div>
      )}
    </main>
  </div>
</Base>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1.5rem; padding: 0.875rem 1.5rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: var(--font-mono); font-weight: 700; color: var(--teal); text-decoration: none; font-size: 1.1rem; }
  .admin-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-secondary); }
  .logout-btn { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; }
  .btn-primary-sm { padding: 0.35rem 0.875rem; background: var(--teal); color: #fff; border: none; border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; text-decoration: none; }
  .btn-ghost-sm { padding: 0.35rem 0.875rem; background: none; color: var(--text-secondary); border: 1px solid var(--border); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
  .page-main { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
  .filters-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .filter-input { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.375rem; color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-sm); padding: 0.5rem 0.75rem; outline: none; }
  .filter-input:focus { border-color: var(--teal); }
  .stats-bar { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1rem; }
  .stat { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); }
  .stat-badge { padding: 0.2rem 0.5rem; background: rgba(74,141,131,0.15); color: var(--teal); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); }
  .table-wrapper { overflow-x: auto; border: 1px solid var(--border); border-radius: 0.5rem; }
  .data-table { width: 100%; border-collapse: collapse; }
  .data-table th { padding: 0.75rem 1rem; text-align: left; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
  .data-table td { padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: rgba(255,255,255,0.02); }
  .entry-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-primary); }
  .type-badge { padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; }
  .type-project_spec { background: rgba(74,141,131,0.2); color: var(--teal); }
  .type-published_article { background: rgba(138,78,100,0.2); color: var(--violet); }
  .type-external_research { background: rgba(214,183,121,0.2); color: var(--gold); }
  .type-personal_note { background: rgba(148,163,184,0.15); color: var(--text-secondary); }
  .score-bar { display: flex; align-items: center; gap: 0.5rem; }
  .score-fill { height: 4px; background: var(--teal); border-radius: 2px; min-width: 2px; max-width: 80px; }
  .score-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .tags-cell { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .tag { padding: 0.1rem 0.4rem; background: rgba(255,255,255,0.06); border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); }
  .date-cell { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); white-space: nowrap; }
  .empty-state { text-align: center; color: var(--text-muted); font-family: var(--font-mono); font-size: var(--text-sm); padding: 3rem !important; }
  .empty-state a { color: var(--teal); }
  .pagination { display: flex; gap: 1rem; align-items: center; justify-content: center; margin-top: 1.5rem; }
  .page-btn { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--teal); text-decoration: none; padding: 0.4rem 0.875rem; border: 1px solid rgba(74,141,131,0.3); border-radius: 0.25rem; }
  .page-info { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
</style>
