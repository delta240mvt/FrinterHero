---
import Base from '@/components/layouts/Base.astro';
import { db } from '@/db/client';
import { ytTargets } from '@/db/schema';
import { desc } from 'drizzle-orm';

const session = Astro.cookies.get('session')?.value;
if (!session) return Astro.redirect('/admin/login');

const targets = await db.select().from(ytTargets).orderBy(desc(ytTargets.priority));
---

<Base title="YouTube Targets — Admin" description="Manage YouTube scraping targets">
<div class="admin-layout">
  <header class="admin-header">
    <a href="/admin" class="admin-logo">P·F</a>
    <nav class="breadcrumb">
      <a href="/admin" class="bc-link">Admin</a>
      <span class="bc-sep">›</span>
      <a href="/admin/youtube" class="bc-link">YouTube Intelligence</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">Targets</span>
    </nav>
    <a href="/api/logout" class="btn-logout">Logout</a>
  </header>

  <main class="admin-main">
    <h1 class="page-title">YouTube Scraping Targets</h1>

    <!-- TYPE TABS -->
    <div class="type-tabs">
      <button class="type-tab active" id="tab-channel" onclick="switchTab('channel')">
        📺 Channel <span class="tab-hint">recommended</span>
      </button>
      <button class="type-tab" id="tab-video" onclick="switchTab('video')">
        ▶ Single Video
      </button>
    </div>

    <!-- ADD FORM — CHANNEL -->
    <div class="add-form-wrap" id="form-channel">
      <h2 class="section-title">Add Channel Target</h2>
      <p class="form-hint">System will automatically discover top <strong>N most popular videos</strong> from the channel and scrape their comments.</p>
      <form id="add-form-channel" class="add-form">
        <input type="hidden" name="type" value="channel" />
        <input name="url" class="form-input url-input"
          placeholder="https://www.youtube.com/@channelhandle" required />
        <input name="label" class="form-input" placeholder="Channel label" required />
        <input name="maxVideosPerChannel" type="number" class="form-input mv-input"
          placeholder="5" min="1" max="20" value="5" title="Max videos to scrape per channel" />
        <input name="maxComments" type="number" class="form-input mc-input"
          placeholder="300" min="10" max="2000" value="300" title="Max comments per video" />
        <input name="priority" type="number" class="form-input priority-input"
          placeholder="50" min="0" max="100" value="50" />
        <button type="submit" class="btn-add">Add Channel</button>
      </form>

      <div class="presets">
        <span class="presets-label">Quick add:</span>
        {[
          { label: 'Ali Abdaal',        url: 'https://www.youtube.com/@aliabdaal' },
          { label: 'Huberman Lab',      url: 'https://www.youtube.com/@hubermanlab' },
          { label: 'Cal Newport',       url: 'https://www.youtube.com/@CalNewportMedia' },
          { label: 'Thomas Frank',      url: 'https://www.youtube.com/@Thomasfrank' },
          { label: 'Andrew Kirby',      url: 'https://www.youtube.com/@AndrewKirby' },
          { label: 'Matt D\'Avella',    url: 'https://www.youtube.com/@mattdavella' },
          { label: 'Better Ideas',      url: 'https://www.youtube.com/@betterideas' },
          { label: 'Mike and Matty',    url: 'https://www.youtube.com/@MikeandMatty' },
          { label: 'Rian Doris',        url: 'https://www.youtube.com/@RianDoris' },
          { label: 'Improvement Pill',  url: 'https://www.youtube.com/@ImprovementPill' },
        ].map(preset => (
          <button class="preset-btn" onclick={`quickAddChannel('${preset.url}', '${preset.label}')`}>{preset.label}</button>
        ))}
      </div>
    </div>

    <!-- ADD FORM — VIDEO -->
    <div class="add-form-wrap" id="form-video" style="display:none">
      <h2 class="section-title">Add Single Video Target</h2>
      <p class="form-hint">Scrape comments from one specific video URL.</p>
      <form id="add-form-video" class="add-form">
        <input type="hidden" name="type" value="video" />
        <input name="url" class="form-input url-input"
          placeholder="https://www.youtube.com/watch?v=..." required />
        <input name="label" class="form-input" placeholder="Display label" required />
        <input name="maxComments" type="number" class="form-input mc-input"
          placeholder="300" min="10" max="2000" value="300" />
        <input name="priority" type="number" class="form-input priority-input"
          placeholder="50" min="0" max="100" value="50" />
        <button type="submit" class="btn-add">Add Video</button>
      </form>
    </div>

    <!-- TARGETS TABLE -->
    <div class="targets-table-wrap">
      <div class="bulk-actions">
        <button class="bulk-btn" onclick="selectAll()">Select All</button>
        <button class="bulk-btn" onclick="deselectAll()">Deselect All</button>
      </div>
      <table class="targets-table" id="targets-table">
        <thead>
          <tr>
            <th><input type="checkbox" id="check-all" onchange="toggleCheckAll(this)" /></th>
            <th>Type</th>
            <th>Label</th>
            <th>URL / Handle</th>
            <th>Videos</th>
            <th>Max Comments</th>
            <th>Priority</th>
            <th>Active</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {targets.map(t => (
            <tr id={`trow-${t.id}`}>
              <td><input type="checkbox" class="row-check" data-id={t.id} /></td>
              <td>
                <span class={`type-badge type-badge--${t.type}`}>
                  {t.type === 'channel' ? '📺' : '▶'} {t.type}
                </span>
              </td>
              <td class="td-label">{t.label}</td>
              <td class="td-value">
                {t.type === 'channel' && t.channelHandle
                  ? <span class="handle-tag">@{t.channelHandle}</span>
                  : (
                    <a href={t.url} target="_blank" rel="noopener" class="url-link">
                      {t.url.substring(0, 40)}{t.url.length > 40 ? '...' : ''}
                    </a>
                  )
                }
              </td>
              <td class="td-center">
                {t.type === 'channel' ? t.maxVideosPerChannel : '—'}
              </td>
              <td class="td-center">{t.maxComments}</td>
              <td class="td-center">{t.priority}</td>
              <td>
                <button
                  class={`toggle-btn ${t.isActive ? 'active' : 'inactive'}`}
                  onclick={`toggleTarget(${t.id}, ${!t.isActive})`}
                >
                  {t.isActive ? 'ON' : 'OFF'}
                </button>
              </td>
              <td>
                <button class="btn-delete" onclick={`deleteTarget(${t.id})`}>Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>
</div>
</Base>

<script>
function switchTab(tab: string) {
  const isChannel = tab === 'channel';
  document.getElementById('form-channel')!.style.display = isChannel ? '' : 'none';
  document.getElementById('form-video')!.style.display = isChannel ? 'none' : '';
  document.getElementById('tab-channel')!.classList.toggle('active', isChannel);
  document.getElementById('tab-video')!.classList.toggle('active', !isChannel);
}

async function toggleTarget(id: number, newState: boolean) {
  const res = await fetch(`/api/youtube/targets/${id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ isActive: newState }),
  });
  if (res.ok) {
    const btn = document.querySelector(`#trow-${id} .toggle-btn`) as HTMLButtonElement;
    if (btn) {
      btn.textContent = newState ? 'ON' : 'OFF';
      btn.className = `toggle-btn ${newState ? 'active' : 'inactive'}`;
      btn.setAttribute('onclick', `toggleTarget(${id}, ${!newState})`);
    }
  }
}

async function deleteTarget(id: number) {
  if (!confirm('Delete this target?')) return;
  const res = await fetch(`/api/youtube/targets/${id}`, { method: 'DELETE' });
  if (res.ok || res.status === 204) document.getElementById(`trow-${id}`)?.remove();
}

function quickAddChannel(url: string, label: string) {
  switchTab('channel');
  const form = document.getElementById('add-form-channel') as HTMLFormElement;
  (form.elements.namedItem('url') as HTMLInputElement).value = url;
  (form.elements.namedItem('label') as HTMLInputElement).value = label;
  (form.elements.namedItem('priority') as HTMLInputElement).value = '80';
  form.scrollIntoView({ behavior: 'smooth' });
}

async function submitForm(formId: string) {
  const form = document.getElementById(formId) as HTMLFormElement;
  if (!form.checkValidity()) { form.reportValidity(); return; }
  const data = Object.fromEntries(new FormData(form));
  const res = await fetch('/api/youtube/targets', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      ...data,
      priority: parseInt(data.priority as string, 10),
      maxComments: parseInt(data.maxComments as string, 10),
      maxVideosPerChannel: data.maxVideosPerChannel ? parseInt(data.maxVideosPerChannel as string, 10) : 5,
    }),
  });
  if (res.ok) location.reload();
  else { const d = await res.json(); alert(d.error || 'Failed'); }
}

document.getElementById('add-form-channel')?.addEventListener('submit', (e) => {
  e.preventDefault(); submitForm('add-form-channel');
});
document.getElementById('add-form-video')?.addEventListener('submit', (e) => {
  e.preventDefault(); submitForm('add-form-video');
});

function selectAll() {
  document.querySelectorAll<HTMLInputElement>('.row-check').forEach(cb => cb.checked = true);
  (document.getElementById('check-all') as HTMLInputElement).checked = true;
}
function deselectAll() {
  document.querySelectorAll<HTMLInputElement>('.row-check').forEach(cb => cb.checked = false);
  (document.getElementById('check-all') as HTMLInputElement).checked = false;
}
function toggleCheckAll(master: HTMLInputElement) {
  document.querySelectorAll<HTMLInputElement>('.row-check').forEach(cb => cb.checked = master.checked);
}

(window as any).toggleTarget = toggleTarget;
(window as any).deleteTarget = deleteTarget;
(window as any).quickAddChannel = quickAddChannel;
(window as any).selectAll = selectAll;
(window as any).deselectAll = deselectAll;
(window as any).toggleCheckAll = toggleCheckAll;
(window as any).switchTab = switchTab;
</script>

<style>
  .admin-layout { min-height: 100vh; background: var(--bg-base); }
  .admin-header { display: flex; align-items: center; gap: 1rem; padding: 0.875rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
  .admin-logo { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 700; color: var(--teal); text-decoration: none; }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; flex: 1; }
  .bc-link { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; }
  .bc-link:hover { color: var(--teal); }
  .bc-sep { color: var(--text-muted); font-size: var(--text-xs); }
  .bc-current { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); }
  .btn-logout { padding: 0.35rem 0.75rem; background: none; border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.7); border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); text-decoration: none; }
  .admin-main { padding: 1.5rem; max-width: 1000px; margin: 0 auto; }
  .page-title { font-family: var(--font-mono); font-size: var(--text-lg); color: var(--text-primary); margin-bottom: 1.25rem; }

  /* Type tabs */
  .type-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.25rem; }
  .type-tab { padding: 0.5rem 1.25rem; background: var(--bg-elevated); border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.375rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; display: flex; align-items: center; gap: 0.4rem; }
  .type-tab.active { border-color: #ff6b6b; color: #ff6b6b; background: rgba(255,107,107,0.06); }
  .tab-hint { font-size: 0.6rem; background: rgba(74,141,131,0.2); color: var(--teal); padding: 0.1rem 0.35rem; border-radius: 0.2rem; }

  /* Form */
  .section-title { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-primary); margin-bottom: 0.4rem; }
  .form-hint { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-bottom: 0.875rem; line-height: 1.5; }
  .form-hint strong { color: var(--text-secondary); }
  .add-form-wrap { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1.25rem; margin-bottom: 1.5rem; }
  .add-form { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.875rem; }
  .form-input { background: var(--bg-base); border: 1px solid var(--border); color: var(--text-primary); font-family: var(--font-mono); font-size: var(--text-xs); padding: 0.4rem 0.625rem; border-radius: 0.25rem; outline: none; }
  .form-input:focus { border-color: var(--teal); }
  .url-input { flex: 1; min-width: 260px; }
  .mc-input { width: 80px; }
  .mv-input { width: 70px; }
  .priority-input { width: 65px; }
  .btn-add { padding: 0.4rem 1rem; background: #ff6b6b; border: none; color: #fff; border-radius: 0.25rem; font-family: var(--font-mono); font-size: var(--text-xs); cursor: pointer; font-weight: 600; white-space: nowrap; }
  .btn-add:hover { background: #ff4444; }

  /* Presets */
  .presets { display: flex; align-items: center; gap: 0.375rem; flex-wrap: wrap; }
  .presets-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); white-space: nowrap; }
  .preset-btn { padding: 0.2rem 0.5rem; background: none; border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; cursor: pointer; }
  .preset-btn:hover { border-color: #ff6b6b; color: #ff6b6b; }

  /* Table */
  .targets-table-wrap { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 0.5rem; overflow: hidden; }
  .bulk-actions { display: flex; gap: 0.5rem; padding: 0.625rem 1rem; border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02); }
  .bulk-btn { padding: 0.25rem 0.75rem; background: none; border: 1px solid var(--border); color: var(--text-muted); border-radius: 0.25rem; font-family: var(--font-mono); font-size: 0.65rem; cursor: pointer; }
  .bulk-btn:hover { border-color: var(--teal); color: var(--teal); }
  .targets-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: var(--text-xs); }
  .targets-table th { padding: 0.5rem 0.875rem; text-align: left; font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02); white-space: nowrap; }
  .targets-table td { padding: 0.5rem 0.875rem; color: var(--text-secondary); border-bottom: 1px solid rgba(255,255,255,0.04); }
  .td-label { font-weight: 600; }
  .td-value { color: var(--text-muted); font-size: 0.65rem; max-width: 200px; }
  .td-center { text-align: center; }
  .url-link { color: var(--text-muted); font-size: 0.65rem; text-decoration: none; }
  .url-link:hover { color: #ff6b6b; }

  .type-badge { padding: 0.15rem 0.45rem; border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600; }
  .type-badge--channel { background: rgba(255,0,0,0.1); color: #ff6b6b; border: 1px solid rgba(255,0,0,0.2); }
  .type-badge--video   { background: rgba(74,141,131,0.12); color: var(--teal); border: 1px solid rgba(74,141,131,0.25); }

  .handle-tag { font-family: var(--font-mono); font-size: 0.65rem; color: #ff6b6b; }

  .toggle-btn { padding: 0.2rem 0.5rem; border: none; border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.6rem; cursor: pointer; font-weight: 700; }
  .toggle-btn.active   { background: rgba(74,141,131,0.2); color: var(--teal); }
  .toggle-btn.inactive { background: rgba(255,255,255,0.06); color: var(--text-muted); }
  .btn-delete { padding: 0.2rem 0.5rem; background: none; border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.6); border-radius: 0.2rem; font-family: var(--font-mono); font-size: 0.65rem; cursor: pointer; }
  .btn-delete:hover { border-color: rgba(239,68,68,0.5); color: #ef4444; }
</style>
</Base>
