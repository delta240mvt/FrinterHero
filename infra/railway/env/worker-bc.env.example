NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
OPENROUTER_API_KEY=sk-or-placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder
YOUTUBE_API_KEY=AIza_placeholder
WORKER_TOPICS=bc-scrape,bc-parse,bc-selector,bc-cluster,bc-generate
BC_LLM_PROVIDER=openrouter
BC_EXTENDED_THINKING_ENABLED=false
BC_THINKING_BUDGET_DEFAULT=10000
BC_LP_MODEL=anthropic/claude-sonnet-4-6
BC_SCRAPER_MODEL=anthropic/claude-haiku-4-5
BC_CLUSTER_MODEL=anthropic/claude-sonnet-4-6
BC_GENERATOR_MODEL=anthropic/claude-sonnet-4-6
BC_LP_MAX_TOKENS=6144
BC_SCRAPER_MAX_TOKENS=4096
BC_CLUSTER_MAX_TOKENS=3072
BC_GENERATOR_MAX_TOKENS=8192
BC_LP_THINKING_BUDGET=10000
BC_SCRAPER_THINKING_BUDGET=4000
BC_CLUSTER_THINKING_BUDGET=16000
BC_GENERATOR_THINKING_BUDGET=16000
WORKER_HEALTH_PORT=8080
