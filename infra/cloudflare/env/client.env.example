# Environment variables for Astro tenant client apps on Cloudflare Pages
# Set these as Cloudflare Pages environment variables (Settings → Environment Variables)
# or in a local .dev.vars file for wrangler dev.

# URL of the shared backend Worker (Cloudflare Worker or Railway fallback)
# Example: https://api.frinter.workers.dev
API_BASE_URL=https://new-pp-api-2026-03-19-new-pp-copy.up.railway.app

# Tenant site slug — identifies which content/data scope to use.
# Must match one of the slugs registered in the database.
# Values: przemyslawfilipiak | frinter | focusequalsfreedom
# Note: This is also baked in at build time via vite.define in astro.config.mjs,
# but the runtime env var is read via import.meta.env.SITE_SLUG as a fallback.
SITE_SLUG=przemyslawfilipiak
