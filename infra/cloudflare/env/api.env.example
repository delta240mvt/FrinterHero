APP_ENV=development
API_BASE_URL=http://127.0.0.1:8787
FRINTER_HOST=frinter.pl
FOCUS_HOST=focusequalsfreedom.com
PRZEM_HOST=przemyslawfilipiak.com

# Cloudflare bindings configured in apps/api/wrangler.jsonc
HYPERDRIVE=<hyperdrive-binding>
ASSETS_BUCKET=<r2-binding>
JOB_QUEUE=<queue-binding>

# Fallback proxy to Node/Railway API (used when Cloudflare Worker cannot handle a route natively)
NODE_API_URL=https://new-pp-api-2026-03-19-new-pp-copy.up.railway.app

# Secrets — set via `wrangler secret put <NAME>` (never commit real values)
OPENROUTER_API_KEY=<your-openrouter-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
WAVESPEED_API_KEY=<your-wavespeed-api-key>
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
ADMIN_PASSWORD_HASH=<bcrypt-hash-of-admin-password>
